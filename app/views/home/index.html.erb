<% if @budget_overview.is_a?(Hash) && !@budget_overview["error"] %>
  <h2 style="margin-top: 2rem;">Budget</h2>

  <% income = @budget_overview["actual_income"].to_f %>
  <% expenses = @budget_overview["total_spent"].to_f %>
  <% savings = income - expenses %>
  <% savings_rate = @budget_overview["savings_rate"].to_f %>

  <div class="card">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 0;">
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Income</div>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--positive);"><%= number_to_currency(income) %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Expenses</div>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--negative);"><%= number_to_currency(expenses) %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Saved</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= savings >= 0 ? 'positive' : 'negative' %>"><%= number_to_currency(savings) %></div>
      </div>
      <div style="padding: 1rem; text-align: center;">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Savings Rate</div>
        <div style="font-size: 1.5rem; font-weight: 700;"><%= savings_rate %>%</div>
      </div>
    </div>
  </div>

  <div class="content-grid">
    <% if income > 0 %>
      <div class="card" style="padding: 1.25rem;">
        <h3 style="margin-bottom: 0.75rem;">Budget Progress</h3>
        <div class="budget-progress-bar" style="height: 1.25rem; margin-bottom: 0.5rem;">
          <div class="budget-progress-fill <%= expenses <= income ? 'progress-safe' : 'progress-over' %>"
               style="width: <%= [expenses / income * 100, 100].min.round(1) %>%"></div>
        </div>
        <div style="display: flex; justify-content: space-between; font-size: 0.85rem;">
          <span>Spent: <%= number_to_currency(expenses) %></span>
          <span>Budget: <%= number_to_currency(income) %></span>
        </div>
      </div>
    <% end %>

    <% if @budget_forecast.is_a?(Hash) && !@budget_forecast["error"] %>
      <div class="card" style="padding: 1.25rem;">
        <h3 style="margin-bottom: 0.75rem;">Forecast</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; font-size: 0.9rem;">
          <div>
            <span class="text-muted">Daily Spend Rate</span><br>
            <strong><%= number_to_currency(@budget_forecast["daily_spend_rate"]) %>/day</strong>
          </div>
          <div>
            <span class="text-muted">Projected Total</span><br>
            <strong class="<%= @budget_forecast["on_track"] ? 'positive' : 'negative' %>">
              <%= number_to_currency(@budget_forecast["projected_total_spend"]) %>
            </strong>
          </div>
          <div>
            <span class="text-muted">Safe to Spend</span><br>
            <strong><%= number_to_currency(@budget_forecast["safe_to_spend_daily"]) %>/day</strong>
          </div>
          <div>
            <span class="text-muted">Status</span><br>
            <% if @budget_forecast["on_track"] %>
              <span class="badge badge-success">On Track</span>
            <% else %>
              <span class="badge badge-warning">Over Budget</span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <%
    trends_data = @spending_trends.is_a?(Array) ? @spending_trends : (@spending_trends.is_a?(Hash) ? (@spending_trends["trends"] || []) : [])
  %>
  <% if trends_data.length >= 2 %>
    <div class="card">
      <div class="card-header">
        <h2>Spending Trends</h2>
        <%= link_to "Details", budget_reports_spending_path, class: "btn btn-sm" %>
      </div>
      <div class="chart-container"
           data-controller="chart"
           data-chart-type-value="bar"
           data-chart-points-value="<%= trends_data.map { |t| { x: t["label"] || t["month"], y: t["expenses"] || t["total"] } }.to_json %>"
           style="padding: 0.5rem 1rem;">
      </div>
    </div>
  <% end %>

  <% if @active_goals.present? && @active_goals.any? %>
    <div class="card">
      <div class="card-header">
        <h2>Savings Goals</h2>
        <%= link_to "All Goals", budget_goals_path, class: "btn btn-sm" %>
      </div>
      <% @active_goals.first(4).each do |goal| %>
        <%
          current = goal["current_amount"].to_f
          target = goal["target_amount"].to_f
          pct = target > 0 ? (current / target * 100).round(1) : 0
          deadline = goal["deadline"] || goal["target_date"]
        %>
        <div class="budget-category-row" style="padding: 0.625rem 1.25rem;">
          <div class="budget-category-info">
            <strong><%= goal["name"] %></strong>
            <span class="text-muted" style="font-size: 0.8125rem;">
              <%= number_to_currency(current) %> of <%= number_to_currency(target) %>
              <% if deadline.present? %>
                <% days_left = (Date.parse(deadline) - Date.current).to_i rescue nil %>
                <% if days_left && days_left > 0 %>
                  &middot; <%= days_left %> days left
                <% end %>
              <% end %>
            </span>
          </div>
          <div class="budget-progress-bar">
            <div class="budget-progress-fill progress-safe" style="width: <%= [pct, 100].min %>%"></div>
          </div>
          <span class="budget-category-pct"><%= pct %>%</span>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Active Savings Challenges %>
  <% if @active_challenges.is_a?(Array) && @active_challenges.any? %>
    <div class="card">
      <div class="card-header">
        <h2>Active Challenges</h2>
        <%= link_to "All Challenges", budget_challenges_path, class: "btn btn-sm" %>
      </div>
      <% @active_challenges.first(3).each do |ch| %>
        <%
          target = ch["target_amount"].to_f
          current = ch["current_amount"].to_f
          pct = target > 0 ? (current / target * 100).round(0) : 0
          end_date = ch["end_date"].present? ? (Date.parse(ch["end_date"]) rescue nil) : nil
          days_left = end_date ? (end_date - Date.current).to_i : nil
          challenge_type = ch["challenge_type"]
          type_icon = case challenge_type
                      when "no_spend" then "block"
                      when "spending_limit" then "savings"
                      when "savings_target" then "flag"
                      when "category_limit" then "category"
                      else "emoji_events"
                      end
        %>
        <div style="padding: 0.625rem 1.25rem; border-bottom: 1px solid var(--border);">
          <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.375rem;">
            <span class="material-icons-outlined" style="font-size: 1rem; color: var(--primary);"><%= type_icon %></span>
            <strong style="font-size: 0.875rem;"><%= ch["name"] %></strong>
            <% if days_left && days_left > 0 %>
              <span style="margin-left: auto; font-size: 0.6875rem; color: var(--text-secondary);"><%= days_left %>d left</span>
            <% elsif days_left && days_left <= 0 %>
              <span style="margin-left: auto; font-size: 0.6875rem; color: var(--negative);">Ended</span>
            <% end %>
          </div>
          <% if target > 0 %>
            <div class="budget-progress-bar" style="height: 0.5rem; margin-bottom: 0.25rem;">
              <div class="budget-progress-fill <%= pct <= 100 ? 'progress-safe' : 'progress-danger' %>" style="width: <%= [pct, 100].min %>%"></div>
            </div>
            <div style="display: flex; justify-content: space-between; font-size: 0.6875rem; color: var(--text-secondary);">
              <span><%= number_to_currency(current) %> / <%= number_to_currency(target) %></span>
              <span><%= pct %>%</span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @debt_overview.is_a?(Hash) && !@debt_overview["error"] && @debt_overview["total_debt"].to_f > 0 %>
    <div class="card">
      <div class="card-header">
        <h2>Debt Payoff</h2>
        <%= link_to "Details", budget_debt_accounts_path, class: "btn btn-sm" %>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; padding: 0.75rem 1.25rem;">
        <div>
          <span class="text-muted" style="font-size: 0.75rem;">Total Debt</span><br>
          <strong class="negative"><%= number_to_currency(@debt_overview["total_debt"]) %></strong>
        </div>
        <div>
          <span class="text-muted" style="font-size: 0.75rem;">Monthly Payments</span><br>
          <strong><%= number_to_currency(@debt_overview["total_minimum_payments"]) %></strong>
        </div>
        <div>
          <span class="text-muted" style="font-size: 0.75rem;">Monthly Interest</span><br>
          <strong class="negative"><%= number_to_currency(@debt_overview["total_monthly_interest"]) %></strong>
        </div>
      </div>
      <div style="padding: 0.5rem 1.25rem 0.75rem; display: flex; gap: 0.5rem;">
        <%= link_to "Snowball Plan", snowball_budget_debt_accounts_path, class: "btn btn-sm" %>
        <%= link_to "Avalanche Plan", avalanche_budget_debt_accounts_path, class: "btn btn-sm" %>
      </div>
    </div>
  <% end %>

  <% if @recurring_summary.is_a?(Hash) && !@recurring_summary["error"] %>
    <% upcoming = @recurring_summary["upcoming"] || [] %>
    <% if upcoming.any? %>
      <div class="card">
        <div class="card-header">
          <h2>Upcoming Bills</h2>
          <%= link_to "All Recurring", budget_recurring_index_path, class: "btn btn-sm" %>
        </div>
        <table class="table">
          <thead>
            <tr>
              <th>Due</th>
              <th>Description</th>
              <th style="text-align: right;">Amount</th>
            </tr>
          </thead>
          <tbody>
            <% upcoming.first(5).each do |bill| %>
              <% due_date = Date.parse(bill["next_date"] || bill["next_due_date"]) rescue nil %>
              <% days_until = due_date ? (due_date - Date.current).to_i : nil %>
              <tr>
                <td>
                  <% if due_date %>
                    <strong<% if days_until && days_until <= 3 %> class="negative"<% end %>><%= due_date.strftime("%b %d") %></strong>
                    <% if days_until && days_until >= 0 %>
                      <span class="text-muted" style="font-size: 0.75rem;">(<%= days_until == 0 ? "today" : "#{days_until}d" %>)</span>
                    <% end %>
                  <% end %>
                </td>
                <td><%= bill["description"] || bill["name"] %></td>
                <td style="text-align: right;"><%= number_to_currency(bill["amount"]) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <% monthly_total = @recurring_summary["monthly_total"].to_f %>
    <% if monthly_total > 0 %>
      <div class="card" style="padding: 1rem 1.25rem;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <span class="text-muted">Monthly Recurring Total</span>
          <strong><%= number_to_currency(monthly_total) %>/mo</strong>
        </div>
      </div>
    <% end %>
  <% end %>

  <%# Budget Alerts %>
  <% if @budget_alerts.is_a?(Array) && @budget_alerts.any? %>
    <div class="card">
      <div class="card-header">
        <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">notifications_active</span> Alerts</h2>
        <%= link_to "View All", budget_alerts_path, class: "btn btn-sm" %>
      </div>
      <% @budget_alerts.first(5).each do |alert| %>
        <%
          a_severity = alert["severity"] || "info"
          a_color = case a_severity
                    when "danger", "critical" then "var(--negative)"
                    when "warning" then "#f9ab00"
                    else "var(--primary)"
                    end
          a_bg = case a_severity
                 when "danger", "critical" then "rgba(234,67,53,0.1)"
                 when "warning" then "rgba(249,171,0,0.1)"
                 else "rgba(26,115,232,0.1)"
                 end
        %>
        <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 1.25rem; border-bottom: 1px solid var(--border);">
          <div style="flex-shrink: 0; width: 28px; height: 28px; border-radius: 6px; background: <%= a_bg %>; display: flex; align-items: center; justify-content: center;">
            <span class="material-icons-outlined" style="font-size: 1rem; color: <%= a_color %>;"><%= a_severity == "danger" || a_severity == "critical" ? "error" : a_severity == "warning" ? "warning" : "info" %></span>
          </div>
          <div style="flex: 1; min-width: 0;">
            <div style="font-size: 0.8125rem; font-weight: 600;"><%= alert["title"] || alert["message"] %></div>
            <% if alert["message"].present? && alert["title"].present? %>
              <div style="font-size: 0.6875rem; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= alert["message"] %></div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div style="text-align: center; margin-top: 0.75rem;">
    <%= link_to "Full Dashboard", budget_dashboard_path, class: "btn btn-sm" %>
    <%= link_to "Monthly Digest", budget_reports_digest_path, class: "btn btn-sm" %>
    <%= link_to "Notifications", notifications_path, class: "btn btn-sm" %>
  </div>
<% elsif budget_api_token.blank? %>
  <div class="card" style="margin-top: 2rem;">
    <div class="setup-notice">
      <%= icon("link_off") %>
      <h2>Budget Not Connected</h2>
      <p>Set <code>BUDGET_API_URL</code> and <code>BUDGET_API_TOKEN</code> environment variables to connect.</p>
    </div>
  </div>
<% end %>
