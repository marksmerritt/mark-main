              <% end %>
            </div>
            <% if j_preview.present? %>
              <span class="activity-detail text-muted" style="display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= j_preview %></span>
            <% end %>
          </div>
        </a>
      <% end %>
      <div style="padding: 0.75rem 1.25rem; text-align: center;">
        <%= link_to "New Journal Entry", new_journal_entry_path, class: "btn btn-sm btn-primary" %>
      </div>
    </div>
  <% end %>

  <%# Watchlists %>
  <% if @watchlists.present? && @watchlists.is_a?(Array) && @watchlists.any? %>
