        <div style="font-size: 1.5rem; font-weight: 700;"><%= @notes_stats["total_notes"] || @notes_stats["notes_count"] || 0 %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Notebooks</div>
        <div style="font-size: 1.5rem; font-weight: 700;"><%= @notes_stats["total_notebooks"] || @notes_stats["notebooks_count"] || 0 %></div>
      </div>
      <div style="padding: 1rem; text-align: center;">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Tags</div>
