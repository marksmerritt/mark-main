      <div class="card-header">
        <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">visibility</span> Watchlists</h2>
        <%= link_to "Manage", watchlists_path, class: "btn btn-sm" %>
      </div>
      <div style="padding: 0.75rem 1.25rem;">
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
          <% @watchlists.first(6).each do |wl| %>
            <%
              wl_symbols = wl["symbols"].is_a?(Array) ? wl["symbols"] : []
              wl_count = wl["symbols_count"] || wl_symbols.count
            %>
            <%= link_to watchlist_path(wl["id"]), style: "text-decoration: none; flex: 1; min-width: 140px;" do %>
              <div style="padding: 0.625rem; border: 1px solid var(--border); border-radius: var(--radius); transition: border-color 0.15s;">
                <div style="font-size: 0.8125rem; font-weight: 600; margin-bottom: 0.25rem; color: var(--text);"><%= wl["name"] %></div>
                <div style="font-size: 0.6875rem; color: var(--text-secondary);">
                  <span class="material-icons-outlined" style="font-size: 0.75rem; vertical-align: -1px;">list</span>
                  <%= wl_count %> symbol<%= wl_count == 1 ? '' : 's' %>
                </div>
                <% if wl_symbols.any? %>
                  <div style="margin-top: 0.375rem; font-size: 0.6875rem; color: var(--primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                    <%= wl_symbols.first(5).join(", ") %><%= ", ..." if wl_symbols.count > 5 %>
                  </div>
                <% end %>
              </div>
            <% end %>
          <% end %>
