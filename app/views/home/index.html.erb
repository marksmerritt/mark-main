      <div class="card-header">
        <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">auto_stories</span> Recent Journal</h2>
        <%= link_to "View All", journal_entries_path, class: "btn btn-sm" %>
      </div>
      <% @recent_journal.first(5).each do |entry| %>
        <%
