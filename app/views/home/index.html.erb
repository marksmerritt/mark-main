        %>
        <a href="<%= journal_entry_path(entry["id"]) %>" class="activity-item" style="border-bottom: 1px solid var(--border);">
          <span class="activity-icon" style="background: rgba(26,115,232,0.1); color: var(--primary);">
            <span class="material-icons-outlined">auto_stories</span>
          </span>
          <div class="activity-content" style="flex: 1; min-width: 0;">
