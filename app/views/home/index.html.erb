<h1>Dashboard</h1>

<% if @stats.present? && !@stats["error"] %>
  <div class="stats-grid">
    <div class="card stat-card">
      <h3>Total P&L</h3>
      <p class="stat-value <%= @stats["total_pnl"].to_f >= 0 ? 'positive' : 'negative' %>">
        <%= number_to_currency(@stats["total_pnl"]) %>
      </p>
    </div>

    <div class="card stat-card">
      <h3>Total Trades</h3>
      <p class="stat-value"><%= @stats["total_trades"] %></p>
    </div>

    <div class="card stat-card">
      <h3>Win Rate</h3>
      <p class="stat-value"><%= @stats["win_rate"] %>%</p>
    </div>

    <div class="card stat-card">
      <h3>Profit Factor</h3>
      <p class="stat-value"><%= @stats["profit_factor"] %></p>
    </div>

    <div class="card stat-card">
      <h3>Avg Win</h3>
      <p class="stat-value positive"><%= number_to_currency(@stats["avg_win"]) %></p>
    </div>

    <div class="card stat-card">
      <h3>Avg Loss</h3>
      <p class="stat-value negative"><%= number_to_currency(@stats["avg_loss"]) %></p>
    </div>
  </div>

  <div class="content-grid">
    <div class="card">
      <div class="card-header">
        <h2>Recent Trades</h2>
      </div>

      <% if @recent_trades.present? && @recent_trades.any? %>
        <table class="table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Symbol</th>
              <th>Side</th>
              <th>P&L</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_trades.first(10).each do |trade| %>
              <tr>
                <td><%= Date.parse(trade["entry_time"]).strftime("%b %d, %Y") if trade["entry_time"] %></td>
                <td><strong><%= trade["symbol"] %></strong></td>
                <td><%= trade["side"]&.capitalize %></td>
                <td class="<%= trade["pnl"].to_f >= 0 ? 'positive' : 'negative' %>">
                  <%= trade["pnl"] ? number_to_currency(trade["pnl"]) : "—" %>
                </td>
                <td><span class="badge badge-<%= trade["status"] %>"><%= trade["status"]&.capitalize %></span></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="empty-state">No trades yet.</p>
      <% end %>
    </div>

    <div class="card">
      <div class="card-header">
        <h2>Tags</h2>
      </div>

      <% if @tags.present? && @tags.any? %>
        <div class="tag-list">
          <% @tags.each do |tag| %>
            <div class="tag-item">
              <span class="tag" <% if tag["color"].present? %>style="background-color: <%= tag["color"] %>"<% end %>>
                <%= tag["name"] %>
              </span>
              <% if tag["stats"] %>
                <span class="tag-stats">
                  <%= tag["stats"]["trade_count"] %> trades &middot;
                  <%= number_to_currency(tag["stats"]["total_pnl"]) %>
                </span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="empty-state">No tags yet.</p>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="card">
    <div class="setup-notice">
      <span class="material-icons-outlined">link_off</span>
      <h2>Trading Journal Not Connected</h2>
      <p>Set <code>TRADING_JOURNAL_URL</code> and <code>TRADING_JOURNAL_TOKEN</code> environment variables to connect.</p>
    </div>
  </div>
<% end %>
