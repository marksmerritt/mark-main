<% content_for(:title, "Position Sizing Backtest") %>

<div style="max-width: 64rem; margin: 0 auto; padding: 1.5rem 1rem;">
  <div style="margin-bottom: 1.5rem;">
    <h1 style="font-size: 1.5rem; font-weight: 700; margin: 0;">
      <span class="material-icons-outlined" style="vertical-align: -4px; color: var(--primary);">science</span>
      Position Sizing Backtest
    </h1>
    <p style="color: var(--text-secondary); margin: 0.25rem 0 0; font-size: 0.875rem;">
      How different sizing strategies would have performed on your <%= @trade_count %> trades
    </p>
  </div>

  <!-- Context -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
    <div class="card" style="padding: 0.75rem; text-align: center;">
      <div style="font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary);">Starting Capital</div>
      <div style="font-size: 1.125rem; font-weight: 700;">$<%= number_with_delimiter(@starting_capital.round(0), delimiter: ',') %></div>
    </div>
    <div class="card" style="padding: 0.75rem; text-align: center;">
      <div style="font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary);">Win Rate</div>
      <div style="font-size: 1.125rem; font-weight: 700;"><%= @win_rate %>%</div>
    </div>
    <div class="card" style="padding: 0.75rem; text-align: center;">
      <div style="font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary);">Kelly %</div>
      <div style="font-size: 1.125rem; font-weight: 700;"><%= @kelly_fraction %>%</div>
    </div>
    <div class="card" style="padding: 0.75rem; text-align: center;">
      <div style="font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary);">Trades</div>
      <div style="font-size: 1.125rem; font-weight: 700;"><%= @trade_count %></div>
    </div>
  </div>

  <!-- Equity Curves Chart -->
  <div class="card" style="padding: 1rem; margin-bottom: 1.5rem;">
    <div class="card-header" style="margin-bottom: 0.75rem;">Equity Curves Comparison</div>
    <% if @strategies.any? && @trade_count > 0
         all_curves = @strategies.map { |s| s[:curve] }
         all_values = all_curves.flatten + @actual_curve
         max_val = all_values.max
         min_val = [all_values.min, 0].max
         range = max_val - min_val
         range = 1 if range == 0
         chart_w = 720
         chart_h = 280
         pad_l = 60
         pad_r = 20
         pad_t = 20
         pad_b = 30
         plot_w = chart_w - pad_l - pad_r
         plot_h = chart_h - pad_t - pad_b

         colors = ["#1a73e8", "#e65100", "#2e7d32", "#7b1fa2", "#c62828", "#00838f"]
    %>
      <svg viewBox="0 0 <%= chart_w %> <%= chart_h %>" style="width: 100%; height: auto;">
        <!-- Grid lines -->
        <% 5.times do |i|
             y = pad_t + plot_h * i / 4.0
             val = max_val - range * i / 4.0 %>
          <line x1="<%= pad_l %>" y1="<%= y %>" x2="<%= chart_w - pad_r %>" y2="<%= y %>" stroke="var(--border)" stroke-width="0.5" stroke-dasharray="4"/>
          <text x="<%= pad_l - 5 %>" y="<%= y + 3 %>" text-anchor="end" fill="var(--text-secondary)" font-size="8">$<%= val.round(0) %></text>
        <% end %>

        <!-- Actual curve (gray dashed) -->
        <% points = @actual_curve.each_with_index.map { |v, i|
             x = pad_l + (i.to_f / [@actual_curve.length - 1, 1].max * plot_w)
             y = pad_t + ((max_val - v) / range * plot_h)
             "#{x.round(1)},#{y.round(1)}"
           }.join(" ") %>
        <polyline points="<%= points %>" fill="none" stroke="var(--text-secondary)" stroke-width="1.5" stroke-dasharray="6 3" opacity="0.6"/>

        <!-- Strategy curves -->
        <% @strategies.each_with_index do |strat, si|
             c = strat[:curve]
             pts = c.each_with_index.map { |v, i|
               x = pad_l + (i.to_f / [c.length - 1, 1].max * plot_w)
               y = pad_t + ((max_val - v) / range * plot_h)
               "#{x.round(1)},#{y.round(1)}"
             }.join(" ") %>
          <polyline points="<%= pts %>" fill="none" stroke="<%= colors[si] %>" stroke-width="1.5"/>
        <% end %>
      </svg>

      <!-- Legend -->
      <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.5rem; font-size: 0.75rem;">
        <div style="display: flex; align-items: center; gap: 0.25rem;">
          <span style="width: 20px; height: 2px; background: var(--text-secondary); display: inline-block; border-top: 1px dashed var(--text-secondary);"></span>
          <span style="color: var(--text-secondary);">Actual</span>
        </div>
        <% @strategies.each_with_index do |strat, si| %>
          <div style="display: flex; align-items: center; gap: 0.25rem;">
            <span style="width: 20px; height: 2px; background: <%= colors[si] %>; display: inline-block;"></span>
            <span><%= strat[:name] %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div style="text-align: center; padding: 2rem; color: var(--text-secondary);">No closed trades to simulate</div>
    <% end %>
  </div>

  <!-- Results Table -->
  <div class="card" style="padding: 1rem; margin-bottom: 1.5rem;">
    <div class="card-header" style="margin-bottom: 0.75rem;">Strategy Results</div>
    <div style="overflow-x: auto;">
      <table style="width: 100%; font-size: 0.8125rem; border-collapse: collapse; white-space: nowrap;">
        <thead>
          <tr style="border-bottom: 2px solid var(--border);">
            <th style="text-align: left; padding: 0.5rem;">Strategy</th>
            <th style="text-align: right; padding: 0.5rem;">Final Equity</th>
            <th style="text-align: right; padding: 0.5rem;">Total Return</th>
            <th style="text-align: right; padding: 0.5rem;">Max Drawdown</th>
            <th style="text-align: right; padding: 0.5rem;">Return/DD Ratio</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom: 1px solid var(--border); background: var(--surface);">
            <td style="padding: 0.5rem; font-weight: 600;">
              <span style="color: var(--text-secondary);">Actual (No Sizing)</span>
            </td>
            <td style="text-align: right; padding: 0.5rem; font-weight: 600;">
              $<%= number_with_delimiter(@actual_curve.last.round(2), delimiter: ',') %>
            </td>
            <td style="text-align: right; padding: 0.5rem;">
              <% actual_return = @starting_capital > 0 ? ((@actual_curve.last - @starting_capital) / @starting_capital * 100).round(2) : 0 %>
              <span style="color: <%= actual_return >= 0 ? 'var(--positive)' : 'var(--negative)' %>;">
                <%= actual_return >= 0 ? '+' : '' %><%= actual_return %>%
              </span>
            </td>
            <td style="text-align: right; padding: 0.5rem;">
              <% actual_max = @actual_curve.max
                 actual_dd = actual_max > 0 ? ((@actual_curve.max - @actual_curve.min) / actual_max * 100).round(2) : 0 %>
              <%= actual_dd %>%
            </td>
            <td style="text-align: right; padding: 0.5rem;">
              <%= actual_dd > 0 ? (actual_return / actual_dd).round(2) : "N/A" %>
            </td>
          </tr>
          <% best_return = @strategies.max_by { |s| s[:total_return] }&.dig(:total_return) || 0
             best_dd = @strategies.min_by { |s| s[:max_drawdown] }&.dig(:max_drawdown) || 100 %>
          <% @strategies.each do |strat| %>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 0.5rem; font-weight: 600;"><%= strat[:name] %></td>
              <td style="text-align: right; padding: 0.5rem; font-weight: 600;">
                $<%= number_with_delimiter(strat[:final_equity], delimiter: ',') %>
              </td>
              <td style="text-align: right; padding: 0.5rem;">
                <span style="color: <%= strat[:total_return] >= 0 ? 'var(--positive)' : 'var(--negative)' %>; font-weight: <%= strat[:total_return] == best_return ? '700' : '400' %>;">
                  <%= strat[:total_return] >= 0 ? '+' : '' %><%= strat[:total_return] %>%
                  <%= strat[:total_return] == best_return ? ' *' : '' %>
                </span>
              </td>
              <td style="text-align: right; padding: 0.5rem;">
                <span style="<%= strat[:max_drawdown] == best_dd ? 'font-weight: 700;' : '' %>">
                  <%= strat[:max_drawdown] %>%
                  <%= strat[:max_drawdown] == best_dd ? ' *' : '' %>
                </span>
              </td>
              <td style="text-align: right; padding: 0.5rem;">
                <% ratio = strat[:max_drawdown] > 0 ? (strat[:total_return] / strat[:max_drawdown]).round(2) : 0 %>
                <%= ratio %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div style="font-size: 0.6875rem; color: var(--text-secondary); margin-top: 0.5rem;">* Best in category</div>
  </div>

  <!-- Strategy Explanations -->
  <div class="card" style="padding: 1rem;">
    <div class="card-header" style="margin-bottom: 0.75rem;">Strategy Guide</div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr)); gap: 1rem;">
      <div style="padding: 0.75rem; background: var(--surface); border-radius: 8px;">
        <div style="font-weight: 600; font-size: 0.875rem; margin-bottom: 0.25rem;">Fixed Fractional</div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Risk a fixed percentage of current equity per trade. Conservative and consistent. 1% is standard for most traders, 2% is aggressive.</div>
      </div>
      <div style="padding: 0.75rem; background: var(--surface); border-radius: 8px;">
        <div style="font-weight: 600; font-size: 0.875rem; margin-bottom: 0.25rem;">Kelly Criterion (<%= @kelly_fraction %>%)</div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Mathematically optimal sizing based on your win rate and payoff ratio. Maximizes long-term growth but can be volatile. Half Kelly is a popular compromise.</div>
      </div>
      <div style="padding: 0.75rem; background: var(--surface); border-radius: 8px;">
        <div style="font-weight: 600; font-size: 0.875rem; margin-bottom: 0.25rem;">Anti-Martingale</div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Increases position size after consecutive wins (up to 3x), resets after a loss. Capitalizes on hot streaks while limiting damage during losing runs.</div>
      </div>
      <div style="padding: 0.75rem; background: var(--surface); border-radius: 8px;">
        <div style="font-weight: 600; font-size: 0.875rem; margin-bottom: 0.25rem;">Fixed Dollar</div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Risk the same dollar amount every trade regardless of account size. Simple but doesn't scale with your account. Useful for beginners.</div>
      </div>
    </div>
  </div>
</div>
