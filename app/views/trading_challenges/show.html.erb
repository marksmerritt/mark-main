<% content_for(:title) { "Trading Challenges" } %>

<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: #f9a825;">emoji_events</span>
    Trading Challenges
  </h1>
</div>

<% if @trades.blank? && @entries.blank? %>
  <div class="card" style="padding: 3rem; text-align: center; color: var(--text-secondary);">
    <span class="material-icons-outlined" style="font-size: 3rem; margin-bottom: 1rem; color: #f9a825;">emoji_events</span>
    <div style="font-size: 1.125rem; font-weight: 600;">No trading data yet</div>
    <div style="font-size: 0.875rem; margin-top: 0.5rem;">Start trading and journaling to unlock challenges and earn badges.</div>
  </div>
<% else %>

  <%# Trader Level Hero Card %>
  <%
    level_colors = {
      "Bronze" => "#cd7f32",
      "Silver" => "#9e9e9e",
      "Gold" => "#f9a825",
      "Platinum" => "#607d8b",
      "Diamond" => "#00bcd4"
    }
    level_color = level_colors[@trader_level] || "var(--primary)"
    level_icons = {
      "Bronze" => "military_tech",
      "Silver" => "military_tech",
      "Gold" => "military_tech",
      "Platinum" => "workspace_premium",
      "Diamond" => "diamond"
    }
    level_icon = level_icons[@trader_level] || "military_tech"
  %>
  <div class="card" style="margin-bottom: 1.5rem; text-align: center; padding: 2rem; border-top: 4px solid <%= level_color %>;">
    <span class="material-icons-outlined" style="font-size: 3.5rem; color: <%= level_color %>;"><%= level_icon %></span>
    <div style="font-size: 1.5rem; font-weight: 700; margin-top: 0.5rem; color: <%= level_color %>;"><%= @trader_level %> Trader</div>
    <div style="font-size: 0.875rem; color: var(--text-secondary); margin-top: 0.25rem;">
      <%= @completed_count %>/<%= @total_challenges %> challenges completed
    </div>
    <% if @next_level %>
      <div style="max-width: 20rem; margin: 1rem auto 0;">
        <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.25rem;">
          <span><%= @trader_level %></span>
          <span><%= @next_level %></span>
        </div>
        <div style="height: 0.5rem; background: var(--bg); border-radius: 4px; overflow: hidden;">
          <div style="height: 100%; width: <%= @level_progress %>%; background: <%= level_color %>; border-radius: 4px; transition: width 0.3s;"></div>
        </div>
        <div style="font-size: 0.6875rem; color: var(--text-secondary); margin-top: 0.25rem;"><%= @level_progress %>% to <%= @next_level %></div>
      </div>
    <% else %>
      <div style="font-size: 0.8125rem; color: <%= level_color %>; margin-top: 0.5rem; font-weight: 600;">Max level reached!</div>
    <% end %>
  </div>

  <%# Stats Strip %>
  <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem;">
    <div class="card" style="padding: 1rem; text-align: center;">
      <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);"><%= @active_streaks %></div>
      <div style="font-size: 0.75rem; color: var(--text-secondary);">Active Streaks</div>
    </div>
    <div class="card" style="padding: 1rem; text-align: center;">
      <div style="font-size: 1.5rem; font-weight: 700; color: var(--positive);"><%= @badges_earned %></div>
      <div style="font-size: 0.75rem; color: var(--text-secondary);">Badges Earned</div>
    </div>
    <div class="card" style="padding: 1rem; text-align: center;">
      <div style="font-size: 1.5rem; font-weight: 700; color: #f9a825;"><%= @best_win_streak %></div>
      <div style="font-size: 0.75rem; color: var(--text-secondary);">Best Win Streak</div>
    </div>
    <div class="card" style="padding: 1rem; text-align: center;">
      <div style="font-size: 1.5rem; font-weight: 700; color: <%= level_color %>;"><%= @trader_level %></div>
      <div style="font-size: 0.75rem; color: var(--text-secondary);">Trader Level</div>
    </div>
  </div>

  <%# Active Challenges Grid %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">flag</span>
        Active Challenges
      </h2>
    </div>
    <div style="padding: 1.25rem;">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1rem;">
        <% @challenges.each do |challenge| %>
          <%
            pct = challenge[:target] > 0 ? (challenge[:current_progress].to_f / challenge[:target] * 100).round(0).clamp(0, 100) : 0
            if challenge[:is_completed]
              status_label = "Completed"
              status_bg = "var(--positive)"
              status_color = "#fff"
              bar_color = "var(--positive)"
            elsif challenge[:current_progress] > 0
              status_label = "Active"
              status_bg = "var(--primary)"
              status_color = "#fff"
              bar_color = "var(--primary)"
            else
              status_label = "Locked"
              status_bg = "var(--border)"
              status_color = "var(--text-secondary)"
              bar_color = "var(--border)"
            end
          %>
          <div style="border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem; position: relative; background: var(--surface); <%= challenge[:is_completed] ? 'border-color: var(--positive);' : '' %>">
            <%# Status Badge %>
            <div style="position: absolute; top: 0.75rem; right: 0.75rem;">
              <span style="font-size: 0.625rem; font-weight: 600; text-transform: uppercase; padding: 0.2rem 0.5rem; border-radius: 9999px; background: <%= status_bg %>; color: <%= status_color %>; letter-spacing: 0.03em;"><%= status_label %></span>
            </div>

            <%# Icon & Name %>
            <div style="display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.75rem;">
              <span class="material-icons-outlined" style="font-size: 1.5rem; color: <%= challenge[:is_completed] ? 'var(--positive)' : challenge[:current_progress] > 0 ? 'var(--primary)' : 'var(--text-secondary)' %>;"><%= challenge[:icon] %></span>
              <div>
                <div style="font-weight: 700; font-size: 0.9375rem;"><%= challenge[:name] %></div>
                <div style="font-size: 0.75rem; color: var(--text-secondary);"><%= challenge[:description] %></div>
              </div>
            </div>

            <%# Progress Bar %>
            <div style="margin-bottom: 0.5rem;">
              <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.25rem;">
                <span>Progress</span>
                <span><%= challenge[:current_progress] %>/<%= challenge[:target] %></span>
              </div>
              <div style="height: 0.375rem; background: var(--bg); border-radius: 3px; overflow: hidden;">
                <div style="height: 100%; width: <%= pct %>%; background: <%= bar_color %>; border-radius: 3px; transition: width 0.3s;"></div>
              </div>
            </div>

            <%# Current & Best %>
            <div style="display: flex; justify-content: space-between; font-size: 0.8125rem;">
              <span>
                <span style="color: var(--text-secondary);">Current:</span>
                <span style="font-weight: 600;"><%= challenge[:current_progress] %></span>
              </span>
              <span>
                <span style="color: var(--text-secondary);">Best:</span>
                <span style="font-weight: 600;"><%= challenge[:best_ever] %></span>
              </span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Achievement Showcase %>
  <% earned = @challenges.select { |c| c[:is_completed] } %>
  <% if earned.any? %>
    <div class="card" style="margin-bottom: 1.5rem;">
      <div class="card-header">
        <h2>
          <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">workspace_premium</span>
          Achievement Showcase
        </h2>
      </div>
      <div style="padding: 1.25rem; display: flex; flex-wrap: wrap; gap: 0.5rem;">
        <% earned.each do |badge| %>
          <span style="display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.375rem 0.875rem; border-radius: 9999px; background: var(--positive); color: #fff; font-size: 0.8125rem; font-weight: 600;">
            <span class="material-icons-outlined" style="font-size: 1rem;"><%= badge[:icon] %></span>
            <%= badge[:name] %>
          </span>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Recent Milestones %>
  <% if @recent_milestones.any? %>
    <div class="card" style="margin-bottom: 1.5rem;">
      <div class="card-header">
        <h2>
          <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">timeline</span>
          Recent Milestones
        </h2>
      </div>
      <div style="padding: 1.25rem;">
        <% @recent_milestones.each_with_index do |milestone, idx| %>
          <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 0; <%= idx < @recent_milestones.length - 1 ? 'border-bottom: 1px solid var(--border);' : '' %>">
            <span class="material-icons-outlined" style="font-size: 1.25rem; color: <%= milestone[:color] || 'var(--primary)' %>;"><%= milestone[:icon] %></span>
            <div style="flex: 1;">
              <div style="font-size: 0.875rem; font-weight: 500;"><%= milestone[:text] %></div>
              <% if milestone[:date] %>
                <div style="font-size: 0.6875rem; color: var(--text-secondary);"><%= milestone[:date] %></div>
              <% end %>
            </div>
            <span class="material-icons-outlined" style="font-size: 1rem; color: var(--positive);">check_circle</span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

<% end %>

<div style="text-align: center; margin-top: 1.5rem;">
  <%= link_to "Report Card", trading_grades_path, class: "btn" %>
  <%= link_to "Reports Hub", reports_index_path, class: "btn" %>
</div>

<style>
  @media (max-width: 640px) {
    div[style*="grid-template-columns: repeat(4"] {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media print {
    .navbar, .page-actions, .app-footer, .back-to-top, .toast-container { display: none !important; }
    .main-content { padding: 0 !important; }
    .card { break-inside: avoid; box-shadow: none !important; border: 1px solid #ddd !important; }
  }
</style>
