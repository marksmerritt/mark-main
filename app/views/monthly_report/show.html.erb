<% content_for(:title) { "Monthly Report — #{@month_name}" } %>

<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: var(--primary);">calendar_month</span>
    Monthly Report
  </h1>
  <div class="page-actions">
    <%= link_to "← Prev", monthly_report_path(month: @month_offset + 1), class: "btn btn-sm" %>
    <% if @month_offset > 0 %>
      <%= link_to "Next →", monthly_report_path(month: @month_offset - 1), class: "btn btn-sm" %>
    <% end %>
    <% if @month_offset != 0 %>
      <%= link_to "Current", monthly_report_path, class: "btn btn-sm btn-primary" %>
    <% end %>
  </div>
</div>

<%# Month Header %>
<div class="card" style="margin-bottom: 1.5rem; padding: 1.5rem; text-align: center; border-top: 3px solid var(--primary);">
  <div style="font-size: 1.75rem; font-weight: 700;"><%= @month_name %></div>
  <div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.25rem;">
    <%= @month_start.strftime("%B %d") %> — <%= @month_end.strftime("%B %d, %Y") %>
  </div>
</div>

<%# Highlights %>
<% if @highlights.any? %>
  <div style="display: grid; gap: 0.5rem; margin-bottom: 1.5rem;">
    <% @highlights.each do |h| %>
      <div class="card" style="padding: 0.625rem 1.25rem; display: flex; align-items: center; gap: 0.75rem;">
        <span class="material-icons-outlined" style="font-size: 1.125rem; color: <%= h[:color] %>;"><%= h[:icon] %></span>
        <span style="font-size: 0.875rem;"><%= h[:text] %></span>
      </div>
    <% end %>
  </div>
<% end %>

<%# Three-column summary %>
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">

  <%# Trading Summary %>
  <div class="card">
    <div class="card-header">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: var(--primary);">show_chart</span>
        Trading
      </h2>
    </div>
    <% if @trade_count > 0 %>
      <div style="text-align: center; padding: 1.25rem;">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Net P&L</div>
        <div style="font-size: 2rem; font-weight: 700; color: <%= @trade_pnl >= 0 ? 'var(--positive)' : 'var(--negative)' %>;">
          <%= @trade_pnl >= 0 ? '+' : '' %><%= number_to_currency(@trade_pnl) %>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 0; border-top: 1px solid var(--border);">
        <div style="padding: 0.75rem; text-align: center; border-right: 1px solid var(--border);">
          <div style="font-size: 0.6875rem; color: var(--text-secondary);">Trades</div>
          <div style="font-weight: 700;"><%= @trade_count %></div>
        </div>
        <div style="padding: 0.75rem; text-align: center; border-right: 1px solid var(--border);">
          <div style="font-size: 0.6875rem; color: var(--text-secondary);">Win Rate</div>
          <div style="font-weight: 700; color: <%= @trade_win_rate >= 50 ? 'var(--positive)' : 'var(--negative)' %>;"><%= @trade_win_rate %>%</div>
        </div>
        <div style="padding: 0.75rem; text-align: center;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary);">Days</div>
          <div style="font-weight: 700;"><span style="color: var(--positive);"><%= @green_days %></span>/<span style="color: var(--negative);"><%= @red_days %></span></div>
        </div>
      </div>
      <% if @best_trade %>
        <div style="padding: 0.75rem 1.25rem; border-top: 1px solid var(--border); font-size: 0.8125rem;">
          <div style="display: flex; justify-content: space-between;">
            <span style="color: var(--text-secondary);">Best Trade</span>
            <span><%= @best_trade["symbol"] %> <span style="color: var(--positive);"><%= number_to_currency(@best_trade["pnl"]) %></span></span>
          </div>
          <% if @worst_trade && @worst_trade != @best_trade %>
            <div style="display: flex; justify-content: space-between; margin-top: 0.25rem;">
              <span style="color: var(--text-secondary);">Worst Trade</span>
              <span><%= @worst_trade["symbol"] %> <span style="color: var(--negative);"><%= number_to_currency(@worst_trade["pnl"]) %></span></span>
            </div>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div style="padding: 2rem; text-align: center; color: var(--text-secondary); font-size: 0.875rem;">No trades this month</div>
    <% end %>
  </div>

  <%# Budget Summary %>
  <div class="card">
    <div class="card-header">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #0d904f;">account_balance_wallet</span>
        Budget
      </h2>
    </div>
    <% if @transaction_count > 0 %>
      <div style="text-align: center; padding: 1.25rem;">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Net Savings</div>
        <div style="font-size: 2rem; font-weight: 700; color: <%= @budget_net >= 0 ? 'var(--positive)' : 'var(--negative)' %>;">
          <%= @budget_net >= 0 ? '+' : '' %><%= number_to_currency(@budget_net) %>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-top: 1px solid var(--border);">
        <div style="padding: 0.75rem; text-align: center; border-right: 1px solid var(--border);">
          <div style="font-size: 0.6875rem; color: var(--text-secondary);">Income</div>
          <div style="font-weight: 700; color: var(--positive);"><%= number_to_currency(@budget_income) %></div>
        </div>
        <div style="padding: 0.75rem; text-align: center;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary);">Expenses</div>
          <div style="font-weight: 700;"><%= number_to_currency(@budget_expenses) %></div>
        </div>
      </div>
      <% if @budgeted > 0 %>
        <div style="padding: 0.75rem 1.25rem; border-top: 1px solid var(--border);">
          <div style="display: flex; justify-content: space-between; font-size: 0.8125rem; margin-bottom: 0.25rem;">
            <span style="color: var(--text-secondary);">Budget Used</span>
            <span style="color: <%= @budget_utilization <= 100 ? 'var(--positive)' : 'var(--negative)' %>;"><%= @budget_utilization %>%</span>
          </div>
          <div style="height: 6px; background: var(--bg); border-radius: 3px; overflow: hidden;">
            <div style="height: 100%; width: <%= [@budget_utilization, 100].min %>%; background: <%= @budget_utilization <= 100 ? 'var(--positive)' : 'var(--negative)' %>; opacity: 0.7; border-radius: 3px;"></div>
          </div>
        </div>
      <% end %>
      <% if @top_categories.any? %>
        <div style="padding: 0.75rem 1.25rem; border-top: 1px solid var(--border); font-size: 0.8125rem;">
          <% @top_categories.first(3).each do |cat, amount| %>
            <div style="display: flex; justify-content: space-between; margin-bottom: 0.25rem;">
              <span style="color: var(--text-secondary);"><%= cat %></span>
              <span><%= number_to_currency(amount) %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div style="padding: 2rem; text-align: center; color: var(--text-secondary); font-size: 0.875rem;">No transactions this month</div>
    <% end %>
  </div>

  <%# Notes & Journal Summary %>
  <div class="card">
    <div class="card-header">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #9c27b0;">edit_note</span>
        Notes & Journal
      </h2>
    </div>
    <div style="padding: 1.25rem;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; text-align: center;">
        <div style="padding: 0.75rem; background: var(--bg); border-radius: 6px;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary);">Journal Entries</div>
          <div style="font-size: 1.5rem; font-weight: 700;"><%= @journal_entries.count %></div>
        </div>
        <div style="padding: 0.75rem; background: var(--bg); border-radius: 6px;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary);">Notes</div>
          <div style="font-size: 1.5rem; font-weight: 700;"><%= @notes_created %></div>
        </div>
      </div>
      <% if @notes_words > 0 %>
        <div style="text-align: center; margin-top: 0.75rem; font-size: 0.8125rem; color: var(--text-secondary);">
          <span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px;">text_fields</span>
          <%= number_with_delimiter(@notes_words) %> words written
          <% if @notes_notebooks > 0 %> across <%= @notes_notebooks %> notebooks<% end %>
        </div>
      <% end %>

      <%# Journal mood breakdown %>
      <% if @journal_entries.any? %>
        <%
          moods = @journal_entries.map { |e| e["mood"] }.compact.tally
          moods = moods.sort_by { |_, v| -v }
        %>
        <% if moods.any? %>
          <div style="margin-top: 1rem;">
            <div style="font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.375rem;">Mood Distribution</div>
            <div style="display: flex; gap: 0.375rem; flex-wrap: wrap;">
              <% moods.each do |mood, count| %>
                <span style="font-size: 0.6875rem; padding: 0.125rem 0.5rem; border-radius: 9999px; background: var(--bg);"><%= mood %> × <%= count %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<%# Top Symbols %>
<% if @top_symbols.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">label</span> Top Symbols</h2>
    </div>
    <div style="display: flex; flex-wrap: wrap; gap: 0;">
      <% @top_symbols.each do |sym, data| %>
        <div style="flex: 1; min-width: 120px; padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
          <div style="font-weight: 700;"><%= sym %></div>
          <div style="font-size: 1.125rem; font-weight: 700; color: <%= data[:pnl] >= 0 ? 'var(--positive)' : 'var(--negative)' %>;">
            <%= number_to_currency(data[:pnl]) %>
          </div>
          <div style="font-size: 0.6875rem; color: var(--text-secondary);"><%= data[:count] %> trades</div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Quick Links %>
<div style="text-align: center; margin-top: 1.5rem;">
  <%= link_to "Dashboard", root_path, class: "btn" %>
  <%= link_to "Weekly Digest", digest_path, class: "btn" %>
  <%= link_to "Daily Review", daily_review_path, class: "btn" %>
  <%= link_to "Reports Hub", reports_index_path, class: "btn" %>
</div>

<style>
  @media print {
    .navbar, .page-actions, .app-footer, .back-to-top, .toast-container { display: none !important; }
    .main-content { padding: 0 !important; }
    .card { break-inside: avoid; box-shadow: none !important; border: 1px solid #ddd !important; }
  }
</style>
