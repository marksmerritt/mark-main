<% content_for(:title) { "Habit Tracker" } %>

<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: #00bcd4;">self_improvement</span>
    Habit Tracker
  </h1>
  <div class="page-actions">
    <span style="font-size: 0.8125rem; color: var(--text-secondary);">Last 30 days</span>
  </div>
</div>

<%# Discipline Score Card %>
<%
  score = @discipline_score
  score_color = if score >= 80
    "var(--positive)"
  elsif score >= 60
    "#f9a825"
  elsif score >= 40
    "#ff9800"
  else
    "var(--negative)"
  end
  # SVG ring calculations
  ring_radius = 54
  ring_circumference = 2 * Math::PI * ring_radius
  ring_offset = ring_circumference - (score / 100.0 * ring_circumference)
%>
<div class="card" style="margin-bottom: 1.5rem; text-align: center; padding: 2rem; border-top: 4px solid #00bcd4;">
  <div style="display: inline-block; position: relative; width: 140px; height: 140px;">
    <svg width="140" height="140" viewBox="0 0 140 140" style="transform: rotate(-90deg);">
      <circle cx="70" cy="70" r="<%= ring_radius %>" fill="none" stroke="var(--border)" stroke-width="10" />
      <circle cx="70" cy="70" r="<%= ring_radius %>" fill="none" stroke="<%= score_color %>" stroke-width="10"
        stroke-linecap="round"
        stroke-dasharray="<%= ring_circumference %>"
        stroke-dashoffset="<%= ring_offset %>"
        style="transition: stroke-dashoffset 0.6s ease;" />
    </svg>
    <div style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;">
      <div style="font-size: 2rem; font-weight: 700; color: <%= score_color %>;"><%= score %></div>
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em;">Score</div>
    </div>
  </div>
  <div style="font-size: 1.25rem; font-weight: 700; margin-top: 0.75rem;">Discipline Score</div>
  <div style="font-size: 0.8125rem; color: var(--text-secondary); margin-top: 0.25rem;">
    Based on <%= @habits.count %> daily habits over the last 30 days
  </div>
</div>

<%# Quick Stats %>
<%
  total_completions = @habit_stats.values.sum { |s| s[:total_count] }
  best_habit = @habits.max_by { |h| @habit_stats[h[:key]][:completion_rate] }
  best_habit_rate = @habit_stats[best_habit[:key]][:completion_rate]
  longest_streak = @habit_stats.values.map { |s| s[:current_streak] }.max
%>
<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem;">
  <div class="card" style="padding: 1rem; text-align: center;">
    <div style="font-size: 1.5rem; font-weight: 700; color: #00bcd4;"><%= score %>%</div>
    <div style="font-size: 0.75rem; color: var(--text-secondary);">Overall Rate</div>
  </div>
  <div class="card" style="padding: 1rem; text-align: center;">
    <div style="font-size: 1.5rem; font-weight: 700; color: var(--positive);"><%= total_completions %></div>
    <div style="font-size: 0.75rem; color: var(--text-secondary);">Total Completions</div>
  </div>
  <div class="card" style="padding: 1rem; text-align: center;">
    <div style="font-size: 1.5rem; font-weight: 700; color: #f9a825;"><%= longest_streak %></div>
    <div style="font-size: 0.75rem; color: var(--text-secondary);">Best Active Streak</div>
  </div>
  <div class="card" style="padding: 1rem; text-align: center;">
    <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary);"><%= best_habit_rate %>%</div>
    <div style="font-size: 0.75rem; color: var(--text-secondary);">Top Habit Rate</div>
  </div>
</div>

<%# 30-Day Heatmap Grid %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header">
    <h2>
      <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">grid_on</span>
      30-Day Heatmap
    </h2>
  </div>
  <div style="padding: 1.25rem; overflow-x: auto;">
    <table style="width: 100%; border-collapse: separate; border-spacing: 3px; table-layout: fixed;">
      <thead>
        <tr>
          <th style="width: 140px; text-align: left; font-size: 0.6875rem; color: var(--text-secondary); font-weight: 600; padding-bottom: 0.375rem;"></th>
          <% @dates.each do |date| %>
            <th style="font-size: 0.5rem; color: var(--text-secondary); font-weight: 400; padding-bottom: 0.375rem; text-align: center; white-space: nowrap;">
              <% if date.day == 1 || date == @dates.first %>
                <%= date.strftime("%b") %>
              <% end %>
            </th>
          <% end %>
        </tr>
        <tr>
          <th style="width: 140px;"></th>
          <% @dates.each do |date| %>
            <th style="font-size: 0.5625rem; color: var(--text-secondary); font-weight: 400; text-align: center;">
              <%= date.day %>
            </th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% @habits.each do |habit| %>
          <tr>
            <td style="font-size: 0.75rem; font-weight: 500; white-space: nowrap; padding-right: 0.75rem; vertical-align: middle;">
              <span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px; color: var(--text-secondary); margin-right: 0.25rem;"><%= habit[:icon] %></span>
              <%= habit[:name] %>
            </td>
            <% @dates.each do |date| %>
              <%
                val = @habit_grid[habit[:key]][date]
                if val == true
                  cell_bg = "var(--positive)"
                  cell_opacity = "0.85"
                  cell_title = "Done"
                elsif val == false
                  cell_bg = "var(--text-secondary)"
                  cell_opacity = "0.25"
                  cell_title = "Missed"
                else
                  cell_bg = "transparent"
                  cell_opacity = "1"
                  cell_title = "No data"
                end
              %>
              <td style="padding: 0;">
                <div title="<%= date.strftime('%b %d') %>: <%= cell_title %>" style="width: 100%; aspect-ratio: 1; min-width: 12px; background: <%= cell_bg %>; opacity: <%= cell_opacity %>; border-radius: 3px; <%= val.nil? ? 'border: 1px solid var(--border);' : '' %>"></div>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
    <div style="display: flex; align-items: center; gap: 1rem; margin-top: 0.75rem; justify-content: flex-end;">
      <div style="display: flex; align-items: center; gap: 0.25rem; font-size: 0.6875rem; color: var(--text-secondary);">
        <div style="width: 12px; height: 12px; background: var(--positive); opacity: 0.85; border-radius: 2px;"></div>
        Done
      </div>
      <div style="display: flex; align-items: center; gap: 0.25rem; font-size: 0.6875rem; color: var(--text-secondary);">
        <div style="width: 12px; height: 12px; background: var(--text-secondary); opacity: 0.25; border-radius: 2px;"></div>
        Missed
      </div>
      <div style="display: flex; align-items: center; gap: 0.25rem; font-size: 0.6875rem; color: var(--text-secondary);">
        <div style="width: 12px; height: 12px; border: 1px solid var(--border); border-radius: 2px;"></div>
        No data
      </div>
    </div>
  </div>
</div>

<%# Individual Habit Cards %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header">
    <h2>
      <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">insights</span>
      Habit Breakdown
    </h2>
  </div>
  <div style="padding: 1.25rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem;">
      <% @habits.each do |habit| %>
        <%
          stats = @habit_stats[habit[:key]]
          rate = stats[:completion_rate]
          rate_color = if rate >= 80
            "var(--positive)"
          elsif rate >= 50
            "#f9a825"
          else
            "var(--negative)"
          end
        %>
        <div style="border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem; background: var(--surface);">
          <div style="display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.75rem;">
            <span class="material-icons-outlined" style="font-size: 1.5rem; color: #00bcd4;"><%= habit[:icon] %></span>
            <div style="flex: 1;">
              <div style="font-weight: 700; font-size: 0.9375rem;"><%= habit[:name] %></div>
              <div style="font-size: 0.6875rem; color: var(--text-secondary);"><%= stats[:total_count] %> of <%= stats[:active_days] %> active days</div>
            </div>
          </div>

          <%# Completion Rate Bar %>
          <div style="margin-bottom: 0.75rem;">
            <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.25rem;">
              <span>Completion Rate</span>
              <span style="font-weight: 600; color: <%= rate_color %>;"><%= rate %>%</span>
            </div>
            <div style="height: 0.375rem; background: var(--bg); border-radius: 3px; overflow: hidden;">
              <div style="height: 100%; width: <%= rate %>%; background: <%= rate_color %>; border-radius: 3px; transition: width 0.3s;"></div>
            </div>
          </div>

          <%# Streak Info %>
          <div style="display: flex; justify-content: space-between; font-size: 0.8125rem;">
            <span>
              <span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px; color: var(--positive);">local_fire_department</span>
              <span style="color: var(--text-secondary);">Streak:</span>
              <span style="font-weight: 600;"><%= stats[:current_streak] %></span>
            </span>
            <span>
              <span style="color: var(--text-secondary);">Best:</span>
              <span style="font-weight: 600;"><%= stats[:best_streak] %></span>
            </span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# Today's Checklist %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header">
    <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">checklist</span> Today's Checklist</h2>
    <span style="font-size: 0.8125rem; color: var(--text-secondary);">
      <%= @today_checklist.count { |c| c[:done] } %>/<%= @today_checklist.count { |c| !c[:skipped] } %> complete
    </span>
  </div>
  <% @today_checklist.each do |item| %>
    <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--border);">
      <span class="material-icons-outlined" style="font-size: 1.25rem; color: <%= item[:done] ? 'var(--positive)' : item[:skipped] ? 'var(--text-secondary)' : 'var(--negative)' %>;">
        <%= item[:done] ? 'check_circle' : item[:skipped] ? 'remove_circle_outline' : 'radio_button_unchecked' %>
      </span>
      <span class="material-icons-outlined" style="font-size: 1rem; color: var(--text-secondary);"><%= item[:icon] %></span>
      <div style="flex: 1;">
        <span style="font-size: 0.875rem; <%= item[:done] ? 'text-decoration: line-through; color: var(--text-secondary);' : '' %>"><%= item[:name] %></span>
      </div>
      <% if item[:done] %>
        <span class="badge badge-success" style="font-size: 0.625rem;">Done</span>
      <% elsif item[:skipped] %>
        <span class="badge" style="font-size: 0.625rem;">N/A</span>
      <% else %>
        <span class="badge badge-warning" style="font-size: 0.625rem;">Pending</span>
      <% end %>
    </div>
  <% end %>
</div>

<%# Navigation %>
<div style="text-align: center; margin-top: 1.5rem;">
  <%= link_to "Daily Review", daily_review_path, class: "btn" %>
  <%= link_to "Trading Challenges", trading_challenges_path, class: "btn" %>
  <%= link_to "Writing Goals", writing_goals_path, class: "btn" %>
</div>

<style>
  @media (max-width: 640px) {
    div[style*="grid-template-columns: repeat(4"] {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    table { font-size: 0.625rem; }
    td[style*="width: 140px"], th[style*="width: 140px"] {
      width: 100px !important;
      font-size: 0.625rem !important;
    }
  }
  @media print {
    .navbar, .page-actions, .app-footer, .back-to-top, .toast-container { display: none !important; }
    .main-content { padding: 0 !important; }
    .card { break-inside: avoid; box-shadow: none !important; border: 1px solid #ddd !important; }
  }
</style>
