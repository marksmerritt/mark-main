<% content_for(:title, "Streak Calendar") %>

<div style="max-width: 64rem; margin: 0 auto; padding: 1.5rem 1rem;">
  <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem;">
    <div>
      <h1 style="font-size: 1.5rem; font-weight: 700; margin: 0;">
        <span class="material-icons-outlined" style="vertical-align: -4px; color: var(--positive);">local_fire_department</span>
        Streak Calendar
      </h1>
      <p style="color: var(--text-secondary); margin: 0.25rem 0 0; font-size: 0.875rem;">365 days of trading and journaling activity</p>
    </div>
  </div>

  <!-- Current Streaks -->
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
    <div class="card" style="padding: 1rem; text-align: center;">
      <span class="material-icons-outlined" style="font-size: 1.5rem; color: #e65100;">local_fire_department</span>
      <div style="font-size: 1.5rem; font-weight: 700; margin: 0.25rem 0;"><%= @current_trading_streak %></div>
      <div style="font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary);">Trading Streak</div>
    </div>
    <div class="card" style="padding: 1rem; text-align: center;">
      <span class="material-icons-outlined" style="font-size: 1.5rem; color: #9c27b0;">edit_note</span>
      <div style="font-size: 1.5rem; font-weight: 700; margin: 0.25rem 0;"><%= @current_journal_streak %></div>
      <div style="font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary);">Journal Streak</div>
    </div>
    <div class="card" style="padding: 1rem; text-align: center;">
      <span class="material-icons-outlined" style="font-size: 1.5rem; color: var(--primary);">emoji_events</span>
      <div style="font-size: 1.5rem; font-weight: 700; margin: 0.25rem 0;"><%= @longest_trading_streak %></div>
      <div style="font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary);">Best Trading Streak</div>
    </div>
    <div class="card" style="padding: 1rem; text-align: center;">
      <span class="material-icons-outlined" style="font-size: 1.5rem; color: #1a73e8;">military_tech</span>
      <div style="font-size: 1.5rem; font-weight: 700; margin: 0.25rem 0;"><%= @longest_journal_streak %></div>
      <div style="font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary);">Best Journal Streak</div>
    </div>
    <div class="card" style="padding: 1rem; text-align: center;">
      <span class="material-icons-outlined" style="font-size: 1.5rem; color: var(--positive);">check_circle</span>
      <div style="font-size: 1.5rem; font-weight: 700; margin: 0.25rem 0;"><%= @total_active_days %></div>
      <div style="font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary);">Active Days</div>
    </div>
  </div>

  <!-- Activity Heatmap - Trading -->
  <div class="card" style="padding: 1rem; margin-bottom: 1rem; overflow-x: auto;">
    <div class="card-header" style="margin-bottom: 0.75rem;">
      <span class="material-icons-outlined" style="font-size: 1rem; vertical-align: -2px; color: var(--positive);">show_chart</span>
      Trading Activity
      <span style="font-size: 0.75rem; font-weight: 400; color: var(--text-secondary); margin-left: 0.5rem;"><%= @total_trades %> trades over <%= @total_active_days %> days</span>
    </div>
    <%
      # GitHub-style grid: 53 columns (weeks) x 7 rows (days)
      cell = 12
      gap = 2
      label_w = 28
      weeks = 53
      chart_w = label_w + weeks * (cell + gap)
      chart_h = 7 * (cell + gap) + 20
      day_labels = %w[Mon Tue Wed Thu Fri Sat Sun]

      # Build week columns
      # Start from the first Sunday on or before start_date
      cal_start = @start_date - @start_date.wday
    %>
    <svg viewBox="0 0 <%= chart_w %> <%= chart_h %>" style="width: 100%; max-width: 780px; height: auto;">
      <% [1, 3, 5].each do |d| %>
        <text x="2" y="<%= d * (cell + gap) + cell - 2 %>" fill="var(--text-secondary)" font-size="8"><%= day_labels[d] %></text>
      <% end %>
      <% month_labels = [] %>
      <% (0...weeks).each do |w|
           (0..6).each do |d|
             date = cal_start + (w * 7 + d)
             next if date < @start_date || date > @today
             day_data = @activity[date.to_s]
             trades = day_data ? day_data[:trades] : 0
             pnl = day_data ? day_data[:pnl] : 0

             # Color intensity based on trade count
             if trades == 0
               fill = "var(--surface)"
             elsif pnl > 0
               opacity = [0.3 + trades * 0.15, 1.0].min
               fill = "rgba(46,125,50,#{opacity})"
             else
               opacity = [0.3 + trades * 0.15, 1.0].min
               fill = "rgba(198,40,40,#{opacity})"
             end

             x = label_w + w * (cell + gap)
             y = d * (cell + gap)

             # Track month labels
             if date.day <= 7 && d == 0
               month_labels << { x: x, month: date.strftime("%b") }
             end
           %>
        <rect x="<%= x %>" y="<%= y %>" width="<%= cell %>" height="<%= cell %>" rx="2" fill="<%= fill %>" stroke="var(--border)" stroke-width="0.5">
          <title><%= date.strftime("%b %d, %Y") %>: <%= trades %> trades ($<%= pnl.round(2) %>)</title>
        </rect>
        <% end %>
      <% end %>
      <% month_labels.each do |ml| %>
        <text x="<%= ml[:x] %>" y="<%= 7 * (cell + gap) + 14 %>" fill="var(--text-secondary)" font-size="8"><%= ml[:month] %></text>
      <% end %>
    </svg>
    <div style="display: flex; gap: 0.375rem; align-items: center; margin-top: 0.5rem; font-size: 0.6875rem; color: var(--text-secondary);">
      <span>Less</span>
      <span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: var(--surface); border: 1px solid var(--border);"></span>
      <span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: rgba(46,125,50,0.3);"></span>
      <span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: rgba(46,125,50,0.6);"></span>
      <span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: rgba(46,125,50,0.85);"></span>
      <span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: rgba(46,125,50,1);"></span>
      <span>More</span>
      <span style="margin-left: 1rem;">Green = profitable &middot; Red = losing</span>
    </div>
  </div>

  <!-- Activity Heatmap - Journaling -->
  <div class="card" style="padding: 1rem; margin-bottom: 1.5rem; overflow-x: auto;">
    <div class="card-header" style="margin-bottom: 0.75rem;">
      <span class="material-icons-outlined" style="font-size: 1rem; vertical-align: -2px; color: #9c27b0;">edit_note</span>
      Journaling Activity
      <span style="font-size: 0.75rem; font-weight: 400; color: var(--text-secondary); margin-left: 0.5rem;"><%= @total_journal_days %> journal days</span>
    </div>
    <svg viewBox="0 0 <%= chart_w %> <%= chart_h %>" style="width: 100%; max-width: 780px; height: auto;">
      <% [1, 3, 5].each do |d| %>
        <text x="2" y="<%= d * (cell + gap) + cell - 2 %>" fill="var(--text-secondary)" font-size="8"><%= day_labels[d] %></text>
      <% end %>
      <% (0...weeks).each do |w|
           (0..6).each do |d|
             date = cal_start + (w * 7 + d)
             next if date < @start_date || date > @today
             day_data = @activity[date.to_s]
             has_journal = day_data && day_data[:journal]
             note_count = day_data ? day_data[:notes] : 0
             total = (has_journal ? 1 : 0) + [note_count, 2].min

             if total == 0
               fill = "var(--surface)"
             else
               opacity = [0.35 + total * 0.2, 1.0].min
               fill = "rgba(156,39,176,#{opacity})"
             end

             x = label_w + w * (cell + gap)
             y = d * (cell + gap)
           %>
        <rect x="<%= x %>" y="<%= y %>" width="<%= cell %>" height="<%= cell %>" rx="2" fill="<%= fill %>" stroke="var(--border)" stroke-width="0.5">
          <title><%= date.strftime("%b %d, %Y") %>: <%= has_journal ? 'Journal entry' : 'No journal' %>, <%= note_count %> notes</title>
        </rect>
        <% end %>
      <% end %>
      <% month_labels.each do |ml| %>
        <text x="<%= ml[:x] %>" y="<%= 7 * (cell + gap) + 14 %>" fill="var(--text-secondary)" font-size="8"><%= ml[:month] %></text>
      <% end %>
    </svg>
    <div style="display: flex; gap: 0.375rem; align-items: center; margin-top: 0.5rem; font-size: 0.6875rem; color: var(--text-secondary);">
      <span>Less</span>
      <span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: var(--surface); border: 1px solid var(--border);"></span>
      <span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: rgba(156,39,176,0.35);"></span>
      <span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: rgba(156,39,176,0.55);"></span>
      <span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: rgba(156,39,176,0.75);"></span>
      <span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: rgba(156,39,176,1);"></span>
      <span>More</span>
      <span style="margin-left: 1rem;">Purple = journal + notes activity</span>
    </div>
  </div>

  <!-- Monthly Breakdown -->
  <div class="card" style="padding: 1rem; margin-bottom: 1.5rem;">
    <div class="card-header" style="margin-bottom: 0.75rem;">Monthly Activity Summary</div>
    <%
      monthly = {}
      @activity.each do |date_str, day|
        month = date_str.slice(0, 7)
        monthly[month] ||= { trades: 0, journal: 0, notes: 0, pnl: 0.0, active: 0 }
        monthly[month][:trades] += day[:trades]
        monthly[month][:journal] += 1 if day[:journal]
        monthly[month][:notes] += day[:notes]
        monthly[month][:pnl] += day[:pnl]
        monthly[month][:active] += 1 if day[:trades] > 0 || day[:journal] || day[:notes] > 0
      end
    %>
    <table style="width: 100%; font-size: 0.8125rem; border-collapse: collapse;">
      <thead>
        <tr style="border-bottom: 2px solid var(--border);">
          <th style="text-align: left; padding: 0.375rem 0.5rem;">Month</th>
          <th style="text-align: right; padding: 0.375rem 0.5rem;">Active Days</th>
          <th style="text-align: right; padding: 0.375rem 0.5rem;">Trades</th>
          <th style="text-align: right; padding: 0.375rem 0.5rem;">Journal</th>
          <th style="text-align: right; padding: 0.375rem 0.5rem;">Notes</th>
          <th style="text-align: right; padding: 0.375rem 0.5rem;">P&L</th>
        </tr>
      </thead>
      <tbody>
        <% monthly.sort_by { |k, _| k }.reverse.first(12).each do |month, data| %>
          <tr style="border-bottom: 1px solid var(--border);">
            <td style="padding: 0.375rem 0.5rem; font-weight: 600;"><%= Date.parse("#{month}-01").strftime("%B %Y") rescue month %></td>
            <td style="text-align: right; padding: 0.375rem 0.5rem;"><%= data[:active] %></td>
            <td style="text-align: right; padding: 0.375rem 0.5rem;"><%= data[:trades] %></td>
            <td style="text-align: right; padding: 0.375rem 0.5rem;"><%= data[:journal] %></td>
            <td style="text-align: right; padding: 0.375rem 0.5rem;"><%= data[:notes] %></td>
            <td style="text-align: right; padding: 0.375rem 0.5rem; color: <%= data[:pnl] >= 0 ? 'var(--positive)' : 'var(--negative)' %>; font-weight: 600;">
              <%= data[:pnl] >= 0 ? '+' : '' %>$<%= data[:pnl].round(2) %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Consistency Score -->
  <%
    consistency = @total_active_days > 0 ? (@total_active_days.to_f / 365 * 100).round(0) : 0
    ring_r = 45
    ring_c = 2 * Math::PI * ring_r
    ring_offset = ring_c * (1 - consistency / 100.0)
    ring_color = consistency >= 60 ? "var(--positive)" : consistency >= 30 ? "#f9a825" : "var(--negative)"
  %>
  <div class="card" style="padding: 1.5rem; text-align: center;">
    <div class="card-header" style="margin-bottom: 1rem;">Consistency Score</div>
    <svg width="120" height="120" viewBox="0 0 120 120" style="margin: 0 auto; display: block;">
      <circle cx="60" cy="60" r="<%= ring_r %>" fill="none" stroke="var(--surface)" stroke-width="8"/>
      <circle cx="60" cy="60" r="<%= ring_r %>" fill="none" stroke="<%= ring_color %>" stroke-width="8"
              stroke-dasharray="<%= ring_c %>" stroke-dashoffset="<%= ring_offset %>"
              stroke-linecap="round" transform="rotate(-90 60 60)"/>
      <text x="60" y="60" text-anchor="middle" dominant-baseline="central" font-size="22" font-weight="700" fill="<%= ring_color %>"><%= consistency %>%</text>
    </svg>
    <div style="font-size: 0.8125rem; color: var(--text-secondary); margin-top: 0.75rem;">
      Active on <strong><%= @total_active_days %></strong> of the last 365 days
    </div>
  </div>
</div>
