<div class="page-header">
  <h1>Add Debt Account</h1>
  <div class="page-actions"><%= link_to "Back", budget_debt_accounts_path, class: "btn" %></div>
</div>

<div class="card">
  <% if @errors.present? %>
    <div class="alert alert-danger" style="margin: 1rem 1.25rem 0;">
      <ul style="margin: 0; padding-left: 1rem;">
        <% @errors.each do |error| %><li><%= error %></li><% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: budget_debt_accounts_path, method: :post, class: "form-container" do |f| %>
    <div class="form-group">
      <%= f.label :name, "Account Name" %>
      <%= f.text_field :name, value: @account["name"], class: "form-control", name: "debt_account[name]", placeholder: "e.g. Chase Visa, Student Loan", required: true %>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div class="form-group">
        <%= f.label :balance, "Current Balance" %>
        <%= f.number_field :balance, value: @account["balance"], step: "0.01", class: "form-control", name: "debt_account[balance]", required: true %>
      </div>
      <div class="form-group">
        <%= f.label :minimum_payment, "Minimum Payment" %>
        <%= f.number_field :minimum_payment, value: @account["minimum_payment"], step: "0.01", class: "form-control", name: "debt_account[minimum_payment]" %>
      </div>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div class="form-group">
        <%= f.label :interest_rate, "Interest Rate (%)" %>
        <%= f.number_field :interest_rate, value: @account["interest_rate"], step: "0.01", class: "form-control", name: "debt_account[interest_rate]", placeholder: "19.99" %>
      </div>
      <div class="form-group">
        <%= f.label :debt_type, "Debt Type" %>
        <%= f.select :debt_type, [["Credit Card", "credit_card"], ["Student Loan", "student_loan"], ["Car Loan", "car_loan"], ["Personal Loan", "personal_loan"], ["Mortgage", "mortgage"], ["Medical", "medical"], ["Other", "other"]], { selected: @account["debt_type"] || "credit_card" }, class: "form-control", name: "debt_account[debt_type]" %>
      </div>
    </div>
    <div class="form-group">
      <%= f.label :due_date, "Due Date (day of month)" %>
      <%= f.number_field :due_date, value: @account["due_date"], min: 1, max: 31, class: "form-control", name: "debt_account[due_date]" %>
    </div>
    <div class="form-actions">
      <%= f.submit "Add Debt Account", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
