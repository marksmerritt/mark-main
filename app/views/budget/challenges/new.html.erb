<div class="page-header">
  <h1>New Challenge</h1>
  <div class="page-actions">
    <%= link_to "Back", budget_challenges_path, class: "btn" %>
  </div>
</div>

<% if @presets.any? %>
  <%
    preset_icons = {
      "no_spend_week" => "block", "no_spend_weekend" => "weekend",
      "50_dollar_week" => "savings", "500_savings" => "account_balance",
      "no_dining_out" => "restaurant", "1000_savings" => "trending_up"
    }
    preset_colors = {
      "no_spend_week" => "#d93025", "no_spend_weekend" => "#e8710a",
      "50_dollar_week" => "#1a73e8", "500_savings" => "#0d904f",
      "no_dining_out" => "#9334e6", "1000_savings" => "#0d904f"
    }
    difficulty_map = {
      "no_spend_week" => "Hard", "no_spend_weekend" => "Medium",
      "50_dollar_week" => "Medium", "500_savings" => "Medium",
      "no_dining_out" => "Easy", "1000_savings" => "Hard"
    }
  %>
  <h2 style="margin-bottom: 1rem;">Quick Start Presets</h2>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
    <% @presets.each do |preset| %>
      <%
        key = preset["key"]
        icon = preset_icons[key] || "emoji_events"
        color = preset_colors[key] || "#1a73e8"
        difficulty = difficulty_map[key] || "Medium"
      %>
      <div class="card" style="padding: 1.25rem; border-top: 3px solid <%= color %>;">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
          <span class="material-icons-outlined" style="font-size: 1.5rem; color: <%= color %>;"><%= icon %></span>
          <strong><%= preset["name"] %></strong>
        </div>
        <p class="text-muted" style="font-size: 0.8125rem; margin: 0 0 0.75rem; line-height: 1.4;"><%= preset["description"] %></p>
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <div style="display: flex; gap: 0.375rem;">
            <span class="badge" style="font-size: 0.6875rem;"><%= preset["duration_days"] %> days</span>
            <span class="badge" style="font-size: 0.6875rem; background: <%= color %>22; color: <%= color %>;"><%= difficulty %></span>
          </div>
          <%= form_with url: budget_challenges_path, method: :post, style: "display: inline;" do |f| %>
            <%= f.hidden_field :preset, value: key %>
            <%= f.submit "Start", class: "btn btn-sm btn-primary" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<h2 style="margin-bottom: 1rem;">Custom Challenge</h2>
<div class="card">
  <% if @errors.present? %>
    <div class="alert alert-danger" style="margin: 1rem 1.25rem 0;">
      <ul style="margin: 0; padding-left: 1rem;">
        <% @errors.each do |error| %><li><%= error %></li><% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: budget_challenges_path, method: :post, class: "form-container" do |f| %>
    <div class="form-group">
      <%= f.label "savings_challenge[name]", "Challenge Name" %>
      <%= f.text_field "savings_challenge[name]", class: "form-control", placeholder: "My Savings Challenge", required: true %>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div class="form-group">
        <%= f.label "savings_challenge[challenge_type]", "Type" %>
        <%= f.select "savings_challenge[challenge_type]",
            [["No Spend", "no_spend"], ["Spending Limit", "spending_limit"], ["Savings Target", "savings_target"], ["Category Limit", "category_limit"]],
            {}, class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label "savings_challenge[target_amount]", "Target Amount" %>
        <%= f.number_field "savings_challenge[target_amount]", step: "0.01", class: "form-control", placeholder: "0.00" %>
      </div>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div class="form-group">
        <%= f.label "savings_challenge[start_date]", "Start Date" %>
        <%= f.date_field "savings_challenge[start_date]", value: Date.current, class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label "savings_challenge[end_date]", "End Date" %>
        <%= f.date_field "savings_challenge[end_date]", value: Date.current + 30.days, class: "form-control" %>
      </div>
    </div>
    <div class="form-group">
      <%= f.label "savings_challenge[notes]", "Notes (optional)" %>
      <%= f.text_area "savings_challenge[notes]", class: "form-control", rows: 3, placeholder: "Motivation, rules, etc." %>
    </div>
    <div class="form-actions">
      <%= f.submit "Start Challenge", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
