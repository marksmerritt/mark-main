<div class="page-header">
  <h1>Budget Comparison</h1>
  <div class="page-actions">
    <%= link_to "Dashboard", budget_dashboard_path, class: "btn" %>
  </div>
</div>

<div class="card" style="margin-bottom: 1rem;">
  <%= form_with url: budget_reports_comparison_path, method: :get, class: "filter-form" do |f| %>
    <div class="filter-row">
      <div class="form-group">
        <%= f.label :month1, "Current Month" %>
        <%= f.select :month1, (1..12).map { |m| [Date::MONTHNAMES[m], m] },
            { selected: @month1 }, class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :year1, "Year" %>
        <%= f.number_field :year1, value: @year1, class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :month2, "Compare To" %>
        <%= f.select :month2, (1..12).map { |m| [Date::MONTHNAMES[m], m] },
            { selected: @month2 }, class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :year2, "Year" %>
        <%= f.number_field :year2, value: @year2, class: "form-control" %>
      </div>
      <div class="form-group form-actions-inline">
        <%= f.submit "Compare", class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>

<% if @data.present? && !@data["error"] %>
  <% current = @data["current"] %>
  <% previous = @data["previous"] %>
  <% deltas = @data["deltas"] %>

  <div class="card" style="margin-bottom: 1.5rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 0;">
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Income Change</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= deltas["income"].to_f >= 0 ? 'positive' : 'negative' %>">
          <%= deltas["income"].to_f >= 0 ? "+" : "" %><%= number_to_currency(deltas["income"]) %>
        </div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Expense Change</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= deltas["expenses"].to_f <= 0 ? 'positive' : 'negative' %>">
          <%= deltas["expenses"].to_f >= 0 ? "+" : "" %><%= number_to_currency(deltas["expenses"]) %>
        </div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Savings Change</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= deltas["savings"].to_f >= 0 ? 'positive' : 'negative' %>">
          <%= deltas["savings"].to_f >= 0 ? "+" : "" %><%= number_to_currency(deltas["savings"]) %>
        </div>
      </div>
      <div style="padding: 1rem; text-align: center;">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Savings Rate Change</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= deltas["savings_rate"].to_f >= 0 ? 'positive' : 'negative' %>">
          <%= deltas["savings_rate"].to_f >= 0 ? "+" : "" %><%= deltas["savings_rate"] %>%
        </div>
      </div>
    </div>
  </div>

  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header"><h2>Side-by-Side</h2></div>
    <table class="table">
      <thead>
        <tr>
          <th>Metric</th>
          <th style="text-align: right;"><%= current["label"] %></th>
          <th style="text-align: right;"><%= previous["label"] %></th>
          <th style="text-align: right;">Change</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>Income</strong></td>
          <td style="text-align: right;" class="positive"><%= number_to_currency(current["income"]) %></td>
          <td style="text-align: right;" class="positive"><%= number_to_currency(previous["income"]) %></td>
          <td style="text-align: right;" class="<%= deltas["income"].to_f >= 0 ? 'positive' : 'negative' %>">
            <%= deltas["income"].to_f >= 0 ? "+" : "" %><%= number_to_currency(deltas["income"]) %>
          </td>
        </tr>
        <tr>
          <td><strong>Expenses</strong></td>
          <td style="text-align: right;" class="negative"><%= number_to_currency(current["expenses"]) %></td>
          <td style="text-align: right;" class="negative"><%= number_to_currency(previous["expenses"]) %></td>
          <td style="text-align: right;" class="<%= deltas["expenses"].to_f <= 0 ? 'positive' : 'negative' %>">
            <%= deltas["expenses"].to_f >= 0 ? "+" : "" %><%= number_to_currency(deltas["expenses"]) %>
          </td>
        </tr>
        <tr>
          <td><strong>Savings</strong></td>
          <td style="text-align: right;" class="<%= current["savings"].to_f >= 0 ? 'positive' : 'negative' %>"><%= number_to_currency(current["savings"]) %></td>
          <td style="text-align: right;" class="<%= previous["savings"].to_f >= 0 ? 'positive' : 'negative' %>"><%= number_to_currency(previous["savings"]) %></td>
          <td style="text-align: right;" class="<%= deltas["savings"].to_f >= 0 ? 'positive' : 'negative' %>">
            <%= deltas["savings"].to_f >= 0 ? "+" : "" %><%= number_to_currency(deltas["savings"]) %>
          </td>
        </tr>
        <tr>
          <td><strong>Savings Rate</strong></td>
          <td style="text-align: right;"><%= current["savings_rate"] %>%</td>
          <td style="text-align: right;"><%= previous["savings_rate"] %>%</td>
          <td style="text-align: right;" class="<%= deltas["savings_rate"].to_f >= 0 ? 'positive' : 'negative' %>">
            <%= deltas["savings_rate"].to_f >= 0 ? "+" : "" %><%= deltas["savings_rate"] %>%
          </td>
        </tr>
        <tr>
          <td><strong>Budget Planned</strong></td>
          <td style="text-align: right;"><%= number_to_currency(current["planned"]) %></td>
          <td style="text-align: right;"><%= number_to_currency(previous["planned"]) %></td>
          <td style="text-align: right;">
            <% planned_delta = current["planned"].to_f - previous["planned"].to_f %>
            <span class="<%= planned_delta <= 0 ? 'positive' : 'negative' %>">
              <%= planned_delta >= 0 ? "+" : "" %><%= number_to_currency(planned_delta) %>
            </span>
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <%# Visual comparison chart %>
  <%
    chart_metrics = [
      { label: "Income", cur: current["income"].to_f, prev: previous["income"].to_f, better: :higher },
      { label: "Expenses", cur: current["expenses"].to_f, prev: previous["expenses"].to_f, better: :lower },
      { label: "Savings", cur: current["savings"].to_f, prev: previous["savings"].to_f, better: :higher }
    ]
    chart_max = chart_metrics.map { |m| [m[:cur].abs, m[:prev].abs] }.flatten.max
    chart_max = 1 if chart_max.to_f == 0
  %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header"><h2>Visual Comparison</h2></div>
    <div style="padding: 1rem 1.25rem;">
      <% chart_metrics.each do |m| %>
        <%
          cur_w = (m[:cur].abs / chart_max * 100).round(1)
          prev_w = (m[:prev].abs / chart_max * 100).round(1)
          delta = m[:cur] - m[:prev]
          improved = m[:better] == :higher ? delta >= 0 : delta <= 0
        %>
        <div style="margin-bottom: 1rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.375rem;">
            <span style="font-size: 0.8125rem; font-weight: 600;"><%= m[:label] %></span>
            <span style="font-size: 0.75rem; color: <%= improved ? 'var(--positive)' : 'var(--negative)' %>;">
              <span class="material-icons-outlined" style="font-size: 0.75rem; vertical-align: -1px;"><%= improved ? 'arrow_upward' : 'arrow_downward' %></span>
              <%= delta >= 0 ? "+" : "" %><%= number_to_currency(delta) %>
            </span>
          </div>
          <div style="display: flex; gap: 0.25rem; align-items: center;">
            <span style="font-size: 0.625rem; width: 3rem; text-align: right; color: var(--text-secondary);"><%= current["label"].to_s.split(" ").first %></span>
            <div style="flex: 1; height: 1rem; background: var(--bg); border-radius: 4px; overflow: hidden;">
              <div style="height: 100%; width: <%= cur_w %>%; background: var(--primary); opacity: 0.7; border-radius: 4px;"></div>
            </div>
            <span style="font-size: 0.6875rem; width: 5rem; text-align: right;"><%= number_to_currency(m[:cur]) %></span>
          </div>
          <div style="display: flex; gap: 0.25rem; align-items: center; margin-top: 0.25rem;">
            <span style="font-size: 0.625rem; width: 3rem; text-align: right; color: var(--text-secondary);"><%= previous["label"].to_s.split(" ").first %></span>
            <div style="flex: 1; height: 1rem; background: var(--bg); border-radius: 4px; overflow: hidden;">
              <div style="height: 100%; width: <%= prev_w %>%; background: var(--text-secondary); opacity: 0.4; border-radius: 4px;"></div>
            </div>
            <span style="font-size: 0.6875rem; width: 5rem; text-align: right; color: var(--text-secondary);"><%= number_to_currency(m[:prev]) %></span>
          </div>
        </div>
      <% end %>
      <div style="display: flex; gap: 1rem; justify-content: center; margin-top: 0.5rem; font-size: 0.6875rem; color: var(--text-secondary);">
        <span><span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: var(--primary); opacity: 0.7; vertical-align: middle; margin-right: 3px;"></span><%= current["label"] %></span>
        <span><span style="display: inline-block; width: 10px; height: 10px; border-radius: 2px; background: var(--text-secondary); opacity: 0.4; vertical-align: middle; margin-right: 3px;"></span><%= previous["label"] %></span>
      </div>
    </div>
  </div>

  <% if current["categories"].is_a?(Array) && current["categories"].any? %>
    <div class="card">
      <div class="card-header"><h2>Category Comparison</h2></div>
      <table class="table">
        <thead>
          <tr>
            <th>Category</th>
            <th style="text-align: right;"><%= current["label"] %></th>
            <th style="text-align: right;"><%= previous["label"] %></th>
            <th style="text-align: right;">Change</th>
          </tr>
        </thead>
        <tbody>
          <% all_cat_names = ((current["categories"] || []).map { |c| c["name"] } + (previous["categories"] || []).map { |c| c["name"] }).uniq %>
          <% all_cat_names.each do |name| %>
            <% cur_cat = (current["categories"] || []).find { |c| c["name"] == name } %>
            <% prev_cat = (previous["categories"] || []).find { |c| c["name"] == name } %>
            <% cur_actual = cur_cat ? cur_cat["actual"].to_f : 0 %>
            <% prev_actual = prev_cat ? prev_cat["actual"].to_f : 0 %>
            <% cat_delta = cur_actual - prev_actual %>
            <tr>
              <td><strong><%= name %></strong></td>
              <td style="text-align: right;"><%= number_to_currency(cur_actual) %></td>
              <td style="text-align: right;"><%= number_to_currency(prev_actual) %></td>
              <td style="text-align: right;">
                <span class="<%= cat_delta <= 0 ? 'positive' : 'negative' %>">
                  <%= cat_delta >= 0 ? "+" : "" %><%= number_to_currency(cat_delta) %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% else %>
  <div class="card empty-state">
    <p>Select two months to compare budget performance.</p>
  </div>
<% end %>
