<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: var(--primary);">category</span>
    Category Deep Dive
  </h1>
  <div class="page-actions">
    <%= link_to "Spending Report", budget_reports_spending_path, class: "btn btn-sm" %>
  </div>
</div>

<%# Category Filter %>
<div class="card" style="margin-bottom: 1.5rem; padding: 1rem 1.25rem;">
  <form method="get" style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
    <label style="font-size: 0.8125rem; font-weight: 500;">Category:</label>
    <select name="category" class="form-control" style="max-width: 200px;" onchange="this.form.submit()">
      <option value="All" <%= "selected" if @category == "All" %>>All Categories</option>
      <% @all_categories.each do |cat| %>
        <option value="<%= cat %>" <%= "selected" if @category == cat %>><%= cat %></option>
      <% end %>
    </select>
    <label style="font-size: 0.8125rem; font-weight: 500;">Window:</label>
    <% [3, 6, 12].each do |m| %>
      <% if m == @months_back %>
        <span class="btn btn-sm btn-primary"><%= m %>m</span>
      <% else %>
        <%= link_to "#{m}m", budget_reports_category_drill_path(category: @category, months: m), class: "btn btn-sm" %>
      <% end %>
    <% end %>
  </form>
</div>

<%# Summary Strip %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 0;">
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Total Spent</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= number_to_currency(@total_spent) %></div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Transactions</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= @transaction_count %></div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Avg Transaction</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= number_to_currency(@avg_transaction) %></div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Avg Monthly</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= number_to_currency(@avg_monthly) %></div>
    </div>
    <div style="padding: 1rem; text-align: center;">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Trend</div>
      <% if @trend_direction %>
        <div style="font-size: 1.5rem; font-weight: 700; color: <%= @trend_direction == 'decreasing' ? 'var(--positive)' : (@trend_direction == 'increasing' ? 'var(--negative)' : 'var(--text-secondary)') %>;">
          <span class="material-icons-outlined" style="font-size: 1.25rem; vertical-align: -3px;">
            <%= @trend_direction == 'increasing' ? 'trending_up' : (@trend_direction == 'decreasing' ? 'trending_down' : 'trending_flat') %>
          </span>
          <%= @trend_pct > 0 ? '+' : '' %><%= @trend_pct %>%
        </div>
      <% else %>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--text-secondary);">—</div>
      <% end %>
    </div>
  </div>
</div>

<% if @category != "All" && @budgeted.to_f > 0 %>
  <div class="card" style="margin-bottom: 1.5rem; padding: 1.25rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
      <span style="font-weight: 600;">Budget: <%= number_to_currency(@budgeted) %></span>
      <span style="font-weight: 600; color: <%= @pct_used > 100 ? 'var(--negative)' : 'var(--positive)' %>;">
        <%= @pct_used %>% used
      </span>
    </div>
    <div style="height: 0.75rem; background: var(--bg); border-radius: 6px; overflow: hidden;">
      <div style="height: 100%; width: <%= [@pct_used, 100].min %>%; background: <%= @pct_used > 100 ? 'var(--negative)' : (@pct_used > 80 ? '#f9ab00' : 'var(--positive)') %>; border-radius: 6px;"></div>
    </div>
    <div style="display: flex; justify-content: space-between; margin-top: 0.375rem; font-size: 0.75rem; color: var(--text-secondary);">
      <span><%= number_to_currency(@category_spent) %> spent</span>
      <span><%= number_to_currency([@budgeted - @category_spent, 0].max) %> remaining</span>
    </div>
  </div>
<% end %>

<%# Monthly Spending Chart %>
<% if @monthly.count >= 2 %>
  <%
    max_monthly = @monthly.values.map { |d| d[:total] }.max.to_f
    max_monthly = 1 if max_monthly == 0
    chart_w = 700
    chart_h = 220
    padding_l = 70
    padding_r = 20
    usable_w = chart_w - padding_l - padding_r
  %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">show_chart</span> Monthly Spending Trend</h2>
    </div>
    <div style="padding: 1.25rem; overflow-x: auto;">
      <svg viewBox="0 0 <%= chart_w %> <%= chart_h + 40 %>" style="width: 100%; height: auto; font-family: Inter, sans-serif;">
        <!-- Grid -->
        <% 5.times do |i| %>
          <% y = 20 + i * (chart_h / 4.0) %>
          <line x1="<%= padding_l %>" y1="<%= y %>" x2="<%= chart_w - padding_r %>" y2="<%= y %>" stroke="var(--border)" stroke-width="0.5" stroke-dasharray="3"/>
          <text x="<%= padding_l - 5 %>" y="<%= y + 3 %>" text-anchor="end" fill="var(--text-secondary)" font-size="9">
            $<%= ((max_monthly * (4 - i) / 4) / 1).round(0) %>
          </text>
        <% end %>

        <!-- Bars -->
        <% bar_count = @monthly.count %>
        <% bar_w = [(usable_w / bar_count * 0.6).round, 40].min %>
        <% @monthly.each_with_index do |(month_key, data), i| %>
          <%
            x = padding_l + (i + 0.5) * (usable_w.to_f / bar_count)
            h = (data[:total] / max_monthly * chart_h).round
            y = 20 + chart_h - h
          %>
          <rect x="<%= x - bar_w / 2 %>" y="<%= y %>" width="<%= bar_w %>" height="<%= [h, 1].max %>"
                fill="var(--primary)" opacity="0.7" rx="3"/>
          <text x="<%= x %>" y="<%= y - 5 %>" text-anchor="middle" fill="var(--text-secondary)" font-size="8">
            $<%= data[:total].round(0) %>
          </text>
          <text x="<%= x %>" y="<%= chart_h + 35 %>" text-anchor="middle" fill="var(--text-secondary)" font-size="9">
            <%= month_key.slice(5, 2) %>/<%= month_key.slice(2, 2) %>
          </text>
        <% end %>

        <!-- Average line -->
        <% avg_y = 20 + chart_h - (@avg_monthly / max_monthly * chart_h).round %>
        <line x1="<%= padding_l %>" y1="<%= avg_y %>" x2="<%= chart_w - padding_r %>" y2="<%= avg_y %>"
              stroke="#f9ab00" stroke-width="1.5" stroke-dasharray="6,3"/>
        <text x="<%= chart_w - padding_r + 2 %>" y="<%= avg_y - 3 %>" fill="#f9ab00" font-size="8">Avg</text>
      </svg>
    </div>

    <% if @max_month && @min_month %>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; padding: 1rem 1.25rem; border-top: 1px solid var(--border);">
        <div style="padding: 0.75rem; background: rgba(234,67,53,0.06); border-radius: 6px;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary);">Highest Month</div>
          <div style="font-weight: 600;"><%= @max_month[0] %> — <%= number_to_currency(@max_month[1][:total]) %></div>
          <div style="font-size: 0.75rem; color: var(--text-secondary);"><%= @max_month[1][:count] %> transactions</div>
        </div>
        <div style="padding: 0.75rem; background: rgba(52,168,83,0.06); border-radius: 6px;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary);">Lowest Month</div>
          <div style="font-weight: 600;"><%= @min_month[0] %> — <%= number_to_currency(@min_month[1][:total]) %></div>
          <div style="font-size: 0.75rem; color: var(--text-secondary);"><%= @min_month[1][:count] %> transactions</div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">

  <%# Top Merchants %>
  <% if @top_merchants.any? %>
    <%
      max_merchant = @top_merchants.first[:total].to_f
      max_merchant = 1 if max_merchant == 0
    %>
    <div class="card">
      <div class="card-header">
        <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">store</span> Top Merchants</h2>
      </div>
      <% @top_merchants.each_with_index do |m, i| %>
        <div style="padding: 0.625rem 1.25rem; border-bottom: 1px solid var(--border);">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
            <span style="font-size: 0.8125rem; font-weight: 500;">
              <span style="color: var(--text-secondary); font-size: 0.75rem; margin-right: 0.25rem;"><%= i + 1 %>.</span>
              <%= m[:name] %>
            </span>
            <span style="font-size: 0.8125rem; font-weight: 600;"><%= number_to_currency(m[:total]) %></span>
          </div>
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <div style="flex: 1; height: 4px; background: var(--bg); border-radius: 2px; overflow: hidden;">
              <div style="height: 100%; width: <%= (m[:total] / max_merchant * 100).round %>%; background: var(--primary); opacity: 0.6; border-radius: 2px;"></div>
            </div>
            <span style="font-size: 0.6875rem; color: var(--text-secondary); white-space: nowrap;"><%= m[:count] %> txns · avg <%= number_to_currency(m[:avg]) %></span>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Day of Week Distribution %>
  <% if @by_day.any? %>
    <%
      max_day_val = @by_day.values.max.to_f
      max_day_val = 1 if max_day_val == 0
      day_order = %w[Monday Tuesday Wednesday Thursday Friday Saturday Sunday]
    %>
    <div class="card">
      <div class="card-header">
        <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">calendar_month</span> Spending by Day of Week</h2>
      </div>
      <div style="padding: 1.25rem;">
        <% day_order.each do |day| %>
          <% val = @by_day[day] || 0 %>
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.625rem;">
            <span style="width: 30px; font-size: 0.8125rem; font-weight: 500;"><%= day[0..2] %></span>
            <div style="flex: 1; height: 20px; background: var(--bg); border-radius: 4px; overflow: hidden;">
              <div style="height: 100%; width: <%= (val / max_day_val * 100).round %>%; background: var(--primary); opacity: 0.6; border-radius: 4px; display: flex; align-items: center; padding-left: 0.5rem;">
                <% if val / max_day_val > 0.3 %>
                  <span style="font-size: 0.625rem; color: white; font-weight: 500;"><%= number_to_currency(val) %></span>
                <% end %>
              </div>
            </div>
            <% if val / max_day_val <= 0.3 %>
              <span style="font-size: 0.75rem; color: var(--text-secondary);"><%= number_to_currency(val) %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<%# Largest Transactions %>
<% if @largest.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">receipt_long</span> Largest Transactions</h2>
    </div>
    <table class="table" style="font-size: 0.8125rem;">
      <thead>
        <tr>
          <th>Date</th>
          <th>Merchant</th>
          <th>Description</th>
          <% if @category == "All" %><th>Category</th><% end %>
          <th style="text-align: right;">Amount</th>
        </tr>
      </thead>
      <tbody>
        <% @largest.each do |t| %>
          <tr>
            <td><%= t["transaction_date"].to_s.slice(0, 10) %></td>
            <td><strong><%= t["merchant"].presence || "—" %></strong></td>
            <td style="color: var(--text-secondary);"><%= truncate(t["description"].to_s, length: 40) %></td>
            <% if @category == "All" %><td><%= t["category_name"] %></td><% end %>
            <td style="text-align: right; font-weight: 600;"><%= number_to_currency(t["amount"]) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<div style="text-align: center; margin-top: 1.5rem;">
  <%= link_to "Spending Report", budget_reports_spending_path, class: "btn" %>
  <%= link_to "Merchants", budget_reports_merchants_path, class: "btn" %>
  <%= link_to "Insights", budget_reports_insights_path, class: "btn" %>
</div>
