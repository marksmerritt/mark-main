<div class="page-header">
  <h1>Subscription Audit</h1>
  <div class="page-actions">
    <%= link_to "Manage Bills", budget_recurring_index_path, class: "btn" %>
  </div>
</div>

<% if @audit_items.any? %>
  <%# Cost summary %>
  <div class="card" style="display: flex; align-items: center; gap: 2rem; padding: 1.5rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
    <div style="flex-shrink: 0; text-align: center;">
      <div style="font-size: 2rem; font-weight: 700; color: var(--negative);"><%= number_to_currency(@total_monthly) %></div>
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">per month</div>
    </div>
    <div style="flex: 1; display: flex; gap: 1.5rem; flex-wrap: wrap;">
      <div>
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Annual Cost</div>
        <div style="font-size: 1.125rem; font-weight: 700;"><%= number_to_currency(@total_annual) %></div>
      </div>
      <div>
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Daily Cost</div>
        <div style="font-size: 1.125rem; font-weight: 700;"><%= number_to_currency(@total_annual / 365.0) %></div>
      </div>
      <div>
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Subscriptions</div>
        <div style="font-size: 1.125rem; font-weight: 700;"><%= @audit_items.count %></div>
      </div>
      <div>
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Hourly Wage Equiv</div>
        <div style="font-size: 1.125rem; font-weight: 700;"><%= (@total_annual / 2080.0).round(1) %> hrs/yr</div>
      </div>
    </div>
  </div>

  <%# Cost tiers %>
  <div class="content-grid" style="margin-bottom: 1.5rem;">
    <% tier_config = [
      { key: :high, label: "High Cost ($50+/mo)", color: "var(--negative)", icon: "priority_high" },
      { key: :medium, label: "Medium ($15-50/mo)", color: "#f9ab00", icon: "remove" },
      { key: :low, label: "Low (< $15/mo)", color: "var(--positive)", icon: "check" }
    ] %>
    <% tier_config.each do |tc| %>
      <% items = @tiers[tc[:key]] %>
      <div class="card">
        <div class="card-header">
          <h2>
            <span class="material-icons-outlined" style="font-size: 1rem; color: <%= tc[:color] %>; vertical-align: -2px;"><%= tc[:icon] %></span>
            <%= tc[:label] %>
          </h2>
          <span style="font-size: 0.8125rem; font-weight: 600;"><%= items.count %></span>
        </div>
        <% if items.any? %>
          <div style="padding: 0.5rem 1.25rem;">
            <% items.each do |item| %>
              <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.375rem 0; border-bottom: 1px solid var(--border);">
                <div>
                  <div style="font-size: 0.8125rem; font-weight: 600;"><%= item[:name] %></div>
                  <div style="font-size: 0.6875rem; color: var(--text-secondary);"><%= item[:category] %></div>
                </div>
                <div style="text-align: right;">
                  <div style="font-size: 0.8125rem; font-weight: 700;"><%= number_to_currency(item[:monthly]) %>/mo</div>
                  <div style="font-size: 0.6875rem; color: var(--text-secondary);"><%= number_to_currency(item[:annual]) %>/yr</div>
                </div>
              </div>
            <% end %>
            <div style="display: flex; justify-content: space-between; padding: 0.5rem 0; font-weight: 600; font-size: 0.875rem;">
              <span>Subtotal</span>
              <span><%= number_to_currency(items.sum { |i| i[:monthly] }) %>/mo</span>
            </div>
          </div>
        <% else %>
          <p class="text-muted" style="padding: 0.75rem 1.25rem; font-size: 0.8125rem;">None in this tier.</p>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Category breakdown %>
  <% if @by_category.count >= 2 %>
    <div class="card" style="margin-bottom: 1.5rem;">
      <div class="card-header"><h2>By Category</h2></div>
      <div style="padding: 1rem 1.25rem;">
        <%
          cat_max = @by_category.first&.dig(1, :annual) || 1
          cat_colors = ["#1a73e8", "#0d904f", "#e8710a", "#d93025", "#9334e6", "#00bcd4", "#f9ab00"]
        %>
        <% @by_category.each_with_index do |(cat, data), i| %>
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.625rem;">
            <span style="font-size: 0.8125rem; min-width: 7rem; font-weight: 500;"><%= cat %></span>
            <div style="flex: 1; height: 1rem; background: var(--bg); border-radius: 0.5rem; overflow: hidden;">
              <div style="height: 100%; width: <%= (data[:annual] / cat_max * 100).round(1) %>%; background: <%= cat_colors[i % cat_colors.length] %>; opacity: 0.7; border-radius: 0.5rem;"></div>
            </div>
            <span style="font-size: 0.8125rem; font-weight: 600; min-width: 5rem; text-align: right;"><%= number_to_currency(data[:annual] / 12.0) %>/mo</span>
            <span style="font-size: 0.6875rem; color: var(--text-secondary); min-width: 2rem; text-align: right;"><%= data[:count] %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Full list with elimination calculator %>
  <div class="card">
    <div class="card-header">
      <h2>All Subscriptions</h2>
      <span class="text-muted">Sorted by annual cost</span>
    </div>
    <table class="table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Category</th>
          <th>Frequency</th>
          <th style="text-align: right;">Amount</th>
          <th style="text-align: right;">Monthly</th>
          <th style="text-align: right;">Annual</th>
          <th style="text-align: right;">% of Total</th>
        </tr>
      </thead>
      <tbody>
        <% @audit_items.each do |item| %>
          <%
            pct_of_total = @total_annual > 0 ? (item[:annual] / @total_annual * 100).round(1) : 0
          %>
          <tr>
            <td><strong><%= item[:name] %></strong></td>
            <td><%= item[:category] %></td>
            <td><%= item[:frequency]&.capitalize %></td>
            <td style="text-align: right;"><%= number_to_currency(item[:amount]) %></td>
            <td style="text-align: right;"><%= number_to_currency(item[:monthly]) %></td>
            <td style="text-align: right; font-weight: 600;"><%= number_to_currency(item[:annual]) %></td>
            <td style="text-align: right;">
              <div style="display: flex; align-items: center; gap: 0.25rem; justify-content: flex-end;">
                <div style="width: 40px; height: 6px; background: var(--bg); border-radius: 3px; overflow: hidden;">
                  <div style="height: 100%; width: <%= [pct_of_total * 2, 100].min %>%; background: var(--primary); opacity: 0.6; border-radius: 3px;"></div>
                </div>
                <span style="font-size: 0.75rem;"><%= pct_of_total %>%</span>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr style="font-weight: 700;">
          <td colspan="4">Total</td>
          <td style="text-align: right;"><%= number_to_currency(@total_monthly) %></td>
          <td style="text-align: right;"><%= number_to_currency(@total_annual) %></td>
          <td></td>
        </tr>
      </tfoot>
    </table>
  </div>

  <%# Savings scenarios %>
  <div class="card" style="margin-top: 1.5rem;">
    <div class="card-header"><h2>Savings Scenarios</h2></div>
    <div style="padding: 1rem 1.25rem;">
      <p style="font-size: 0.8125rem; color: var(--text-secondary); margin-bottom: 1rem;">
        What if you eliminated some subscriptions? Here's the potential impact.
      </p>
      <%
        scenarios = [
          { label: "Cut top 1 subscription", count: 1 },
          { label: "Cut top 3 subscriptions", count: 3 },
          { label: "Cut all high-cost ($50+)", count: @tiers[:high].count, items: @tiers[:high] }
        ]
      %>
      <% scenarios.each do |scenario| %>
        <%
          cut_items = scenario[:items] || @audit_items.first(scenario[:count])
          savings = cut_items.sum { |i| i[:annual] }
          next if cut_items.empty?
        %>
        <div style="display: flex; align-items: center; gap: 1rem; padding: 0.625rem 0; border-bottom: 1px solid var(--border);">
          <span style="font-size: 0.8125rem; flex: 1;"><%= scenario[:label] %></span>
          <span style="font-size: 0.875rem; font-weight: 700; color: var(--positive);"><%= number_to_currency(savings / 12.0) %>/mo</span>
          <span style="font-size: 0.8125rem; color: var(--text-secondary);"><%= number_to_currency(savings) %>/yr</span>
        </div>
      <% end %>
      <% ten_pct = @total_annual * 0.1 %>
      <div style="margin-top: 1rem; padding: 0.75rem; border-radius: var(--radius); background: var(--bg);">
        <span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px; color: var(--primary);">lightbulb</span>
        <span style="font-size: 0.8125rem;">
          Even a 10% reduction saves <strong class="positive"><%= number_to_currency(ten_pct / 12.0) %>/mo</strong>
          (<%= number_to_currency(ten_pct) %>/yr). Review each subscription and ask: "Would I re-subscribe today?"
        </span>
      </div>
    </div>
  </div>
<% else %>
  <div class="card empty-state">
    <p>No recurring bills found. Add your subscriptions and bills to get an audit.</p>
    <%= link_to "Add Recurring Bill", new_budget_recurring_path, class: "btn btn-primary" %>
  </div>
<% end %>
