<div class="page-header">
  <h1>Recurring Bills</h1>
  <div class="page-actions">
    <%= link_to "Auto-Process Overdue", auto_process_budget_recurring_index_path, data: { turbo_method: :post, turbo_confirm: "Create transactions for all overdue recurring bills?" }, class: "btn" %>
    <%= link_to "Calendar", calendar_budget_recurring_index_path, class: "btn" %>
    <%= link_to "Add Recurring", new_budget_recurring_path, class: "btn btn-primary" %>
  </div>
</div>

<% if @summary.present? && !@summary["error"] %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 0;">
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Monthly</div>
        <div style="font-size: 1.5rem; font-weight: 700;"><%= number_to_currency(@summary["total_monthly"]) %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Annual</div>
        <div style="font-size: 1.5rem; font-weight: 700;"><%= number_to_currency(@summary["total_annual"]) %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Active Bills</div>
        <div style="font-size: 1.5rem; font-weight: 700;"><%= @summary["count"] %></div>
      </div>
      <% if @summary["overdue"].to_i > 0 %>
        <div style="padding: 1rem; text-align: center;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Overdue</div>
          <div style="font-size: 1.5rem; font-weight: 700; color: var(--negative);"><%= @summary["overdue"] %></div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% if @items.is_a?(Array) && @items.any? %>
  <%
    freq_multiplier = { "weekly" => 52, "biweekly" => 26, "monthly" => 12, "quarterly" => 4, "annually" => 1 }
    annual_items = @items.map do |item|
      mult = freq_multiplier[item["frequency"]] || 12
      annual = item["amount"].to_f * mult
      { name: item["name"], amount: item["amount"].to_f, frequency: item["frequency"], annual: annual, merchant: item["merchant"] }
    end.sort_by { |i| -i[:annual] }
    max_annual = annual_items.first&.dig(:annual) || 1
    total_annual = annual_items.sum { |i| i[:annual] }
    daily_cost = total_annual / 365.0

    # Frequency distribution
    freq_groups = @items.group_by { |i| i["frequency"] || "monthly" }
    freq_totals = freq_groups.transform_values { |items| items.sum { |i| i["amount"].to_f } }

    # Upcoming bills in next 14 days
    upcoming_14 = @items.select do |item|
      next false unless item["next_due"].present?
      due = Date.parse(item["next_due"]) rescue nil
      due && due >= Date.current && due <= 14.days.from_now.to_date
    end.sort_by { |item| item["next_due"] }
    upcoming_total = upcoming_14.sum { |i| i["amount"].to_f }
  %>

  <%# Upcoming bills timeline %>
  <% if upcoming_14.any? %>
    <div class="card" style="margin-bottom: 1rem; border-left: 3px solid var(--primary);">
      <div style="padding: 0.75rem 1.25rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
          <strong style="font-size: 0.875rem;">
            <span class="material-icons-outlined" style="font-size: 1rem; vertical-align: -2px;">event</span>
            Next 14 Days
          </strong>
          <span style="font-size: 0.8125rem; font-weight: 600;"><%= number_to_currency(upcoming_total) %> due</span>
        </div>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
          <% upcoming_14.each do |bill| %>
            <% due = Date.parse(bill["next_due"]) rescue nil %>
            <div style="padding: 0.375rem 0.625rem; border-radius: var(--radius); background: var(--bg); display: flex; align-items: center; gap: 0.375rem; font-size: 0.75rem;">
              <span style="font-weight: 600;"><%= bill["name"] %></span>
              <span style="color: var(--text-secondary);"><%= due&.strftime("%b %d") %></span>
              <span style="font-weight: 700;"><%= number_to_currency(bill["amount"]) %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Frequency distribution %>
  <% if freq_groups.count >= 2 %>
    <div class="card" style="margin-bottom: 1rem;">
      <div class="card-header"><h2>By Frequency</h2></div>
      <div style="padding: 0.75rem 1.25rem; display: flex; gap: 1rem; flex-wrap: wrap;">
        <%
          freq_colors = { "weekly" => "#1a73e8", "biweekly" => "#0d904f", "monthly" => "#e8710a", "quarterly" => "#9334e6", "annually" => "#d93025" }
          freq_labels = { "weekly" => "Weekly", "biweekly" => "Biweekly", "monthly" => "Monthly", "quarterly" => "Quarterly", "annually" => "Annual" }
        %>
        <% freq_groups.each do |freq, items| %>
          <div style="flex: 1; min-width: 100px; padding: 0.625rem; border-radius: var(--radius); border: 1px solid var(--border);">
            <div style="font-size: 0.625rem; text-transform: uppercase; color: var(--text-secondary);"><%= freq_labels[freq] || freq.capitalize %></div>
            <div style="font-size: 1.125rem; font-weight: 700; color: <%= freq_colors[freq] || 'var(--text-primary)' %>;"><%= items.count %></div>
            <div style="font-size: 0.75rem; color: var(--text-secondary);"><%= number_to_currency(freq_totals[freq]) %>/cycle</div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2>Annual Cost Breakdown</h2>
      <span class="text-muted">Total: <%= number_to_currency(total_annual) %>/yr &middot; <%= number_to_currency(daily_cost) %>/day</span>
    </div>
    <div style="padding: 1rem 1.25rem;">
      <% annual_items.each do |item| %>
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.625rem;">
          <span style="width: 8rem; font-size: 0.8125rem; font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="<%= item[:name] %>"><%= item[:name] %></span>
          <div class="budget-progress-bar" style="flex: 1; height: 1.25rem;">
            <div style="width: <%= (item[:annual] / max_annual * 100).round(1) %>%; height: 100%; background: var(--primary); border-radius: var(--radius); transition: width 0.3s;"></div>
          </div>
          <span style="width: 5.5rem; text-align: right; font-size: 0.8125rem; font-weight: 600; font-variant-numeric: tabular-nums;"><%= number_to_currency(item[:annual]) %></span>
          <span style="width: 4rem; text-align: right; font-size: 0.75rem; color: var(--text-secondary);"><%= frequency_label(item[:frequency]) %></span>
        </div>
      <% end %>
    </div>
    <div style="padding: 0 1.25rem 1rem; display: flex; gap: 1.5rem; font-size: 0.8125rem; color: var(--text-secondary);">
      <span><span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px;">info</span> These are your fixed costs — reducing any of these has a compounding annual impact.</span>
    </div>
  </div>
  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Merchant</th>
          <th>Frequency</th>
          <th style="text-align: right;">Amount</th>
          <th style="text-align: right;">Monthly Cost</th>
          <th>Next Due</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @items.each do |item| %>
          <tr class="<%= "table-row-warning" if item["overdue?"] %>">
            <td>
              <strong><%= item["name"] %></strong>
              <% if item["category_name"].present? %>
                <br><span class="text-muted" style="font-size: 0.8rem;"><%= item["category_name"] %></span>
              <% end %>
            </td>
            <td><%= item["merchant"] %></td>
            <td><%= frequency_label(item["frequency"]) %></td>
            <td style="text-align: right;"><%= number_to_currency(item["amount"]) %></td>
            <td style="text-align: right;"><%= number_to_currency(item["monthly_cost"]) %></td>
            <td>
              <% if item["next_due"].present? %>
                <% due = Date.parse(item["next_due"]) rescue nil %>
                <% if due %>
                  <span class="<%= due < Date.current ? 'negative' : (due <= 7.days.from_now.to_date ? 'text-warning' : '') %>">
                    <%= due.strftime("%b %d, %Y") %>
                  </span>
                  <% if item["overdue?"] %>
                    <span class="badge badge-danger" style="margin-left: 0.25rem;">Overdue</span>
                  <% elsif item["due_soon?"] %>
                    <span class="badge badge-warning" style="margin-left: 0.25rem;">Due Soon</span>
                  <% end %>
                <% end %>
              <% end %>
            </td>
            <td style="white-space: nowrap;">
              <%= link_to "Edit", edit_budget_recurring_path(item["id"]), class: "btn btn-sm" %>
              <%= link_to "Skip", skip_budget_recurring_path(item["id"]), data: { turbo_method: :post }, class: "btn btn-sm" %>
              <%= link_to "Delete", budget_recurring_path(item["id"]), data: { turbo_method: :delete, turbo_confirm: "Remove?" }, class: "btn btn-sm btn-danger" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="card empty-state">
    <p>No recurring bills tracked. Add your subscriptions and bills to monitor monthly commitments.</p>
  </div>
<% end %>
