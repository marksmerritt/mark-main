<div style="text-align: center; margin-top: 1.5rem;">
  <%= link_to "Dashboard", budget_dashboard_path, class: "btn" %>
  <%= link_to "Spending Report", budget_reports_spending_path, class: "btn" %>
  <%= link_to "Year in Review", budget_year_in_review_path, class: "btn" %>
</div>
