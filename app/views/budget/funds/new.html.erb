<div class="page-header">
  <h1>New Sinking Fund</h1>
  <div class="page-actions"><%= link_to "Back", budget_funds_path, class: "btn" %></div>
</div>

<div class="card">
  <% if @errors.present? %>
    <div class="alert alert-danger" style="margin: 1rem 1.25rem 0;">
      <ul style="margin: 0; padding-left: 1rem;">
        <% @errors.each do |error| %><li><%= error %></li><% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: budget_funds_path, method: :post, class: "form-container" do |f| %>
    <div class="form-group">
      <%= f.label :name, "Fund Name" %>
      <%= f.text_field :name, value: @fund["name"], class: "form-control", name: "fund[name]", placeholder: "e.g. Emergency Fund, Vacation, New Car", required: true %>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div class="form-group">
        <%= f.label :target_amount, "Target Amount" %>
        <%= f.number_field :target_amount, value: @fund["target_amount"], step: "0.01", class: "form-control", name: "fund[target_amount]", placeholder: "10000.00" %>
      </div>
      <div class="form-group">
        <%= f.label :target_date, "Target Date" %>
        <%= f.date_field :target_date, value: @fund["target_date"], class: "form-control", name: "fund[target_date]" %>
      </div>
    </div>
    <div class="form-group">
      <%= f.label :notes, "Notes" %>
      <%= f.text_area :notes, value: @fund["notes"], class: "form-control", name: "fund[notes]", rows: 3 %>
    </div>
    <div class="form-actions">
      <%= f.submit "Create Fund", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
