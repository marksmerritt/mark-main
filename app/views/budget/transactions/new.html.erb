<div class="page-header">
  <h1>Add Transaction</h1>
  <div class="page-actions">
    <%= link_to "Back", budget_transactions_path, class: "btn" %>
  </div>
</div>

<div class="card">
  <% if @errors.present? %>
    <div class="alert alert-danger" style="margin: 1rem 1.25rem 0;">
      <ul style="margin: 0; padding-left: 1rem;">
        <% @errors.each do |error| %><li><%= error %></li><% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: budget_transactions_path, method: :post, class: "form-container" do |f| %>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div class="form-group">
        <%= f.label :amount, "Amount" %>
        <%= f.number_field :amount, value: @transaction["amount"], step: "0.01", class: "form-control", name: "transaction[amount]", required: true %>
      </div>
      <div class="form-group">
        <%= f.label :transaction_date, "Date" %>
        <%= f.date_field :transaction_date, value: @transaction["transaction_date"] || Date.current, class: "form-control", name: "transaction[transaction_date]", required: true %>
      </div>
    </div>
    <div class="form-group">
      <%= f.label :description, "Description" %>
      <%= f.text_field :description, value: @transaction["description"], class: "form-control", name: "transaction[description]", placeholder: "What was this for?" %>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div class="form-group" data-controller="remote-autocomplete"
           data-remote-autocomplete-url-value="<%= merchants_budget_transactions_path %>"
           style="position: relative;">
        <%= f.label :merchant, "Merchant" %>
        <%= f.text_field :merchant, value: @transaction["merchant"], class: "form-control", name: "transaction[merchant]", placeholder: "Store name",
            data: { remote_autocomplete_target: "input" }, autocomplete: "off" %>
        <div class="autocomplete-list hidden" data-remote-autocomplete-target="list"></div>
      </div>
      <div class="form-group">
        <%= f.label :transaction_type, "Type" %>
        <%= f.select :transaction_type, [["Expense", "expense"], ["Income", "income"]], { selected: @transaction["transaction_type"] || "expense" }, class: "form-control", name: "transaction[transaction_type]" %>
      </div>
    </div>
    <div class="form-group">
      <%= f.label :notes, "Notes (optional)" %>
      <%= f.text_area :notes, value: @transaction["notes"], class: "form-control", name: "transaction[notes]", rows: 2, placeholder: "Receipt details, reminders, etc." %>
    </div>
    <div class="form-actions">
      <%= f.submit "Add Transaction", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
