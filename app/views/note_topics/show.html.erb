<% content_for(:title) { "Topic Discovery" } %>

<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: #00796b;">category</span>
    Topic Discovery
  </h1>
  <p style="color: var(--text-secondary); font-size: 0.875rem; margin-top: 0.25rem;">
    Discover topics and themes across your notes library
  </p>
</div>

<% if @error.present? %>
  <div class="card" style="padding: 1.25rem; margin-bottom: 1.5rem; border-left: 3px solid var(--negative);">
    <strong>Error loading data:</strong> <%= @error %>
  </div>
<% end %>

<%# Stats Strip %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 0;">
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Topics Found</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: #00796b;"><%= @topics_found %></div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Top Topic</div>
      <div style="font-size: 1.25rem; font-weight: 700;"><%= @top_topic ? @top_topic[:name].capitalize : "---" %></div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Emerging Topics</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: #2e7d32;"><%= @emerging_topics.count %></div>
    </div>
    <div style="padding: 1rem; text-align: center;">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Notes Covered</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= @notes_covered %><span style="font-size: 0.75rem; color: var(--text-secondary);"> (<%= @notes_covered_pct %>%)</span></div>
    </div>
  </div>
</div>

<%# Major Themes %>
<% if @themes.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #00796b;">auto_awesome</span> Major Themes</h2>
    </div>
    <div style="padding: 1.25rem; display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center;">
      <%
        theme_max = @themes.first[:count].to_f
        theme_min = @themes.last[:count].to_f
        theme_range = [theme_max - theme_min, 1].max.to_f
      %>
      <% @themes.each do |theme| %>
        <%
          ratio = (theme[:count] - theme_min) / theme_range
          font_size = 0.875 + ratio * 1.75
        %>
        <span style="font-size: <%= font_size.round(2) %>rem; font-weight: <%= ratio > 0.4 ? 700 : 500 %>; color: #00796b; opacity: <%= (0.5 + ratio * 0.5).round(2) %>; cursor: default; line-height: 1.3; padding: 0.125rem 0.25rem;"
              title="<%= theme[:name] %>: appears <%= theme[:count] %> times"><%= theme[:name] %></span>
      <% end %>
    </div>
  </div>
<% end %>

<%# Topic Cards %>
<% if @topics.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">hub</span> Discovered Topics</h2>
    </div>
    <div style="padding: 1.25rem;">
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem;">
        <% @topics.each do |topic| %>
          <%
            trend_color = case topic[:trend]
            when "growing" then "#2e7d32"
            when "fading" then "#c62828"
            else "var(--text-secondary)"
            end
            trend_icon = case topic[:trend]
            when "growing" then "trending_up"
            when "fading" then "trending_down"
            else "trending_flat"
            end
            trend_label = topic[:trend].capitalize
          %>
          <div style="border: 1px solid var(--border); border-radius: 8px; padding: 1rem; background: var(--card-bg, #fff);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
              <div style="font-size: 1rem; font-weight: 700; color: #00796b;"><%= topic[:name].capitalize %></div>
              <div style="display: flex; align-items: center; gap: 0.25rem; font-size: 0.6875rem; color: <%= trend_color %>; font-weight: 600;">
                <span class="material-icons-outlined" style="font-size: 0.875rem;"><%= trend_icon %></span>
                <%= trend_label %>
              </div>
            </div>
            <div style="display: flex; flex-wrap: wrap; gap: 0.25rem; margin-bottom: 0.625rem;">
              <% topic[:keywords].each do |kw| %>
                <span style="font-size: 0.6875rem; padding: 0.125rem 0.5rem; border-radius: 9999px; background: rgba(0,121,107,0.08); color: #00796b;"><%= kw %></span>
              <% end %>
            </div>
            <div style="display: flex; gap: 1rem; font-size: 0.75rem; color: var(--text-secondary);">
              <span><span class="material-icons-outlined" style="font-size: 0.75rem; vertical-align: -1px;">description</span> <%= topic[:note_count] %> notes</span>
              <span><span class="material-icons-outlined" style="font-size: 0.75rem; vertical-align: -1px;">text_fields</span> <%= number_with_delimiter(topic[:total_words]) %> words</span>
            </div>
            <% if topic[:first_seen] && topic[:last_seen] %>
              <div style="font-size: 0.6875rem; color: var(--text-secondary); margin-top: 0.375rem;">
                <%= topic[:first_seen].strftime("%b %Y") %> &mdash; <%= topic[:last_seen].strftime("%b %Y") %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%# Topic Timeline SVG %>
<% if @topic_timeline.any? && @all_months.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">timeline</span> Topic Activity Over Time</h2>
    </div>
    <div style="padding: 1.25rem; overflow-x: auto;">
      <%
        tl_topics = @topic_timeline.keys.first(6)
        tl_colors = ["#00796b", "#1565c0", "#ad1457", "#e65100", "#4527a0", "#2e7d32"]
        months = @all_months
        chart_w = [months.count * 65 + 120, 500].max
        row_h = 28
        chart_h = 50 + tl_topics.count * row_h + 30
        plot_left = 100
        plot_right = chart_w - 30
        col_w = months.count > 1 ? (plot_right - plot_left).to_f / (months.count - 1) : (plot_right - plot_left)
        max_count = 1
        @topic_timeline.each do |_, monthly|
          monthly.each { |_, c| max_count = c if c > max_count }
        end
      %>
      <svg viewBox="0 0 <%= chart_w %> <%= chart_h %>" style="width: 100%; height: auto; font-family: Inter, sans-serif;">
        <%# Month headers %>
        <% months.each_with_index do |m, i| %>
          <%
            x = months.count > 1 ? plot_left + i * col_w : plot_left
          %>
          <text x="<%= x.round(1) %>" y="18" text-anchor="middle" fill="var(--text-secondary)" font-size="7"><%= m[-5..] %></text>
          <line x1="<%= x.round(1) %>" y1="24" x2="<%= x.round(1) %>" y2="<%= 30 + tl_topics.count * row_h %>" stroke="var(--border)" stroke-width="0.5" opacity="0.4"/>
        <% end %>

        <%# Topic rows %>
        <% tl_topics.each_with_index do |topic_name, ti| %>
          <%
            y_base = 40 + ti * row_h
            color = tl_colors[ti % tl_colors.count]
          %>
          <text x="<%= plot_left - 8 %>" y="<%= y_base + 5 %>" text-anchor="end" fill="<%= color %>" font-size="7.5" font-weight="600"><%= topic_name.length > 12 ? topic_name[0..11] + "..." : topic_name %></text>
          <line x1="<%= plot_left %>" y1="<%= y_base %>" x2="<%= plot_right %>" y2="<%= y_base %>" stroke="var(--border)" stroke-width="0.5" opacity="0.2"/>

          <% monthly = @topic_timeline[topic_name] || {} %>
          <% months.each_with_index do |m, mi| %>
            <%
              cnt = monthly[m].to_i
              next if cnt == 0
              x = months.count > 1 ? plot_left + mi * col_w : plot_left
              r = 3 + (cnt.to_f / max_count) * 8
              opacity = 0.4 + (cnt.to_f / max_count) * 0.6
            %>
            <circle cx="<%= x.round(1) %>" cy="<%= y_base %>" r="<%= r.round(1) %>" fill="<%= color %>" opacity="<%= opacity.round(2) %>"/>
            <% if cnt > 1 %>
              <text x="<%= x.round(1) %>" y="<%= y_base + 3 %>" text-anchor="middle" fill="white" font-size="5.5" font-weight="600"><%= cnt %></text>
            <% end %>
          <% end %>
        <% end %>
      </svg>
    </div>
  </div>
<% end %>

<%# Emerging vs Fading Topics Side by Side %>
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
  <%# Emerging Topics %>
  <div class="card">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #2e7d32;">trending_up</span> Emerging Topics</h2>
    </div>
    <div style="padding: 1rem;">
      <% if @emerging_topics.any? %>
        <% @emerging_topics.each do |topic| %>
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid var(--border);">
            <div>
              <div style="font-size: 0.875rem; font-weight: 600; color: #2e7d32;"><%= topic[:name].capitalize %></div>
              <div style="font-size: 0.6875rem; color: var(--text-secondary);">
                <%= topic[:note_count] %> notes &middot; <%= topic[:keywords].first(4).join(", ") %>
              </div>
            </div>
            <div style="display: flex; align-items: center; gap: 0.25rem; color: #2e7d32;">
              <span class="material-icons-outlined" style="font-size: 1rem;">trending_up</span>
            </div>
          </div>
        <% end %>
      <% else %>
        <div style="color: var(--text-secondary); font-size: 0.8125rem; padding: 0.5rem 0;">No emerging topics detected yet.</div>
      <% end %>
    </div>
  </div>

  <%# Fading Topics %>
  <div class="card">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #c62828;">trending_down</span> Fading Topics</h2>
    </div>
    <div style="padding: 1rem;">
      <% if @fading_topics.any? %>
        <% @fading_topics.each do |topic| %>
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid var(--border);">
            <div>
              <div style="font-size: 0.875rem; font-weight: 600; color: #c62828;"><%= topic[:name].capitalize %></div>
              <div style="font-size: 0.6875rem; color: var(--text-secondary);">
                <%= topic[:note_count] %> notes &middot; Last: <%= topic[:last_seen] ? topic[:last_seen].strftime("%b %Y") : "N/A" %>
              </div>
            </div>
            <div style="display: flex; align-items: center; gap: 0.25rem; color: #c62828;">
              <span class="material-icons-outlined" style="font-size: 1rem;">trending_down</span>
            </div>
          </div>
        <% end %>
      <% else %>
        <div style="color: var(--text-secondary); font-size: 0.8125rem; padding: 0.5rem 0;">No fading topics detected.</div>
      <% end %>
    </div>
  </div>
</div>

<%# Cross-Notebook Topics %>
<% if @cross_notebook_topics.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #1565c0;">library_books</span> Cross-Notebook Topics</h2>
    </div>
    <div style="padding: 1.25rem;">
      <% @cross_notebook_topics.each do |ct| %>
        <div style="display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.625rem 0; border-bottom: 1px solid var(--border);">
          <div style="min-width: 5rem;">
            <div style="font-size: 0.875rem; font-weight: 700; color: #1565c0;"><%= ct[:name].capitalize %></div>
            <div style="font-size: 0.6875rem; color: var(--text-secondary);"><%= ct[:note_count] %> notes</div>
          </div>
          <div style="flex: 1; display: flex; flex-wrap: wrap; gap: 0.25rem;">
            <% ct[:notebooks].each do |nb| %>
              <span style="font-size: 0.6875rem; padding: 0.125rem 0.5rem; border-radius: 9999px; background: rgba(21,101,192,0.08); color: #1565c0; border: 1px solid rgba(21,101,192,0.15);">
                <span class="material-icons-outlined" style="font-size: 0.625rem; vertical-align: -1px;">book</span>
                <%= nb %>
              </span>
            <% end %>
          </div>
          <div style="font-size: 0.75rem; font-weight: 600; color: #1565c0; white-space: nowrap;">
            <%= ct[:notebook_count] %> notebooks
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Topic Diversity Score Card %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header">
    <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #6a1b9a;">diversity_3</span> Topic Diversity</h2>
  </div>
  <div style="padding: 1.5rem; text-align: center;">
    <div style="font-size: 2.5rem; font-weight: 700; color: #6a1b9a;"><%= @diversity_label %></div>
    <div style="font-size: 0.875rem; color: var(--text-secondary); margin-top: 0.25rem;">
      <%= @topics_found %> distinct topics &middot; <%= @unique_topic_keywords %> unique keywords
    </div>
    <div style="margin-top: 1rem; max-width: 300px; margin-left: auto; margin-right: auto;">
      <div style="height: 0.5rem; background: var(--bg); border-radius: 9999px; overflow: hidden;">
        <div style="height: 100%; width: <%= [@topic_diversity * 5, 100].min %>%; background: linear-gradient(90deg, #6a1b9a, #00796b); border-radius: 9999px;"></div>
      </div>
    </div>
  </div>
</div>

<%# Topic Depth Table %>
<% if @topic_depth.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">layers</span> Topic Depth</h2>
    </div>
    <div style="padding: 1.25rem; overflow-x: auto;">
      <%
        depth_max_words = @topic_depth.map { |t| t[:words] }.max.to_f
        depth_max_words = 1 if depth_max_words == 0
      %>
      <% @topic_depth.each do |td| %>
        <%
          bar_pct = (td[:words].to_f / depth_max_words * 100).round(1)
        %>
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
          <span style="width: 7rem; font-size: 0.8125rem; font-weight: 600; text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= td[:name].capitalize %></span>
          <div style="flex: 1; height: 1.25rem; background: var(--bg); border-radius: 4px; overflow: hidden;">
            <div style="height: 100%; width: <%= bar_pct %>%; background: #00796b; opacity: 0.6; border-radius: 4px;"></div>
          </div>
          <span style="min-width: 4rem; text-align: right; font-size: 0.75rem; color: var(--text-secondary);"><%= number_with_delimiter(td[:words]) %> words</span>
          <span style="min-width: 3rem; text-align: right; font-size: 0.75rem; color: var(--text-secondary);"><%= td[:notes] %> notes</span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<%# Bottom Navigation %>
<div style="text-align: center; margin-top: 1.5rem;">
  <%= link_to "Notes", notes_path, class: "btn" %>
  <%= link_to "Knowledge Graph", knowledge_graph_notes_path, class: "btn" %>
  <%= link_to "Connections", note_links_path, class: "btn" %>
</div>
