<% @journal_entries.each do |entry| %>
  <div class="card entry-card">
    <div class="entry-card-header">
      <span class="entry-date"><%= Date.parse(entry["date"]).strftime("%A, %B %-d, %Y") %></span>
      <%= mood_badge(entry["mood"]) %>
    </div>
    <div class="entry-card-footer">
      <%= link_to "View", journal_entry_path(entry["id"]), class: "btn btn-sm" %>
    </div>
  </div>
<% end %>
