<div class="page-header">
  <h1>Journal Entries</h1>
  <%= link_to "New Entry", new_journal_entry_path, class: "btn btn-primary" %>
</div>

<div class="card">
  <%= form_with url: journal_entries_path, method: :get, class: "filter-form" do |f| %>
    <div class="filter-row">
      <div class="form-group">
        <%= f.label :start_date, "From" %>
        <%= f.date_field :start_date, value: params[:start_date], class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :end_date, "To" %>
        <%= f.date_field :end_date, value: params[:end_date], class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :mood, "Mood" %>
        <%= f.select :mood,
              options_for_select(["Confident", "Neutral", "Anxious", "Frustrated", "Excited", "Disciplined", "Fearful"], params[:mood]),
              { include_blank: "All Moods" },
              { class: "form-control" } %>
      </div>
      <div class="form-group form-actions-inline">
        <%= f.submit "Filter", class: "btn btn-primary" %>
        <%= link_to "Clear", journal_entries_path, class: "btn" %>
      </div>
    </div>
  <% end %>
</div>

<div class="entries-list">
  <% if @journal_entries.is_a?(Array) && @journal_entries.any? %>
    <% @journal_entries.each do |entry| %>
      <div class="card entry-card">
        <div class="entry-card-header">
          <span class="entry-date"><%= Date.parse(entry["date"]).strftime("%A, %B %-d, %Y") %></span>
          <% if entry["mood"].present? %>
            <span class="badge badge-mood"><%= entry["mood"] %></span>
          <% end %>
        </div>
        <div class="entry-card-footer">
          <%= link_to "View", journal_entry_path(entry["id"]), class: "btn btn-sm" %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="card empty-state">
      <p>No journal entries found. <%= link_to "Create your first entry", new_journal_entry_path %>.</p>
    </div>
  <% end %>
</div>
