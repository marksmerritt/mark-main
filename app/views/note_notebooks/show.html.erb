<%
  nb = @notebook
  nb_notes = @notes.is_a?(Array) ? @notes : []
  nb_count = nb_notes.size
  nb_pinned = nb_notes.count { |n| n["pinned"] }
  nb_favorited = nb_notes.count { |n| n["favorited"] }
  nb_total_words = nb_notes.sum { |n| n["word_count"].to_i }
  nb_with_tags = nb_notes.count { |n| n["tags"].is_a?(Array) && n["tags"].any? }
  nb_all_tags = nb_notes.flat_map { |n| n["tags"].is_a?(Array) ? n["tags"].map { |t| t["name"] } : [] }.tally.sort_by { |_, v| -v }
  nb_latest = nb_notes.max_by { |n| n["updated_at"].to_s } if nb_notes.any?
%>

<div class="page-header">
  <h1><%= nb["name"] %></h1>
  <div class="page-actions">
    <%= link_to new_note_path(notebook_id: nb["id"]), class: "btn btn-primary" do %>
      <span class="material-icons-outlined" style="font-size: 1rem; vertical-align: -2px;">add</span> New Note
    <% end %>
    <%= link_to "Edit", edit_note_notebook_path(nb["id"]), class: "btn" %>
    <%= link_to "Delete", note_notebook_path(nb["id"]), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this notebook?" }, class: "btn btn-danger" %>
    <%= link_to "Back to Notebooks", note_notebooks_path, class: "btn" %>
  </div>
</div>

<%# Notebook overview hero %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div style="display: flex; align-items: center; gap: 1.5rem; padding: 1.25rem; flex-wrap: wrap;">
    <div style="flex-shrink: 0; width: 60px; height: 60px; border-radius: var(--radius); background: rgba(99,102,241,0.1); display: flex; align-items: center; justify-content: center;">
      <span class="material-icons-outlined" style="font-size: 2rem; color: #6366f1;">menu_book</span>
    </div>
    <div style="flex: 1; min-width: 200px;">
      <div style="font-size: 1.25rem; font-weight: 700;"><%= nb["name"] %></div>
      <% if nb["description"].present? %>
        <div style="font-size: 0.8125rem; color: var(--text-secondary); margin-top: 0.25rem;"><%= truncate(nb["description"], length: 120) %></div>
      <% end %>
    </div>
    <div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
      <div style="text-align: center;">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Notes</div>
        <div style="font-size: 1.25rem; font-weight: 700;"><%= nb_count %></div>
      </div>
      <% if nb_total_words > 0 %>
        <div style="text-align: center;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Words</div>
          <div style="font-size: 1.25rem; font-weight: 700;"><%= nb_total_words.to_s.reverse.gsub(/(\d{3})(?=\d)/, '\\1,').reverse %></div>
        </div>
      <% end %>
      <% if nb_pinned > 0 %>
        <div style="text-align: center;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Pinned</div>
          <div style="font-size: 1.25rem; font-weight: 700;"><%= nb_pinned %></div>
        </div>
      <% end %>
      <% if nb_latest %>
        <div style="text-align: center;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Last Updated</div>
          <div style="font-size: 0.875rem; font-weight: 600;"><%= time_ago_in_words(Time.parse(nb_latest["updated_at"])) %> ago</div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Tag cloud for notebook %>
  <% if nb_all_tags.any? %>
    <div style="padding: 0 1.25rem 0.75rem; border-top: 1px solid var(--border); padding-top: 0.75rem;">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 0.375rem;">Tags in this notebook</div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
        <% nb_all_tags.first(15).each do |tag_name, count| %>
          <span class="badge" style="font-size: 0.6875rem;"><%= tag_name %> <span style="opacity: 0.6;"><%= count %></span></span>
        <% end %>
        <% if nb_all_tags.size > 15 %>
          <span style="font-size: 0.6875rem; color: var(--text-secondary);">+<%= nb_all_tags.size - 15 %> more</span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<% if nb_notes.any? %>
  <%# Sort: pinned first, then by updated_at %>
  <%
    sorted_notes = nb_notes.sort_by { |n| [n["pinned"] ? 0 : 1, -(Time.parse(n["updated_at"]).to_i rescue 0)] }
  %>
  <div class="entries-list">
    <% sorted_notes.each do |note| %>
      <div class="card entry-card" <% if note["color"].present? %>style="border-left: 4px solid <%= note["color"] %>"<% end %>>
        <div class="entry-card-header">
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <% if note["pinned"] %>
              <span class="material-icons-outlined" style="font-size: 0.875rem; color: var(--primary);" title="Pinned">push_pin</span>
            <% end %>
            <% if note["favorited"] %>
              <span class="material-icons-outlined" style="font-size: 0.875rem; color: #f59e0b;" title="Favorited">star</span>
            <% end %>
            <span class="entry-date">
              <%= link_to note["title"].presence || "Untitled", note_path(note["id"]) %>
            </span>
          </div>
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <% if note["word_count"].to_i > 0 %>
              <span style="font-size: 0.6875rem; color: var(--text-secondary);"><%= note["word_count"] %> words</span>
            <% end %>
          </div>
        </div>

        <% if note["content_preview"].present? || note["content"].present? %>
          <p class="text-muted"><%= truncate(note["content_preview"] || note["content"], length: 150) %></p>
        <% end %>

        <% if note["tags"].present? && note["tags"].any? %>
          <div class="tag-list-horizontal">
            <% note["tags"].each do |tag| %>
              <span class="tag" <% if tag["color"].present? %>style="background-color: <%= tag["color"] %>"<% end %>><%= tag["name"] %></span>
            <% end %>
          </div>
        <% end %>

        <div class="entry-card-footer">
          <span class="text-muted">
            <% if note["updated_at"].present? %>
              Updated <%= time_ago_in_words(Time.parse(note["updated_at"])) %> ago
            <% end %>
          </span>
          <%= link_to "View", note_path(note["id"]), class: "btn btn-sm" %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card empty-state">
    <p>No notes in this notebook yet. <%= link_to "Create a note", new_note_path(notebook_id: nb["id"]) %>.</p>
  </div>
<% end %>
