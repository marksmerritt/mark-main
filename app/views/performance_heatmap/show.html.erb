<% content_for(:title) { "Performance Heatmap" } %>

<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: #6a1b9a;">grid_on</span>
    Performance Heatmap
  </h1>
</div>

<% if @trades.blank? || @trades.empty? %>
  <div class="card" style="padding: 3rem; text-align: center; color: var(--text-secondary);">
    <span class="material-icons-outlined" style="font-size: 3rem; margin-bottom: 1rem; color: #6a1b9a;">grid_on</span>
    <div style="font-size: 1.125rem; font-weight: 600;">Not enough trading data</div>
    <div style="font-size: 0.875rem; margin-top: 0.5rem;">Close some trades with P&amp;L to see multi-dimensional performance heatmaps.</div>
  </div>
<% else %>

  <%# ── Stats Strip ── %>
  <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem;">
    <div class="card" style="padding: 1rem; text-align: center;">
      <div style="font-size: 1.5rem; font-weight: 700; color: #6a1b9a;"><%= @cells_analyzed %></div>
      <div style="font-size: 0.75rem; color: var(--text-secondary);">Cells Analyzed</div>
    </div>
    <div class="card" style="padding: 1rem; text-align: center;">
      <% if @best_combination %>
        <div style="font-size: 1.125rem; font-weight: 700; color: var(--positive);"><%= @best_combination[:row] %> &times; <%= @best_combination[:col] %></div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Best Combination (<%= @best_combination[:stats][:win_rate] %>%)</div>
      <% else %>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--text-secondary);">&mdash;</div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Best Combination</div>
      <% end %>
    </div>
    <div class="card" style="padding: 1rem; text-align: center;">
      <% if @worst_combination %>
        <div style="font-size: 1.125rem; font-weight: 700; color: var(--negative);"><%= @worst_combination[:row] %> &times; <%= @worst_combination[:col] %></div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Worst Combination (<%= @worst_combination[:stats][:win_rate] %>%)</div>
      <% else %>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--text-secondary);">&mdash;</div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Worst Combination</div>
      <% end %>
    </div>
    <div class="card" style="padding: 1rem; text-align: center;">
      <div style="font-size: 1.5rem; font-weight: 700; color: #6a1b9a;"><%= @data_points %></div>
      <div style="font-size: 0.75rem; color: var(--text-secondary);">Data Points</div>
    </div>
  </div>

  <%# ── Hour x Day of Week SVG Heatmap ── %>
  <div class="card" style="margin-bottom: 1.5rem; border-top: 4px solid #6a1b9a;">
    <div class="card-header">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #6a1b9a;">schedule</span>
        Hour &times; Day of Week
      </h2>
    </div>
    <div style="padding: 1.25rem; overflow-x: auto;">
      <div style="font-size: 0.8125rem; color: var(--text-secondary); margin-bottom: 1rem;">
        Win rate by trading hour and day. Green cells indicate above-average performance, red cells indicate below-average.
      </div>
      <%
        cell_w = 80
        cell_h = 32
        label_w = 60
        header_h = 28
        svg_w = label_w + (@day_labels.count * cell_w) + 10
        svg_h = header_h + (@hour_day_hours.count * cell_h) + 10
      %>
      <svg viewBox="0 0 <%= svg_w %> <%= svg_h %>" style="width: 100%; max-width: <%= svg_w %>px; height: auto; font-family: Inter, sans-serif;">
        <%# Column headers %>
        <% @day_labels.each_with_index do |day, i| %>
          <text x="<%= label_w + (i * cell_w) + cell_w / 2 %>" y="<%= header_h - 8 %>" text-anchor="middle" fill="var(--text-secondary)" font-size="11" font-weight="600"><%= day %></text>
        <% end %>

        <%# Grid rows %>
        <% @hour_day_hours.each_with_index do |hour, row_idx| %>
          <% y = header_h + (row_idx * cell_h) %>
          <%# Row label %>
          <text x="<%= label_w - 6 %>" y="<%= y + cell_h / 2 + 4 %>" text-anchor="end" fill="var(--text-secondary)" font-size="10"><%= format_hour(hour) %></text>

          <% @day_labels.each_with_index do |day, col_idx| %>
            <% x = label_w + (col_idx * cell_w) %>
            <% stats = @hour_day_data.dig(hour, day) %>
            <% if stats %>
              <%
                wr = stats[:win_rate]
                if wr >= 65
                  fill = "rgba(46, 125, 50, 0.35)"
                  text_color = "#2e7d32"
                elsif wr >= 55
                  fill = "rgba(46, 125, 50, 0.18)"
                  text_color = "#2e7d32"
                elsif wr >= 45
                  fill = "rgba(158, 158, 158, 0.1)"
                  text_color = "var(--text-secondary)"
                elsif wr >= 35
                  fill = "rgba(211, 47, 47, 0.18)"
                  text_color = "#d32f2f"
                else
                  fill = "rgba(211, 47, 47, 0.35)"
                  text_color = "#d32f2f"
                end
              %>
              <rect x="<%= x + 1 %>" y="<%= y + 1 %>" width="<%= cell_w - 2 %>" height="<%= cell_h - 2 %>" rx="4" fill="<%= fill %>" />
              <text x="<%= x + cell_w / 2 %>" y="<%= y + cell_h / 2 - 2 %>" text-anchor="middle" fill="<%= text_color %>" font-size="11" font-weight="700"><%= wr %>%</text>
              <text x="<%= x + cell_w / 2 %>" y="<%= y + cell_h / 2 + 10 %>" text-anchor="middle" fill="var(--text-secondary)" font-size="8">n=<%= stats[:trade_count] %></text>
            <% else %>
              <rect x="<%= x + 1 %>" y="<%= y + 1 %>" width="<%= cell_w - 2 %>" height="<%= cell_h - 2 %>" rx="4" fill="var(--bg)" opacity="0.5" />
              <text x="<%= x + cell_w / 2 %>" y="<%= y + cell_h / 2 + 3 %>" text-anchor="middle" fill="var(--text-secondary)" font-size="10" opacity="0.4">&mdash;</text>
            <% end %>
          <% end %>
        <% end %>
      </svg>
    </div>
  </div>

  <%# ── Monthly P&L Calendar Heatmap (GitHub-style) ── %>
  <% if @calendar_weeks.present? && @calendar_weeks.any? %>
    <div class="card" style="margin-bottom: 1.5rem;">
      <div class="card-header">
        <h2>
          <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #6a1b9a;">calendar_month</span>
          P&amp;L Calendar
        </h2>
      </div>
      <div style="padding: 1.25rem; overflow-x: auto;">
        <div style="font-size: 0.8125rem; color: var(--text-secondary); margin-bottom: 1rem;">
          Daily P&amp;L intensity. Greener = more profit, redder = more loss. Hover for details.
        </div>
        <%
          sq = 13
          gap = 3
          day_label_w = 28
          header_h2 = 18
          cal_svg_w = day_label_w + (@calendar_weeks.count * (sq + gap)) + 10
          cal_svg_h = header_h2 + (7 * (sq + gap)) + 10
          day_abbrs = %w[S M T W T F S]
        %>
        <svg viewBox="0 0 <%= cal_svg_w %> <%= cal_svg_h %>" style="width: 100%; max-width: <%= [cal_svg_w, 900].min %>px; height: auto; font-family: Inter, sans-serif;">
          <%# Day of week labels %>
          <% day_abbrs.each_with_index do |abbr, i| %>
            <% next if i.even? && i != 0 %>
            <text x="<%= day_label_w - 4 %>" y="<%= header_h2 + (i * (sq + gap)) + sq - 2 %>" text-anchor="end" fill="var(--text-secondary)" font-size="9"><%= abbr %></text>
          <% end %>

          <%# Month labels %>
          <%
            month_positions = {}
            @calendar_weeks.each_with_index do |week, wi|
              first_day = week.first[:date]
              if first_day.day <= 7
                month_positions[first_day.strftime("%b")] ||= wi
              end
            end
          %>
          <% month_positions.each do |label, wi| %>
            <text x="<%= day_label_w + (wi * (sq + gap)) %>" y="<%= header_h2 - 4 %>" fill="var(--text-secondary)" font-size="9"><%= label %></text>
          <% end %>

          <%# Calendar squares %>
          <% @calendar_weeks.each_with_index do |week, wi| %>
            <% week.each_with_index do |day_data, dow| %>
              <%
                x = day_label_w + (wi * (sq + gap))
                y = header_h2 + (dow * (sq + gap))
                pnl = day_data[:pnl]
                if pnl.nil?
                  fill = "var(--bg)"
                  opacity = "0.4"
                elsif pnl > 0
                  intensity = [pnl.abs / @calendar_max_pnl, 1.0].min
                  level = (intensity * 4).ceil.clamp(1, 4)
                  alpha = [0.15, 0.3, 0.5, 0.75][level - 1]
                  fill = "rgba(46, 125, 50, #{alpha})"
                  opacity = "1"
                elsif pnl < 0
                  intensity = [pnl.abs / @calendar_max_pnl, 1.0].min
                  level = (intensity * 4).ceil.clamp(1, 4)
                  alpha = [0.15, 0.3, 0.5, 0.75][level - 1]
                  fill = "rgba(211, 47, 47, #{alpha})"
                  opacity = "1"
                else
                  fill = "rgba(158, 158, 158, 0.15)"
                  opacity = "1"
                end
              %>
              <rect x="<%= x %>" y="<%= y %>" width="<%= sq %>" height="<%= sq %>" rx="2" fill="<%= fill %>" opacity="<%= opacity %>">
                <% if pnl %>
                  <title><%= day_data[:date].strftime("%b %d, %Y") %>: <%= number_to_currency(pnl) %></title>
                <% end %>
              </rect>
            <% end %>
          <% end %>
        </svg>

        <%# Monthly summary table %>
        <% if @years.present? && @years.any? %>
          <div style="margin-top: 1.25rem;">
            <div style="font-size: 0.8125rem; font-weight: 600; margin-bottom: 0.5rem;">Monthly P&amp;L Summary</div>
            <div style="overflow-x: auto;">
              <table style="width: 100%; border-collapse: collapse; font-size: 0.75rem;">
                <thead>
                  <tr>
                    <th style="padding: 0.375rem 0.5rem; text-align: left; border-bottom: 2px solid var(--border);">Year</th>
                    <% @month_labels.each do |m| %>
                      <th style="padding: 0.375rem 0.5rem; text-align: center; border-bottom: 2px solid var(--border);"><%= m %></th>
                    <% end %>
                    <th style="padding: 0.375rem 0.5rem; text-align: center; border-bottom: 2px solid var(--border); font-weight: 700;">Total</th>
                  </tr>
                </thead>
                <tbody>
                  <% @years.each do |year| %>
                    <tr>
                      <td style="padding: 0.375rem 0.5rem; font-weight: 600; border-bottom: 1px solid var(--border);"><%= year %></td>
                      <%
                        year_total = 0
                      %>
                      <% (1..12).each do |month| %>
                        <% data = @month_year_data.dig(year, month) %>
                        <% if data %>
                          <%
                            pnl = data[:total_pnl]
                            year_total += pnl
                            intensity = [pnl.abs / @monthly_max_pnl, 1.0].min
                            if pnl > 0
                              bg = "rgba(46, 125, 50, #{(intensity * 0.3).round(2)})"
                              fg = "#2e7d32"
                            elsif pnl < 0
                              bg = "rgba(211, 47, 47, #{(intensity * 0.3).round(2)})"
                              fg = "#d32f2f"
                            else
                              bg = "transparent"
                              fg = "var(--text-secondary)"
                            end
                          %>
                          <td style="padding: 0.375rem 0.5rem; text-align: center; background: <%= bg %>; border-bottom: 1px solid var(--border);">
                            <span style="font-weight: 600; color: <%= fg %>; font-size: 0.6875rem;"><%= number_to_currency(pnl, precision: 0) %></span>
                            <div style="font-size: 0.5625rem; color: var(--text-secondary);"><%= data[:trade_count] %>t &middot; <%= data[:win_rate] %>%</div>
                          </td>
                        <% else %>
                          <td style="padding: 0.375rem 0.5rem; text-align: center; border-bottom: 1px solid var(--border); color: var(--text-secondary);">&mdash;</td>
                        <% end %>
                      <% end %>
                      <td style="padding: 0.375rem 0.5rem; text-align: center; border-bottom: 1px solid var(--border); font-weight: 700; color: <%= year_total >= 0 ? '#2e7d32' : '#d32f2f' %>;"><%= number_to_currency(year_total, precision: 0) %></td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ── Symbol x Day of Week ── %>
  <% if @symbol_day_symbols.present? && @symbol_day_symbols.any? %>
    <div class="card" style="margin-bottom: 1.5rem;">
      <div class="card-header">
        <h2>
          <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #6a1b9a;">sell</span>
          Symbol &times; Day of Week
        </h2>
      </div>
      <div style="padding: 1.25rem; overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; font-size: 0.75rem;">
          <thead>
            <tr>
              <th style="padding: 0.375rem 0.5rem; text-align: left; border-bottom: 2px solid var(--border);">Symbol</th>
              <% @day_labels.each do |day| %>
                <th style="padding: 0.375rem 0.5rem; text-align: center; border-bottom: 2px solid var(--border);"><%= day %></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% @symbol_day_symbols.each do |sym| %>
              <tr>
                <td style="padding: 0.375rem 0.5rem; font-weight: 600; border-bottom: 1px solid var(--border);"><%= sym %></td>
                <% @day_labels.each do |day| %>
                  <% stats = @symbol_day_data.dig(sym, day) %>
                  <% if stats %>
                    <%
                      wr = stats[:win_rate]
                      bg = if wr >= 65
                        "rgba(46, 125, 50, 0.3)"
                      elsif wr >= 55
                        "rgba(46, 125, 50, 0.15)"
                      elsif wr >= 45
                        "rgba(158, 158, 158, 0.08)"
                      elsif wr >= 35
                        "rgba(211, 47, 47, 0.15)"
                      else
                        "rgba(211, 47, 47, 0.3)"
                      end
                      fg = wr >= 55 ? "#2e7d32" : wr < 45 ? "#d32f2f" : "var(--text-secondary)"
                    %>
                    <td style="padding: 0.375rem 0.5rem; text-align: center; background: <%= bg %>; border-bottom: 1px solid var(--border);">
                      <span style="font-weight: 700; color: <%= fg %>;"><%= wr %>%</span>
                      <div style="font-size: 0.625rem; color: var(--text-secondary);">n=<%= stats[:trade_count] %> &middot; <%= number_to_currency(stats[:avg_pnl]) %></div>
                    </td>
                  <% else %>
                    <td style="padding: 0.375rem 0.5rem; text-align: center; border-bottom: 1px solid var(--border); color: var(--text-secondary);">&mdash;</td>
                  <% end %>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <%# ── Direction x Duration ── %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #6a1b9a;">swap_vert</span>
        Direction &times; Duration
      </h2>
    </div>
    <div style="padding: 1.25rem; overflow-x: auto;">
      <table style="width: 100%; border-collapse: collapse; font-size: 0.75rem;">
        <thead>
          <tr>
            <th style="padding: 0.5rem; text-align: left; border-bottom: 2px solid var(--border);">Direction</th>
            <% @durations.each do |dur| %>
              <th style="padding: 0.5rem; text-align: center; border-bottom: 2px solid var(--border);"><%= dur %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @directions.each do |dir| %>
            <tr>
              <td style="padding: 0.5rem; font-weight: 600; border-bottom: 1px solid var(--border);">
                <span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px; color: <%= dir == 'Long' ? '#2e7d32' : '#d32f2f' %>;"><%= dir == 'Long' ? 'trending_up' : 'trending_down' %></span>
                <%= dir %>
              </td>
              <% @durations.each do |dur| %>
                <% stats = @dir_dur_data.dig(dir, dur) %>
                <% if stats %>
                  <%
                    wr = stats[:win_rate]
                    bg = if wr >= 65
                      "rgba(46, 125, 50, 0.3)"
                    elsif wr >= 55
                      "rgba(46, 125, 50, 0.15)"
                    elsif wr >= 45
                      "rgba(158, 158, 158, 0.08)"
                    elsif wr >= 35
                      "rgba(211, 47, 47, 0.15)"
                    else
                      "rgba(211, 47, 47, 0.3)"
                    end
                    fg = wr >= 55 ? "#2e7d32" : wr < 45 ? "#d32f2f" : "var(--text-primary)"
                  %>
                  <td style="padding: 0.5rem; text-align: center; background: <%= bg %>; border-bottom: 1px solid var(--border);">
                    <div style="font-weight: 700; font-size: 0.875rem; color: <%= fg %>;"><%= wr %>%</div>
                    <div style="font-size: 0.625rem; color: var(--text-secondary);">
                      <%= stats[:trade_count] %> trades &middot; <%= number_to_currency(stats[:avg_pnl]) %> avg
                    </div>
                    <div style="font-size: 0.625rem; color: <%= stats[:total_pnl] >= 0 ? '#2e7d32' : '#d32f2f' %>; font-weight: 600;">
                      Total: <%= number_to_currency(stats[:total_pnl]) %>
                    </div>
                  </td>
                <% else %>
                  <td style="padding: 0.5rem; text-align: center; border-bottom: 1px solid var(--border); color: var(--text-secondary);">
                    <div>&mdash;</div>
                    <div style="font-size: 0.625rem;">< 3 trades</div>
                  </td>
                <% end %>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# ── Size x Time ── %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #6a1b9a;">tune</span>
        Position Size &times; Time of Day
      </h2>
    </div>
    <div style="padding: 1.25rem; overflow-x: auto;">
      <table style="width: 100%; border-collapse: collapse; font-size: 0.75rem;">
        <thead>
          <tr>
            <th style="padding: 0.5rem; text-align: left; border-bottom: 2px solid var(--border);">Size</th>
            <% @time_buckets.each do |tb| %>
              <th style="padding: 0.5rem; text-align: center; border-bottom: 2px solid var(--border);"><%= tb %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @size_buckets.each do |sb| %>
            <tr>
              <td style="padding: 0.5rem; font-weight: 600; border-bottom: 1px solid var(--border);"><%= sb %></td>
              <% @time_buckets.each do |tb| %>
                <% stats = @size_time_data.dig(sb, tb) %>
                <% if stats %>
                  <%
                    wr = stats[:win_rate]
                    bg = if wr >= 65
                      "rgba(46, 125, 50, 0.3)"
                    elsif wr >= 55
                      "rgba(46, 125, 50, 0.15)"
                    elsif wr >= 45
                      "rgba(158, 158, 158, 0.08)"
                    elsif wr >= 35
                      "rgba(211, 47, 47, 0.15)"
                    else
                      "rgba(211, 47, 47, 0.3)"
                    end
                    fg = wr >= 55 ? "#2e7d32" : wr < 45 ? "#d32f2f" : "var(--text-primary)"
                  %>
                  <td style="padding: 0.5rem; text-align: center; background: <%= bg %>; border-bottom: 1px solid var(--border);">
                    <div style="font-weight: 700; font-size: 0.875rem; color: <%= fg %>;"><%= wr %>%</div>
                    <div style="font-size: 0.625rem; color: var(--text-secondary);">
                      n=<%= stats[:trade_count] %> &middot; <%= number_to_currency(stats[:avg_pnl]) %>
                    </div>
                  </td>
                <% else %>
                  <td style="padding: 0.5rem; text-align: center; border-bottom: 1px solid var(--border); color: var(--text-secondary);">
                    <div>&mdash;</div>
                    <div style="font-size: 0.625rem;">< 3 trades</div>
                  </td>
                <% end %>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# ── Best / Worst Combination Cards ── %>
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
    <% if @best_combination %>
      <div class="card" style="border-top: 4px solid var(--positive); padding: 1.25rem;">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
          <span class="material-icons-outlined" style="color: var(--positive);">emoji_events</span>
          <span style="font-weight: 700; font-size: 0.9375rem;">Best Combination</span>
        </div>
        <div style="font-size: 1.25rem; font-weight: 700; color: var(--positive); margin-bottom: 0.25rem;">
          <%= @best_combination[:row] %> &times; <%= @best_combination[:col] %>
        </div>
        <div style="font-size: 0.8125rem; color: var(--text-secondary); margin-bottom: 0.5rem;"><%= @best_combination[:heatmap] %></div>
        <div style="display: flex; gap: 1.5rem; font-size: 0.8125rem;">
          <span><strong style="color: var(--positive);"><%= @best_combination[:stats][:win_rate] %>%</strong> win rate</span>
          <span><strong><%= @best_combination[:stats][:trade_count] %></strong> trades</span>
          <span><strong style="color: <%= @best_combination[:stats][:avg_pnl] >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(@best_combination[:stats][:avg_pnl]) %></strong> avg</span>
        </div>
      </div>
    <% else %>
      <div class="card" style="padding: 1.25rem; text-align: center; color: var(--text-secondary);">
        <span class="material-icons-outlined" style="font-size: 2rem; opacity: 0.3;">emoji_events</span>
        <div style="font-size: 0.8125rem; margin-top: 0.5rem;">Not enough data for best combination</div>
      </div>
    <% end %>

    <% if @worst_combination %>
      <div class="card" style="border-top: 4px solid var(--negative); padding: 1.25rem;">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
          <span class="material-icons-outlined" style="color: var(--negative);">warning</span>
          <span style="font-weight: 700; font-size: 0.9375rem;">Worst Combination</span>
        </div>
        <div style="font-size: 1.25rem; font-weight: 700; color: var(--negative); margin-bottom: 0.25rem;">
          <%= @worst_combination[:row] %> &times; <%= @worst_combination[:col] %>
        </div>
        <div style="font-size: 0.8125rem; color: var(--text-secondary); margin-bottom: 0.5rem;"><%= @worst_combination[:heatmap] %></div>
        <div style="display: flex; gap: 1.5rem; font-size: 0.8125rem;">
          <span><strong style="color: var(--negative);"><%= @worst_combination[:stats][:win_rate] %>%</strong> win rate</span>
          <span><strong><%= @worst_combination[:stats][:trade_count] %></strong> trades</span>
          <span><strong style="color: <%= @worst_combination[:stats][:avg_pnl] >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(@worst_combination[:stats][:avg_pnl]) %></strong> avg</span>
        </div>
      </div>
    <% else %>
      <div class="card" style="padding: 1.25rem; text-align: center; color: var(--text-secondary);">
        <span class="material-icons-outlined" style="font-size: 2rem; opacity: 0.3;">warning</span>
        <div style="font-size: 0.8125rem; margin-top: 0.5rem;">Not enough data for worst combination</div>
      </div>
    <% end %>
  </div>

  <%# ── Legend ── %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #6a1b9a;">info</span>
        Color Legend
      </h2>
    </div>
    <div style="padding: 1.25rem;">
      <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; font-size: 0.8125rem; align-items: center;">
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <div style="width: 2rem; height: 1rem; border-radius: 3px; background: rgba(211, 47, 47, 0.3);"></div>
          <span>&lt; 35% win rate</span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <div style="width: 2rem; height: 1rem; border-radius: 3px; background: rgba(211, 47, 47, 0.15);"></div>
          <span>35-44% win rate</span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <div style="width: 2rem; height: 1rem; border-radius: 3px; background: rgba(158, 158, 158, 0.1); border: 1px solid var(--border);"></div>
          <span>45-54% (neutral)</span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <div style="width: 2rem; height: 1rem; border-radius: 3px; background: rgba(46, 125, 50, 0.15);"></div>
          <span>55-64% win rate</span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <div style="width: 2rem; height: 1rem; border-radius: 3px; background: rgba(46, 125, 50, 0.3);"></div>
          <span>&gt; 65% win rate</span>
        </div>
      </div>
      <div style="margin-top: 0.75rem; font-size: 0.75rem; color: var(--text-secondary);">
        Cells require a minimum of 3 trades for statistical validity. Cells with fewer trades show &ldquo;&mdash;&rdquo;.
      </div>
    </div>
  </div>

<% end %>

<%# ── Bottom Nav ── %>
<div style="text-align: center; margin-top: 1.5rem;">
  <%= link_to edge_finder_path, class: "btn" do %><span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px;">gps_fixed</span> Edge Finder<% end %>
  <%= link_to reports_index_path, class: "btn" do %><span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px;">hub</span> Reports<% end %>
  <%= link_to account_summary_path, class: "btn" do %><span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px;">account_balance</span> Account Summary<% end %>
</div>

<style>
  @media (max-width: 640px) {
    div[style*="grid-template-columns: repeat(4"] { grid-template-columns: repeat(2, 1fr) !important; }
    div[style*="grid-template-columns: 1fr 1fr"] { grid-template-columns: 1fr !important; }
  }
  @media print {
    .navbar, .page-actions, .app-footer, .back-to-top, .toast-container { display: none !important; }
    .main-content { padding: 0 !important; }
    .card { break-inside: avoid; box-shadow: none !important; border: 1px solid #ddd !important; }
  }
</style>
