<% content_for(:title) { "Goal Tracker" } %>

<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: #4caf50;">flag</span>
    Goal Tracker
  </h1>
  <span style="font-size: 0.8125rem; color: var(--text-secondary);"><%= Date.current.strftime("%A, %B %-d, %Y") %></span>
</div>

<%# Overall Progress Card %>
<div class="card" style="margin-bottom: 1.5rem; padding: 1.5rem; background: linear-gradient(135deg, rgba(76,175,80,0.06), rgba(76,175,80,0.02));">
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
    <div>
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em;">Overall Progress</div>
      <div style="font-size: 2.5rem; font-weight: 700; color: #4caf50; line-height: 1.2;"><%= @completed %>/<%= @total_goals %></div>
      <div style="font-size: 0.8125rem; color: var(--text-secondary);">goals completed</div>
    </div>
    <div style="text-align: center;">
      <div style="position: relative; width: 100px; height: 100px;">
        <svg viewBox="0 0 36 36" style="width: 100px; height: 100px; transform: rotate(-90deg);">
          <circle cx="18" cy="18" r="15.9" fill="none" stroke="var(--border)" stroke-width="3"/>
          <circle cx="18" cy="18" r="15.9" fill="none" stroke="#4caf50" stroke-width="3"
                  stroke-dasharray="<%= @overall_progress %>, 100" stroke-linecap="round"/>
        </svg>
        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 1.125rem; font-weight: 700;"><%= @overall_progress %>%</div>
      </div>
    </div>
  </div>

  <%# Status summary strip %>
  <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem; margin-top: 0.75rem;">
    <div style="text-align: center; padding: 0.5rem; border-radius: 8px; background: rgba(76,175,80,0.1);">
      <div style="font-size: 1.25rem; font-weight: 700; color: #4caf50;"><%= @completed %></div>
      <div style="font-size: 0.625rem; color: var(--text-secondary); text-transform: uppercase;">Completed</div>
    </div>
    <div style="text-align: center; padding: 0.5rem; border-radius: 8px; background: rgba(33,150,243,0.1);">
      <div style="font-size: 1.25rem; font-weight: 700; color: #2196f3;"><%= @on_track %></div>
      <div style="font-size: 0.625rem; color: var(--text-secondary); text-transform: uppercase;">On Track</div>
    </div>
    <div style="text-align: center; padding: 0.5rem; border-radius: 8px; background: rgba(255,152,0,0.1);">
      <div style="font-size: 1.25rem; font-weight: 700; color: #ff9800;"><%= @at_risk %></div>
      <div style="font-size: 0.625rem; color: var(--text-secondary); text-transform: uppercase;">At Risk</div>
    </div>
    <div style="text-align: center; padding: 0.5rem; border-radius: 8px; background: rgba(244,67,54,0.1);">
      <div style="font-size: 1.25rem; font-weight: 700; color: #f44336;"><%= @behind %></div>
      <div style="font-size: 0.625rem; color: var(--text-secondary); text-transform: uppercase;">Behind</div>
    </div>
  </div>
</div>

<%# Goals by Category %>
<%
  category_config = {
    "Trading" => { icon: "show_chart", color: "#1565c0", bg: "rgba(21,101,192,0.06)" },
    "Budget"  => { icon: "account_balance_wallet", color: "#0d904f", bg: "rgba(13,144,79,0.06)" },
    "Writing" => { icon: "edit_note", color: "#9c27b0", bg: "rgba(156,39,176,0.06)" }
  }

  status_config = {
    completed: { label: "Completed", bg: "#e8f5e9", color: "#2e7d32" },
    on_track:  { label: "On Track",  bg: "#e3f2fd", color: "#1565c0" },
    at_risk:   { label: "At Risk",   bg: "#fff3e0", color: "#e65100" },
    behind:    { label: "Behind",    bg: "#fbe9e7", color: "#c62828" }
  }
%>

<% @by_category.each do |category, goals| %>
  <% cat = category_config[category] || { icon: "flag", color: "#4caf50", bg: "rgba(76,175,80,0.06)" } %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header" style="border-bottom: 2px solid <%= cat[:color] %>;">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: <%= cat[:color] %>;"><%= cat[:icon] %></span>
        <%= category %> Goals
        <span style="float: right; font-size: 0.75rem; color: var(--text-secondary); font-weight: 400;">
          <%= goals.count { |g| g[:status] == :completed } %>/<%= goals.count %> complete
        </span>
      </h2>
    </div>
    <div style="padding: 1.25rem;">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem;">
        <% goals.each do |goal| %>
          <% sc = status_config[goal[:status]] || status_config[:behind] %>
          <div style="border: 1px solid var(--border); border-radius: 8px; padding: 1rem; background: <%= goal[:status] == :completed ? 'rgba(76,175,80,0.03)' : 'transparent' %>;">
            <%# Header row %>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
              <div style="display: flex; align-items: center; gap: 0.5rem;">
                <span class="material-icons-outlined" style="font-size: 1.25rem; color: <%= goal[:color] %>;"><%= goal[:icon] %></span>
                <span style="font-weight: 600; font-size: 0.875rem;"><%= goal[:name] %></span>
              </div>
              <span style="font-size: 0.6875rem; padding: 0.125rem 0.5rem; border-radius: 9999px; background: <%= sc[:bg] %>; color: <%= sc[:color] %>; font-weight: 600;">
                <%= sc[:label] %>
              </span>
            </div>

            <%# Progress ring + values %>
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              <div style="position: relative; width: 56px; height: 56px; flex-shrink: 0;">
                <svg viewBox="0 0 36 36" style="width: 56px; height: 56px; transform: rotate(-90deg);">
                  <circle cx="18" cy="18" r="15.9" fill="none" stroke="var(--border)" stroke-width="2.5"/>
                  <circle cx="18" cy="18" r="15.9" fill="none" stroke="<%= goal[:color] %>" stroke-width="2.5"
                          stroke-dasharray="<%= goal[:progress_pct] %>, 100" stroke-linecap="round"/>
                </svg>
                <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 0.6875rem; font-weight: 700;">
                  <%= goal[:progress_pct].round(0) %>%
                </div>
              </div>
              <div style="flex: 1;">
                <div style="font-size: 1.25rem; font-weight: 700;">
                  <%
                    current_display = case goal[:format]
                                      when :currency then number_to_currency(goal[:current_value], precision: 0)
                                      when :pct then "#{goal[:current_value].round(1)}%"
                                      when :streak then "#{goal[:current_value].to_i} days"
                                      else number_with_delimiter(goal[:current_value].to_i)
                                      end
                    target_display = case goal[:format]
                                    when :currency then number_to_currency(goal[:target_value], precision: 0)
                                    when :pct then "#{goal[:target_value].round(1)}%"
                                    when :streak then "#{goal[:target_value].to_i} days"
                                    else number_with_delimiter(goal[:target_value].to_i)
                                    end
                  %>
                  <%= current_display %>
                  <span style="font-size: 0.75rem; font-weight: 400; color: var(--text-secondary);">
                    / <%= target_display %>
                    <% if goal[:inverted] %>
                      <span style="font-size: 0.625rem;">(limit)</span>
                    <% end %>
                  </span>
                </div>
                <div style="width: 100%; height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; margin-top: 0.375rem;">
                  <div style="height: 100%; width: <%= goal[:progress_pct] %>%; background: <%= goal[:color] %>; border-radius: 3px; transition: width 0.3s;"></div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<% if @goals.empty? %>
  <div class="card" style="padding: 3rem; text-align: center; color: var(--text-secondary);">
    <span class="material-icons-outlined" style="font-size: 3rem; margin-bottom: 1rem;">flag</span>
    <div style="font-size: 1.125rem; font-weight: 600;">No goals to display</div>
    <div style="font-size: 0.875rem; margin-top: 0.5rem;">Connect your APIs in <%= link_to "Settings", settings_path %> to start tracking goals across all products.</div>
  </div>
<% end %>

<%# Motivational Section %>
<% if @goals.any? %>
  <div class="card" style="margin-bottom: 1.5rem; padding: 1.5rem;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
      <%# Next Milestone %>
      <div style="border-right: 1px solid var(--border); padding-right: 1.5rem;">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
          <span class="material-icons-outlined" style="font-size: 1.25rem; color: #ff9800;">stars</span>
          <span style="font-weight: 700; font-size: 0.9375rem;">Next Milestone</span>
        </div>
        <% if @next_milestone %>
          <div style="font-size: 0.875rem; margin-bottom: 0.375rem;">
            <span style="font-weight: 600;"><%= @next_milestone[:name] %></span>
            <span style="color: var(--text-secondary);"> &mdash; <%= @next_milestone[:category] %></span>
          </div>
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <div style="flex: 1; height: 8px; background: var(--border); border-radius: 4px; overflow: hidden;">
              <div style="height: 100%; width: <%= @next_milestone[:progress_pct] %>%; background: <%= @next_milestone[:color] %>; border-radius: 4px;"></div>
            </div>
            <span style="font-size: 0.75rem; font-weight: 700; color: <%= @next_milestone[:color] %>;"><%= @next_milestone[:progress_pct].round(0) %>%</span>
          </div>
          <div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.375rem;">
            <%
              remaining_display = case @next_milestone[:format]
                                  when :currency then number_to_currency(@next_milestone[:target_value] - @next_milestone[:current_value], precision: 0)
                                  when :pct then "#{(@next_milestone[:target_value] - @next_milestone[:current_value]).round(1)}%"
                                  when :streak then "#{(@next_milestone[:target_value] - @next_milestone[:current_value]).to_i} days"
                                  else number_with_delimiter((@next_milestone[:target_value] - @next_milestone[:current_value]).to_i)
                                  end
            %>
            <%= remaining_display %> to go
          </div>
        <% else %>
          <div style="font-size: 0.875rem; color: var(--positive); font-weight: 600;">
            <span class="material-icons-outlined" style="font-size: 1rem; vertical-align: -2px;">check_circle</span>
            All goals completed!
          </div>
        <% end %>
      </div>

      <%# Streak Info %>
      <div style="padding-left: 0.5rem;">
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
          <span class="material-icons-outlined" style="font-size: 1.25rem; color: #e65100;">local_fire_department</span>
          <span style="font-weight: 700; font-size: 0.9375rem;">Best Active Streak</span>
        </div>
        <div style="font-size: 2rem; font-weight: 700; color: <%= @best_streak[:value] > 0 ? '#e65100' : 'var(--text-secondary)' %>;">
          <%= @best_streak[:value] %>
          <span style="font-size: 0.875rem; font-weight: 400; color: var(--text-secondary);">days</span>
        </div>
        <div style="font-size: 0.8125rem; color: var(--text-secondary);">
          <%= @best_streak[:type] %> streak
        </div>
        <% if @best_streak[:value] >= 3 %>
          <div style="font-size: 0.75rem; margin-top: 0.5rem; padding: 0.25rem 0.5rem; background: rgba(230,81,0,0.1); border-radius: 4px; display: inline-block; color: #e65100;">
            <span class="material-icons-outlined" style="font-size: 0.75rem; vertical-align: -1px;">whatshot</span>
            Keep it going!
          </div>
        <% elsif @best_streak[:value] == 0 %>
          <div style="font-size: 0.75rem; margin-top: 0.5rem; color: var(--text-secondary);">
            Start a streak today!
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%# Bottom Nav %>
<div style="text-align: center; margin-top: 1.5rem;">
  <%= link_to reports_index_path, class: "btn" do %>
    <span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px;">assessment</span>
    Reports Hub
  <% end %>
  <%= link_to budget_dashboard_path, class: "btn" do %>
    <span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px;">account_balance_wallet</span>
    Budget Dashboard
  <% end %>
  <%= link_to writing_stats_path, class: "btn" do %>
    <span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px;">edit_note</span>
    Writing Stats
  <% end %>
</div>
