<%
  today_pnl = @today_trades.sum { |t| t["pnl"].to_f }
  today_wins = @today_trades.count { |t| t["pnl"].to_f > 0 }
  today_losses = @today_trades.count { |t| t["pnl"].to_f < 0 }
  today_wr = @today_trades.any? ? (today_wins.to_f / @today_trades.count * 100).round(0) : 0
  yesterday_pnl = @yesterday_trades.sum { |t| t["pnl"].to_f }
  pnl_delta = today_pnl - yesterday_pnl
  is_today = @date == Date.current
%>

<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: var(--primary);">today</span>
    Daily Review
  </h1>
  <div class="page-actions">
    <%= link_to daily_review_path(date: (@date - 1.day).to_s), class: "btn btn-sm", title: "Previous day" do %>
      <span class="material-icons-outlined" style="font-size: 1rem;">chevron_left</span>
    <% end %>
    <span style="font-weight: 600; padding: 0 0.5rem;"><%= @date.strftime("%A, %B %d, %Y") %></span>
    <% unless is_today %>
      <%= link_to daily_review_path(date: (@date + 1.day).to_s), class: "btn btn-sm", title: "Next day" do %>
        <span class="material-icons-outlined" style="font-size: 1rem;">chevron_right</span>
      <% end %>
    <% end %>
    <% unless is_today %>
      <%= link_to "Today", daily_review_path, class: "btn btn-sm btn-primary" %>
    <% end %>
  </div>
</div>

<%# Daily Checklist %>
<% if @checklist.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">checklist</span> Daily Checklist</h2>
      <span style="font-size: 0.8125rem; color: var(--text-secondary);">
        <%= @checklist.count { |c| c[:done] } %>/<%= @checklist.count %> complete
      </span>
    </div>
    <% @checklist.each do |item| %>
      <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--border);">
        <span class="material-icons-outlined" style="font-size: 1.25rem; color: <%= item[:done] ? 'var(--positive)' : 'var(--text-secondary)' %>;">
          <%= item[:done] ? 'check_circle' : 'radio_button_unchecked' %>
        </span>
        <div style="flex: 1;">
          <span style="font-size: 0.875rem; <%= item[:done] ? 'text-decoration: line-through; color: var(--text-secondary);' : '' %>"><%= item[:label] %></span>
        </div>
        <% if item[:action_path] && !item[:done] %>
          <%= link_to item[:action_label], item[:action_path], class: "btn btn-sm btn-primary" %>
        <% elsif item[:done] %>
          <span class="badge badge-success" style="font-size: 0.625rem;">Done</span>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<%# Trading Summary %>
<% if @today_trades.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 0;">
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Today's P&L</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= today_pnl >= 0 ? 'positive' : 'negative' %>"><%= number_to_currency(today_pnl) %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Trades</div>
        <div style="font-size: 1.5rem; font-weight: 700;"><%= @today_trades.count %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Win Rate</div>
        <div style="font-size: 1.5rem; font-weight: 700; color: <%= today_wr >= 50 ? 'var(--positive)' : 'var(--negative)' %>;"><%= today_wr %>%</div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Record</div>
        <div style="font-size: 1.5rem; font-weight: 700;">
          <span class="positive"><%= today_wins %>W</span> <span class="negative"><%= today_losses %>L</span>
        </div>
      </div>
      <div style="padding: 1rem; text-align: center;">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">vs Yesterday</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= pnl_delta >= 0 ? 'positive' : 'negative' %>">
          <%= pnl_delta >= 0 ? "+" : "" %><%= number_to_currency(pnl_delta) %>
        </div>
      </div>
    </div>
  </div>

  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2>Today's Trades</h2>
    </div>
    <table class="table">
      <thead>
        <tr>
          <th>Symbol</th>
          <th>Side</th>
          <th style="text-align: right;">P&L</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @today_trades.each do |trade| %>
          <tr>
            <td><strong><%= link_to trade["symbol"], trade_path(trade["id"]) %></strong></td>
            <td><%= trade["side"]&.capitalize %></td>
            <td style="text-align: right;" class="<%= trade["pnl"].to_f >= 0 ? 'positive' : 'negative' %>">
              <strong><%= number_to_currency(trade["pnl"]) %></strong>
            </td>
            <td><%= badge_for(trade["status"]) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% elsif is_today %>
  <div class="card" style="margin-bottom: 1.5rem; padding: 1.5rem; text-align: center;">
    <span class="material-icons-outlined" style="font-size: 2rem; color: var(--text-secondary);">trending_flat</span>
    <p style="margin: 0.5rem 0 0; color: var(--text-secondary);">No trades today yet.</p>
  </div>
<% end %>

<%# Streaks %>
<% if @streaks.present? && !@streaks["error"] %>
  <%
    win_streak = @streaks["current_winning_day_streak"].to_i
    loss_streak = @streaks["current_losing_day_streak"].to_i
    journal_streak = @streaks["journal_entry_streak"].to_i
    active_streak = win_streak > 0 ? win_streak : loss_streak
    streak_type = win_streak > 0 ? :winning : (loss_streak > 0 ? :losing : :none)
  %>
  <% if active_streak > 0 || journal_streak > 0 %>
    <div class="card" style="margin-bottom: 1.5rem;">
      <div class="card-header"><h2>Current Streaks</h2></div>
      <div style="padding: 1rem 1.25rem; display: flex; gap: 1.5rem; flex-wrap: wrap;">
        <% if active_streak > 0 %>
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span class="material-icons-outlined" style="font-size: 1.5rem; color: <%= streak_type == :winning ? 'var(--positive)' : 'var(--negative)' %>;">
              <%= streak_type == :winning ? 'local_fire_department' : 'warning' %>
            </span>
            <div>
              <div style="font-size: 1.125rem; font-weight: 700;"><%= active_streak %>-day <%= streak_type == :winning ? 'winning' : 'losing' %> streak</div>
              <div style="font-size: 0.6875rem; color: var(--text-secondary);"><%= streak_type == :winning ? 'Keep the momentum!' : 'Consider reviewing your strategy.' %></div>
            </div>
          </div>
        <% end %>
        <% if journal_streak > 0 %>
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span class="material-icons-outlined" style="font-size: 1.5rem; color: var(--primary);">auto_stories</span>
            <div>
              <div style="font-size: 1.125rem; font-weight: 700;"><%= journal_streak %>-day journal streak</div>
              <div style="font-size: 0.6875rem; color: var(--text-secondary);">Consistent journaling builds discipline.</div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>

<%# Journal Entries %>
<% if @journal_entries.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">auto_stories</span> Journal</h2>
    </div>
    <% @journal_entries.each do |entry| %>
      <a href="<%= journal_entry_path(entry["id"]) %>" class="activity-item" style="border-bottom: 1px solid var(--border);">
        <span class="activity-icon" style="background: rgba(26,115,232,0.1); color: var(--primary);">
          <span class="material-icons-outlined">auto_stories</span>
        </span>
        <div class="activity-content" style="flex: 1;">
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span class="activity-title"><%= entry["date"] %></span>
            <% if entry["mood"].present? %>
              <span class="badge" style="font-size: 0.5625rem;"><%= entry["mood"] %></span>
            <% end %>
          </div>
          <% if entry["content"].present? %>
            <span class="activity-detail text-muted"><%= truncate(entry["content"], length: 150) %></span>
          <% end %>
        </div>
      </a>
    <% end %>
  </div>
<% end %>

<%# Reminders %>
<% if @reminders.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">alarm</span> Due Today</h2>
    </div>
    <% @reminders.each do |reminder| %>
      <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 1.25rem; border-bottom: 1px solid var(--border);">
        <span class="material-icons-outlined" style="font-size: 1rem; color: var(--primary);">alarm</span>
        <div style="flex: 1; font-size: 0.875rem;"><%= reminder["message"].presence || "Reminder" %></div>
        <% if reminder["remind_at"] %>
          <span style="font-size: 0.75rem; color: var(--text-secondary);"><%= Time.parse(reminder["remind_at"]).strftime("%l:%M %p") rescue "" %></span>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<%# Budget Snapshot %>
<% if @budget_overview.is_a?(Hash) && !@budget_overview["error"] && @budget_overview["total_spent"].to_f > 0 %>
  <%
    bo_income = @budget_overview["actual_income"].to_f
    bo_spent = @budget_overview["total_spent"].to_f
    bo_remaining = bo_income - bo_spent
    bo_pct = bo_income > 0 ? (bo_spent / bo_income * 100).round(0) : 0
  %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">account_balance</span> Budget Snapshot</h2>
      <%= link_to "Dashboard", budget_dashboard_path, class: "btn btn-sm" %>
    </div>
    <div style="padding: 1rem 1.25rem;">
      <div style="display: flex; justify-content: space-between; font-size: 0.8125rem; margin-bottom: 0.375rem;">
        <span><%= number_to_currency(bo_spent) %> spent</span>
        <span><%= number_to_currency(bo_remaining) %> remaining</span>
      </div>
      <div style="height: 0.625rem; background: var(--bg); border-radius: 4px; overflow: hidden;">
        <div style="height: 100%; width: <%= [bo_pct, 100].min %>%; background: <%= bo_pct > 90 ? 'var(--negative)' : bo_pct > 70 ? '#f9ab00' : 'var(--positive)' %>; opacity: 0.7; border-radius: 4px;"></div>
      </div>
      <div style="text-align: center; margin-top: 0.375rem; font-size: 0.75rem; color: var(--text-secondary);">
        <%= bo_pct %>% of budget used this month
      </div>
    </div>
  </div>
<% end %>

<%# Upcoming Bills %>
<% today_bills = @upcoming_bills.select { |b|
  due = Date.parse(b["next_date"] || b["next_due_date"]) rescue nil
  due && (due - @date).to_i.between?(0, 3)
} %>
<% if today_bills.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">receipt</span> Upcoming Bills</h2>
    </div>
    <% today_bills.each do |bill| %>
      <%
        bill_due = Date.parse(bill["next_date"] || bill["next_due_date"]) rescue nil
        days_until = bill_due ? (bill_due - @date).to_i : nil
      %>
      <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.625rem 1.25rem; border-bottom: 1px solid var(--border);">
        <span class="material-icons-outlined" style="font-size: 1rem; color: <%= days_until == 0 ? 'var(--negative)' : 'var(--primary)' %>;">receipt</span>
        <div style="flex: 1;">
          <div style="font-size: 0.875rem; font-weight: 500;"><%= bill["description"] || bill["name"] %></div>
          <div style="font-size: 0.6875rem; color: var(--text-secondary);">
            <%= days_until == 0 ? 'Due today' : "Due in #{days_until} day#{'s' if days_until != 1}" %>
          </div>
        </div>
        <span style="font-weight: 700;"><%= number_to_currency(bill["amount"]) %></span>
      </div>
    <% end %>
  </div>
<% end %>

<div style="text-align: center; margin-top: 1rem;">
  <%= link_to "Weekly Digest", digest_path, class: "btn btn-sm" %>
  <%= link_to "Dashboard", root_path, class: "btn btn-sm" %>
  <%= link_to "Notifications", notifications_path, class: "btn btn-sm" %>
</div>
