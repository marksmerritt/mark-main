<div class="page-header">
  <h1>Tags</h1>
  <%= link_to "New Tag", new_tag_path, class: "btn btn-primary" %>
</div>

<div class="tags-grid">
  <% if @tags.is_a?(Array) && @tags.any? %>
    <% @tags.each do |tag| %>
      <div class="card tag-card">
        <div class="tag-card-header">
          <span class="tag-color-swatch" style="background-color: <%= tag["color"] %>;"></span>
          <h3><%= link_to tag["name"], tag_path(tag["id"]) %></h3>
        </div>
        <% if tag["stats"] %>
          <div class="tag-card-body">
            <div class="tag-stat">
              <span class="stat-label">Trades</span>
              <span class="stat-value"><%= tag["stats"]["trade_count"] %></span>
            </div>
            <div class="tag-stat">
              <span class="stat-label">Total P&L</span>
              <span class="stat-value <%= tag["stats"]["total_pnl"].to_f >= 0 ? 'positive' : 'negative' %>">
                <%= number_to_currency(tag["stats"]["total_pnl"]) %>
              </span>
            </div>
          </div>
        <% end %>
        <div class="tag-card-footer">
          <%= link_to "View", tag_path(tag["id"]), class: "btn btn-sm" %>
          <%= link_to "Edit", edit_tag_path(tag["id"]), class: "btn btn-sm" %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="card empty-state">
      <p>No tags yet. <%= link_to "Create your first tag", new_tag_path %> to organize your trades.</p>
    </div>
  <% end %>
</div>
