<% content_for(:title) { "Trade Templates" } %>

<div class="page-header" data-controller="trade-templates">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: var(--primary);">content_copy</span>
    Trade Templates
  </h1>
  <div class="page-actions">
    <%= link_to "New Trade", new_trade_path, class: "btn" %>
  </div>
</div>

<div data-controller="trade-templates">

  <%# ── Your Saved Templates ── %>
  <div class="card" style="margin-bottom: 1.5rem; border-top: 4px solid var(--primary);">
    <div class="card-header">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: var(--primary);">bookmark</span>
        Your Templates
      </h2>
    </div>
    <div style="padding: 1.25rem;">
      <div data-trade-templates-target="emptyState" style="text-align: center; padding: 1.5rem; color: var(--text-secondary);">
        <span class="material-icons-outlined" style="font-size: 2.5rem; margin-bottom: 0.5rem; display: block; color: var(--border);">content_copy</span>
        <div style="font-size: 0.875rem;">No saved templates yet. Create one below or save a suggested template.</div>
      </div>
      <div data-trade-templates-target="savedList" style="display: grid; gap: 0.75rem;"></div>
    </div>
  </div>

  <%# ── Create Template Form ── %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: var(--primary);">add_circle_outline</span>
        Create Template
      </h2>
    </div>
    <div style="padding: 1.25rem;">
      <form data-action="submit->trade-templates#createTemplate">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
          <div>
            <label style="display: block; font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 0.25rem;">Template Name *</label>
            <input type="text" data-trade-templates-target="nameInput" placeholder="e.g. AAPL Scalp Long" style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid var(--border); border-radius: 6px; background: var(--bg); color: var(--text); font-size: 0.875rem;">
          </div>
          <div>
            <label style="display: block; font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 0.25rem;">Symbol *</label>
            <input type="text" data-trade-templates-target="symbolInput" placeholder="e.g. AAPL" style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid var(--border); border-radius: 6px; background: var(--bg); color: var(--text); font-size: 0.875rem; text-transform: uppercase;">
          </div>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
          <div>
            <label style="display: block; font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 0.25rem;">Side</label>
            <select data-trade-templates-target="sideInput" style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid var(--border); border-radius: 6px; background: var(--bg); color: var(--text); font-size: 0.875rem;">
              <option value="long">Long</option>
              <option value="short">Short</option>
            </select>
          </div>
          <div>
            <label style="display: block; font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 0.25rem;">Quantity *</label>
            <input type="number" data-trade-templates-target="quantityInput" min="1" placeholder="100" style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid var(--border); border-radius: 6px; background: var(--bg); color: var(--text); font-size: 0.875rem;">
          </div>
          <div>
            <label style="display: block; font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 0.25rem;">Asset Class</label>
            <input type="text" data-trade-templates-target="assetClassInput" placeholder="Equity" style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid var(--border); border-radius: 6px; background: var(--bg); color: var(--text); font-size: 0.875rem;">
          </div>
        </div>
        <div style="margin-bottom: 1rem;">
          <label style="display: block; font-size: 0.75rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 0.25rem;">Notes</label>
          <textarea data-trade-templates-target="notesInput" rows="2" placeholder="Optional notes about this setup..." style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid var(--border); border-radius: 6px; background: var(--bg); color: var(--text); font-size: 0.875rem; resize: vertical;"></textarea>
        </div>
        <div style="display: flex; align-items: center; gap: 1rem;">
          <button type="submit" class="btn" style="background: var(--primary); color: #fff; border: none; padding: 0.5rem 1.25rem; border-radius: 6px; font-size: 0.875rem; cursor: pointer;">
            <span class="material-icons-outlined" style="font-size: 1rem; vertical-align: -2px;">save</span>
            Save Template
          </button>
          <span data-trade-templates-target="formMessage" style="font-size: 0.8125rem; display: none;"></span>
        </div>
      </form>
    </div>
  </div>

  <%# ── Suggested Templates ── %>
  <% if @suggested_templates.any? %>
    <div class="card" style="margin-bottom: 1.5rem; border-top: 4px solid var(--positive);">
      <div class="card-header">
        <h2>
          <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: var(--positive);">auto_awesome</span>
          Suggested Templates
        </h2>
      </div>
      <div style="padding: 1.25rem;">
        <div style="font-size: 0.8125rem; color: var(--text-secondary); margin-bottom: 1rem;">
          Auto-generated from your most recent trades. Save any template to keep it.
        </div>
        <div style="display: grid; gap: 0.75rem;">
          <% @suggested_templates.each do |tmpl| %>
            <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; padding: 1rem; background: var(--bg); border-radius: 0.5rem; border-left: 4px solid var(--positive);">
              <div style="flex: 1;">
                <div style="font-weight: 700; font-size: 0.9375rem; margin-bottom: 0.375rem;"><%= tmpl[:name] %></div>
                <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.375rem;">
                  <span style="display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.125rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; background: var(--surface); border: 1px solid var(--border);"><%= tmpl[:symbol] %></span>
                  <span style="display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.125rem 0.5rem; border-radius: 4px; font-size: 0.75rem; font-weight: 600; color: #fff; background: <%= tmpl[:side] == 'long' ? 'var(--positive)' : 'var(--negative)' %>;"><%= tmpl[:side].upcase %></span>
                  <span style="font-size: 0.75rem; color: var(--text-secondary);"><%= tmpl[:quantity] %> shares</span>
                  <span style="font-size: 0.75rem; color: var(--text-secondary);"><%= tmpl[:asset_class] %></span>
                  <% if tmpl[:trade_count] %>
                    <span style="font-size: 0.75rem; color: var(--text-secondary);">
                      <span class="material-icons-outlined" style="font-size: 0.75rem; vertical-align: -1px;">bar_chart</span>
                      <%= tmpl[:trade_count] %> trades
                    </span>
                  <% end %>
                  <% if tmpl[:win_rate] %>
                    <span style="font-size: 0.75rem; font-weight: 600; color: <%= tmpl[:win_rate] >= 50 ? 'var(--positive)' : 'var(--negative)' %>;">
                      <%= tmpl[:win_rate] %>% win
                    </span>
                  <% end %>
                </div>
                <% if tmpl[:notes].present? %>
                  <div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.25rem;"><%= tmpl[:notes] %></div>
                <% end %>
              </div>
              <div style="display: flex; gap: 0.375rem; flex-shrink: 0;">
                <button class="btn btn-sm" style="font-size: 0.75rem; padding: 0.25rem 0.625rem;"
                  data-action="click->trade-templates#useSuggested"
                  data-symbol="<%= tmpl[:symbol] %>"
                  data-side="<%= tmpl[:side] %>"
                  data-quantity="<%= tmpl[:quantity] %>"
                  data-asset-class="<%= tmpl[:asset_class] %>">
                  <span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px;">play_arrow</span> Use
                </button>
                <button class="btn btn-sm" style="font-size: 0.75rem; padding: 0.25rem 0.625rem;"
                  data-action="click->trade-templates#saveSuggested"
                  data-name="<%= tmpl[:name] %>"
                  data-symbol="<%= tmpl[:symbol] %>"
                  data-side="<%= tmpl[:side] %>"
                  data-quantity="<%= tmpl[:quantity] %>"
                  data-asset-class="<%= tmpl[:asset_class] %>"
                  data-notes="<%= tmpl[:notes] %>"
                  data-playbook-id="<%= tmpl[:playbook_id] %>">
                  <span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px;">bookmark_add</span> Save
                </button>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <div class="card" style="margin-bottom: 1.5rem; padding: 2rem; text-align: center; color: var(--text-secondary);">
      <span class="material-icons-outlined" style="font-size: 2.5rem; margin-bottom: 0.5rem; display: block; color: var(--border);">auto_awesome</span>
      <div style="font-size: 0.9375rem; font-weight: 600;">No suggested templates yet</div>
      <div style="font-size: 0.8125rem; margin-top: 0.25rem;">Log some trades to get auto-generated template suggestions based on your trading patterns.</div>
    </div>
  <% end %>

  <%# ── Quick Links ── %>
  <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1.5rem;">
    <%= link_to new_trade_path, class: "btn", style: "display: inline-flex; align-items: center; gap: 0.375rem;" do %>
      <span class="material-icons-outlined" style="font-size: 1rem;">add_circle_outline</span> New Trade
    <% end %>
    <%= link_to trades_path, class: "btn", style: "display: inline-flex; align-items: center; gap: 0.375rem;" do %>
      <span class="material-icons-outlined" style="font-size: 1rem;">show_chart</span> All Trades
    <% end %>
    <%= link_to playbooks_path, class: "btn", style: "display: inline-flex; align-items: center; gap: 0.375rem;" do %>
      <span class="material-icons-outlined" style="font-size: 1rem;">menu_book</span> Playbooks
    <% end %>
    <%= link_to strategy_builder_path, class: "btn", style: "display: inline-flex; align-items: center; gap: 0.375rem;" do %>
      <span class="material-icons-outlined" style="font-size: 1rem;">architecture</span> Strategy Builder
    <% end %>
  </div>

</div>
