<% content_for(:title) { "Account Health" } %>

<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: var(--primary);">health_and_safety</span>
    Account Health
  </h1>
</div>

<%# ── Overall Score Gauge ──────────────────────────────────── %>
<div class="card" style="margin-bottom: 1.5rem; text-align: center; padding: 2.5rem 2rem;">
  <div style="position: relative; display: inline-block;">
    <svg viewBox="0 0 140 140" style="width: 10rem; height: 10rem;">
      <%# Background circle %>
      <circle cx="70" cy="70" r="60" fill="none" stroke="var(--border)" stroke-width="10" opacity="0.3"/>
      <%# Score arc %>
      <%
        circumference = (2 * Math::PI * 60).round(1)
        dash = (circumference * @overall_score / 100.0).round(1)
      %>
      <circle cx="70" cy="70" r="60" fill="none" stroke="<%= @tier[:color] %>" stroke-width="10"
              stroke-dasharray="<%= dash %> <%= circumference %>" stroke-linecap="round"
              transform="rotate(-90 70 70)" style="transition: stroke-dasharray 1s ease;"/>
    </svg>
    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center;">
      <div style="font-size: 3rem; font-weight: 800; color: <%= @tier[:color] %>; line-height: 1;"><%= @overall_score %></div>
      <div style="font-size: 0.75rem; color: var(--text-secondary); font-weight: 500;">out of 100</div>
    </div>
  </div>

  <div style="margin-top: 1rem;">
    <span class="material-icons-outlined" style="font-size: 1.25rem; vertical-align: -3px; color: <%= @tier[:color] %>;"><%= @tier[:icon] %></span>
    <span style="font-size: 1.25rem; font-weight: 700; color: <%= @tier[:color] %>;"><%= @tier[:label] %></span>
  </div>
  <div style="font-size: 0.875rem; color: var(--text-secondary); margin-top: 0.25rem;"><%= @tier[:message] %></div>

  <%# Score breakdown summary %>
  <div style="display: flex; justify-content: center; gap: 2rem; margin-top: 1.5rem; flex-wrap: wrap;">
    <%
      trading_total = @trading_scores.sum { |s| s[:score] }
      financial_total = @financial_scores.sum { |s| s[:score] }
      behavioral_total = @behavioral_scores.sum { |s| s[:score] }
    %>
    <div style="text-align: center;">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Trading</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= trading_total %><span style="font-size: 0.75rem; color: var(--text-secondary);">/40</span></div>
    </div>
    <div style="text-align: center;">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Financial</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= financial_total %><span style="font-size: 0.75rem; color: var(--text-secondary);">/30</span></div>
    </div>
    <div style="text-align: center;">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Behavioral</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= behavioral_total %><span style="font-size: 0.75rem; color: var(--text-secondary);">/30</span></div>
    </div>
  </div>
</div>

<%# ── Sub-Score Cards ──────────────────────────────────────── %>
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">

  <%# Trading Health Card %>
  <div class="card">
    <div class="card-header" style="border-bottom: 2px solid var(--primary);">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: var(--primary);">show_chart</span>
        Trading Health
        <span style="float: right; font-size: 0.8125rem; font-weight: 700; color: var(--primary);"><%= trading_total %>/40</span>
      </h2>
    </div>
    <div style="padding: 1rem 1.25rem;">
      <% @trading_scores.each do |s| %>
        <% bar_pct = (s[:score].to_f / s[:max] * 100).round(0) %>
        <% bar_color = bar_pct > 70 ? "var(--positive)" : bar_pct > 40 ? "#f9a825" : "var(--negative)" %>
        <div style="margin-bottom: 1rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
            <div style="display: flex; align-items: center; gap: 0.375rem;">
              <span class="material-icons-outlined" style="font-size: 1rem; color: <%= bar_color %>;"><%= s[:icon] %></span>
              <span style="font-weight: 600; font-size: 0.875rem;"><%= s[:name] %></span>
            </div>
            <span style="font-weight: 700; font-size: 0.875rem; color: <%= bar_color %>;"><%= s[:score] %>/<%= s[:max] %></span>
          </div>
          <div style="height: 0.375rem; background: var(--bg); border-radius: 3px; overflow: hidden; margin-bottom: 0.375rem;">
            <div style="height: 100%; width: <%= bar_pct %>%; background: <%= bar_color %>; border-radius: 3px; transition: width 0.5s ease;"></div>
          </div>
          <div style="font-size: 0.75rem; color: var(--text-secondary);">
            <strong><%= s[:value] %></strong> &mdash; <%= s[:diagnosis] %>. <%= s[:recommendation] %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Financial Health Card %>
  <div class="card">
    <div class="card-header" style="border-bottom: 2px solid #0d904f;">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #0d904f;">account_balance</span>
        Financial Health
        <span style="float: right; font-size: 0.8125rem; font-weight: 700; color: #0d904f;"><%= financial_total %>/30</span>
      </h2>
    </div>
    <div style="padding: 1rem 1.25rem;">
      <% @financial_scores.each do |s| %>
        <% bar_pct = (s[:score].to_f / s[:max] * 100).round(0) %>
        <% bar_color = bar_pct > 70 ? "var(--positive)" : bar_pct > 40 ? "#f9a825" : "var(--negative)" %>
        <div style="margin-bottom: 1rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
            <div style="display: flex; align-items: center; gap: 0.375rem;">
              <span class="material-icons-outlined" style="font-size: 1rem; color: <%= bar_color %>;"><%= s[:icon] %></span>
              <span style="font-weight: 600; font-size: 0.875rem;"><%= s[:name] %></span>
            </div>
            <span style="font-weight: 700; font-size: 0.875rem; color: <%= bar_color %>;"><%= s[:score] %>/<%= s[:max] %></span>
          </div>
          <div style="height: 0.375rem; background: var(--bg); border-radius: 3px; overflow: hidden; margin-bottom: 0.375rem;">
            <div style="height: 100%; width: <%= bar_pct %>%; background: <%= bar_color %>; border-radius: 3px; transition: width 0.5s ease;"></div>
          </div>
          <div style="font-size: 0.75rem; color: var(--text-secondary);">
            <strong><%= s[:value] %></strong> &mdash; <%= s[:diagnosis] %>. <%= s[:recommendation] %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Behavioral Health Card %>
  <div class="card">
    <div class="card-header" style="border-bottom: 2px solid #9c27b0;">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #9c27b0;">psychology</span>
        Behavioral Health
        <span style="float: right; font-size: 0.8125rem; font-weight: 700; color: #9c27b0;"><%= behavioral_total %>/30</span>
      </h2>
    </div>
    <div style="padding: 1rem 1.25rem;">
      <% @behavioral_scores.each do |s| %>
        <% bar_pct = (s[:score].to_f / s[:max] * 100).round(0) %>
        <% bar_color = bar_pct > 70 ? "var(--positive)" : bar_pct > 40 ? "#f9a825" : "var(--negative)" %>
        <div style="margin-bottom: 1rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
            <div style="display: flex; align-items: center; gap: 0.375rem;">
              <span class="material-icons-outlined" style="font-size: 1rem; color: <%= bar_color %>;"><%= s[:icon] %></span>
              <span style="font-weight: 600; font-size: 0.875rem;"><%= s[:name] %></span>
            </div>
            <span style="font-weight: 700; font-size: 0.875rem; color: <%= bar_color %>;"><%= s[:score] %>/<%= s[:max] %></span>
          </div>
          <div style="height: 0.375rem; background: var(--bg); border-radius: 3px; overflow: hidden; margin-bottom: 0.375rem;">
            <div style="height: 100%; width: <%= bar_pct %>%; background: <%= bar_color %>; border-radius: 3px; transition: width 0.5s ease;"></div>
          </div>
          <div style="font-size: 0.75rem; color: var(--text-secondary);">
            <strong><%= s[:value] %></strong> &mdash; <%= s[:diagnosis] %>. <%= s[:recommendation] %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# ── Top 3 Improvements ──────────────────────────────────── %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header">
    <h2>
      <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: var(--negative);">priority_high</span>
      Top 3 Improvements
    </h2>
  </div>
  <div style="padding: 1rem 1.25rem;">
    <% @improvements.each_with_index do |item, i| %>
      <% bar_pct = (item[:score].to_f / item[:max] * 100).round(0) %>
      <% bar_color = bar_pct > 70 ? "var(--positive)" : bar_pct > 40 ? "#f9a825" : "var(--negative)" %>
      <div style="display: flex; align-items: flex-start; gap: 0.75rem; margin-bottom: 1rem; padding-bottom: 1rem;<%= i < @improvements.length - 1 ? ' border-bottom: 1px solid var(--border);' : '' %>">
        <div style="min-width: 2rem; height: 2rem; border-radius: 50%; background: <%= bar_color %>; color: white; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.875rem;">
          <%= i + 1 %>
        </div>
        <div style="flex: 1;">
          <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
              <span style="font-weight: 700;"><%= item[:name] %></span>
              <span style="font-size: 0.75rem; color: var(--text-secondary); margin-left: 0.375rem;">(<%= item[:category] %>)</span>
            </div>
            <span style="font-weight: 700; color: <%= bar_color %>;"><%= item[:score] %>/<%= item[:max] %></span>
          </div>
          <div style="font-size: 0.8125rem; color: var(--text-secondary); margin-top: 0.25rem;">
            <span class="material-icons-outlined" style="font-size: 0.8125rem; vertical-align: -2px;">lightbulb</span>
            <%= item[:recommendation] %>
          </div>
          <% if item[:link_path] %>
            <div style="margin-top: 0.375rem;">
              <%= link_to item[:link_text] || "Go", send(item[:link_path]), style: "font-size: 0.75rem; color: var(--primary); text-decoration: none; font-weight: 600;" %>
              <span class="material-icons-outlined" style="font-size: 0.75rem; vertical-align: -2px; color: var(--primary);">arrow_forward</span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%# ── 30-Day Trend ─────────────────────────────────────────── %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header">
    <h2>
      <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">trending_up</span>
      30-Day Trend
    </h2>
  </div>
  <div style="padding: 1.25rem;">
    <% if @trend.any? %>
      <%# Visual bar chart %>
      <div style="display: flex; align-items: flex-end; gap: 0.5rem; height: 8rem; margin-bottom: 1rem;">
        <% max_score = [@trend.map { |w| w[:score] }.max, 1].max %>
        <% @trend.each do |week| %>
          <% bar_h = (week[:score].to_f / max_score * 100).round(0) %>
          <% w_color = week[:score] >= 70 ? "var(--positive)" : week[:score] >= 40 ? "#f9a825" : "var(--negative)" %>
          <div style="flex: 1; display: flex; flex-direction: column; align-items: center; height: 100%; justify-content: flex-end;">
            <div style="font-size: 0.6875rem; font-weight: 700; color: <%= w_color %>; margin-bottom: 0.25rem;"><%= week[:score] %></div>
            <div style="width: 100%; max-width: 3rem; height: <%= bar_h %>%; min-height: 4px; background: <%= w_color %>; border-radius: 4px 4px 0 0; opacity: 0.7;"></div>
          </div>
        <% end %>
      </div>
      <%# Labels %>
      <div style="display: flex; gap: 0.5rem;">
        <% @trend.each do |week| %>
          <div style="flex: 1; text-align: center; font-size: 0.625rem; color: var(--text-secondary); line-height: 1.3;">
            <%= week[:label] %>
          </div>
        <% end %>
      </div>

      <%# Weekly detail table %>
      <div style="margin-top: 1rem; overflow-x: auto;">
        <table style="width: 100%; font-size: 0.75rem; border-collapse: collapse;">
          <thead>
            <tr style="border-bottom: 1px solid var(--border);">
              <th style="text-align: left; padding: 0.375rem 0.5rem; color: var(--text-secondary);">Week</th>
              <th style="text-align: center; padding: 0.375rem 0.5rem; color: var(--text-secondary);">Trades</th>
              <th style="text-align: center; padding: 0.375rem 0.5rem; color: var(--text-secondary);">Journal</th>
              <th style="text-align: center; padding: 0.375rem 0.5rem; color: var(--text-secondary);">Notes</th>
              <th style="text-align: center; padding: 0.375rem 0.5rem; color: var(--text-secondary);">Score</th>
            </tr>
          </thead>
          <tbody>
            <% @trend.each do |week| %>
              <% w_color = week[:score] >= 70 ? "var(--positive)" : week[:score] >= 40 ? "#f9a825" : "var(--negative)" %>
              <tr style="border-bottom: 1px solid var(--border);">
                <td style="padding: 0.375rem 0.5rem;"><%= week[:label] %></td>
                <td style="padding: 0.375rem 0.5rem; text-align: center;"><%= week[:trades] %></td>
                <td style="padding: 0.375rem 0.5rem; text-align: center;"><%= week[:journal] %></td>
                <td style="padding: 0.375rem 0.5rem; text-align: center;"><%= week[:notes] %></td>
                <td style="padding: 0.375rem 0.5rem; text-align: center; font-weight: 700; color: <%= w_color %>;"><%= week[:score] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div style="text-align: center; color: var(--text-secondary); padding: 1rem;">
        Not enough data for trend analysis.
      </div>
    <% end %>
  </div>
</div>

<%# ── Quick Links ──────────────────────────────────────────── %>
<div style="text-align: center; margin-top: 1.5rem;">
  <%= link_to "Dashboard", root_path, class: "btn" %>
  <%= link_to "Report Card", trading_grades_path, class: "btn" %>
  <%= link_to "Financial Pulse", financial_pulse_path, class: "btn" %>
  <%= link_to "Budget", budget_dashboard_path, class: "btn" %>
  <%= link_to "Habit Tracker", habit_tracker_path, class: "btn" %>
  <%= link_to "Journal", journal_entries_path, class: "btn" %>
</div>

<style>
  @media (max-width: 640px) {
    .page-header h1 { font-size: 1.25rem; }
  }
  @media print {
    .navbar, .page-actions, .app-footer, .back-to-top, .toast-container { display: none !important; }
    .main-content { padding: 0 !important; }
    .card { break-inside: avoid; box-shadow: none !important; border: 1px solid #ddd !important; }
  }
</style>
