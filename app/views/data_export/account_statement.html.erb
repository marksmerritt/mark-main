<% content_for(:title) { "Account Statement" } %>

<div class="page-header" style="margin-bottom: 1.5rem;">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: var(--primary);">summarize</span>
    Account Statement
  </h1>
  <div class="page-actions">
    <button onclick="window.print()" class="btn btn-sm">
      <span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px;">print</span> Print
    </button>
    <%= link_to "Export Data", data_export_index_path, class: "btn btn-sm" %>
  </div>
</div>

<%# Date Range Picker %>
<div class="card" style="margin-bottom: 1.5rem; padding: 1rem 1.25rem;">
  <%= form_with url: data_export_account_statement_path, method: :get, style: "display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;" do |f| %>
    <div style="display: flex; align-items: center; gap: 0.5rem;">
      <label style="font-size: 0.8125rem; font-weight: 500; white-space: nowrap;">From</label>
      <%= f.date_field :start_date, value: @start_date, class: "form-control", style: "width: auto;" %>
    </div>
    <div style="display: flex; align-items: center; gap: 0.5rem;">
      <label style="font-size: 0.8125rem; font-weight: 500; white-space: nowrap;">To</label>
      <%= f.date_field :end_date, value: @end_date, class: "form-control", style: "width: auto;" %>
    </div>
    <button type="submit" class="btn btn-sm btn-primary">Generate</button>
    <div style="display: flex; gap: 0.375rem; margin-left: auto;">
      <% [
        ["MTD", Date.current.beginning_of_month, Date.current],
        ["Last Month", (Date.current - 1.month).beginning_of_month, (Date.current - 1.month).end_of_month],
        ["QTD", Date.current.beginning_of_quarter, Date.current],
        ["YTD", Date.current.beginning_of_year, Date.current],
        ["Last 90d", Date.current - 90, Date.current]
      ].each do |label, sd, ed| %>
        <%= link_to label, data_export_account_statement_path(start_date: sd, end_date: ed), class: "btn btn-sm", style: "font-size: 0.6875rem; padding: 0.25rem 0.5rem;" %>
      <% end %>
    </div>
  <% end %>
</div>

<%# Statement Header %>
<div class="card" style="margin-bottom: 1.5rem; padding: 2rem; text-align: center; border-top: 3px solid var(--primary);">
  <div style="font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary); letter-spacing: 1px;">Trading Account Statement</div>
  <div style="font-size: 1.5rem; font-weight: 700; margin-top: 0.5rem;">
    <%= @start_date.strftime("%B %d, %Y") %> — <%= @end_date.strftime("%B %d, %Y") %>
  </div>
  <div style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.25rem;">Generated <%= Date.current.strftime("%B %d, %Y") %></div>
</div>

<%# Key Metrics %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 0;">
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Net P&L</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: <%= @net_pnl >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(@net_pnl) %></div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Total Trades</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= @total_trades %></div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Win Rate</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: <%= @win_rate >= 50 ? 'var(--positive)' : 'var(--negative)' %>;"><%= @win_rate %>%</div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Profit Factor</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: <%= @profit_factor >= 1.5 ? 'var(--positive)' : @profit_factor >= 1 ? '#f9ab00' : 'var(--negative)' %>;"><%= @profit_factor %></div>
    </div>
    <div style="padding: 1rem; text-align: center;">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Max Drawdown</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: var(--negative);"><%= number_to_currency(@max_drawdown) %></div>
    </div>
  </div>
</div>

<%# P&L Breakdown %>
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">
  <div class="card" style="padding: 1.25rem;">
    <h3 style="font-size: 0.875rem; margin-bottom: 1rem;">P&L Breakdown</h3>
    <table style="width: 100%; font-size: 0.8125rem;">
      <tr style="border-bottom: 1px solid var(--border);">
        <td style="padding: 0.5rem 0; color: var(--text-secondary);">Gross P&L</td>
        <td style="padding: 0.5rem 0; text-align: right; font-weight: 600; color: <%= @total_pnl >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(@total_pnl) %></td>
      </tr>
      <tr style="border-bottom: 1px solid var(--border);">
        <td style="padding: 0.5rem 0; color: var(--text-secondary);">Fees & Commissions</td>
        <td style="padding: 0.5rem 0; text-align: right; font-weight: 600; color: var(--negative);">-<%= number_to_currency(@total_fees) %></td>
      </tr>
      <tr style="border-bottom: 2px solid var(--text);">
        <td style="padding: 0.5rem 0; font-weight: 700;">Net P&L</td>
        <td style="padding: 0.5rem 0; text-align: right; font-weight: 700; color: <%= @net_pnl >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(@net_pnl) %></td>
      </tr>
      <tr>
        <td colspan="2" style="padding-top: 0.75rem;"></td>
      </tr>
      <tr style="border-bottom: 1px solid var(--border);">
        <td style="padding: 0.5rem 0; color: var(--text-secondary);">Winning Trades</td>
        <td style="padding: 0.5rem 0; text-align: right; color: var(--positive);"><%= @winners.count %> (<%= number_to_currency(@winners.sum { |t| t["pnl"].to_f }) %>)</td>
      </tr>
      <tr style="border-bottom: 1px solid var(--border);">
        <td style="padding: 0.5rem 0; color: var(--text-secondary);">Losing Trades</td>
        <td style="padding: 0.5rem 0; text-align: right; color: var(--negative);"><%= @losers.count %> (<%= number_to_currency(@losers.sum { |t| t["pnl"].to_f }) %>)</td>
      </tr>
      <tr style="border-bottom: 1px solid var(--border);">
        <td style="padding: 0.5rem 0; color: var(--text-secondary);">Breakeven</td>
        <td style="padding: 0.5rem 0; text-align: right;"><%= @breakeven.count %></td>
      </tr>
    </table>
  </div>

  <div class="card" style="padding: 1.25rem;">
    <h3 style="font-size: 0.875rem; margin-bottom: 1rem;">Performance Metrics</h3>
    <table style="width: 100%; font-size: 0.8125rem;">
      <tr style="border-bottom: 1px solid var(--border);">
        <td style="padding: 0.5rem 0; color: var(--text-secondary);">Average Win</td>
        <td style="padding: 0.5rem 0; text-align: right; font-weight: 600; color: var(--positive);"><%= number_to_currency(@avg_win) %></td>
      </tr>
      <tr style="border-bottom: 1px solid var(--border);">
        <td style="padding: 0.5rem 0; color: var(--text-secondary);">Average Loss</td>
        <td style="padding: 0.5rem 0; text-align: right; font-weight: 600; color: var(--negative);"><%= number_to_currency(@avg_loss) %></td>
      </tr>
      <tr style="border-bottom: 1px solid var(--border);">
        <td style="padding: 0.5rem 0; color: var(--text-secondary);">Largest Win</td>
        <td style="padding: 0.5rem 0; text-align: right; color: var(--positive);"><%= number_to_currency(@largest_win) %></td>
      </tr>
      <tr style="border-bottom: 1px solid var(--border);">
        <td style="padding: 0.5rem 0; color: var(--text-secondary);">Largest Loss</td>
        <td style="padding: 0.5rem 0; text-align: right; color: var(--negative);"><%= number_to_currency(@largest_loss) %></td>
      </tr>
      <tr style="border-bottom: 1px solid var(--border);">
        <td style="padding: 0.5rem 0; color: var(--text-secondary);">Trading Days</td>
        <td style="padding: 0.5rem 0; text-align: right; font-weight: 600;"><%= @trading_days %></td>
      </tr>
      <tr style="border-bottom: 1px solid var(--border);">
        <td style="padding: 0.5rem 0; color: var(--text-secondary);">Green / Red Days</td>
        <td style="padding: 0.5rem 0; text-align: right;">
          <span style="color: var(--positive);"><%= @green_days %></span> / <span style="color: var(--negative);"><%= @red_days %></span>
        </td>
      </tr>
      <tr style="border-bottom: 1px solid var(--border);">
        <td style="padding: 0.5rem 0; color: var(--text-secondary);">Avg P&L / Trade</td>
        <td style="padding: 0.5rem 0; text-align: right; font-weight: 600;"><%= @total_trades > 0 ? number_to_currency(@net_pnl / @total_trades) : "$0.00" %></td>
      </tr>
    </table>
  </div>
</div>

<%# Equity Curve %>
<% if @equity_curve.count >= 2 %>
  <%
    values = @equity_curve.map { |pt| pt[:cumulative] }
    max_v = values.max.to_f
    min_v = values.min.to_f
    v_range = [max_v - min_v, 1].max
    chart_w = 700; chart_h = 180; pad_l = 70; pad_r = 20
    usable_w = chart_w - pad_l - pad_r
    usable_h = chart_h - 30
  %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">show_chart</span> Equity Curve</h2>
      <span style="font-size: 0.8125rem; color: var(--text-secondary);"><%= @equity_curve.count %> trades</span>
    </div>
    <div style="padding: 1.25rem; overflow-x: auto;">
      <svg viewBox="0 0 <%= chart_w %> <%= chart_h + 20 %>" style="width: 100%; height: auto; font-family: Inter, sans-serif;">
        <%# Zero line %>
        <% if min_v < 0 && max_v > 0 %>
          <% zero_y = 10 + (max_v / v_range * usable_h) %>
          <line x1="<%= pad_l %>" y1="<%= zero_y %>" x2="<%= chart_w - pad_r %>" y2="<%= zero_y %>" stroke="var(--text-secondary)" stroke-width="0.5" stroke-dasharray="4"/>
          <text x="<%= pad_l - 5 %>" y="<%= zero_y + 3 %>" text-anchor="end" fill="var(--text-secondary)" font-size="8">$0</text>
        <% end %>

        <%# Grid lines %>
        <% 5.times do |i| %>
          <% y = 10 + i * (usable_h / 4.0) %>
          <line x1="<%= pad_l %>" y1="<%= y %>" x2="<%= chart_w - pad_r %>" y2="<%= y %>" stroke="var(--border)" stroke-width="0.5" stroke-dasharray="3"/>
          <text x="<%= pad_l - 5 %>" y="<%= y + 3 %>" text-anchor="end" fill="var(--text-secondary)" font-size="8">
            $<%= ((max_v - i * v_range / 4.0) / 1000).round(1) %>k
          </text>
        <% end %>

        <%
          step = usable_w.to_f / [@equity_curve.count - 1, 1].max
          points = @equity_curve.each_with_index.map { |pt, i|
            x = pad_l + i * step
            y = 10 + (max_v - pt[:cumulative]) / v_range * usable_h
            [x, y.clamp(5, chart_h)]
          }

          fill_pts = points.map { |p| "#{p[0].round(1)},#{p[1].round(1)}" }.join(' ')
          fill_pts += " #{points.last[0].round(1)},#{10 + usable_h} #{points.first[0].round(1)},#{10 + usable_h}"
          line_color = @net_pnl >= 0 ? "var(--positive)" : "var(--negative)"
        %>
        <polygon points="<%= fill_pts %>" fill="<%= line_color %>" opacity="0.08"/>
        <polyline points="<%= points.map { |p| "#{p[0].round(1)},#{p[1].round(1)}" }.join(' ') %>"
                  fill="none" stroke="<%= line_color %>" stroke-width="2"/>
      </svg>
    </div>
  </div>
<% end %>

<%# By Symbol %>
<% if @by_symbol.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">label</span> Performance by Symbol</h2>
      <span style="font-size: 0.8125rem; color: var(--text-secondary);"><%= @by_symbol.count %> symbols</span>
    </div>
    <div style="overflow-x: auto;">
      <table class="table" style="font-size: 0.8125rem;">
        <thead>
          <tr>
            <th>Symbol</th>
            <th style="text-align: center;">Trades</th>
            <th style="text-align: center;">Wins</th>
            <th style="text-align: center;">Win Rate</th>
            <th style="text-align: right;">P&L</th>
          </tr>
        </thead>
        <tbody>
          <% @by_symbol.each do |sym, data| %>
            <% wr = data[:trades] > 0 ? (data[:wins].to_f / data[:trades] * 100).round(1) : 0 %>
            <tr>
              <td><strong><%= sym %></strong></td>
              <td style="text-align: center;"><%= data[:trades] %></td>
              <td style="text-align: center;"><%= data[:wins] %></td>
              <td style="text-align: center; color: <%= wr >= 50 ? 'var(--positive)' : 'var(--negative)' %>;"><%= wr %>%</td>
              <td style="text-align: right; font-weight: 600; color: <%= data[:pnl] >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(data[:pnl]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<%# Trade Log %>
<% if @trades.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">list_alt</span> Trade Log</h2>
      <span style="font-size: 0.8125rem; color: var(--text-secondary);"><%= @trades.count %> trades</span>
    </div>
    <div style="overflow-x: auto;">
      <table class="table" style="font-size: 0.8125rem;">
        <thead>
          <tr>
            <th>Date</th>
            <th>Symbol</th>
            <th>Side</th>
            <th style="text-align: right;">Entry</th>
            <th style="text-align: right;">Exit</th>
            <th style="text-align: center;">Qty</th>
            <th style="text-align: right;">P&L</th>
            <th style="text-align: right;">Fees</th>
          </tr>
        </thead>
        <tbody>
          <% running_total = 0 %>
          <% @trades.sort_by { |t| t["exit_time"] || t["entry_time"] || "" }.each do |trade| %>
            <% trade_pnl = trade["pnl"].to_f; running_total += trade_pnl %>
            <tr>
              <td><%= Date.parse(trade["exit_time"] || trade["entry_time"]).strftime("%m/%d/%y") rescue "—" %></td>
              <td><%= link_to trade["symbol"], trade_path(trade["id"]) %></td>
              <td><%= trade["side"]&.capitalize %></td>
              <td style="text-align: right;"><%= number_to_currency(trade["entry_price"]) %></td>
              <td style="text-align: right;"><%= number_to_currency(trade["exit_price"]) %></td>
              <td style="text-align: center;"><%= trade["quantity"] %></td>
              <td style="text-align: right; font-weight: 600; color: <%= trade_pnl >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(trade_pnl) %></td>
              <td style="text-align: right; color: var(--text-secondary);"><%= number_to_currency(trade["fees"]) %></td>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <tr style="font-weight: 700; border-top: 2px solid var(--text);">
            <td colspan="6">Total</td>
            <td style="text-align: right; color: <%= @total_pnl >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(@total_pnl) %></td>
            <td style="text-align: right;"><%= number_to_currency(@total_fees) %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
<% end %>

<div style="text-align: center; margin-top: 1.5rem;">
  <%= link_to "Export Trades CSV", data_export_trades_csv_path, class: "btn" %>
  <%= link_to "Reports Hub", reports_index_path, class: "btn" %>
  <%= link_to "Overview", reports_overview_path, class: "btn" %>
</div>

<style>
  @media print {
    .navbar, .page-actions, .app-footer, .back-to-top, .toast-container { display: none !important; }
    .main-content { padding: 0 !important; }
    .card { break-inside: avoid; box-shadow: none !important; border: 1px solid #ddd !important; }
    a { color: inherit !important; text-decoration: none !important; }
  }
</style>
