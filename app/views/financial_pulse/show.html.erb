<% content_for(:title) { "Financial Pulse" } %>

<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: var(--primary);">monitor_heart</span>
    Financial Pulse
  </h1>
</div>

<%# Overall Status Banner %>
<%
  status_config = case @overall_status
                  when :great then { bg: "rgba(52,168,83,0.1)", border: "var(--positive)", icon: "check_circle", text: "Everything looks great", color: "var(--positive)" }
                  when :attention then { bg: "rgba(234,67,53,0.1)", border: "var(--negative)", icon: "warning", text: "Some areas need attention", color: "var(--negative)" }
                  else { bg: "rgba(66,133,244,0.1)", border: "var(--primary)", icon: "info", text: "Things are steady", color: "var(--primary)" }
                  end
%>
<div class="card" style="margin-bottom: 1.5rem; padding: 1rem 1.25rem; border-left: 4px solid <%= status_config[:border] %>; background: <%= status_config[:bg] %>;">
  <div style="display: flex; align-items: center; gap: 0.75rem;">
    <span class="material-icons-outlined" style="font-size: 1.5rem; color: <%= status_config[:color] %>;"><%= status_config[:icon] %></span>
    <div>
      <div style="font-weight: 700; font-size: 1.125rem;"><%= status_config[:text] %></div>
      <div style="font-size: 0.75rem; color: var(--text-secondary);"><%= Date.current.strftime("%A, %B %d, %Y") %></div>
    </div>
  </div>
</div>

<%# Signal Cards %>
<div style="display: grid; gap: 1.5rem; margin-bottom: 1.5rem;">
  <% @signals.each do |signal| %>
    <div class="card">
      <div class="card-header" style="border-bottom: 2px solid <%= signal[:color] %>;">
        <h2>
          <span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: <%= signal[:color] %>;"><%= signal[:icon] %></span>
          <%= signal[:category] %>
          <%
            indicator_color = case signal[:status]
                              when :positive then "var(--positive)"
                              when :negative then "var(--negative)"
                              else "var(--text-secondary)"
                              end
          %>
          <span style="float: right; font-size: 0.75rem; padding: 0.125rem 0.5rem; border-radius: 9999px; background: <%= indicator_color %>; color: white; font-weight: 600;">
            <%= signal[:headline] %>
          </span>
        </h2>
      </div>

      <%# Metrics %>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 0; border-bottom: <%= signal[:alerts].any? ? '1px solid var(--border)' : 'none' %>;">
        <% signal[:metrics].each_with_index do |m, i| %>
          <div style="padding: 0.75rem; text-align: center;<%= i < signal[:metrics].length - 1 ? ' border-right: 1px solid var(--border);' : '' %>">
            <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;"><%= m[:label] %></div>
            <div style="font-size: 1.125rem; font-weight: 700;<%= m[:color] ? " color: #{m[:color]};" : '' %>"><%= m[:value] %></div>
          </div>
        <% end %>
      </div>

      <%# Alerts %>
      <% if signal[:alerts].any? %>
        <div style="padding: 0.75rem 1.25rem;">
          <% signal[:alerts].each do |a| %>
            <%
              alert_icon = case a[:severity]
                           when :danger then "error"
                           when :warning then "warning"
                           else "check_circle"
                           end
              alert_color = case a[:severity]
                            when :danger then "var(--negative)"
                            when :warning then "#fbbc04"
                            else "var(--positive)"
                            end
            %>
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.375rem; font-size: 0.8125rem;">
              <span class="material-icons-outlined" style="font-size: 0.875rem; color: <%= alert_color %>;"><%= alert_icon %></span>
              <span><%= a[:text] %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<% if @signals.empty? %>
  <div class="card" style="padding: 3rem; text-align: center; color: var(--text-secondary);">
    <span class="material-icons-outlined" style="font-size: 3rem; margin-bottom: 1rem;">monitor_heart</span>
    <div style="font-size: 1.125rem; font-weight: 600;">Connect your APIs</div>
    <div style="font-size: 0.875rem; margin-top: 0.5rem;">Configure API tokens in <%= link_to "Settings", settings_path %> to see your financial pulse.</div>
  </div>
<% end %>

<%# Quick Links %>
<div style="text-align: center; margin-top: 1.5rem;">
  <%= link_to "Dashboard", root_path, class: "btn" %>
  <%= link_to "Daily Review", daily_review_path, class: "btn" %>
  <%= link_to "Pre-Market", pre_market_path, class: "btn" %>
  <%= link_to "Monthly Report", monthly_report_path, class: "btn" %>
</div>
