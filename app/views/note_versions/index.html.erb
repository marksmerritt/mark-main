<div class="page-header">
  <h1>Version History</h1>
  <div class="page-actions">
    <%= link_to "Back to Note", note_path(@note["id"]), class: "btn" %>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <h2><%= @note["title"].presence || "Untitled Note" %></h2>
  </div>

  <% if @versions.is_a?(Array) && @versions.any? %>
    <table class="table">
      <thead>
        <tr>
          <th>Version</th>
          <th>Changed By</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @versions.each do |version| %>
          <tr>
            <td><%= version["version_number"] || version["id"] %></td>
            <td><%= version.dig("user", "name") || version["user_name"] || version["user_id"] || "Unknown" %></td>
            <td><%= Time.parse(version["created_at"]).strftime("%b %d, %Y %l:%M %p") if version["created_at"] %></td>
            <td>
              <%= link_to "View", note_note_version_path(@note["id"], version["id"]), class: "btn btn-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="empty-state">No version history available for this note.</p>
  <% end %>
</div>
