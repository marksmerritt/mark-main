<div class="page-header">
  <h1>Search Notes</h1>
</div>

<div class="card">
  <%= form_with url: notes_search_search_path, method: :get, class: "filter-form" do |f| %>
    <div class="filter-row">
      <div class="form-group">
        <%= f.label :q, "Search" %>
        <%= f.text_field :q, value: params[:q], placeholder: "Search notes...", class: "form-control", autofocus: true %>
      </div>

      <div class="form-group form-actions-inline">
        <%= f.submit "Search", class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>

<% if @notes.is_a?(Array) && @notes.any? %>
  <div class="entries-list">
    <% @notes.each do |note| %>
      <div class="card entry-card" <% if note["color"].present? %>style="border-left: 4px solid <%= note["color"] %>"<% end %>>
        <div class="entry-card-header">
          <span class="entry-date">
            <%= link_to note["title"].presence || "Untitled", note_path(note["id"]) %>
          </span>
        </div>

        <% if note["notebook"].present? %>
          <span class="text-muted"><%= note.dig("notebook", "name") || note["notebook"] %></span>
        <% end %>

        <% if note["content_preview"].present? || note["content"].present? %>
          <p class="text-muted"><%= truncate(note["content_preview"] || note["content"], length: 150) %></p>
        <% end %>

        <div class="entry-card-footer">
          <%= link_to "View", note_path(note["id"]), class: "btn btn-sm" %>
        </div>
      </div>
    <% end %>
  </div>
<% elsif @query.present? %>
  <div class="card empty-state">
    <p>No notes found matching "<%= @query %>".</p>
  </div>
<% end %>
