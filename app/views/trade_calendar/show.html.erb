<%# ── Page Header ── %>
<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: var(--primary);">calendar_month</span>
    Trade Calendar
  </h1>
  <div class="page-actions">
    <%= link_to reports_pnl_calendar_path, class: "btn btn-sm" do %>
      <span class="material-icons-outlined" style="font-size: 1rem; vertical-align: -3px;">event</span> P&L Calendar
    <% end %>
  </div>
</div>

<%# ── Month Navigation ── %>
<div class="week-nav">
  <%= link_to trade_calendar_path(month: @prev_month, year: @prev_year), class: "btn btn-sm" do %>
    <span class="material-icons-outlined" style="font-size: 1rem; vertical-align: -3px;">chevron_left</span> Previous
  <% end %>
  <h2 class="week-nav-title"><%= @target_date.strftime("%B %Y") %></h2>
  <% if @can_go_next %>
    <%= link_to trade_calendar_path(month: @next_month, year: @next_year), class: "btn btn-sm" do %>
      Next <span class="material-icons-outlined" style="font-size: 1rem; vertical-align: -3px;">chevron_right</span>
    <% end %>
  <% else %>
    <span class="btn btn-sm" style="opacity: 0.3; pointer-events: none;">Next</span>
  <% end %>
</div>

<%# ── Summary Stats Bar ── %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 0;">
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Month P&L</div>
      <div style="font-size: 1.5rem; font-weight: 700;" class="<%= @month_pnl >= 0 ? 'positive' : 'negative' %>"><%= number_to_currency(@month_pnl) %></div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Trades</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= @month_trade_count %></div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Win Rate</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: <%= @month_win_rate >= 50 ? 'var(--positive)' : 'var(--negative)' %>;"><%= @month_win_rate %>%</div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Best Day</div>
      <% if @best_day %>
        <div style="font-size: 1.125rem; font-weight: 700;" class="positive"><%= number_to_currency(@best_day[1][:total_pnl]) %></div>
        <div style="font-size: 0.625rem; color: var(--text-secondary);"><%= Date.parse(@best_day[0]).strftime("%b %-d") rescue @best_day[0] %></div>
      <% else %>
        <div style="font-size: 1.125rem; font-weight: 700; color: var(--text-secondary);">--</div>
      <% end %>
    </div>
    <div style="padding: 1rem; text-align: center;">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Worst Day</div>
      <% if @worst_day %>
        <div style="font-size: 1.125rem; font-weight: 700;" class="negative"><%= number_to_currency(@worst_day[1][:total_pnl]) %></div>
        <div style="font-size: 0.625rem; color: var(--text-secondary);"><%= Date.parse(@worst_day[0]).strftime("%b %-d") rescue @worst_day[0] %></div>
      <% else %>
        <div style="font-size: 1.125rem; font-weight: 700; color: var(--text-secondary);">--</div>
      <% end %>
    </div>
  </div>
</div>

<%# ── Desktop Calendar Grid ── %>
<div class="card trade-calendar-desktop" style="margin-bottom: 1.5rem;">
  <div style="padding: 0.75rem 1.25rem;">
    <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px;">
      <%# Day-of-week headers %>
      <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |day| %>
        <div style="text-align: center; font-size: 0.6875rem; font-weight: 600; color: var(--text-secondary); padding: 0.5rem 0;"><%= day %></div>
      <% end %>

      <%# Leading empty cells for days before month start %>
      <% @month_start.wday.times do %>
        <div class="tc-day-cell tc-day-other" style="min-height: 6.5rem;"></div>
      <% end %>

      <%# Calendar days %>
      <% (@month_start..@month_end).each do |date| %>
        <%
          date_str = date.strftime("%Y-%m-%d")
          day_data = @daily_data[date_str]
          is_today = date == Date.current
          is_future = date > Date.current
          has_trades = day_data.present?
          has_journal = @journal_dates[date_str]
          total_pnl = day_data ? day_data[:total_pnl] : 0
          intensity = has_trades ? (total_pnl.abs / @max_abs_pnl).clamp(0, 1) : 0
        %>
        <div class="tc-day-cell" style="min-height: 6.5rem; border: 1px solid <%= is_today ? 'var(--primary)' : 'var(--border)' %>; border-radius: 4px; padding: 0.375rem; position: relative; display: flex; flex-direction: column;
                    background: <%=
                      if has_trades && total_pnl > 0
                        "rgba(13, 144, 79, #{(intensity * 0.2).round(2)})"
                      elsif has_trades && total_pnl < 0
                        "rgba(217, 48, 37, #{(intensity * 0.2).round(2)})"
                      elsif is_future
                        "var(--bg)"
                      else
                        "transparent"
                      end
                    %>; <%= is_today ? 'box-shadow: 0 0 0 2px var(--primary);' : '' %>">

          <%# Day number + journal icon row %>
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
            <span style="font-size: 0.75rem; font-weight: <%= is_today ? '700' : '500' %>; color: <%= is_today ? 'var(--primary)' : 'var(--text-secondary)' %>;">
              <%= date.day %>
            </span>
            <% if has_journal %>
              <span class="material-icons-outlined" style="font-size: 0.75rem; color: var(--primary); opacity: 0.7;" title="Journal entry">auto_stories</span>
            <% end %>
          </div>

          <%# Trade chips %>
          <% if has_trades %>
            <div style="flex: 1; display: flex; flex-direction: column; gap: 2px;">
              <% day_data[:trades].first(3).each do |trade| %>
                <%
                  trade_pnl = trade["pnl"].to_f
                  trade_side = (trade["side"] || trade["direction"] || "").to_s
                  side_icon = trade_side.downcase.include?("short") || trade_side.downcase.include?("sell") ? "south" : "north"
                %>
                <div class="tc-trade-chip" style="display: flex; align-items: center; gap: 2px; padding: 1px 4px; border-radius: 3px; font-size: 0.5625rem; line-height: 1.4;
                            background: <%= trade_pnl >= 0 ? 'rgba(13, 144, 79, 0.1)' : 'rgba(217, 48, 37, 0.1)' %>;">
                  <span class="material-icons-outlined" style="font-size: 0.5rem; color: <%= trade_pnl >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= side_icon %></span>
                  <%= link_to trade["symbol"], trade_path(trade["id"]), style: "font-weight: 600; color: var(--text); text-decoration: none; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" %>
                  <span style="margin-left: auto; font-weight: 600; white-space: nowrap;" class="<%= trade_pnl >= 0 ? 'positive' : 'negative' %>">
                    <%= trade_pnl >= 0 ? "+" : "" %><%= number_to_currency(trade_pnl, precision: 0) %>
                  </span>
                </div>
              <% end %>

              <% if day_data[:trade_count] > 3 %>
                <div style="font-size: 0.5rem; color: var(--text-secondary); text-align: center; padding-top: 1px;">
                  +<%= day_data[:trade_count] - 3 %> more
                </div>
              <% end %>
            </div>

            <%# Day total P&L footer %>
            <div style="margin-top: auto; padding-top: 0.25rem; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center;">
              <span style="font-size: 0.5625rem; color: var(--text-secondary);"><%= day_data[:trade_count] %> trade<%= day_data[:trade_count] == 1 ? '' : 's' %></span>
              <span style="font-size: 0.6875rem; font-weight: 700;" class="<%= total_pnl >= 0 ? 'positive' : 'negative' %>">
                <%= total_pnl >= 0 ? "+" : "" %><%= number_to_currency(total_pnl, precision: 0) %>
              </span>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# Trailing empty cells %>
      <% trailing = (7 - ((@month_start.wday + (@month_end.day)) % 7)) % 7 %>
      <% trailing.times do %>
        <div class="tc-day-cell tc-day-other" style="min-height: 6.5rem;"></div>
      <% end %>
    </div>
  </div>
</div>

<%# ── Mobile List View ── %>
<div class="trade-calendar-mobile" style="display: none; margin-bottom: 1.5rem;">
  <% (@month_start..@month_end).each do |date| %>
    <%
      date_str = date.strftime("%Y-%m-%d")
      day_data = @daily_data[date_str]
      has_journal = @journal_dates[date_str]
      is_today = date == Date.current
      next if !day_data && !has_journal && !is_today
    %>
    <div class="card" style="margin-bottom: 0.5rem; border-left: 3px solid <%=
      if day_data && day_data[:total_pnl] > 0
        'var(--positive)'
      elsif day_data && day_data[:total_pnl] < 0
        'var(--negative)'
      else
        'var(--border)'
      end
    %>; <%= is_today ? 'box-shadow: 0 0 0 1px var(--primary);' : '' %>">
      <div style="padding: 0.75rem 1rem;">
        <%# Date header %>
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
          <div>
            <span style="font-weight: 600; font-size: 0.9375rem; color: <%= is_today ? 'var(--primary)' : 'var(--text)' %>;">
              <%= date.strftime("%a, %b %-d") %>
            </span>
            <% if is_today %>
              <span style="font-size: 0.625rem; background: var(--primary); color: white; padding: 1px 6px; border-radius: 8px; margin-left: 0.375rem; font-weight: 600;">TODAY</span>
            <% end %>
            <% if has_journal %>
              <span class="material-icons-outlined" style="font-size: 0.875rem; color: var(--primary); vertical-align: -2px; margin-left: 0.25rem;">auto_stories</span>
            <% end %>
          </div>
          <% if day_data %>
            <span style="font-size: 1rem; font-weight: 700;" class="<%= day_data[:total_pnl] >= 0 ? 'positive' : 'negative' %>">
              <%= day_data[:total_pnl] >= 0 ? "+" : "" %><%= number_to_currency(day_data[:total_pnl]) %>
            </span>
          <% end %>
        </div>

        <%# Trade list %>
        <% if day_data %>
          <div style="display: flex; flex-direction: column; gap: 4px;">
            <% day_data[:trades].each do |trade| %>
              <%
                trade_pnl = trade["pnl"].to_f
                trade_side = (trade["side"] || trade["direction"] || "").to_s
              %>
              <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0.5rem; border-radius: 4px;
                          background: <%= trade_pnl >= 0 ? 'rgba(13, 144, 79, 0.08)' : 'rgba(217, 48, 37, 0.08)' %>;">
                <span style="font-size: 0.625rem; color: var(--text-secondary); width: 2rem; text-transform: uppercase;"><%= trade_side.truncate(5, omission: '') %></span>
                <%= link_to trade["symbol"], trade_path(trade["id"]), style: "font-weight: 600; font-size: 0.8125rem; color: var(--text); text-decoration: none;" %>
                <span style="margin-left: auto; font-weight: 600; font-size: 0.8125rem;" class="<%= trade_pnl >= 0 ? 'positive' : 'negative' %>">
                  <%= trade_pnl >= 0 ? "+" : "" %><%= number_to_currency(trade_pnl) %>
                </span>
              </div>
            <% end %>
          </div>
          <div style="margin-top: 0.375rem; font-size: 0.6875rem; color: var(--text-secondary);">
            <%= day_data[:trade_count] %> trade<%= day_data[:trade_count] == 1 ? '' : 's' %> &middot;
            <span class="positive"><%= day_data[:wins] %>W</span> / <span class="negative"><%= day_data[:losses] %>L</span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @daily_data.empty? && @journal_dates.empty? %>
    <div class="card empty-state" style="padding: 2rem; text-align: center;">
      <span class="material-icons-outlined" style="font-size: 2.5rem; color: var(--text-secondary);">calendar_month</span>
      <p style="margin: 0.5rem 0 0; color: var(--text-secondary);">No trades or journal entries for <%= @target_date.strftime("%B %Y") %>.</p>
    </div>
  <% end %>
</div>

<%# ── Empty State for Desktop ── %>
<% if @daily_data.empty? %>
  <div class="trade-calendar-desktop">
    <div class="card empty-state" style="padding: 2rem; text-align: center; margin-bottom: 1.5rem;">
      <span class="material-icons-outlined" style="font-size: 2.5rem; color: var(--text-secondary);">calendar_month</span>
      <p style="margin: 0.5rem 0 0; color: var(--text-secondary);">No trades found for <%= @target_date.strftime("%B %Y") %>.</p>
    </div>
  </div>
<% end %>

<%# ── Responsive CSS ── %>
<style>
  .tc-day-cell {
    transition: transform 0.1s ease;
  }
  .tc-day-cell:hover {
    transform: scale(1.02);
    z-index: 1;
  }
  .tc-day-other {
    background: var(--bg) !important;
    opacity: 0.4;
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  .tc-trade-chip:hover {
    filter: brightness(0.95);
  }

  /* Desktop: show grid, hide list */
  @media (min-width: 769px) {
    .trade-calendar-desktop { display: block !important; }
    .trade-calendar-mobile { display: none !important; }
  }

  /* Mobile: hide grid, show list */
  @media (max-width: 768px) {
    .trade-calendar-desktop { display: none !important; }
    .trade-calendar-mobile { display: block !important; }
  }
</style>
