      grid-template-columns: 1fr !important;
    }
    div[style*="grid-template-columns: 1fr auto 1fr auto 1fr"] {
      grid-template-columns: 1fr !important;
    }
    div[style*="grid-template-columns: 1fr auto 1fr auto 1fr"] > span.material-icons-outlined {
      display: none;
    }
  }
  @media print {
    .navbar, .page-actions, .app-footer, .back-to-top, .toast-container { display: none !important; }
    .main-content { padding: 0 !important; }
    .card { break-inside: avoid; box-shadow: none !important; border: 1px solid #ddd !important; }
  }
</style>
