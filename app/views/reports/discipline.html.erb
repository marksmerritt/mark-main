<div class="page-header">
  <h1>Trading Discipline</h1>
  <div class="page-actions">
    <button class="btn" onclick="window.print()">
      <span class="material-icons-outlined">print</span> Print
    </button>
  </div>
</div>

<div class="card">
  <%= form_with url: reports_discipline_path, method: :get, class: "filter-form" do |f| %>
    <div class="filter-row">
      <div class="form-group">
        <%= f.label :start_date, "Start Date" %>
        <%= f.date_field :start_date, value: params[:start_date], class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :end_date, "End Date" %>
        <%= f.date_field :end_date, value: params[:end_date], class: "form-control" %>
      </div>
      <div class="form-group form-actions-inline">
        <%= f.submit "Apply", class: "btn btn-primary" %>
        <%= link_to "Clear", reports_discipline_path, class: "btn" %>
      </div>
    </div>
  <% end %>
</div>

<% if @total_trades >= 5 %>
  <%# Discipline Score Gauge %>
  <div class="card" style="display: flex; align-items: center; gap: 2rem; padding: 1.5rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
    <div style="flex-shrink: 0;">
      <%
        ds_pct = @discipline_score / 100.0
        ds_arc = [ds_pct * 180, 180].min
        ds_end_rad = (180 - ds_arc) * Math::PI / 180
        ds_end_x = (70 + 55 * Math.cos(ds_end_rad)).round(1)
        ds_end_y = (75 - 55 * Math.sin(ds_end_rad)).round(1)
        ds_color = @discipline_score >= 80 ? "var(--positive)" : @discipline_score >= 60 ? "#f9ab00" : @discipline_score >= 40 ? "var(--primary)" : "var(--negative)"
        ds_label = @discipline_score >= 80 ? "Excellent" : @discipline_score >= 60 ? "Good" : @discipline_score >= 40 ? "Fair" : "Needs Work"
      %>
      <svg viewBox="0 0 140 85" style="width: 140px;">
        <path d="M 15 75 A 55 55 0 0 1 125 75" fill="none" stroke="var(--border)" stroke-width="8" stroke-linecap="round" />
        <% if ds_arc > 0 %>
          <path d="M 15 75 A 55 55 0 <%= ds_arc > 180 ? 1 : 0 %> 1 <%= ds_end_x %> <%= ds_end_y %>"
                fill="none" stroke="<%= ds_color %>" stroke-width="8" stroke-linecap="round" />
        <% end %>
        <text x="70" y="58" text-anchor="middle" fill="<%= ds_color %>" font-size="22" font-weight="700"><%= @discipline_score %></text>
        <text x="70" y="78" text-anchor="middle" fill="var(--text-secondary)" font-size="7"><%= ds_label %></text>
      </svg>
    </div>
    <div style="flex: 1; min-width: 200px;">
      <h2 style="margin-bottom: 0.375rem;">Discipline Score</h2>
      <p style="font-size: 0.8125rem; color: var(--text-secondary); margin-bottom: 0.5rem;">
        Composite score based on trade grading, setup documentation, stop loss usage, plan adherence, and note-taking.
      </p>
      <div style="display: flex; gap: 1.5rem; flex-wrap: wrap; font-size: 0.875rem;">
        <div>
          <span class="text-muted">Trades</span>
          <div style="font-weight: 700;"><%= @total_trades %></div>
        </div>
        <div>
          <span class="text-muted">Graded</span>
          <div style="font-weight: 700;"><%= @graded_trades %></div>
        </div>
        <div>
          <span class="text-muted">Reviewed</span>
          <div style="font-weight: 700;"><%= @reviewed_trades %></div>
        </div>
      </div>
    </div>
  </div>

  <%# Discipline dimensions %>
  <%
    dimensions = [
      { label: "Trade Grading", done: @graded_trades, total: @total_trades, icon: "grade", tip: "Grade each trade A-F" },
      { label: "Setup Documented", done: @with_setup, total: @total_trades, icon: "lightbulb", tip: "Record your setup for each trade" },
      { label: "Stop Loss Set", done: @with_stops, total: @total_trades, icon: "shield", tip: "Define stop loss before entry" },
      { label: "Take Profit Set", done: @with_targets, total: @total_trades, icon: "flag", tip: "Set a target price" },
      { label: "Plan Followed", done: @followed_plan, total: [@with_plan, 1].max, icon: "task_alt", tip: "Follow your trade plan" },
      { label: "Notes Written", done: @with_notes, total: @total_trades, icon: "notes", tip: "Write post-trade notes" },
      { label: "Emotion Logged", done: @with_emotion, total: @total_trades, icon: "psychology", tip: "Track your emotional state" }
    ]
  %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header"><h2>Discipline Breakdown</h2></div>
    <div style="padding: 1rem 1.25rem;">
      <% dimensions.each do |dim| %>
        <%
          pct = dim[:total] > 0 ? (dim[:done].to_f / dim[:total] * 100).round(0) : 0
          bar_color = pct >= 80 ? "var(--positive)" : pct >= 50 ? "#f9ab00" : "var(--negative)"
        %>
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;" title="<%= dim[:tip] %>">
          <span class="material-icons-outlined" style="font-size: 1rem; color: var(--text-secondary); width: 1.25rem;"><%= dim[:icon] %></span>
          <span style="font-size: 0.8125rem; font-weight: 500; min-width: 9rem;"><%= dim[:label] %></span>
          <div style="flex: 1; height: 0.625rem; background: var(--bg); border-radius: 0.3rem; overflow: hidden;">
            <div style="height: 100%; width: <%= pct %>%; background: <%= bar_color %>; border-radius: 0.3rem; transition: width 0.3s;"></div>
          </div>
          <span style="font-size: 0.8125rem; font-weight: 700; min-width: 3rem; text-align: right; color: <%= bar_color %>;"><%= pct %>%</span>
          <span style="font-size: 0.6875rem; color: var(--text-secondary); min-width: 3rem;"><%= dim[:done] %>/<%= dim[:total] %></span>
        </div>
      <% end %>
    </div>
  </div>

  <%# Weekly discipline trends %>
  <% if @weekly_trends.count >= 3 %>
    <%
      trend_dims = [
        { key: :graded_pct, label: "Graded", color: "#1a73e8" },
        { key: :setup_pct, label: "Setup", color: "#0d904f" },
        { key: :stop_pct, label: "Stop Loss", color: "#e8710a" },
        { key: :plan_pct, label: "Plan", color: "#9334e6" },
        { key: :notes_pct, label: "Notes", color: "#d93025" }
      ]
    %>
    <div class="card" style="margin-bottom: 1.5rem;">
      <div class="card-header"><h2>Weekly Discipline Trends</h2></div>
      <div style="padding: 1rem 1.25rem;">
        <table class="data-table" style="font-size: 0.8125rem;">
          <thead>
            <tr>
              <th>Week</th>
              <th style="text-align: center;">Trades</th>
              <% trend_dims.each do |td| %>
                <th style="text-align: center;"><%= td[:label] %></th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% @weekly_trends.each do |week| %>
              <tr>
                <td><%= Date.parse(week[:week]).strftime("%b %d") rescue week[:week] %></td>
                <td style="text-align: center;"><%= week[:total] %></td>
                <% trend_dims.each do |td| %>
                  <%
                    val = week[td[:key]]
                    cell_color = val >= 80 ? "var(--positive)" : val >= 50 ? "#f9ab00" : val > 0 ? "var(--negative)" : "var(--text-secondary)"
                  %>
                  <td style="text-align: center;">
                    <span style="display: inline-block; padding: 0.125rem 0.5rem; border-radius: 3px; font-weight: 600;
                                 background: <%= val >= 80 ? 'rgba(13,144,79,0.1)' : val >= 50 ? 'rgba(249,171,0,0.1)' : 'rgba(217,48,37,0.1)' %>;
                                 color: <%= cell_color %>;"><%= val %>%</span>
                  </td>
                <% end %>
              </tr>
            <% end %>
          </tbody>
        </table>
        <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.75rem; font-size: 0.6875rem;">
          <% trend_dims.each do |td| %>
            <span style="display: flex; align-items: center; gap: 4px;">
              <span style="width: 8px; height: 8px; border-radius: 2px; background: <%= td[:color] %>;"></span>
              <%= td[:label] %>
            </span>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="content-grid">
    <%# Grade Performance %>
    <% if @grade_performance.any? %>
      <div class="card">
        <div class="card-header"><h2>Performance by Grade</h2></div>
        <div style="padding: 1rem 1.25rem;">
          <%
            grade_colors = { "A" => "#0d904f", "B" => "#34a853", "C" => "#f9ab00", "D" => "#ea8600", "F" => "#d93025" }
            grade_order = %w[A B C D F]
          %>
          <% grade_order.each do |grade| %>
            <% data = @grade_performance[grade] %>
            <% next unless data %>
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--border);">
              <div style="width: 2rem; height: 2rem; border-radius: 50%; background: <%= grade_colors[grade] %>; color: white;
                          display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.875rem; flex-shrink: 0;">
                <%= grade %>
              </div>
              <div style="flex: 1; min-width: 0;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.25rem;">
                  <span style="font-size: 0.8125rem;"><%= data[:count] %> trades</span>
                  <span style="font-size: 0.8125rem;" class="<%= data[:avg_pnl] >= 0 ? 'positive' : 'negative' %>">Avg: <%= number_to_currency(data[:avg_pnl]) %></span>
                </div>
                <div style="display: flex; gap: 0.5rem; font-size: 0.75rem; color: var(--text-secondary);">
                  <span class="<%= data[:total_pnl] >= 0 ? 'positive' : 'negative' %>">Total: <%= number_to_currency(data[:total_pnl]) %></span>
                  <span>WR: <%= data[:win_rate] %>%</span>
                </div>
              </div>
            </div>
          <% end %>
          <% if @grade_performance["A"] && @grade_performance["F"] %>
            <%
              a_avg = @grade_performance["A"][:avg_pnl]
              f_avg = @grade_performance["F"][:avg_pnl]
              edge = a_avg - f_avg
            %>
            <div style="padding: 0.5rem; border-radius: var(--radius); background: var(--bg); font-size: 0.8125rem;">
              <span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px;">lightbulb</span>
              A-grade trades average <strong class="<%= edge >= 0 ? 'positive' : 'negative' %>"><%= number_to_currency(edge) %></strong> more per trade than F-grade trades.
              <% if edge > 0 %>
                Discipline pays.
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Emotional Discipline %>
    <% if @emotion_performance.any? %>
      <div class="card">
        <div class="card-header"><h2>Emotional Discipline</h2></div>
        <div style="padding: 1rem 1.25rem;">
          <%
            calm_emotions = @emotion_performance.select { |_, d| d[:category] == :calm }
            elevated_emotions = @emotion_performance.select { |_, d| d[:category] == :elevated }
            calm_pnl = calm_emotions.any? ? calm_emotions.values.sum { |d| d[:total_pnl] } : 0
            elevated_pnl = elevated_emotions.any? ? elevated_emotions.values.sum { |d| d[:total_pnl] } : 0
          %>
          <% if calm_emotions.any? && elevated_emotions.any? %>
            <div style="display: flex; gap: 1rem; margin-bottom: 1rem;">
              <div style="flex: 1; padding: 0.75rem; border-radius: var(--radius); background: rgba(13,144,79,0.05); border: 1px solid rgba(13,144,79,0.2);">
                <div style="font-size: 0.625rem; text-transform: uppercase; color: var(--positive);">Calm States</div>
                <div style="font-size: 1.125rem; font-weight: 700;" class="<%= calm_pnl >= 0 ? 'positive' : 'negative' %>"><%= number_to_currency(calm_pnl) %></div>
                <div style="font-size: 0.6875rem; color: var(--text-secondary);"><%= calm_emotions.values.sum { |d| d[:count] } %> trades</div>
              </div>
              <div style="flex: 1; padding: 0.75rem; border-radius: var(--radius); background: rgba(217,48,37,0.05); border: 1px solid rgba(217,48,37,0.2);">
                <div style="font-size: 0.625rem; text-transform: uppercase; color: var(--negative);">Elevated States</div>
                <div style="font-size: 1.125rem; font-weight: 700;" class="<%= elevated_pnl >= 0 ? 'positive' : 'negative' %>"><%= number_to_currency(elevated_pnl) %></div>
                <div style="font-size: 0.6875rem; color: var(--text-secondary);"><%= elevated_emotions.values.sum { |d| d[:count] } %> trades</div>
              </div>
            </div>
          <% end %>
          <%
            sorted_emotions = @emotion_performance.sort_by { |_, d| -d[:avg_pnl] }
            em_icons = { "calm" => "spa", "focused" => "center_focus_strong", "confident" => "sentiment_very_satisfied",
                         "disciplined" => "verified", "anxious" => "warning", "fearful" => "sentiment_very_dissatisfied",
                         "greedy" => "attach_money", "fomo" => "speed", "revenge" => "local_fire_department",
                         "bored" => "sentiment_dissatisfied", "frustrated" => "mood_bad" }
          %>
          <% sorted_emotions.each do |state, data| %>
            <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0; font-size: 0.8125rem;">
              <span class="material-icons-outlined" style="font-size: 1rem; color: <%= data[:category] == :calm ? 'var(--positive)' : 'var(--negative)' %>;"><%= em_icons[state] || "psychology" %></span>
              <span style="font-weight: 600; min-width: 5rem;"><%= state.capitalize %></span>
              <span style="color: var(--text-secondary);"><%= data[:count] %> trades</span>
              <span class="<%= data[:avg_pnl] >= 0 ? 'positive' : 'negative' %>" style="margin-left: auto;"><%= number_to_currency(data[:avg_pnl]) %>/trade</span>
              <span style="color: var(--text-secondary);"><%= data[:win_rate] %>% WR</span>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Discipline Insights %>
  <div class="card" style="margin-top: 1.5rem;">
    <div class="card-header"><h2>Discipline Insights</h2></div>
    <div style="padding: 1rem 1.25rem;">
      <% insights = [] %>

      <% if @with_stops.to_f / @total_trades < 0.5 %>
        <% insights << { icon: "warning", color: "var(--negative)", text: "Only #{(@with_stops.to_f / @total_trades * 100).round(0)}% of trades have a stop loss. Consider setting stops on every trade to protect your capital." } %>
      <% end %>

      <% if @graded_trades.to_f / @total_trades < 0.3 %>
        <% insights << { icon: "info", color: "var(--primary)", text: "You're only grading #{(@graded_trades.to_f / @total_trades * 100).round(0)}% of trades. Grading helps you identify patterns in your best and worst trades." } %>
      <% end %>

      <% if @with_plan > 0 && @followed_plan.to_f / @with_plan < 0.7 %>
        <% insights << { icon: "warning", color: "#f9ab00", text: "Plan adherence is at #{(@followed_plan.to_f / @with_plan * 100).round(0)}%. Deviating from plans often leads to emotional trading." } %>
      <% end %>

      <% if @with_setup.to_f / @total_trades < 0.5 %>
        <% insights << { icon: "info", color: "var(--primary)", text: "#{(@with_setup.to_f / @total_trades * 100).round(0)}% of trades have a documented setup. Knowing your edge starts with identifying your setups." } %>
      <% end %>

      <% calm_emo = @emotion_performance.select { |_, d| d[:category] == :calm } %>
      <% elevated_emo = @emotion_performance.select { |_, d| d[:category] == :elevated } %>
      <% if calm_emo.any? && elevated_emo.any? %>
        <% calm_avg = calm_emo.values.sum { |d| d[:total_pnl] }.to_f / calm_emo.values.sum { |d| d[:count] } %>
        <% elevated_avg = elevated_emo.values.sum { |d| d[:total_pnl] }.to_f / elevated_emo.values.sum { |d| d[:count] } %>
        <% if calm_avg > elevated_avg %>
          <% insights << { icon: "check_circle", color: "var(--positive)", text: "You average #{number_to_currency(calm_avg - elevated_avg)} more per trade when in a calm state. Keep prioritizing your mental game." } %>
        <% end %>
      <% end %>

      <% if @discipline_score >= 80 %>
        <% insights << { icon: "emoji_events", color: "var(--positive)", text: "Outstanding discipline! Your score of #{@discipline_score}/100 shows consistent process adherence. Keep it up." } %>
      <% end %>

      <% if insights.empty? %>
        <% insights << { icon: "check_circle", color: "var(--positive)", text: "Good discipline habits. Keep documenting your trades, setting stops, and following your plans." } %>
      <% end %>

      <% insights.each do |insight| %>
        <div style="display: flex; align-items: flex-start; gap: 0.5rem; margin-bottom: 0.75rem; padding: 0.5rem; border-radius: var(--radius); background: var(--bg);">
          <span class="material-icons-outlined" style="font-size: 1rem; color: <%= insight[:color] %>; margin-top: 2px;"><%= insight[:icon] %></span>
          <span style="font-size: 0.8125rem;"><%= insight[:text] %></span>
        </div>
      <% end %>
    </div>
  </div>
<% elsif @total_trades > 0 %>
  <div class="card empty-state">
    <p>Need at least 5 closed trades to generate discipline metrics. You have <%= @total_trades %>.</p>
  </div>
<% else %>
  <div class="card empty-state">
    <p>No closed trades found. Start trading and reviewing your trades to build discipline metrics.</p>
  </div>
<% end %>
