<div class="page-header">
  <h1>Monte Carlo Simulation</h1>
  <div class="page-actions">
    <button class="btn" onclick="window.print()">
      <span class="material-icons-outlined">print</span> Print
    </button>
  </div>
</div>

<div class="card">
  <%= form_with url: reports_monte_carlo_path, method: :get, class: "filter-form" do |f| %>
    <div class="filter-row">
      <div class="form-group">
        <%= f.label :start_date, "Start Date" %>
        <%= f.date_field :start_date, value: params[:start_date], class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :end_date, "End Date" %>
        <%= f.date_field :end_date, value: params[:end_date], class: "form-control" %>
      </div>
      <div class="form-group form-actions-inline">
        <%= f.submit "Apply", class: "btn btn-primary" %>
        <%= link_to "Clear", reports_monte_carlo_path, class: "btn" %>
      </div>
    </div>
  <% end %>
</div>

<% if @monte_carlo.present? && !@monte_carlo["error"] %>
  <% sim = @monte_carlo %>

  <div class="card" style="margin-bottom: 1.5rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 0;">
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Simulations</div>
        <div style="font-size: 1.5rem; font-weight: 700;"><%= number_with_delimiter(sim["sample_size"]) %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Trades per Sim</div>
        <div style="font-size: 1.5rem; font-weight: 700;"><%= number_with_delimiter(sim["trades_per_simulation"]) %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Probability of Profit</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= sim["probability_of_profit"].to_f > 50 ? 'positive' : 'negative' %>"><%= sim["probability_of_profit"] %>%</div>
      </div>
      <div style="padding: 1rem; text-align: center;">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Avg Final P&L</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= pnl_class(sim["average_final_pnl"]) %>"><%= number_to_currency(sim["average_final_pnl"]) %></div>
      </div>
    </div>
  </div>

  <%# Probability gauge %>
  <%
    prob = sim["probability_of_profit"].to_f
    gauge_color = prob >= 70 ? "var(--positive)" : prob >= 50 ? "var(--primary)" : prob >= 30 ? "#f9ab00" : "var(--negative)"
  %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header"><h2>Profit Probability</h2></div>
    <div style="padding: 1.5rem 1.25rem; display: flex; align-items: center; gap: 2rem; flex-wrap: wrap;">
      <div style="position: relative; width: 140px; height: 80px; flex-shrink: 0;">
        <svg viewBox="0 0 140 80" style="width: 100%; height: 100%;">
          <%# Background arc %>
          <path d="M 10 75 A 60 60 0 0 1 130 75" fill="none" stroke="var(--border)" stroke-width="10" stroke-linecap="round" />
          <%# Progress arc — percentage of 180 degrees %>
          <%
            arc_angle = prob / 100.0 * 180
            end_x = 70 - 60 * Math.cos(arc_angle * Math::PI / 180)
            end_y = 75 - 60 * Math.sin(arc_angle * Math::PI / 180)
            large_arc = arc_angle > 180 ? 1 : 0
          %>
          <path d="M 10 75 A 60 60 0 <%= large_arc %> 1 <%= end_x.round(1) %> <%= end_y.round(1) %>"
                fill="none" stroke="<%= gauge_color %>" stroke-width="10" stroke-linecap="round" />
          <text x="70" y="70" text-anchor="middle" fill="<%= gauge_color %>" font-size="22" font-weight="700"><%= prob.round(0) %>%</text>
          <text x="70" y="55" text-anchor="middle" fill="var(--text-secondary)" font-size="8">PROFIT PROB</text>
        </svg>
      </div>
      <div style="flex: 1;">
        <div style="font-size: 0.9375rem; margin-bottom: 0.5rem;">
          <% if prob >= 70 %>
            <strong class="positive">Strong Edge</strong> — Your system has a high probability of profitable outcomes.
          <% elsif prob >= 50 %>
            <strong style="color: var(--primary);">Marginal Edge</strong> — Slightly favorable odds. Focus on improving win rate or payoff ratio.
          <% elsif prob >= 30 %>
            <strong style="color: #f9ab00;">Weak Edge</strong> — The odds are nearly coin-flip. Consider refining your strategy.
          <% else %>
            <strong class="negative">No Edge</strong> — Simulations suggest this approach is unlikely to be profitable long-term.
          <% end %>
        </div>
        <div style="font-size: 0.8125rem; color: var(--text-secondary);">
          Based on <%= number_with_delimiter(sim["sample_size"]) %> simulations of <%= sim["trades_per_simulation"] %> trades each,
          using your actual trade distribution.
        </div>
      </div>
    </div>
  </div>

  <%# P&L Distribution Visualization %>
  <% pnl_percentiles = sim["pnl_percentiles"] || {} %>
  <% if pnl_percentiles.any? %>
    <%
      p5 = pnl_percentiles["p5"].to_f
      p25 = pnl_percentiles["p25"].to_f
      p50 = pnl_percentiles["p50"].to_f
      p75 = pnl_percentiles["p75"].to_f
      p95 = pnl_percentiles["p95"].to_f
      range_min = [p5, sim["worst_case"].to_f].min
      range_max = [p95, sim["best_case"].to_f].max
      total_range = range_max - range_min
      total_range = 1 if total_range == 0

      pct = ->(val) { ((val - range_min) / total_range * 100).round(1) }
    %>
    <div class="card" style="margin-bottom: 1.5rem;">
      <div class="card-header"><h2>Outcome Distribution</h2></div>
      <div style="padding: 1.5rem 1.25rem;">
        <%# Box plot visualization %>
        <div style="position: relative; height: 80px; margin: 0 2rem 1.5rem;">
          <%# Whisker line (P5 to P95) %>
          <div style="position: absolute; top: 38px; left: <%= pct.call(p5) %>%; right: <%= 100 - pct.call(p95) %>%;
                      height: 2px; background: var(--text-secondary);"></div>
          <%# Box (P25 to P75) %>
          <div style="position: absolute; top: 20px; left: <%= pct.call(p25) %>%; width: <%= pct.call(p75) - pct.call(p25) %>%;
                      height: 40px; background: var(--primary); opacity: 0.15; border: 2px solid var(--primary); border-radius: 4px;"></div>
          <%# Median line %>
          <div style="position: absolute; top: 16px; left: <%= pct.call(p50) %>%; width: 3px; height: 48px;
                      background: var(--primary); border-radius: 2px; transform: translateX(-50%);"></div>
          <%# Zero line %>
          <% if range_min < 0 && range_max > 0 %>
            <div style="position: absolute; top: 10px; left: <%= pct.call(0) %>%; width: 1px; height: 58px;
                        background: var(--border); border-style: dashed;"></div>
            <span style="position: absolute; top: 0; left: <%= pct.call(0) %>%; transform: translateX(-50%);
                         font-size: 0.5625rem; color: var(--text-secondary);">$0</span>
          <% end %>
          <%# Labels %>
          <span style="position: absolute; top: 68px; left: <%= pct.call(p5) %>%; transform: translateX(-50%);
                       font-size: 0.625rem; color: var(--text-secondary); white-space: nowrap;">P5<br><%= number_to_currency(p5) %></span>
          <span style="position: absolute; top: 68px; left: <%= pct.call(p25) %>%; transform: translateX(-50%);
                       font-size: 0.625rem; color: var(--text-secondary); white-space: nowrap;">P25</span>
          <span style="position: absolute; top: -2px; left: <%= pct.call(p50) %>%; transform: translateX(-50%);
                       font-size: 0.6875rem; font-weight: 700; color: var(--primary); white-space: nowrap;">Median: <%= number_to_currency(p50) %></span>
          <span style="position: absolute; top: 68px; left: <%= pct.call(p75) %>%; transform: translateX(-50%);
                       font-size: 0.625rem; color: var(--text-secondary); white-space: nowrap;">P75</span>
          <span style="position: absolute; top: 68px; left: <%= pct.call(p95) %>%; transform: translateX(-50%);
                       font-size: 0.625rem; color: var(--text-secondary); white-space: nowrap;">P95<br><%= number_to_currency(p95) %></span>
        </div>
        <div style="margin-top: 2.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
          <div style="flex: 1; min-width: 200px; padding: 0.75rem; border-radius: var(--radius); background: var(--bg);">
            <div style="font-size: 0.6875rem; color: var(--text-secondary);">Worst 5% of outcomes</div>
            <div style="font-size: 1rem; font-weight: 700;" class="negative">Below <%= number_to_currency(p5) %></div>
          </div>
          <div style="flex: 1; min-width: 200px; padding: 0.75rem; border-radius: var(--radius); background: var(--bg);">
            <div style="font-size: 0.6875rem; color: var(--text-secondary);">Most likely range (50%)</div>
            <div style="font-size: 1rem; font-weight: 700;"><%= number_to_currency(p25) %> to <%= number_to_currency(p75) %></div>
          </div>
          <div style="flex: 1; min-width: 200px; padding: 0.75rem; border-radius: var(--radius); background: var(--bg);">
            <div style="font-size: 0.6875rem; color: var(--text-secondary);">Best 5% of outcomes</div>
            <div style="font-size: 1rem; font-weight: 700;" class="positive">Above <%= number_to_currency(p95) %></div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%# Drawdown Risk Assessment %>
  <% dd_percentiles = sim["drawdown_percentiles"] || {} %>
  <div class="content-grid">
    <div class="card">
      <div class="card-header"><h2>Drawdown Risk</h2></div>
      <div style="padding: 1rem 1.25rem;">
        <% dd_p50 = dd_percentiles["p50"].to_f.abs %>
        <% dd_p95 = dd_percentiles["p95"].to_f.abs %>
        <div style="margin-bottom: 1rem;">
          <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.25rem;">
            <span>Typical Drawdown (P50)</span>
            <span class="negative"><%= number_to_currency(dd_p50) %></span>
          </div>
          <div style="height: 12px; background: var(--bg); border-radius: 6px; overflow: hidden;">
            <div style="height: 100%; width: <%= dd_p95 > 0 ? (dd_p50 / dd_p95 * 100).clamp(5, 100).round(1) : 50 %>%;
                        background: #f9ab00; border-radius: 6px;"></div>
          </div>
        </div>
        <div>
          <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.25rem;">
            <span>Severe Drawdown (P95)</span>
            <span class="negative"><%= number_to_currency(dd_p95) %></span>
          </div>
          <div style="height: 12px; background: var(--bg); border-radius: 6px; overflow: hidden;">
            <div style="height: 100%; width: 100%; background: var(--negative); border-radius: 6px;"></div>
          </div>
        </div>
        <% if @avg_pnl && dd_p50 > 0 %>
          <div style="margin-top: 0.75rem; font-size: 0.8125rem; color: var(--text-secondary);">
            Recovery: ~<%= (@avg_pnl > 0 ? (dd_p50 / @avg_pnl).ceil : "∞").to_s %> trades to recover from typical drawdown at your average P&L
          </div>
        <% end %>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><h2>Best / Worst Case</h2></div>
      <div style="padding: 1rem 1.25rem;">
        <div style="display: flex; gap: 1rem; margin-bottom: 1rem;">
          <div style="flex: 1; padding: 0.75rem; border-radius: var(--radius); background: var(--bg); text-align: center;">
            <div style="font-size: 0.6875rem; color: var(--text-secondary);">Best Case</div>
            <div style="font-size: 1.25rem; font-weight: 700;" class="<%= pnl_class(sim["best_case"]) %>">
              <%= number_to_currency(sim["best_case"]) %>
            </div>
          </div>
          <div style="flex: 1; padding: 0.75rem; border-radius: var(--radius); background: var(--bg); text-align: center;">
            <div style="font-size: 0.6875rem; color: var(--text-secondary);">Worst Case</div>
            <div style="font-size: 1.25rem; font-weight: 700;" class="<%= pnl_class(sim["worst_case"]) %>">
              <%= number_to_currency(sim["worst_case"]) %>
            </div>
          </div>
        </div>
        <% if sim["best_case"].to_f > 0 && sim["worst_case"].to_f < 0 %>
          <%
            asym = (sim["best_case"].to_f / sim["worst_case"].to_f.abs).round(2)
          %>
          <div style="font-size: 0.8125rem; color: var(--text-secondary);">
            Upside/Downside Ratio: <strong><%= asym %>:1</strong>
            <% if asym > 1.5 %>
              — <span class="positive">favorable asymmetry</span>
            <% elsif asym < 0.7 %>
              — <span class="negative">unfavorable risk/reward</span>
            <% else %>
              — roughly symmetric
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Input Statistics (from actual trades) %>
  <% if @trade_pnls&.any? %>
    <div class="card" style="margin-top: 1.5rem;">
      <div class="card-header"><h2>Simulation Inputs</h2></div>
      <div style="padding: 1rem 1.25rem;">
        <p style="font-size: 0.8125rem; color: var(--text-secondary); margin-bottom: 1rem;">
          These are the actual trade statistics used to drive the Monte Carlo simulation.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 1rem;">
          <div style="flex: 1; min-width: 120px; padding: 0.5rem 0.75rem; border-radius: var(--radius); background: var(--bg); text-align: center;">
            <div style="font-size: 0.6875rem; color: var(--text-secondary);">Trades</div>
            <div style="font-size: 1.125rem; font-weight: 700;"><%= @trade_count %></div>
          </div>
          <div style="flex: 1; min-width: 120px; padding: 0.5rem 0.75rem; border-radius: var(--radius); background: var(--bg); text-align: center;">
            <div style="font-size: 0.6875rem; color: var(--text-secondary);">Win Rate</div>
            <div style="font-size: 1.125rem; font-weight: 700;"><%= @win_rate %>%</div>
          </div>
          <div style="flex: 1; min-width: 120px; padding: 0.5rem 0.75rem; border-radius: var(--radius); background: var(--bg); text-align: center;">
            <div style="font-size: 0.6875rem; color: var(--text-secondary);">Avg P&L</div>
            <div style="font-size: 1.125rem; font-weight: 700;" class="<%= pnl_class(@avg_pnl) %>"><%= number_to_currency(@avg_pnl) %></div>
          </div>
          <div style="flex: 1; min-width: 120px; padding: 0.5rem 0.75rem; border-radius: var(--radius); background: var(--bg); text-align: center;">
            <div style="font-size: 0.6875rem; color: var(--text-secondary);">P&L Std Dev</div>
            <div style="font-size: 1.125rem; font-weight: 700;"><%= number_to_currency(@pnl_stddev) %></div>
          </div>
          <div style="flex: 1; min-width: 120px; padding: 0.5rem 0.75rem; border-radius: var(--radius); background: var(--bg); text-align: center;">
            <div style="font-size: 0.6875rem; color: var(--text-secondary);">Max Win Streak</div>
            <div style="font-size: 1.125rem; font-weight: 700; color: var(--positive);"><%= @max_consecutive_win %></div>
          </div>
          <div style="flex: 1; min-width: 120px; padding: 0.5rem 0.75rem; border-radius: var(--radius); background: var(--bg); text-align: center;">
            <div style="font-size: 0.6875rem; color: var(--text-secondary);">Max Loss Streak</div>
            <div style="font-size: 1.125rem; font-weight: 700; color: var(--negative);"><%= @max_consecutive_loss %></div>
          </div>
        </div>
      </div>
    </div>

    <%# Risk of Ruin estimation %>
    <%
      # Simplified risk of ruin: P(ruin) ≈ ((1 - edge) / (1 + edge))^units
      # Where edge = avg_pnl / pnl_stddev (simplified)
      edge = @pnl_stddev > 0 ? (@avg_pnl / @pnl_stddev).round(3) : 0
      kelly = @pnl_stddev > 0 ? (@avg_pnl / (@pnl_stddev ** 2) * 100).round(1) : 0
    %>
    <div class="card" style="margin-top: 1.5rem;">
      <div class="card-header"><h2>Risk Metrics</h2></div>
      <div style="padding: 1rem 1.25rem;">
        <div style="display: flex; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 1rem;">
          <div style="flex: 1; min-width: 200px;">
            <div style="font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.25rem;">Edge Ratio (Avg / StdDev)</div>
            <div style="font-size: 1.5rem; font-weight: 700;" class="<%= edge > 0 ? 'positive' : 'negative' %>">
              <%= edge %>
            </div>
            <div style="font-size: 0.6875rem; color: var(--text-secondary);">
              <% if edge > 0.3 %>
                Strong edge — your average gain significantly exceeds volatility
              <% elsif edge > 0 %>
                Slight edge — returns are positive but volatile
              <% else %>
                No edge — average returns are negative relative to volatility
              <% end %>
            </div>
          </div>
          <div style="flex: 1; min-width: 200px;">
            <div style="font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.25rem;">Kelly Criterion</div>
            <div style="font-size: 1.5rem; font-weight: 700;">
              <%= kelly.clamp(-100, 100) %>%
            </div>
            <div style="font-size: 0.6875rem; color: var(--text-secondary);">
              Optimal capital allocation per trade. Half-Kelly (<%= (kelly / 2.0).round(1) %>%) is more conservative.
            </div>
          </div>
          <div style="flex: 1; min-width: 200px;">
            <div style="font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.25rem;">Coefficient of Variation</div>
            <div style="font-size: 1.5rem; font-weight: 700;">
              <%= @avg_pnl != 0 ? (@pnl_stddev / @avg_pnl.abs * 100).round(0) : "—" %>%
            </div>
            <div style="font-size: 0.6875rem; color: var(--text-secondary);">
              Lower is better — measures consistency of returns
            </div>
          </div>
        </div>

        <%# Visual risk thermometer %>
        <%
          risk_score = 50 # baseline
          risk_score -= 20 if prob >= 60
          risk_score -= 10 if edge > 0.2
          risk_score += 20 if dd_p95 > 0 && @avg_pnl > 0 && dd_p95 / @avg_pnl > 20
          risk_score += 15 if @max_consecutive_loss >= 5
          risk_score += 10 if prob < 45
          risk_score = risk_score.clamp(0, 100)
          risk_label = risk_score <= 25 ? "Low" : risk_score <= 50 ? "Moderate" : risk_score <= 75 ? "High" : "Very High"
          risk_color = risk_score <= 25 ? "var(--positive)" : risk_score <= 50 ? "var(--primary)" : risk_score <= 75 ? "#f9ab00" : "var(--negative)"
        %>
        <div style="margin-top: 1rem; padding: 0.75rem; border-radius: var(--radius); background: var(--bg);">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
            <span style="font-size: 0.875rem; font-weight: 600;">Overall Risk Level</span>
            <span style="font-size: 0.875rem; font-weight: 700; color: <%= risk_color %>;"><%= risk_label %></span>
          </div>
          <div style="height: 8px; background: var(--surface); border-radius: 4px; overflow: hidden;">
            <div style="height: 100%; width: <%= risk_score %>%; background: <%= risk_color %>; border-radius: 4px; transition: width 0.3s;"></div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%# Percentile Tables %>
  <div class="content-grid" style="margin-top: 1.5rem;">
    <div class="card">
      <div class="card-header"><h2>P&L Percentiles</h2></div>
      <table class="table">
        <thead>
          <tr>
            <th>Percentile</th>
            <th style="text-align: right;">Final P&L</th>
            <th>Range</th>
          </tr>
        </thead>
        <tbody>
          <% pnl_pcts = sim["pnl_percentiles"] || {} %>
          <%
            pct_labels = { "p5" => "5th", "p25" => "25th", "p50" => "50th (Median)", "p75" => "75th", "p95" => "95th" }
            pct_max = pnl_pcts.values.map { |v| v.to_f.abs }.max.to_f
            pct_max = 1 if pct_max == 0
          %>
          <% %w[p5 p25 p50 p75 p95].each do |key| %>
            <% val = pnl_pcts[key].to_f %>
            <tr>
              <td><strong><%= pct_labels[key] %></strong></td>
              <td style="text-align: right;" class="<%= pnl_class(val) %>">
                <%= number_to_currency(val) %>
              </td>
              <td style="min-width: 100px;">
                <div style="position: relative; height: 12px;">
                  <div style="position: absolute; left: 50%; top: 0; bottom: 0; width: 1px; background: var(--border);"></div>
                  <% bar_w = (val.abs / pct_max * 45).round(1) %>
                  <% if val >= 0 %>
                    <div style="position: absolute; left: 50%; top: 1px; bottom: 1px; width: <%= bar_w %>%;
                                background: var(--positive); border-radius: 0 3px 3px 0;"></div>
                  <% else %>
                    <div style="position: absolute; right: 50%; top: 1px; bottom: 1px; width: <%= bar_w %>%;
                                background: var(--negative); border-radius: 3px 0 0 3px;"></div>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card">
      <div class="card-header"><h2>Drawdown Percentiles</h2></div>
      <table class="table">
        <thead>
          <tr>
            <th>Percentile</th>
            <th style="text-align: right;">Max Drawdown</th>
          </tr>
        </thead>
        <tbody>
          <% dd_pcts = sim["drawdown_percentiles"] || {} %>
          <% %w[p50 p95].each do |key| %>
            <tr>
              <td><strong><%= key == "p50" ? "50th (Typical)" : "95th (Severe)" %></strong></td>
              <td style="text-align: right;" class="negative"><%= number_to_currency(dd_pcts[key]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="card empty-state">
    <p>No simulation data available. Add at least 10 closed trades to generate Monte Carlo analysis.</p>
  </div>
<% end %>
