<div class="page-header">
  <h1>Risk Analysis</h1>
</div>

<div class="card">
  <%= form_with url: reports_risk_analysis_path, method: :get, class: "filter-form" do |f| %>
    <div class="filter-row">
      <div class="form-group">
        <%= f.label :start_date, "Start Date" %>
        <%= f.date_field :start_date, value: params[:start_date], class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :end_date, "End Date" %>
        <%= f.date_field :end_date, value: params[:end_date], class: "form-control" %>
      </div>
      <div class="form-group form-actions-inline">
        <%= f.submit "Apply", class: "btn btn-primary" %>
        <%= link_to "Clear", reports_risk_analysis_path, class: "btn" %>
      </div>
    </div>
  <% end %>
</div>

<% if @risk.present? && !@risk["error"] %>
  <%
    sharpe = @risk["sharpe_like"].to_f
    sortino = @risk["sortino_ratio"].to_f
    calmar = @risk["calmar_ratio"].to_f
    payoff = @risk["payoff_ratio"].to_f
    recovery = @risk["recovery_factor"].to_f
    kelly = @risk["kelly_criterion"].to_f
    expectancy = @risk["expectancy"].to_f
    max_dd = @risk["max_drawdown"].to_f
    avg_pnl = @risk["avg_pnl"].to_f
    std_dev = @risk["std_dev"].to_f

    # Normalize metrics to 0-100 for radar chart
    sharpe_score = [[sharpe / 3.0 * 100, 0].max, 100].min.round(0)
    sortino_score = [[sortino / 4.0 * 100, 0].max, 100].min.round(0)
    calmar_score = [[calmar / 5.0 * 100, 0].max, 100].min.round(0)
    payoff_score = [[payoff / 3.0 * 100, 0].max, 100].min.round(0)
    recovery_score = [[recovery / 5.0 * 100, 0].max, 100].min.round(0)
    kelly_score = kelly > 0 ? [[kelly / 30.0 * 100, 0].max, 100].min.round(0) : 0

    # Overall risk health score (weighted)
    risk_health = (
      sharpe_score * 0.25 +
      sortino_score * 0.20 +
      payoff_score * 0.20 +
      recovery_score * 0.15 +
      calmar_score * 0.10 +
      kelly_score * 0.10
    ).round(0)

    risk_label = risk_health >= 75 ? "Excellent" : risk_health >= 55 ? "Good" : risk_health >= 35 ? "Fair" : "Needs Work"
    risk_color = risk_health >= 75 ? "var(--positive)" : risk_health >= 55 ? "var(--primary)" : risk_health >= 35 ? "#f9ab00" : "var(--negative)"
  %>

  <%# Overall Risk Health gauge %>
  <div class="card" style="display: flex; align-items: center; gap: 2rem; padding: 1.5rem; flex-wrap: wrap;">
    <div style="flex-shrink: 0;">
      <svg viewBox="0 0 140 85" style="width: 140px;">
        <%
          gauge_pct = risk_health / 100.0
          arc_angle = gauge_pct * 180
          end_rad = (180 - arc_angle) * Math::PI / 180
          end_x = (70 + 60 * Math.cos(end_rad)).round(1)
          end_y = (75 - 60 * Math.sin(end_rad)).round(1)
        %>
        <path d="M 10 75 A 60 60 0 0 1 130 75" fill="none" stroke="var(--border)" stroke-width="10" stroke-linecap="round" />
        <% if arc_angle > 0 %>
          <path d="M 10 75 A 60 60 0 <%= arc_angle > 180 ? 1 : 0 %> 1 <%= end_x %> <%= end_y %>"
                fill="none" stroke="<%= risk_color %>" stroke-width="10" stroke-linecap="round" />
        <% end %>
        <text x="70" y="68" text-anchor="middle" fill="<%= risk_color %>" font-size="24" font-weight="700"><%= risk_health %></text>
        <text x="70" y="82" text-anchor="middle" fill="var(--text-secondary)" font-size="9">/ 100</text>
      </svg>
    </div>
    <div>
      <h2 style="margin-bottom: 0.25rem;">Risk Health: <span style="color: <%= risk_color %>;"><%= risk_label %></span></h2>
      <p class="text-muted" style="font-size: 0.875rem; max-width: 400px;">
        Composite score based on Sharpe, Sortino, Payoff Ratio, Recovery Factor, Calmar, and Kelly Criterion.
        <% if risk_health >= 75 %>
          Your risk-adjusted performance is strong across all dimensions.
        <% elsif risk_health >= 55 %>
          Solid risk management with some room for improvement.
        <% elsif risk_health >= 35 %>
          Risk metrics show mixed results — focus on consistency.
        <% else %>
          Multiple risk dimensions need attention. Review your position sizing and stop strategy.
        <% end %>
      </p>
    </div>
  </div>

  <%# Risk Radar Chart + Key Metrics side by side %>
  <div class="content-grid" style="margin-top: 1.5rem;">
    <div class="card">
      <div class="card-header"><h2>Risk Profile Radar</h2></div>
      <div style="padding: 1rem; display: flex; justify-content: center;">
        <%
          radar_dims = [
            { label: "Sharpe", score: sharpe_score },
            { label: "Sortino", score: sortino_score },
            { label: "Calmar", score: calmar_score },
            { label: "Payoff", score: payoff_score },
            { label: "Recovery", score: recovery_score },
            { label: "Kelly", score: kelly_score }
          ]
          radar_cx = 140; radar_cy = 130; radar_r = 100
          radar_n = radar_dims.length
          radar_angle_step = 360.0 / radar_n
        %>
        <svg viewBox="0 0 280 270" style="width: 100%; max-width: 280px;">
          <%# Grid rings %>
          <% [20, 40, 60, 80, 100].each do |pct| %>
            <polygon points="<%= radar_dims.each_with_index.map { |_, j|
              angle = (radar_angle_step * j - 90) * Math::PI / 180
              x = radar_cx + radar_r * pct / 100.0 * Math.cos(angle)
              y = radar_cy + radar_r * pct / 100.0 * Math.sin(angle)
              "#{x.round(1)},#{y.round(1)}"
            }.join(' ') %>" fill="none" stroke="var(--border)" stroke-width="0.5" />
          <% end %>
          <%# Axis lines %>
          <% radar_dims.each_with_index do |dim, j| %>
            <%
              angle = (radar_angle_step * j - 90) * Math::PI / 180
              lx = (radar_cx + radar_r * Math.cos(angle)).round(1)
              ly = (radar_cy + radar_r * Math.sin(angle)).round(1)
              tx = (radar_cx + (radar_r + 16) * Math.cos(angle)).round(1)
              ty = (radar_cy + (radar_r + 16) * Math.sin(angle)).round(1)
            %>
            <line x1="<%= radar_cx %>" y1="<%= radar_cy %>" x2="<%= lx %>" y2="<%= ly %>" stroke="var(--border)" stroke-width="0.5" />
            <text x="<%= tx %>" y="<%= ty.to_f + 4 %>" text-anchor="middle" fill="var(--text-secondary)" font-size="9" font-weight="600"><%= dim[:label] %></text>
          <% end %>
          <%# Data polygon %>
          <polygon points="<%= radar_dims.each_with_index.map { |dim, j|
            angle = (radar_angle_step * j - 90) * Math::PI / 180
            x = radar_cx + radar_r * dim[:score] / 100.0 * Math.cos(angle)
            y = radar_cy + radar_r * dim[:score] / 100.0 * Math.sin(angle)
            "#{x.round(1)},#{y.round(1)}"
          }.join(' ') %>" fill="<%= risk_color %>" fill-opacity="0.15" stroke="<%= risk_color %>" stroke-width="2" />
          <%# Data points %>
          <% radar_dims.each_with_index do |dim, j| %>
            <%
              angle = (radar_angle_step * j - 90) * Math::PI / 180
              px = (radar_cx + radar_r * dim[:score] / 100.0 * Math.cos(angle)).round(1)
              py = (radar_cy + radar_r * dim[:score] / 100.0 * Math.sin(angle)).round(1)
            %>
            <circle cx="<%= px %>" cy="<%= py %>" r="3" fill="<%= risk_color %>" />
          <% end %>
        </svg>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><h2>Score Breakdown</h2></div>
      <div style="padding: 1rem 1.25rem;">
        <% radar_dims.each do |dim| %>
          <%
            s = dim[:score]
            bar_color = s >= 70 ? "var(--positive)" : s >= 45 ? "var(--primary)" : s >= 25 ? "#f9ab00" : "var(--negative)"
          %>
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
            <span style="width: 70px; font-size: 0.8125rem; font-weight: 600;"><%= dim[:label] %></span>
            <div style="flex: 1; height: 14px; background: var(--bg); border-radius: 7px; overflow: hidden;">
              <div style="height: 100%; width: <%= s %>%; background: <%= bar_color %>; border-radius: 7px; transition: width 0.3s;"></div>
            </div>
            <span style="width: 40px; text-align: right; font-size: 0.875rem; font-weight: 700; color: <%= bar_color %>;"><%= s %></span>
          </div>
        <% end %>
        <div style="margin-top: 1rem; padding-top: 0.75rem; border-top: 1px solid var(--border); font-size: 0.75rem; color: var(--text-secondary);">
          Scores normalized: Sharpe (0-3), Sortino (0-4), Calmar (0-5), Payoff (0-3), Recovery (0-5), Kelly (0-30%)
        </div>
      </div>
    </div>
  </div>

  <div class="card" style="margin-top: 1.5rem; margin-bottom: 1.5rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 0;">
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Avg P&L</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= pnl_class(@risk["avg_pnl"]) %>"><%= number_to_currency(@risk["avg_pnl"]) %></div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Per trade expectation</div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Std Deviation</div>
        <div style="font-size: 1.5rem; font-weight: 700;"><%= number_to_currency(@risk["std_dev"]) %></div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">
          <% cv = avg_pnl != 0 ? (std_dev / avg_pnl.abs * 100).round(0) : 0 %>
          CV: <%= cv %>%
        </div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Sharpe Ratio</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= sharpe >= 1 ? 'positive' : sharpe >= 0.5 ? '' : 'negative' %>"><%= @risk["sharpe_like"] %></div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);"><%= sharpe >= 2 ? "Excellent" : sharpe >= 1 ? "Good" : sharpe >= 0.5 ? "Fair" : "Poor" %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Sortino Ratio</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= sortino >= 1.5 ? 'positive' : sortino >= 0.5 ? '' : 'negative' %>"><%= @risk["sortino_ratio"] %></div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);"><%= sortino >= 2 ? "Excellent" : sortino >= 1 ? "Good" : sortino >= 0.5 ? "Fair" : "Poor" %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Calmar Ratio</div>
        <div style="font-size: 1.5rem; font-weight: 700;"><%= @risk["calmar_ratio"] %></div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Return per unit drawdown</div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Expectancy</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= pnl_class(@risk["expectancy"]) %>"><%= number_to_currency(@risk["expectancy"]) %></div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);"><%= expectancy > 0 ? "Edge is positive" : "No positive edge" %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Recovery Factor</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= recovery >= 3 ? 'positive' : recovery >= 1 ? '' : 'negative' %>"><%= @risk["recovery_factor"] %></div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);"><%= recovery >= 3 ? "Strong" : recovery >= 1 ? "Adequate" : "Weak" %> recovery</div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Max Drawdown</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="negative"><%= number_to_currency(@risk["max_drawdown"]) %></div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Peak-to-trough decline</div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Payoff Ratio</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="<%= payoff >= 1.5 ? 'positive' : payoff >= 1 ? '' : 'negative' %>"><%= @risk["payoff_ratio"] %></div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Avg win / avg loss</div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Kelly Criterion</div>
        <div style="font-size: 1.5rem; font-weight: 700;"><%= @risk["kelly_criterion"] %>%</div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Half-Kelly: <%= (kelly * 0.5).round(1) %>%</div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Downside Deviation</div>
        <div style="font-size: 1.5rem; font-weight: 700;"><%= number_to_currency(@risk["downside_deviation"]) %></div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Volatility of losses only</div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Avg MFE</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="positive"><%= @risk["avg_mfe"] %></div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Max favorable excursion</div>
      </div>
      <div style="padding: 1rem; text-align: center;">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Avg MAE</div>
        <div style="font-size: 1.5rem; font-weight: 700;" class="negative"><%= @risk["avg_mae"] %></div>
        <div style="font-size: 0.75rem; color: var(--text-secondary);">Max adverse excursion</div>
      </div>
    </div>
  </div>

  <%# MFE vs MAE visual comparison %>
  <%
    mfe_val = @risk["avg_mfe"].to_f.abs
    mae_val = @risk["avg_mae"].to_f.abs
    excursion_max = [mfe_val, mae_val].max
    excursion_max = 1 if excursion_max == 0
  %>
  <% if mfe_val > 0 || mae_val > 0 %>
    <div class="card" style="margin-top: 1.5rem;">
      <div class="card-header"><h2>Excursion Balance</h2></div>
      <div style="padding: 1rem 1.25rem;">
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
          <span class="material-icons-outlined" style="color: var(--positive); font-size: 1rem;">trending_up</span>
          <span style="width: 50px; font-size: 0.8125rem; font-weight: 600;">MFE</span>
          <div style="flex: 1; height: 20px; background: var(--bg); border-radius: 4px; overflow: hidden;">
            <div style="height: 100%; width: <%= (mfe_val / excursion_max * 100).round(1) %>%; background: var(--positive); opacity: 0.6; border-radius: 4px;"></div>
          </div>
          <span style="width: 60px; text-align: right; font-size: 0.875rem; font-weight: 600;"><%= @risk["avg_mfe"] %></span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
          <span class="material-icons-outlined" style="color: var(--negative); font-size: 1rem;">trending_down</span>
          <span style="width: 50px; font-size: 0.8125rem; font-weight: 600;">MAE</span>
          <div style="flex: 1; height: 20px; background: var(--bg); border-radius: 4px; overflow: hidden;">
            <div style="height: 100%; width: <%= (mae_val / excursion_max * 100).round(1) %>%; background: var(--negative); opacity: 0.6; border-radius: 4px;"></div>
          </div>
          <span style="width: 60px; text-align: right; font-size: 0.875rem; font-weight: 600;"><%= @risk["avg_mae"] %></span>
        </div>
        <% if mfe_val > 0 && mae_val > 0 %>
          <% mfe_mae_ratio = (mfe_val / mae_val).round(2) %>
          <div style="font-size: 0.8125rem; padding-top: 0.75rem; border-top: 1px solid var(--border);">
            <strong>MFE:MAE Ratio: <%= mfe_mae_ratio %></strong>
            <span class="text-muted"> —
              <% if mfe_mae_ratio >= 2 %>
                Trades run well in your favor before adverse moves. Strong edge capture.
              <% elsif mfe_mae_ratio >= 1.2 %>
                Favorable excursion exceeds adverse. Entries are reasonably timed.
              <% elsif mfe_mae_ratio >= 0.8 %>
                Nearly balanced — consider tighter entries or wider profit targets.
              <% else %>
                Adverse excursion dominates. Review entry timing and stop placement.
              <% end %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Risk insights %>
  <div class="card" style="margin-top: 1.5rem;">
    <div class="card-header"><h2>Risk Insights</h2></div>
    <div style="padding: 1rem 1.25rem;">
      <% insights = [] %>
      <% if sharpe >= 1.5 %>
        <% insights << { icon: "verified", text: "Sharpe ratio of #{sharpe.round(2)} indicates strong risk-adjusted returns.", type: "success" } %>
      <% elsif sharpe < 0.5 && sharpe > 0 %>
        <% insights << { icon: "warning", text: "Sharpe ratio below 0.5 — returns don't adequately compensate for volatility.", type: "warning" } %>
      <% end %>
      <% if payoff >= 2 %>
        <% insights << { icon: "emoji_events", text: "Payoff ratio of #{payoff.round(2)}:1 — your winners significantly outpace losers.", type: "success" } %>
      <% elsif payoff < 1 %>
        <% insights << { icon: "warning", text: "Payoff ratio below 1:1 — average losses exceed average wins. You need a high win rate to compensate.", type: "danger" } %>
      <% end %>
      <% if kelly > 25 %>
        <% insights << { icon: "speed", text: "Kelly suggests #{kelly.round(1)}% allocation, but use half-Kelly (#{(kelly * 0.5).round(1)}%) to reduce variance.", type: "info" } %>
      <% elsif kelly <= 0 %>
        <% insights << { icon: "block", text: "Kelly criterion is zero or negative — current edge doesn't support aggressive sizing.", type: "danger" } %>
      <% end %>
      <% if recovery >= 3 %>
        <% insights << { icon: "trending_up", text: "Recovery factor of #{recovery.round(1)} — you've recovered well beyond your worst drawdown.", type: "success" } %>
      <% elsif recovery < 1 %>
        <% insights << { icon: "warning", text: "Recovery factor below 1 — you haven't fully recovered from your max drawdown.", type: "warning" } %>
      <% end %>
      <% if sortino > sharpe * 1.5 %>
        <% insights << { icon: "shield", text: "Sortino significantly exceeds Sharpe — your upside volatility is healthy, not a concern.", type: "info" } %>
      <% end %>
      <% if insights.empty? %>
        <% insights << { icon: "info", text: "Trade more to generate deeper risk insights.", type: "info" } %>
      <% end %>
      <% insights.each do |insight| %>
        <div class="insight-item insight-<%= insight[:type] %>" style="margin-bottom: 0.5rem;">
          <span class="material-icons-outlined"><%= insight[:icon] %></span>
          <span><%= insight[:text] %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="content-grid" style="margin-top: 1.5rem;">
    <div class="card">
      <div class="card-header">
        <h2>Risk Metrics Explained</h2>
      </div>
      <table class="table">
        <tbody>
          <tr>
            <td><strong>Sharpe Ratio</strong></td>
            <td>Risk-adjusted return (avg P&L / std deviation). Higher is better. > 1 is good.</td>
          </tr>
          <tr>
            <td><strong>Sortino Ratio</strong></td>
            <td>Like Sharpe but only penalizes downside volatility. Higher is better.</td>
          </tr>
          <tr>
            <td><strong>Calmar Ratio</strong></td>
            <td>Total return / max drawdown. Measures return per unit of drawdown risk.</td>
          </tr>
          <tr>
            <td><strong>Expectancy</strong></td>
            <td>Expected value per trade. Positive means your edge is working.</td>
          </tr>
          <tr>
            <td><strong>Recovery Factor</strong></td>
            <td>Total P&L / max drawdown. > 3 is strong.</td>
          </tr>
          <tr>
            <td><strong>Kelly Criterion</strong></td>
            <td>Optimal position size % based on win rate and payoff ratio.</td>
          </tr>
          <tr>
            <td><strong>MFE (Max Favorable Excursion)</strong></td>
            <td>Avg maximum profit during a trade before close.</td>
          </tr>
          <tr>
            <td><strong>MAE (Max Adverse Excursion)</strong></td>
            <td>Avg maximum drawdown during a trade before close.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
<% else %>
  <div class="card empty-state">
    <p>No data available.</p>
  </div>
<% end %>
