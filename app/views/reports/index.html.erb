<% report_sections.each do |section| %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.125rem; vertical-align: -3px; color: <%= section[:color] %>;"><%= section[:icon] %></span>
        <%= section[:title] %>
      </h2>
      <span style="font-size: 0.75rem; color: var(--text-secondary);"><%= section[:reports].count %> reports</span>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0;">
      <% section[:reports].each_with_index do |report, i| %>
        <%= link_to report[:path], style: "display: block; padding: 1rem 1.25rem; border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); text-decoration: none; color: inherit; transition: background 0.15s;", class: "report-hub-link" do %>
          <div style="display: flex; align-items: flex-start; gap: 0.75rem;">
            <span class="material-icons-outlined" style="font-size: 1.25rem; color: <%= section[:color] %>; margin-top: 2px;"><%= report[:icon] %></span>
            <div>
              <div style="font-size: 0.9375rem; font-weight: 600; margin-bottom: 0.125rem;"><%= report[:name] %></div>
              <div style="font-size: 0.75rem; color: var(--text-secondary); line-height: 1.4;"><%= report[:desc] %></div>
            </div>
            <span class="material-icons-outlined" style="font-size: 1rem; color: var(--text-secondary); margin-left: auto; opacity: 0.5; margin-top: 4px;">chevron_right</span>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<style>
  .report-hub-link:hover {
    background: var(--bg) !important;
  }
</style>
