<div class="page-header">
  <h1>Overview Report</h1>
</div>

<div class="card">
  <%= form_with url: reports_overview_path, method: :get, class: "filter-form" do |f| %>
    <div class="filter-row">
      <div class="form-group">
        <%= f.label :start_date, "Start Date" %>
        <%= f.date_field :start_date, value: params[:start_date], class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :end_date, "End Date" %>
        <%= f.date_field :end_date, value: params[:end_date], class: "form-control" %>
      </div>
      <div class="form-group form-actions-inline">
        <%= f.submit "Apply", class: "btn btn-primary" %>
        <%= link_to "Clear", reports_overview_path, class: "btn" %>
      </div>
    </div>
  <% end %>
</div>

<% if @stats.present? && !@stats["error"] %>
  <div class="stats-grid">
    <div class="card stat-card">
      <h3>Total P&L</h3>
      <p class="stat-value <%= @stats["total_pnl"].to_f >= 0 ? 'positive' : 'negative' %>">
        <%= number_to_currency(@stats["total_pnl"]) %>
      </p>
    </div>

    <div class="card stat-card">
      <h3>Total Trades</h3>
      <p class="stat-value"><%= @stats["total_trades"] %></p>
    </div>

    <div class="card stat-card">
      <h3>Win Rate</h3>
      <p class="stat-value"><%= @stats["win_rate"] %>%</p>
    </div>

    <div class="card stat-card">
      <h3>Winning Trades</h3>
      <p class="stat-value positive"><%= @stats["winning_trades"] %></p>
    </div>

    <div class="card stat-card">
      <h3>Losing Trades</h3>
      <p class="stat-value negative"><%= @stats["losing_trades"] %></p>
    </div>

    <div class="card stat-card">
      <h3>Breakeven Trades</h3>
      <p class="stat-value"><%= @stats["breakeven_trades"] %></p>
    </div>

    <div class="card stat-card">
      <h3>Avg Win</h3>
      <p class="stat-value positive"><%= number_to_currency(@stats["avg_win"]) %></p>
    </div>

    <div class="card stat-card">
      <h3>Avg Loss</h3>
      <p class="stat-value negative"><%= number_to_currency(@stats["avg_loss"]) %></p>
    </div>

    <div class="card stat-card">
      <h3>Profit Factor</h3>
      <p class="stat-value"><%= @stats["profit_factor"] %></p>
    </div>

    <div class="card stat-card">
      <h3>Largest Win</h3>
      <p class="stat-value positive"><%= number_to_currency(@stats["largest_win"]) %></p>
    </div>

    <div class="card stat-card">
      <h3>Largest Loss</h3>
      <p class="stat-value negative"><%= number_to_currency(@stats["largest_loss"]) %></p>
    </div>

    <div class="card stat-card">
      <h3>Total Commissions</h3>
      <p class="stat-value"><%= number_to_currency(@stats["total_commissions"]) %></p>
    </div>

    <div class="card stat-card">
      <h3>Total Fees</h3>
      <p class="stat-value"><%= number_to_currency(@stats["total_fees"]) %></p>
    </div>
  </div>

  <% if @stats["daily_pnl"].present? %>
    <div class="card">
      <div class="card-header">
        <h2>Daily P&L</h2>
      </div>
      <table class="table">
        <thead>
          <tr>
            <th>Date</th>
            <th style="text-align: right;">P&L</th>
          </tr>
        </thead>
        <tbody>
          <% @stats["daily_pnl"].each do |date, pnl| %>
            <tr>
              <td><%= date %></td>
              <td style="text-align: right;" class="<%= pnl.to_f >= 0 ? 'positive' : 'negative' %>">
                <%= number_to_currency(pnl) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% else %>
  <div class="card empty-state">
    <p>No data available.</p>
  </div>
<% end %>
