<div class="page-header">
  <h1>Setup Analysis</h1>
  <div class="page-actions">
    <button class="btn" onclick="window.print()">
      <span class="material-icons-outlined">print</span> Print
    </button>
  </div>
</div>

<div class="card">
  <%= form_with url: reports_setup_analysis_path, method: :get, class: "filter-form" do |f| %>
    <div class="filter-row">
      <div class="form-group">
        <%= f.label :start_date, "Start Date" %>
        <%= f.date_field :start_date, value: params[:start_date], class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :end_date, "End Date" %>
        <%= f.date_field :end_date, value: params[:end_date], class: "form-control" %>
      </div>
      <div class="form-group form-actions-inline">
        <%= f.submit "Apply", class: "btn btn-primary" %>
        <%= link_to "Clear", reports_setup_analysis_path, class: "btn" %>
      </div>
    </div>
  <% end %>
</div>

<% if @setups.present? && @setups.any? %>
  <%
    best = @setups.max_by { |_, d| d[:avg_pnl] }
    most_used = @setups.max_by { |_, d| d[:trades] }
    highest_wr = @setups.select { |_, d| d[:trades] >= 5 }.max_by { |_, d| d[:win_rate] }
    qualified_setups = @setups.select { |_, d| d[:trades] >= 3 }
    profitable_setups = qualified_setups.select { |_, d| d[:total_pnl] > 0 }
    unprofitable_setups = qualified_setups.select { |_, d| d[:total_pnl] < 0 }

    # Setup portfolio health score
    if qualified_setups.any?
      avg_win_rate = qualified_setups.values.sum { |d| d[:win_rate] } / qualified_setups.count.to_f
      profitability_ratio = qualified_setups.count > 0 ? (profitable_setups.count.to_f / qualified_setups.count * 100) : 0
      weighted_avg_pnl = qualified_setups.values.sum { |d| d[:avg_pnl] * d[:trades] } / qualified_setups.values.sum { |d| d[:trades] }.to_f
      setup_health = [
        [avg_win_rate, 100].min * 0.35,
        [profitability_ratio, 100].min * 0.35,
        weighted_avg_pnl > 0 ? [30, 30].min : 0
      ].sum.round(0)
      setup_health = setup_health.clamp(0, 100)
      health_color = setup_health >= 70 ? "var(--positive)" : setup_health >= 40 ? "#f9ab00" : "var(--negative)"
    end
  %>

  <%# Setup Health Gauge %>
  <% if qualified_setups.count >= 2 %>
    <div class="card" style="display: flex; align-items: center; gap: 2rem; padding: 1.5rem; margin-bottom: 1.5rem; flex-wrap: wrap;">
      <div style="flex-shrink: 0;">
        <%
          gauge_pct = setup_health / 100.0
          arc_angle = [gauge_pct * 180, 180].min
          end_rad = (180 - arc_angle) * Math::PI / 180
          end_x = (70 + 55 * Math.cos(end_rad)).round(1)
          end_y = (75 - 55 * Math.sin(end_rad)).round(1)
        %>
        <svg viewBox="0 0 140 85" style="width: 130px;">
          <path d="M 15 75 A 55 55 0 0 1 125 75" fill="none" stroke="var(--border)" stroke-width="8" stroke-linecap="round" />
          <% if arc_angle > 0 %>
            <path d="M 15 75 A 55 55 0 <%= arc_angle > 180 ? 1 : 0 %> 1 <%= end_x %> <%= end_y %>"
                  fill="none" stroke="<%= health_color %>" stroke-width="8" stroke-linecap="round" />
          <% end %>
          <text x="70" y="60" text-anchor="middle" fill="<%= health_color %>" font-size="22" font-weight="700"><%= setup_health %></text>
          <text x="70" y="78" text-anchor="middle" fill="var(--text-secondary)" font-size="7">setup health</text>
        </svg>
      </div>
      <div style="flex: 1; min-width: 200px;">
        <h2 style="margin-bottom: 0.5rem;">Setup Portfolio</h2>
        <div style="display: flex; gap: 1.5rem; flex-wrap: wrap; font-size: 0.875rem;">
          <div>
            <span class="text-muted">Setups</span>
            <div style="font-weight: 700;"><%= @setups.count %></div>
          </div>
          <div>
            <span class="text-muted">Qualified (3+)</span>
            <div style="font-weight: 700;"><%= qualified_setups.count %></div>
          </div>
          <div>
            <span class="text-muted">Profitable</span>
            <div style="font-weight: 700;" class="positive"><%= profitable_setups.count %></div>
          </div>
          <div>
            <span class="text-muted">Avg Win Rate</span>
            <div style="font-weight: 700;"><%= avg_win_rate.round(1) %>%</div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="card" style="margin-bottom: 1.5rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 0;">
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Total Setups</div>
        <div style="font-size: 1.5rem; font-weight: 700;"><%= @setups.count %></div>
      </div>
      <% if best %>
        <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Best Avg P&L</div>
          <div style="font-size: 1.5rem; font-weight: 700;" class="positive"><%= best[0] %></div>
          <div style="font-size: 0.75rem;" class="positive"><%= number_to_currency(best[1][:avg_pnl]) %></div>
        </div>
      <% end %>
      <% if most_used %>
        <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Most Used</div>
          <div style="font-size: 1.5rem; font-weight: 700;"><%= most_used[0] %></div>
          <div style="font-size: 0.75rem;"><%= most_used[1][:trades] %> trades</div>
        </div>
      <% end %>
      <% if highest_wr %>
        <div style="padding: 1rem; text-align: center;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Highest Win Rate</div>
          <div style="font-size: 1.5rem; font-weight: 700;" class="positive"><%= highest_wr[0] %></div>
          <div style="font-size: 0.75rem;" class="positive"><%= highest_wr[1][:win_rate] %>%</div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Setup Edge Matrix - Win Rate vs Avg P&L scatter %>
  <% qualified = @setups.select { |_, d| d[:trades] >= 3 } %>
  <% if qualified.count >= 3 %>
    <div class="card" style="margin-bottom: 1.5rem;">
      <div class="card-header"><h2>Setup Edge Matrix</h2></div>
      <div style="padding: 1rem 1.25rem;">
        <div style="position: relative; height: 220px; border-left: 1px solid var(--border); border-bottom: 1px solid var(--border); margin-left: 2rem; margin-bottom: 1.5rem;">
          <%# Axis labels %>
          <span style="position: absolute; left: -2.5rem; top: 50%; transform: rotate(-90deg) translateX(50%); font-size: 0.625rem; color: var(--text-secondary); white-space: nowrap;">Avg P&L</span>
          <span style="position: absolute; bottom: -1.25rem; left: 50%; transform: translateX(-50%); font-size: 0.625rem; color: var(--text-secondary);">Win Rate</span>

          <%# Zero line (horizontal) %>
          <%
            max_avg = qualified.values.map { |d| d[:avg_pnl].abs }.max.to_f
            max_avg = 1 if max_avg == 0
            zero_y = (max_avg / (max_avg * 2) * 100).round(1)
          %>
          <div style="position: absolute; left: 0; right: 0; top: 50%; height: 1px; background: var(--border); opacity: 0.5;"></div>
          <div style="position: absolute; top: 0; bottom: 0; left: 50%; width: 1px; background: var(--border); opacity: 0.5;"></div>

          <%# Quadrant labels %>
          <span style="position: absolute; top: 0.25rem; right: 0.25rem; font-size: 0.5rem; color: var(--positive); opacity: 0.6;">HIGH EDGE</span>
          <span style="position: absolute; bottom: 0.25rem; left: 0.25rem; font-size: 0.5rem; color: var(--negative); opacity: 0.6;">LOW EDGE</span>

          <%
            setup_colors = ["#1a73e8", "#0d904f", "#e8710a", "#d93025", "#9334e6", "#f9ab00", "#80868b", "#00bcd4"]
          %>
          <% qualified.each_with_index do |(name, data), i| %>
            <%
              x_pct = data[:win_rate].clamp(0, 100)
              y_pct = 50 - (data[:avg_pnl] / max_avg * 45)
              dot_size = [8 + (data[:trades] / qualified.values.map { |d| d[:trades] }.max.to_f * 20).round(0), 28].min
            %>
            <div style="position: absolute; left: <%= x_pct %>%; top: <%= y_pct.round(1) %>%;
                        width: <%= dot_size %>px; height: <%= dot_size %>px; border-radius: 50%;
                        background: <%= setup_colors[i % setup_colors.length] %>; opacity: 0.65;
                        transform: translate(-50%, -50%); cursor: default;"
                 title="<%= name %>: WR <%= data[:win_rate] %>%, Avg P&L <%= number_to_currency(data[:avg_pnl]) %>, <%= data[:trades] %> trades">
            </div>
            <% if qualified.count <= 8 %>
              <span style="position: absolute; left: <%= x_pct %>%; top: calc(<%= y_pct.round(1) %>% + <%= dot_size / 2 + 3 %>px);
                           transform: translateX(-50%); font-size: 0.5625rem; color: var(--text-secondary); white-space: nowrap; pointer-events: none;">
                <%= name.truncate(12) %>
              </span>
            <% end %>
          <% end %>
        </div>
        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; font-size: 0.6875rem;">
          <% qualified.each_with_index do |(name, data), i| %>
            <span style="display: inline-flex; align-items: center; gap: 3px;">
              <span style="width: 8px; height: 8px; border-radius: 50%; background: <%= setup_colors[i % setup_colors.length] %>;"></span>
              <%= name %> (<%= data[:trades] %>)
            </span>
          <% end %>
          <span style="margin-left: auto; color: var(--text-secondary);">Dot size = trade count</span>
        </div>
      </div>
    </div>
  <% end %>

  <div class="card">
    <div class="card-header">
      <h2>Avg P&L by Setup</h2>
    </div>
    <% top_setups = @setups.select { |_, d| d[:trades] >= 3 }.first(15) %>
    <% if top_setups.any? %>
      <div class="chart-wrapper"
           data-controller="chart"
           data-chart-type-value="bar"
           data-chart-points-value="<%= top_setups.map { |name, data| { x: name.truncate(15), y: data[:avg_pnl] } }.to_json %>">
      </div>
    <% end %>
  </div>

  <div class="card">
    <div class="card-header">
      <h2>Setup Performance</h2>
      <span class="text-muted"><%= @total_trades %> total trades</span>
    </div>
    <table class="table">
      <thead>
        <tr>
          <th>Setup</th>
          <th>Trades</th>
          <th>Win Rate</th>
          <th>Total P&L</th>
          <th>Avg P&L</th>
          <th>Best</th>
          <th>Worst</th>
          <th>Performance</th>
        </tr>
      </thead>
      <tbody>
        <% max_pnl = @setups.values.map { |d| d[:total_pnl].abs }.max.to_f %>
        <% @setups.each do |name, data| %>
          <tr>
            <td><strong><%= name %></strong></td>
            <td><%= data[:trades] %></td>
            <td><%= data[:win_rate] %>%</td>
            <td class="<%= pnl_class(data[:total_pnl]) %>"><%= number_to_currency(data[:total_pnl]) %></td>
            <td class="<%= pnl_class(data[:avg_pnl]) %>"><%= number_to_currency(data[:avg_pnl]) %></td>
            <td class="positive"><%= number_to_currency(data[:best]) %></td>
            <td class="negative"><%= number_to_currency(data[:worst]) %></td>
            <td>
              <div class="mini-bar-container">
                <div class="mini-bar <%= data[:total_pnl] >= 0 ? 'positive' : 'negative' %>"
                     style="width: <%= max_pnl > 0 ? (data[:total_pnl].abs / max_pnl * 100).round(1) : 0 %>%"></div>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <div class="card-header">
      <h2>Key Insights</h2>
    </div>
    <div class="text-content" style="padding: 1rem 1.25rem;">
      <% profitable = @setups.select { |_, d| d[:total_pnl] > 0 && d[:trades] >= 3 } %>
      <% unprofitable = @setups.select { |_, d| d[:total_pnl] < 0 && d[:trades] >= 3 } %>

      <% if profitable.any? %>
        <p><strong>Profitable setups (3+ trades):</strong>
          <%= profitable.map { |name, d| "#{name} (#{number_to_currency(d[:avg_pnl])}/trade)" }.join(", ") %>
        </p>
      <% end %>

      <% if unprofitable.any? %>
        <p><strong>Unprofitable setups to review:</strong>
          <%= unprofitable.map { |name, d| "#{name} (#{number_to_currency(d[:avg_pnl])}/trade)" }.join(", ") %>
        </p>
      <% end %>

      <% no_setup = @setups["No Setup"] %>
      <% if no_setup && no_setup[:trades] > 5 %>
        <p><strong>Note:</strong> <%= no_setup[:trades] %> trades have no setup defined.
          Adding setups to your trades helps identify what's working and what isn't.</p>
      <% end %>
    </div>
  </div>

  <%# Setup Recommendations %>
  <% if qualified_setups.count >= 3 %>
    <%
      # Rank setups by edge score (win_rate * avg_pnl weighting)
      ranked = qualified_setups.sort_by { |_, d| -(d[:win_rate] * [d[:avg_pnl], 0].max) }
      top_setups_list = ranked.select { |_, d| d[:win_rate] >= 50 && d[:avg_pnl] > 0 }
      cut_setups_list = ranked.select { |_, d| d[:win_rate] < 40 && d[:avg_pnl] < 0 && d[:trades] >= 5 }
      review_setups_list = ranked.select { |_, d| (d[:win_rate] >= 50 && d[:avg_pnl] < 0) || (d[:win_rate] < 50 && d[:avg_pnl] > 0) }
    %>
    <div class="card">
      <div class="card-header"><h2>Setup Recommendations</h2></div>
      <div style="padding: 1rem 1.25rem;">
        <% if top_setups_list.any? %>
          <div style="margin-bottom: 1rem;">
            <div style="display: flex; align-items: center; gap: 0.375rem; margin-bottom: 0.5rem;">
              <span class="material-icons-outlined" style="font-size: 1rem; color: var(--positive);">thumb_up</span>
              <strong style="font-size: 0.875rem;">Keep Trading</strong>
            </div>
            <% top_setups_list.first(5).each do |name, data| %>
              <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0; font-size: 0.8125rem;">
                <span style="font-weight: 600; min-width: 6rem;"><%= name %></span>
                <span class="positive"><%= data[:win_rate] %>% WR</span>
                <span class="positive"><%= number_to_currency(data[:avg_pnl]) %>/trade</span>
                <span style="color: var(--text-secondary);"><%= data[:trades] %> trades</span>
              </div>
            <% end %>
          </div>
        <% end %>
        <% if review_setups_list.any? %>
          <div style="margin-bottom: 1rem;">
            <div style="display: flex; align-items: center; gap: 0.375rem; margin-bottom: 0.5rem;">
              <span class="material-icons-outlined" style="font-size: 1rem; color: #f9ab00;">rate_review</span>
              <strong style="font-size: 0.875rem;">Review & Refine</strong>
            </div>
            <% review_setups_list.first(5).each do |name, data| %>
              <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0; font-size: 0.8125rem;">
                <span style="font-weight: 600; min-width: 6rem;"><%= name %></span>
                <span class="<%= data[:win_rate] >= 50 ? 'positive' : 'negative' %>"><%= data[:win_rate] %>% WR</span>
                <span class="<%= data[:avg_pnl] >= 0 ? 'positive' : 'negative' %>"><%= number_to_currency(data[:avg_pnl]) %>/trade</span>
                <span style="color: var(--text-secondary);"><%= data[:trades] %> trades</span>
              </div>
            <% end %>
          </div>
        <% end %>
        <% if cut_setups_list.any? %>
          <div>
            <div style="display: flex; align-items: center; gap: 0.375rem; margin-bottom: 0.5rem;">
              <span class="material-icons-outlined" style="font-size: 1rem; color: var(--negative);">do_not_disturb</span>
              <strong style="font-size: 0.875rem;">Consider Dropping</strong>
            </div>
            <% cut_setups_list.first(5).each do |name, data| %>
              <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0; font-size: 0.8125rem;">
                <span style="font-weight: 600; min-width: 6rem;"><%= name %></span>
                <span class="negative"><%= data[:win_rate] %>% WR</span>
                <span class="negative"><%= number_to_currency(data[:avg_pnl]) %>/trade</span>
                <span style="color: var(--text-secondary);"><%= data[:trades] %> trades</span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="card empty-state">
    <p>No closed trades found.</p>
  </div>
<% end %>
