<div class="page-header">
  <h1>Performance by Duration</h1>
  <div class="page-actions">
    <button class="btn" onclick="window.print()">
      <span class="material-icons-outlined">print</span> Print
    </button>
  </div>
</div>

<div class="card">
  <%= form_with url: reports_by_duration_path, method: :get, class: "filter-form" do |f| %>
    <div class="filter-row">
      <div class="form-group">
        <%= f.label :start_date, "Start Date" %>
        <%= f.date_field :start_date, value: params[:start_date], class: "form-control" %>
      </div>
      <div class="form-group">
        <%= f.label :end_date, "End Date" %>
        <%= f.date_field :end_date, value: params[:end_date], class: "form-control" %>
      </div>
      <div class="form-group form-actions-inline">
        <%= f.submit "Apply", class: "btn btn-primary" %>
        <%= link_to "Clear", reports_by_duration_path, class: "btn" %>
      </div>
    </div>
  <% end %>
</div>

<% if @duration_stats.present? && !@duration_stats["error"] %>
  <%# Best duration bucket %>
  <% non_empty = @duration_stats.select { |_, s| s["count"].to_i > 0 } %>
  <% best_bucket = non_empty.max_by { |_, s| s["avg_pnl"].to_f } %>
  <% most_active = non_empty.max_by { |_, s| s["count"].to_i } %>

  <% if best_bucket || most_active %>
    <div class="card" style="margin-bottom: 1.5rem;">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 0;">
        <% if best_bucket %>
          <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
            <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Most Profitable Duration</div>
            <div style="font-size: 1.5rem; font-weight: 700;" class="positive"><%= best_bucket[0] %></div>
            <div style="font-size: 0.75rem;" class="positive">Avg: <%= number_to_currency(best_bucket[1]["avg_pnl"]) %></div>
          </div>
        <% end %>
        <% if most_active %>
          <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
            <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Most Active Duration</div>
            <div style="font-size: 1.5rem; font-weight: 700;"><%= most_active[0] %></div>
            <div style="font-size: 0.75rem;"><%= most_active[1]["count"] %> trades</div>
          </div>
        <% end %>
        <div style="padding: 1rem; text-align: center;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Total Trades</div>
          <div style="font-size: 1.5rem; font-weight: 700;"><%= non_empty.sum { |_, s| s["count"].to_i } %></div>
        </div>
      </div>
    </div>
  <% end %>

  <%# Performance Zones %>
  <% if non_empty.count >= 3 %>
    <%
      green_zone = non_empty.select { |_, s| s["avg_pnl"].to_f > 0 }.sort_by { |_, s| -s["avg_pnl"].to_f }
      red_zone = non_empty.select { |_, s| s["avg_pnl"].to_f < 0 }.sort_by { |_, s| s["avg_pnl"].to_f }
      max_avg = non_empty.map { |_, s| s["avg_pnl"].to_f.abs }.max.to_f
      max_avg = 1 if max_avg == 0
    %>
    <div class="card" style="margin-bottom: 1.5rem;">
      <div class="card-header"><h2>Duration Performance Zones</h2></div>
      <div style="padding: 1rem 1.25rem;">
        <div style="display: flex; gap: 2px; align-items: end; height: 120px; margin-bottom: 0.5rem;">
          <% non_empty.each do |bucket, stats| %>
            <%
              avg = stats["avg_pnl"].to_f
              bar_h = (avg.abs / max_avg * 100).round(0)
              bar_h = [bar_h, 5].max
              count = stats["count"].to_i
            %>
            <div style="flex: 1; display: flex; flex-direction: column; justify-content: end; align-items: center; height: 100%;">
              <% if avg >= 0 %>
                <div style="width: 80%; height: <%= bar_h %>%; background: var(--positive); opacity: 0.7; border-radius: 3px 3px 0 0; min-height: 4px;"
                     title="<%= bucket %>: Avg <%= number_to_currency(avg) %>, <%= count %> trades"></div>
              <% else %>
                <div style="flex: 1;"></div>
                <div style="width: 80%; height: <%= bar_h %>%; background: var(--negative); opacity: 0.7; border-radius: 0 0 3px 3px; min-height: 4px;"
                     title="<%= bucket %>: Avg <%= number_to_currency(avg) %>, <%= count %> trades"></div>
              <% end %>
            </div>
          <% end %>
        </div>
        <div style="display: flex; gap: 2px;">
          <% non_empty.each do |bucket, stats| %>
            <div style="flex: 1; text-align: center; font-size: 0.5625rem; color: var(--text-secondary); padding-top: 0.25rem; border-top: 1px solid var(--border);"><%= bucket.to_s.split(" ").first(2).join(" ") %></div>
          <% end %>
        </div>
        <div style="display: flex; gap: 1rem; margin-top: 1rem; font-size: 0.8125rem;">
          <% if green_zone.any? %>
            <div style="flex: 1; padding: 0.5rem; border-radius: var(--radius); background: rgba(13,144,79,0.06); border: 1px solid rgba(13,144,79,0.2);">
              <div style="font-weight: 700; color: var(--positive); margin-bottom: 0.25rem;">
                <span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px;">check_circle</span> Sweet Spot
              </div>
              <div style="font-size: 0.75rem; color: var(--text-secondary);">
                <%= green_zone.map { |b, _| b }.join(", ") %>
              </div>
            </div>
          <% end %>
          <% if red_zone.any? %>
            <div style="flex: 1; padding: 0.5rem; border-radius: var(--radius); background: rgba(217,48,37,0.06); border: 1px solid rgba(217,48,37,0.2);">
              <div style="font-weight: 700; color: var(--negative); margin-bottom: 0.25rem;">
                <span class="material-icons-outlined" style="font-size: 0.875rem; vertical-align: -2px;">cancel</span> Danger Zone
              </div>
              <div style="font-size: 0.75rem; color: var(--text-secondary);">
                <%= red_zone.map { |b, _| b }.join(", ") %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Chart %>
  <% if non_empty.any? %>
    <div class="card">
      <div class="card-header">
        <h2>Avg P&L by Duration</h2>
      </div>
      <div class="chart-wrapper"
           data-controller="chart"
           data-chart-type-value="bar"
           data-chart-points-value="<%= non_empty.map { |bucket, stats| { x: bucket, y: stats["avg_pnl"] } }.to_json %>">
      </div>
    </div>
  <% end %>

  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th>Duration</th>
          <th>Count</th>
          <th>Total P&L</th>
          <th>Avg P&L</th>
          <th>Wins</th>
          <th>Losses</th>
          <th>Win Rate</th>
          <th>Performance</th>
        </tr>
      </thead>
      <tbody>
        <% max_pnl = non_empty.map { |_, s| s["total_pnl"].to_f.abs }.max.to_f %>
        <% @duration_stats.each do |bucket, stats| %>
          <% next if stats["count"].to_i == 0 %>
          <tr>
            <td><strong><%= bucket %></strong></td>
            <td><%= stats["count"] %></td>
            <td class="<%= pnl_class(stats["total_pnl"]) %>"><%= number_to_currency(stats["total_pnl"]) %></td>
            <td class="<%= pnl_class(stats["avg_pnl"]) %>"><%= number_to_currency(stats["avg_pnl"]) %></td>
            <td class="positive"><%= stats["wins"] %></td>
            <td class="negative"><%= stats["losses"] %></td>
            <td>
              <% total = stats["wins"].to_i + stats["losses"].to_i %>
              <%= total > 0 ? (stats["wins"].to_f / total * 100).round(1) : 0 %>%
            </td>
            <td>
              <div class="mini-bar-container">
                <div class="mini-bar <%= stats["total_pnl"].to_f >= 0 ? 'positive' : 'negative' %>"
                     style="width: <%= max_pnl > 0 ? (stats["total_pnl"].to_f.abs / max_pnl * 100).round(1) : 0 %>%"></div>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <div class="card-header">
      <h2>Key Insight</h2>
    </div>
    <div class="text-content" style="padding: 1rem 1.25rem;">
      <% if best_bucket %>
        <p>Your most profitable trade duration is <strong><%= best_bucket[0] %></strong> with an average P&L of
        <strong class="positive"><%= number_to_currency(best_bucket[1]["avg_pnl"]) %></strong> per trade.
        <% worst = non_empty.min_by { |_, s| s["avg_pnl"].to_f } %>
        <% if worst && worst[1]["avg_pnl"].to_f < 0 %>
          Consider reducing <strong><%= worst[0] %></strong> duration trades where your average P&L is
          <strong class="negative"><%= number_to_currency(worst[1]["avg_pnl"]) %></strong>.
        <% end %>
        </p>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="card empty-state">
    <p>No data available.</p>
  </div>
<% end %>
