<% content_for(:title) { "Portfolio Exposure" } %>

<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px;">pie_chart</span>
    Portfolio Exposure
  </h1>
  <div class="page-actions">
    <%= link_to "All Trades", trades_path(status: "open"), class: "btn" %>
    <%= link_to "Risk Analysis", reports_risk_analysis_path, class: "btn" %>
  </div>
</div>

<% if @total_positions == 0 %>
  <div class="card" style="padding: 3rem; text-align: center;">
    <span class="material-icons-outlined" style="font-size: 3rem; color: var(--text-secondary); display: block; margin-bottom: 1rem;">pie_chart_outline</span>
    <h3>No Open Positions</h3>
    <p class="text-muted" style="margin: 0.5rem 0 1rem;">Open some trades to see your portfolio exposure analysis.</p>
    <%= link_to "New Trade", new_trade_path, class: "btn btn-primary" %>
  </div>
<% else %>

  <%# Summary strip %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 0;">
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Positions</div>
        <div style="font-size: 1.25rem; font-weight: 700;"><%= @total_positions %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Gross Exposure</div>
        <div style="font-size: 1.25rem; font-weight: 700;"><%= number_to_currency(@gross_exposure) %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Net Exposure</div>
        <div style="font-size: 1.25rem; font-weight: 700; color: <%= @net_exposure >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(@net_exposure) %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Unrealized P&L</div>
        <div style="font-size: 1.25rem; font-weight: 700; color: <%= @unrealized_pnl >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(@unrealized_pnl) %></div>
      </div>
      <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Risk at Stop</div>
        <div style="font-size: 1.25rem; font-weight: 700; color: var(--negative);"><%= number_to_currency(@total_risk_at_stop) %></div>
      </div>
      <div style="padding: 1rem; text-align: center;">
        <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Concentration</div>
        <div style="font-size: 1.25rem; font-weight: 700; color: <%= @concentration_color %>;"><%= @concentration %></div>
      </div>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">

    <%# Long / Short balance %>
    <div class="card">
      <div class="card-header">
        <h2>
          <span class="material-icons-outlined" style="font-size: 1.125rem; vertical-align: -3px;">swap_vert</span>
          Directional Exposure
        </h2>
      </div>
      <div style="padding: 1.25rem;">
        <%# Visual bar %>
        <div style="display: flex; height: 28px; border-radius: 4px; overflow: hidden; margin-bottom: 1rem;">
          <% if @long_pct > 0 %>
            <div style="width: <%= @long_pct %>%; background: var(--positive); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 0.6875rem; font-weight: 600;">
              <% if @long_pct > 15 %><%= @long_pct %>% Long<% end %>
            </div>
          <% end %>
          <% if @short_pct > 0 %>
            <div style="width: <%= @short_pct %>%; background: var(--negative); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 0.6875rem; font-weight: 600;">
              <% if @short_pct > 15 %><%= @short_pct %>% Short<% end %>
            </div>
          <% end %>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div style="padding: 0.75rem; background: rgba(13,144,79,0.05); border-radius: var(--radius); border-left: 3px solid var(--positive);">
            <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Long</div>
            <div style="font-size: 1.125rem; font-weight: 700;"><%= number_to_currency(@long_exposure) %></div>
            <div style="font-size: 0.75rem; color: var(--text-secondary);"><%= @long_trades.count %> position<%= @long_trades.count == 1 ? '' : 's' %></div>
          </div>
          <div style="padding: 0.75rem; background: rgba(234,67,53,0.05); border-radius: var(--radius); border-left: 3px solid var(--negative);">
            <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Short</div>
            <div style="font-size: 1.125rem; font-weight: 700;"><%= number_to_currency(@short_exposure) %></div>
            <div style="font-size: 0.75rem; color: var(--text-secondary);"><%= @short_trades.count %> position<%= @short_trades.count == 1 ? '' : 's' %></div>
          </div>
        </div>
      </div>
    </div>

    <%# By asset class %>
    <div class="card">
      <div class="card-header">
        <h2>
          <span class="material-icons-outlined" style="font-size: 1.125rem; vertical-align: -3px;">category</span>
          By Asset Class
        </h2>
      </div>
      <div style="padding: 1.25rem;">
        <%
          ac_colors = { "stocks" => "#1a73e8", "options" => "#e91e63", "futures" => "#f9ab00", "forex" => "#00bcd4", "crypto" => "#9c27b0" }
        %>
        <% @by_asset_class.sort_by { |_, d| -d[:exposure] }.each do |ac, data| %>
          <div style="margin-bottom: 0.75rem;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
              <span style="font-size: 0.875rem; font-weight: 600; text-transform: capitalize;"><%= ac %></span>
              <span style="font-size: 0.875rem; font-weight: 700;"><%= number_to_currency(data[:exposure]) %></span>
            </div>
            <div style="display: flex; align-items: center; gap: 0.5rem;">
              <div style="flex: 1; height: 6px; background: var(--bg); border-radius: 3px; overflow: hidden;">
                <div style="height: 100%; width: <%= data[:pct] %>%; background: <%= ac_colors[ac] || '#666' %>; border-radius: 3px;"></div>
              </div>
              <span style="font-size: 0.6875rem; color: var(--text-secondary); min-width: 36px; text-align: right;"><%= data[:pct] %>%</span>
            </div>
            <div style="font-size: 0.6875rem; color: var(--text-secondary); margin-top: 0.125rem;">
              <%= data[:trades] %> trade<%= data[:trades] == 1 ? '' : 's' %>
              &middot; P&L: <span style="color: <%= data[:pnl] >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(data[:pnl]) %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Symbol concentration donut + table %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.125rem; vertical-align: -3px;">donut_large</span>
        Symbol Concentration
      </h2>
      <% if @hhi %>
        <span style="font-size: 0.75rem; color: var(--text-secondary);">HHI: <%= @hhi %></span>
      <% end %>
    </div>
    <div style="padding: 1.25rem;">
      <div style="display: flex; align-items: flex-start; gap: 2rem; flex-wrap: wrap;">
        <%# Donut chart %>
        <%
          donut_colors = ["#1a73e8", "#0d904f", "#e91e63", "#f9ab00", "#9c27b0", "#00bcd4", "#ff5722", "#607d8b"]
          top_symbols = @by_symbol.first(8)
          cx = 80; cy = 80; r = 60; stroke_w = 20
          circumference = 2 * Math::PI * r
          offset = 0
        %>
        <svg viewBox="0 0 160 160" style="width: 160px; flex-shrink: 0;">
          <% top_symbols.each_with_index do |(sym, data), i| %>
            <%
              pct = data[:pct] / 100.0
              dash = circumference * pct
              gap = circumference - dash
            %>
            <circle cx="<%= cx %>" cy="<%= cy %>" r="<%= r %>" fill="none"
                    stroke="<%= donut_colors[i % donut_colors.length] %>" stroke-width="<%= stroke_w %>"
                    stroke-dasharray="<%= dash.round(1) %> <%= gap.round(1) %>"
                    stroke-dashoffset="<%= (-offset).round(1) %>"
                    transform="rotate(-90 <%= cx %> <%= cy %>)" />
            <% offset += dash %>
          <% end %>
          <text x="<%= cx %>" y="<%= cy - 2 %>" text-anchor="middle" fill="var(--text)" font-size="12" font-weight="700"><%= @by_symbol.count %></text>
          <text x="<%= cx %>" y="<%= cy + 10 %>" text-anchor="middle" fill="var(--text-secondary)" font-size="8">symbols</text>
        </svg>

        <%# Legend %>
        <div style="flex: 1; min-width: 200px;">
          <% top_symbols.each_with_index do |(sym, data), i| %>
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem;">
              <span style="width: 10px; height: 10px; border-radius: 2px; background: <%= donut_colors[i % donut_colors.length] %>; flex-shrink: 0;"></span>
              <span style="font-size: 0.875rem; font-weight: 600; min-width: 50px;"><%= sym %></span>
              <div style="flex: 1; height: 4px; background: var(--bg); border-radius: 2px; overflow: hidden;">
                <div style="height: 100%; width: <%= data[:pct] %>%; background: <%= donut_colors[i % donut_colors.length] %>; border-radius: 2px;"></div>
              </div>
              <span style="font-size: 0.75rem; color: var(--text-secondary); min-width: 36px; text-align: right;"><%= data[:pct] %>%</span>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# Open positions table %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2>
        <span class="material-icons-outlined" style="font-size: 1.125rem; vertical-align: -3px;">list_alt</span>
        Open Positions
      </h2>
    </div>
    <div style="overflow-x: auto;">
      <table class="data-table" style="width: 100%; font-size: 0.875rem;">
        <thead>
          <tr>
            <th style="text-align: left; padding: 0.625rem 1rem;">Symbol</th>
            <th style="text-align: center; padding: 0.625rem 0.5rem;">Side</th>
            <th style="text-align: right; padding: 0.625rem 0.5rem;">Qty</th>
            <th style="text-align: right; padding: 0.625rem 0.5rem;">Entry</th>
            <th style="text-align: right; padding: 0.625rem 0.5rem;">Exposure</th>
            <th style="text-align: right; padding: 0.625rem 0.5rem;">% of Book</th>
            <th style="text-align: right; padding: 0.625rem 0.5rem;">Stop</th>
            <th style="text-align: right; padding: 0.625rem 0.5rem;">Risk at Stop</th>
            <th style="text-align: right; padding: 0.625rem 0.5rem;">Unreal. P&L</th>
            <th style="text-align: right; padding: 0.625rem 1rem;">Opened</th>
          </tr>
        </thead>
        <tbody>
          <% @open_trades.sort_by { |t| -(t["entry_price"].to_f * t["quantity"].to_i) }.each do |trade| %>
            <%
              entry = trade["entry_price"].to_f
              qty = trade["quantity"].to_i
              exposure = entry * qty
              pct_book = @gross_exposure > 0 ? (exposure / @gross_exposure * 100).round(1) : 0
              stop = trade["stop_loss"]&.to_f
              risk = stop && stop > 0 ? ((entry - stop).abs * qty) : nil
              pnl = trade["pnl"].to_f
              opened = trade["entry_time"]&.to_s&.slice(0, 10)
            %>
            <tr>
              <td style="padding: 0.625rem 1rem;">
                <%= link_to trade["symbol"], trade_path(trade["id"]), style: "font-weight: 600; color: var(--primary); text-decoration: none;" %>
              </td>
              <td style="padding: 0.625rem 0.5rem; text-align: center;">
                <span style="font-size: 0.6875rem; padding: 0.125rem 0.375rem; border-radius: 3px; font-weight: 600; text-transform: uppercase; background: <%= trade['side'] == 'long' ? 'rgba(13,144,79,0.1)' : 'rgba(234,67,53,0.1)' %>; color: <%= trade['side'] == 'long' ? 'var(--positive)' : 'var(--negative)' %>;"><%= trade["side"] %></span>
              </td>
              <td style="padding: 0.625rem 0.5rem; text-align: right;"><%= qty %></td>
              <td style="padding: 0.625rem 0.5rem; text-align: right;"><%= number_to_currency(entry) %></td>
              <td style="padding: 0.625rem 0.5rem; text-align: right; font-weight: 600;"><%= number_to_currency(exposure) %></td>
              <td style="padding: 0.625rem 0.5rem; text-align: right;">
                <div style="display: flex; align-items: center; gap: 0.375rem; justify-content: flex-end;">
                  <div style="width: 40px; height: 4px; background: var(--bg); border-radius: 2px; overflow: hidden;">
                    <div style="height: 100%; width: <%= [pct_book, 100].min %>%; background: <%= pct_book > 25 ? 'var(--negative)' : pct_book > 15 ? '#f9ab00' : 'var(--primary)' %>; border-radius: 2px;"></div>
                  </div>
                  <span style="font-size: 0.75rem;"><%= pct_book %>%</span>
                </div>
              </td>
              <td style="padding: 0.625rem 0.5rem; text-align: right; color: var(--text-secondary);"><%= stop ? number_to_currency(stop) : '&mdash;'.html_safe %></td>
              <td style="padding: 0.625rem 0.5rem; text-align: right; color: var(--negative);"><%= risk ? number_to_currency(risk) : '&mdash;'.html_safe %></td>
              <td style="padding: 0.625rem 0.5rem; text-align: right; font-weight: 600; color: <%= pnl >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(pnl) %></td>
              <td style="padding: 0.625rem 1rem; text-align: right; font-size: 0.75rem; color: var(--text-secondary);"><%= opened %></td>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <tr style="border-top: 2px solid var(--border); font-weight: 700;">
            <td style="padding: 0.625rem 1rem;">Total</td>
            <td colspan="3"></td>
            <td style="padding: 0.625rem 0.5rem; text-align: right;"><%= number_to_currency(@gross_exposure) %></td>
            <td style="padding: 0.625rem 0.5rem; text-align: right;">100%</td>
            <td></td>
            <td style="padding: 0.625rem 0.5rem; text-align: right; color: var(--negative);"><%= number_to_currency(@total_risk_at_stop) %></td>
            <td style="padding: 0.625rem 0.5rem; text-align: right; color: <%= @unrealized_pnl >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(@unrealized_pnl) %></td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <%# Concentration warnings %>
  <% concentrated = @by_symbol.select { |_, d| d[:pct] > 25 } %>
  <% no_stops = @open_trades.select { |t| t["stop_loss"].nil? || t["stop_loss"].to_f == 0 } %>
  <% if concentrated.any? || no_stops.any? %>
    <div class="card" style="margin-bottom: 1.5rem;">
      <div class="card-header">
        <h2>
          <span class="material-icons-outlined" style="font-size: 1.125rem; vertical-align: -3px; color: #f9ab00;">warning</span>
          Risk Warnings
        </h2>
      </div>
      <div style="padding: 1rem 1.25rem; display: grid; gap: 0.75rem;">
        <% concentrated.each do |sym, data| %>
          <div style="display: flex; gap: 0.75rem; padding: 0.75rem; background: rgba(249,171,0,0.05); border-radius: var(--radius); border-left: 3px solid #f9ab00;">
            <span class="material-icons-outlined" style="color: #f9ab00; margin-top: 2px;">warning</span>
            <div>
              <div style="font-size: 0.875rem; font-weight: 600;">High Concentration: <%= sym %></div>
              <div style="font-size: 0.8125rem; color: var(--text-secondary);">
                <%= sym %> represents <%= data[:pct] %>% of your portfolio. Consider reducing to under 20% to limit single-name risk.
              </div>
            </div>
          </div>
        <% end %>
        <% if no_stops.any? %>
          <div style="display: flex; gap: 0.75rem; padding: 0.75rem; background: rgba(234,67,53,0.05); border-radius: var(--radius); border-left: 3px solid var(--negative);">
            <span class="material-icons-outlined" style="color: var(--negative); margin-top: 2px;">gpp_bad</span>
            <div>
              <div style="font-size: 0.875rem; font-weight: 600;">Missing Stop Losses</div>
              <div style="font-size: 0.8125rem; color: var(--text-secondary);">
                <%= no_stops.count %> position<%= no_stops.count == 1 ? ' has' : 's have' %> no stop loss set:
                <strong><%= no_stops.map { |t| t["symbol"] }.uniq.join(", ") %></strong>.
                Set stops to define your maximum risk.
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

<% end %>
