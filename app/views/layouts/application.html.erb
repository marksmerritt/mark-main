          <div class="nav-notifications" data-controller="notifications" data-notifications-url-value="<%= notifications_path %>">
            <button class="nav-link" data-action="click->notifications#toggle" title="Notifications" style="position: relative;">
              <span class="material-icons-outlined">notifications</span>
              <span class="notif-badge hidden" data-notifications-target="badge"></span>
            </button>
            <div class="notif-dropdown hidden" data-notifications-target="dropdown">
              <div class="notif-header">
                <strong>Notifications</strong>
                <%= link_to "View All", notifications_path, style: "font-size: 0.75rem; color: var(--primary); text-decoration: none;" %>
              </div>
              <div class="notif-list" data-notifications-target="list">
                <div class="notif-empty">Loading...</div>
              </div>
            </div>
          </div>
          <%= link_to financial_pulse_path, class: "nav-link", title: "Financial Pulse" do %>
            <span class="material-icons-outlined">monitor_heart</span>
          <% end %>
          <%= link_to timeline_path, class: "nav-link", title: "Activity Timeline" do %>
            <span class="material-icons-outlined">timeline</span>
          <% end %>
          <%= link_to daily_review_path, class: "nav-link", title: "Daily Review" do %>
            <span class="material-icons-outlined">today</span>
          <% end %>
          <%= link_to morning_briefing_path, class: "nav-link", title: "Morning Briefing" do %>
            <span class="material-icons-outlined">wb_sunny</span>
          <% end %>
          <%= link_to account_health_path, class: "nav-link", title: "Account Health" do %>
            <span class="material-icons-outlined">health_and_safety</span>
          <% end %>
          <%= link_to streak_calendar_path, class: "nav-link", title: "Streak Calendar" do %>
            <span class="material-icons-outlined">local_fire_department</span>
          <% end %>
          <%= link_to cross_product_insights_path, class: "nav-link", title: "Cross-Product Insights" do %>
            <span class="material-icons-outlined">hub</span>
          <% end %>
          <%= link_to weekly_report_path, class: "nav-link", title: "Weekly Report" do %>
            <span class="material-icons-outlined">summarize</span>
          <% end %>
          <%= link_to monthly_report_path, class: "nav-link", title: "Monthly Report" do %>
            <span class="material-icons-outlined">calendar_month</span>
          <% end %>
          <%= link_to digest_path, class: "nav-link", title: "Weekly Digest" do %>
            <span class="material-icons-outlined">summarize</span>
          <% end %>
          <%= link_to settings_path, class: "nav-link", title: "Settings" do %>
            <span class="material-icons-outlined">settings</span>
          <% end %>
          <%= link_to quick_search_path, class: "nav-link", title: "Quick Search (Cmd+K)" do %>
            <span class="material-icons-outlined">manage_search</span>
          <% end %>
          <%= link_to search_path, class: "nav-link search-nav-link", title: "Search" do %>
            <span class="material-icons-outlined">search</span>
          <% end %>
          <div data-controller="theme">
            <button class="theme-toggle" data-action="click->theme#toggle" title="Toggle dark mode">
              <span class="material-icons-outlined" data-theme-target="icon">dark_mode</span>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <div class="toast-container">
      <% flash.each do |type, message| %>
        <div class="toast toast-<%= type %>" data-controller="toast" data-action="click->toast#dismiss">
          <%= message %>
        </div>
      <% end %>
    </div>

    <main class="main-content">
      <%= yield %>
    </main>

    <div data-controller="quick-trade">
      <div class="shortcuts-overlay hidden" data-quick-trade-target="modal">
        <div class="shortcuts-dialog" style="max-width: 28rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h2>Quick Add Trade</h2>
            <button class="btn-icon" data-action="quick-trade#close" title="Close">
              <span class="material-icons-outlined">close</span>
            </button>
          </div>
          <form action="<%= trades_path %>" method="post" data-action="submit->quick-trade#submit">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div class="form-group">
              <label for="qt_symbol">Symbol</label>
              <input type="text" id="qt_symbol" name="trade[symbol]" class="form-control" placeholder="AAPL" required>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
              <div class="form-group">
                <label for="qt_side">Side</label>
                <select id="qt_side" name="trade[side]" class="form-control">
                  <option value="long">Long</option>
                  <option value="short">Short</option>
                </select>
              </div>
              <div class="form-group">
                <label for="qt_quantity">Quantity</label>
                <input type="number" id="qt_quantity" name="trade[quantity]" class="form-control" value="100">
              </div>
              <div class="form-group">
                <label for="qt_entry">Entry Price</label>
                <input type="number" id="qt_entry" name="trade[entry_price]" class="form-control" step="0.01" required>
              </div>
              <div class="form-group">
                <label for="qt_asset">Asset Class</label>
                <select id="qt_asset" name="trade[asset_class]" class="form-control">
                  <option value="stocks">Stocks</option>
                  <option value="options">Options</option>
                  <option value="futures">Futures</option>
                  <option value="forex">Forex</option>
                  <option value="crypto">Crypto</option>
                </select>
              </div>
            </div>
            <div class="form-actions" style="margin-top: 1rem;">
              <button type="submit" class="btn btn-primary">Create Trade</button>
              <button type="button" class="btn" data-action="quick-trade#close">Cancel</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div data-controller="quick-journal">
      <div class="shortcuts-overlay hidden" data-quick-journal-target="modal">
        <div class="shortcuts-dialog" style="max-width: 32rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h2>Quick Journal</h2>
            <button class="btn-icon" data-action="quick-journal#close" title="Close">
              <span class="material-icons-outlined">close</span>
            </button>
          </div>
          <form action="<%= journal_entries_path %>" method="post" data-action="submit->quick-journal#submit">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <input type="hidden" name="journal_entry[date]" value="<%= Date.today.to_s %>">
            <div class="form-group">
              <label>How are you feeling?</label>
              <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                <% %w[Confident Disciplined Neutral Anxious Frustrated].each do |mood| %>
                  <label style="cursor: pointer;">
                    <input type="radio" name="journal_entry[mood]" value="<%= mood %>" style="display: none;" data-quick-journal-target="mood">
                    <span class="preset-chip"><%= mood %></span>
                  </label>
                <% end %>
              </div>
            </div>
            <div class="form-group">
              <label for="qj_content">What's on your mind?</label>
              <textarea id="qj_content" name="journal_entry[content]" class="form-control" rows="4" placeholder="Quick thoughts about today's trading..." data-quick-journal-target="content"></textarea>
            </div>
            <div class="form-actions" style="margin-top: 0.75rem;">
              <button type="submit" class="btn btn-primary">Save Entry</button>
              <button type="button" class="btn" data-action="quick-journal#close">Cancel</button>
              <%= link_to "Full Form", new_journal_entry_path, class: "btn", style: "margin-left: auto;" %>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div data-controller="quick-capture">
      <div class="shortcuts-overlay hidden" data-quick-capture-target="modal">
        <div class="shortcuts-dialog" style="max-width: 32rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h2>Quick Note</h2>
            <button class="btn-icon" data-action="quick-capture#close" title="Close">
              <span class="material-icons-outlined">close</span>
            </button>
          </div>
          <form action="<%= notes_path %>" method="post" data-action="submit->quick-capture#submit">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div class="form-group">
              <label for="qn_title">Title</label>
              <input type="text" id="qn_title" name="note[title]" class="form-control" placeholder="Quick thought..." data-quick-capture-target="title">
            </div>
            <div class="form-group">
              <label for="qn_content">Content</label>
              <textarea id="qn_content" name="note[content]" class="form-control" rows="4" placeholder="Capture your thought..." data-quick-capture-target="content"></textarea>
            </div>
            <div class="form-actions" style="margin-top: 0.75rem;">
              <button type="submit" class="btn btn-primary">Save Note</button>
              <button type="button" class="btn" data-action="quick-capture#close">Cancel</button>
              <%= link_to "Full Editor", new_note_path, class: "btn", style: "margin-left: auto;" %>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div data-controller="quick-expense">
      <div class="shortcuts-overlay hidden" data-quick-expense-target="modal">
        <div class="shortcuts-dialog" style="max-width: 28rem;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h2>Quick Expense</h2>
            <button class="btn-icon" data-action="quick-expense#close" title="Close">
              <span class="material-icons-outlined">close</span>
            </button>
          </div>
          <form action="<%= budget_transactions_path %>" method="post" data-action="submit->quick-expense#submit">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <input type="hidden" name="transaction[transaction_type]" value="expense">
            <input type="hidden" name="transaction[status]" value="cleared">
            <input type="hidden" name="transaction[transaction_date]" value="<%= Date.today.to_s %>">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
              <div class="form-group">
                <label for="qe_amount">Amount ($)</label>
                <input type="number" id="qe_amount" name="transaction[amount]" class="form-control" step="0.01" min="0" required placeholder="0.00">
              </div>
              <div class="form-group">
                <label for="qe_merchant">Merchant</label>
                <input type="text" id="qe_merchant" name="transaction[merchant]" class="form-control" placeholder="e.g. Grocery Store">
              </div>
            </div>
            <div class="form-group">
              <label for="qe_description">Description</label>
              <input type="text" id="qe_description" name="transaction[description]" class="form-control" placeholder="What did you spend on?">
            </div>
            <div class="form-actions" style="margin-top: 1rem;">
              <button type="submit" class="btn btn-primary">Log Expense</button>
              <button type="button" class="btn" data-action="quick-expense#close">Cancel</button>
              <%= link_to "Full Form", new_budget_transaction_path, class: "btn", style: "margin-left: auto;" %>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div data-controller="command-palette">
      <div class="cmd-overlay hidden" data-command-palette-target="modal" data-action="click->command-palette#backdropClick">
        <div class="cmd-dialog">
          <div class="cmd-input-wrapper">
            <span class="material-icons-outlined cmd-search-icon">search</span>
            <input type="text" class="cmd-input" placeholder="Type a command or search..." data-command-palette-target="input" data-action="input->command-palette#filter" autocomplete="off" spellcheck="false">
            <kbd class="cmd-esc">esc</kbd>
          </div>
          <div class="cmd-results" data-command-palette-target="results"></div>
        </div>
      </div>
    </div>

    <div data-controller="back-to-top">
      <button class="back-to-top hidden" data-back-to-top-target="button" data-action="back-to-top#scrollToTop" title="Back to top">
        <span class="material-icons-outlined">arrow_upward</span>
      </button>
    </div>

    <footer class="app-footer">
      <span>Press <kbd>⌘K</kbd> command palette &middot; <kbd>?</kbd> shortcuts &middot; <kbd>a</kbd> trade &middot; <kbd>q</kbd> journal &middot; <kbd>x</kbd> expense &middot; <kbd>g</kbd> budget &middot; <kbd>v</kbd> review</span>
    </footer>

    <script>
      document.addEventListener("keydown", function(e) {
        if ((e.metaKey || e.ctrlKey) && e.key === "k") {
          e.preventDefault();
          window.location.href = "<%= quick_search_path %>";
        }
      });
    </script>
  </body>
</html>
