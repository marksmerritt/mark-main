<% content_for(:title) { "Spending vs Trading" } %>

<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: #1565c0;">sync_alt</span>
    Spending vs Trading
  </h1>
  <div class="page-actions">
    <%= link_to "Cross-Product Insights", cross_product_insights_path, class: "btn" %>
  </div>
</div>

<%# Correlation Score + Summary Stats %>
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 0.75rem; margin-bottom: 1.5rem;">
  <div class="card" style="padding: 0.75rem 1rem; text-align: center;">
    <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Correlation Score</div>
    <div style="font-size: 1.75rem; font-weight: 700; color: <%= @correlation.abs > 0.3 ? (@correlation > 0 ? '#f9a825' : 'var(--positive)') : 'var(--text-secondary)' %>;">
      <%= @correlation > 0 ? '+' : '' %><%= @correlation %>
    </div>
    <div style="font-size: 0.625rem; color: var(--text-secondary);">
      <%= if @correlation.abs < 0.1 then "No correlation"
          elsif @correlation.abs < 0.3 then "Weak correlation"
          elsif @correlation.abs < 0.6 then "Moderate correlation"
          else "Strong correlation"
          end %>
    </div>
  </div>
  <%
    total_pnl = @days.sum { |d| d[:pnl] }
    total_spending = @days.sum { |d| d[:spending] }
    trading_days_count = @days.count { |d| d[:pnl] != 0 }
    spending_days_count = @days.count { |d| d[:spending] > 0 }
  %>
  <div class="card" style="padding: 0.75rem 1rem; text-align: center;">
    <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">90-Day P&L</div>
    <div style="font-size: 1.25rem; font-weight: 700; color: <%= total_pnl >= 0 ? 'var(--positive)' : 'var(--negative)' %>;">
      <%= number_to_currency(total_pnl) %>
    </div>
    <div style="font-size: 0.625rem; color: var(--text-secondary);"><%= trading_days_count %> trading days</div>
  </div>
  <div class="card" style="padding: 0.75rem 1rem; text-align: center;">
    <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">90-Day Spending</div>
    <div style="font-size: 1.25rem; font-weight: 700; color: var(--text);">
      <%= number_to_currency(total_spending) %>
    </div>
    <div style="font-size: 0.625rem; color: var(--text-secondary);"><%= spending_days_count %> spending days</div>
  </div>
  <div class="card" style="padding: 0.75rem 1rem; text-align: center;">
    <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Net (P&L - Spending)</div>
    <% net = total_pnl - total_spending %>
    <div style="font-size: 1.25rem; font-weight: 700; color: <%= net >= 0 ? 'var(--positive)' : 'var(--negative)' %>;">
      <%= number_to_currency(net) %>
    </div>
    <div style="font-size: 0.625rem; color: var(--text-secondary);">Last 90 days</div>
  </div>
</div>

<%# Dual-Axis SVG Chart %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header">
    <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">ssid_chart</span> Daily P&L vs Spending (90 Days)</h2>
  </div>
  <div style="padding: 1.25rem; overflow-x: auto;">
    <%
      chart_w = 800
      chart_h = 260
      pad_l = 60
      pad_r = 60
      pad_t = 20
      pad_b = 40
      plot_w = chart_w - pad_l - pad_r
      plot_h = chart_h - pad_t - pad_b

      pnl_values = @days.map { |d| d[:pnl] }
      spend_values = @days.map { |d| d[:spending] }

      pnl_max = [pnl_values.max || 0, 1].max.to_f
      pnl_min = [pnl_values.min || 0, -1].min.to_f
      pnl_range = (pnl_max - pnl_min)
      pnl_range = 1.0 if pnl_range == 0

      spend_max = [spend_values.max || 0, 1].max.to_f

      bar_width = (plot_w.to_f / @days.size * 0.6).round(1)
      zero_y = pad_t + (pnl_max / pnl_range * plot_h).round(1)
    %>
    <svg viewBox="0 0 <%= chart_w %> <%= chart_h %>" style="width: 100%; height: auto; max-height: 300px;">
      <!-- Grid lines -->
      <line x1="<%= pad_l %>" y1="<%= pad_t %>" x2="<%= pad_l %>" y2="<%= pad_t + plot_h %>" stroke="var(--border)" stroke-width="1"/>
      <line x1="<%= pad_l %>" y1="<%= zero_y %>" x2="<%= chart_w - pad_r %>" y2="<%= zero_y %>" stroke="var(--border)" stroke-width="1" stroke-dasharray="4,2"/>
      <line x1="<%= chart_w - pad_r %>" y1="<%= pad_t %>" x2="<%= chart_w - pad_r %>" y2="<%= pad_t + plot_h %>" stroke="var(--border)" stroke-width="1"/>

      <!-- Y-axis labels (P&L left) -->
      <text x="<%= pad_l - 5 %>" y="<%= pad_t + 4 %>" text-anchor="end" fill="var(--text-secondary)" font-size="9"><%= number_to_currency(pnl_max, precision: 0) %></text>
      <text x="<%= pad_l - 5 %>" y="<%= zero_y + 3 %>" text-anchor="end" fill="var(--text-secondary)" font-size="9">$0</text>
      <text x="<%= pad_l - 5 %>" y="<%= pad_t + plot_h + 4 %>" text-anchor="end" fill="var(--text-secondary)" font-size="9"><%= number_to_currency(pnl_min, precision: 0) %></text>

      <!-- Y-axis labels (Spending right) -->
      <text x="<%= chart_w - pad_r + 5 %>" y="<%= pad_t + 4 %>" text-anchor="start" fill="#7b1fa2" font-size="9"><%= number_to_currency(spend_max, precision: 0) %></text>
      <text x="<%= chart_w - pad_r + 5 %>" y="<%= pad_t + plot_h + 4 %>" text-anchor="start" fill="#7b1fa2" font-size="9">$0</text>

      <!-- P&L bars -->
      <% @days.each_with_index do |day, i|
        x = pad_l + (i.to_f / @days.size * plot_w) + (plot_w.to_f / @days.size * 0.2)
        bar_h = (day[:pnl].abs / pnl_range * plot_h).round(1)
        if day[:pnl] >= 0
          bar_y = zero_y - bar_h
          bar_color = "var(--positive)"
        else
          bar_y = zero_y
          bar_color = "var(--negative)"
        end
      %>
        <rect x="<%= x %>" y="<%= bar_y %>" width="<%= bar_width %>" height="<%= [bar_h, 0.5].max %>" fill="<%= bar_color %>" opacity="0.7" rx="1">
          <title><%= day[:date].strftime('%b %d') %> P&L: <%= number_to_currency(day[:pnl]) %></title>
        </rect>
      <% end %>

      <!-- Spending line -->
      <%
        line_points = @days.each_with_index.map do |day, i|
          lx = pad_l + (i.to_f / @days.size * plot_w) + (plot_w.to_f / @days.size * 0.5)
          ly = spend_max > 0 ? (pad_t + plot_h - (day[:spending] / spend_max * plot_h)).round(1) : (pad_t + plot_h)
          "#{lx.round(1)},#{ly}"
        end.join(" ")
      %>
      <polyline points="<%= line_points %>" fill="none" stroke="#7b1fa2" stroke-width="2" opacity="0.8"/>

      <!-- Spending dots for high-spend days -->
      <% @days.each_with_index do |day, i|
        next if day[:spending] == 0
        dx = pad_l + (i.to_f / @days.size * plot_w) + (plot_w.to_f / @days.size * 0.5)
        dy = spend_max > 0 ? (pad_t + plot_h - (day[:spending] / spend_max * plot_h)).round(1) : (pad_t + plot_h)
      %>
        <% if day[:spending] > spend_max * 0.5 %>
          <circle cx="<%= dx.round(1) %>" cy="<%= dy %>" r="3" fill="#7b1fa2" opacity="0.9">
            <title><%= day[:date].strftime('%b %d') %> Spending: <%= number_to_currency(day[:spending]) %></title>
          </circle>
        <% end %>
      <% end %>

      <!-- Month labels on X axis -->
      <% months_shown = {}
         @days.each_with_index do |day, i|
           if day[:date].day == 1 || (i == 0 && !months_shown[day[:date].strftime('%b')])
             months_shown[day[:date].strftime('%b')] = true
             lx = pad_l + (i.to_f / @days.size * plot_w) + (plot_w.to_f / @days.size * 0.5)
      %>
        <text x="<%= lx.round(1) %>" y="<%= chart_h - 5 %>" text-anchor="middle" fill="var(--text-secondary)" font-size="10"><%= day[:date].strftime('%b') %></text>
        <line x1="<%= lx.round(1) %>" y1="<%= pad_t %>" x2="<%= lx.round(1) %>" y2="<%= pad_t + plot_h %>" stroke="var(--border)" stroke-width="0.5" opacity="0.5"/>
      <%   end
         end %>

      <!-- Legend -->
      <rect x="<%= pad_l + 10 %>" y="<%= pad_t + 5 %>" width="10" height="10" fill="var(--positive)" opacity="0.7" rx="1"/>
      <text x="<%= pad_l + 24 %>" y="<%= pad_t + 13 %>" fill="var(--text-secondary)" font-size="9">P&L (bars)</text>
      <line x1="<%= pad_l + 90 %>" y1="<%= pad_t + 10 %>" x2="<%= pad_l + 110 %>" y2="<%= pad_t + 10 %>" stroke="#7b1fa2" stroke-width="2"/>
      <text x="<%= pad_l + 114 %>" y="<%= pad_t + 13 %>" fill="var(--text-secondary)" font-size="9">Spending (line)</text>
    </svg>
  </div>
</div>

<%# Key Findings %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header">
    <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">lightbulb</span> Key Findings</h2>
  </div>
  <div style="padding: 1.25rem;">
    <div style="display: grid; gap: 0.75rem;">
      <% @insights.each do |insight| %>
        <div style="display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.75rem; border-radius: 8px; background: var(--bg);">
          <span class="material-icons-outlined" style="color: <%= insight[:color] %>; flex-shrink: 0; margin-top: 2px;"><%= insight[:icon] %></span>
          <div>
            <div style="font-weight: 600; font-size: 0.875rem; margin-bottom: 0.25rem;"><%= insight[:title] %></div>
            <div style="font-size: 0.8125rem; color: var(--text-secondary);"><%= insight[:text] %></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# Spending After Losses vs Wins %>
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
  <div class="card" style="border-top: 3px solid #e65100;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #e65100;">shopping_bag</span> Spending After Losses</h2>
    </div>
    <div style="padding: 1.25rem;">
      <div style="display: grid; gap: 1rem;">
        <div style="text-align: center;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Avg Spending After a Loss</div>
          <div style="font-size: 1.5rem; font-weight: 700; color: var(--negative);"><%= number_to_currency(@spending_after[:post_loss][:avg]) %></div>
          <div style="font-size: 0.625rem; color: var(--text-secondary);"><%= @spending_after[:post_loss][:count] %> days sampled</div>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Avg Spending After a Win</div>
          <div style="font-size: 1.5rem; font-weight: 700; color: var(--positive);"><%= number_to_currency(@spending_after[:post_win][:avg]) %></div>
          <div style="font-size: 0.625rem; color: var(--text-secondary);"><%= @spending_after[:post_win][:count] %> days sampled</div>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Avg on Neutral Days</div>
          <div style="font-size: 1.25rem; font-weight: 600; color: var(--text-secondary);"><%= number_to_currency(@spending_after[:neutral][:avg]) %></div>
          <div style="font-size: 0.625rem; color: var(--text-secondary);"><%= @spending_after[:neutral][:count] %> days</div>
        </div>
      </div>
      <% if @spending_after[:post_loss][:avg] > 0 && @spending_after[:post_win][:avg] > 0 %>
        <div style="margin-top: 1rem; padding: 0.75rem; border-radius: 6px; background: var(--bg);">
          <div style="display: flex; height: 24px; border-radius: 4px; overflow: hidden;">
            <% loss_pct = (@spending_after[:post_loss][:avg] / (@spending_after[:post_loss][:avg] + @spending_after[:post_win][:avg]) * 100).round(1) %>
            <div style="width: <%= loss_pct %>%; background: var(--negative); display: flex; align-items: center; justify-content: center; color: white; font-size: 0.625rem; font-weight: 600;">
              Post-Loss
            </div>
            <div style="width: <%= 100 - loss_pct %>%; background: var(--positive); display: flex; align-items: center; justify-content: center; color: white; font-size: 0.625rem; font-weight: 600;">
              Post-Win
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="card" style="border-top: 3px solid #1565c0;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px; color: #1565c0;">show_chart</span> Trading After Big Spending</h2>
    </div>
    <div style="padding: 1.25rem;">
      <div style="font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 1rem;">
        High spend threshold: <%= number_to_currency(@trading_after_spending[:high_spend_threshold]) %> (75th percentile)
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div style="text-align: center;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">After High Spending</div>
          <div style="font-size: 1.25rem; font-weight: 700; color: <%= @trading_after_spending[:post_high][:avg_pnl] >= 0 ? 'var(--positive)' : 'var(--negative)' %>;">
            <%= number_to_currency(@trading_after_spending[:post_high][:avg_pnl]) %>
          </div>
          <div style="font-size: 0.625rem; color: var(--text-secondary);">
            Win rate: <%= @trading_after_spending[:post_high][:win_rate] %>%
            (<%= @trading_after_spending[:post_high][:count] %> days)
          </div>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">After Normal Spending</div>
          <div style="font-size: 1.25rem; font-weight: 700; color: <%= @trading_after_spending[:post_low][:avg_pnl] >= 0 ? 'var(--positive)' : 'var(--negative)' %>;">
            <%= number_to_currency(@trading_after_spending[:post_low][:avg_pnl]) %>
          </div>
          <div style="font-size: 0.625rem; color: var(--text-secondary);">
            Win rate: <%= @trading_after_spending[:post_low][:win_rate] %>%
            (<%= @trading_after_spending[:post_low][:count] %> days)
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Monthly Comparison Table %>
<% if @monthly.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">calendar_month</span> Monthly Comparison</h2>
    </div>
    <div style="padding: 1.25rem;">
      <table style="width: 100%; border-collapse: collapse; font-size: 0.8125rem;">
        <thead>
          <tr style="border-bottom: 2px solid var(--border);">
            <th style="padding: 0.5rem 0.75rem; text-align: left;">Month</th>
            <th style="padding: 0.5rem 0.75rem; text-align: right;">Trading P&L</th>
            <th style="padding: 0.5rem 0.75rem; text-align: right;">Spending</th>
            <th style="padding: 0.5rem 0.75rem; text-align: right;">Net</th>
            <th style="padding: 0.5rem 0.75rem; text-align: center;">Trading Days</th>
            <th style="padding: 0.5rem 0.75rem; text-align: center;">Spend Days</th>
          </tr>
        </thead>
        <tbody>
          <% @monthly.sort.each do |month_key, data|
            month_net = data[:pnl] - data[:spending]
          %>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 0.5rem 0.75rem; font-weight: 600;"><%= Date.parse("#{month_key}-01").strftime('%B %Y') %></td>
              <td style="padding: 0.5rem 0.75rem; text-align: right; color: <%= data[:pnl] >= 0 ? 'var(--positive)' : 'var(--negative)' %>; font-weight: 600;">
                <%= number_to_currency(data[:pnl]) %>
              </td>
              <td style="padding: 0.5rem 0.75rem; text-align: right;"><%= number_to_currency(data[:spending]) %></td>
              <td style="padding: 0.5rem 0.75rem; text-align: right; font-weight: 600; color: <%= month_net >= 0 ? 'var(--positive)' : 'var(--negative)' %>;">
                <%= number_to_currency(month_net) %>
              </td>
              <td style="padding: 0.5rem 0.75rem; text-align: center;"><%= data[:trading_days] %></td>
              <td style="padding: 0.5rem 0.75rem; text-align: center;"><%= data[:spending_days] %></td>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <tr style="border-top: 2px solid var(--border); font-weight: 700;">
            <td style="padding: 0.5rem 0.75rem;">Total</td>
            <% t_pnl = @monthly.values.sum { |d| d[:pnl] }; t_spend = @monthly.values.sum { |d| d[:spending] }; t_net = t_pnl - t_spend %>
            <td style="padding: 0.5rem 0.75rem; text-align: right; color: <%= t_pnl >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(t_pnl) %></td>
            <td style="padding: 0.5rem 0.75rem; text-align: right;"><%= number_to_currency(t_spend) %></td>
            <td style="padding: 0.5rem 0.75rem; text-align: right; color: <%= t_net >= 0 ? 'var(--positive)' : 'var(--negative)' %>;"><%= number_to_currency(t_net) %></td>
            <td style="padding: 0.5rem 0.75rem; text-align: center;"><%= @monthly.values.sum { |d| d[:trading_days] } %></td>
            <td style="padding: 0.5rem 0.75rem; text-align: center;"><%= @monthly.values.sum { |d| d[:spending_days] } %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
<% end %>

<%# Quick Links %>
<div style="text-align: center; margin-top: 1.5rem;">
  <%= link_to "Cross-Product Insights", cross_product_insights_path, class: "btn" %>
  <%= link_to "Financial Pulse", financial_pulse_path, class: "btn" %>
  <%= link_to "Budget Dashboard", budget_dashboard_path, class: "btn" %>
  <%= link_to "Reports Hub", reports_index_path, class: "btn" %>
</div>
