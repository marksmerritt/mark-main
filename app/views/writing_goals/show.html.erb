<% content_for(:title) { "Writing Goals" } %>

<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: #2e7d32;">flag</span>
    Writing Goals
  </h1>
  <span style="font-size: 0.8125rem; color: var(--text-secondary);"><%= Date.current.strftime("%A, %B %-d, %Y") %></span>
</div>

<%# Today's Progress Card %>
<div class="card" style="margin-bottom: 1.5rem; padding: 1.5rem; background: linear-gradient(135deg, rgba(46,125,50,0.06), rgba(46,125,50,0.02));">
  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
    <div>
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em;">Today's Words</div>
      <div style="font-size: 2.5rem; font-weight: 700; color: #2e7d32; line-height: 1.2;"><%= number_with_delimiter(@today_words) %></div>
      <div style="font-size: 0.8125rem; color: var(--text-secondary);">of <%= number_with_delimiter(@daily_word_goal) %> word goal</div>
    </div>
    <div style="text-align: center;">
      <div style="position: relative; width: 80px; height: 80px;">
        <svg viewBox="0 0 36 36" style="width: 80px; height: 80px; transform: rotate(-90deg);">
          <circle cx="18" cy="18" r="15.9" fill="none" stroke="var(--border)" stroke-width="3"/>
          <circle cx="18" cy="18" r="15.9" fill="none" stroke="#2e7d32" stroke-width="3"
                  stroke-dasharray="<%= @daily_progress %>, 100" stroke-linecap="round"/>
        </svg>
        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 0.875rem; font-weight: 700;"><%= @daily_progress.round(0) %>%</div>
      </div>
    </div>
  </div>
  <div style="width: 100%; height: 8px; background: var(--border); border-radius: 4px; overflow: hidden;">
    <div style="height: 100%; width: <%= @daily_progress %>%; background: #2e7d32; border-radius: 4px; transition: width 0.3s;"></div>
  </div>
  <div style="display: flex; justify-content: space-between; font-size: 0.6875rem; color: var(--text-secondary); margin-top: 0.375rem;">
    <span><%= @today_notes.count %> note<%= @today_notes.count == 1 ? '' : 's' %> today</span>
    <span><%= [@daily_word_goal - @today_words, 0].max %> words to go</span>
  </div>
</div>

<%# Stats Strip %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 0;">
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Today's Words</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: #2e7d32;"><%= number_with_delimiter(@today_words) %></div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Weekly Words</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= number_with_delimiter(@week_words) %></div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Monthly Words</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= number_with_delimiter(@month_words) %></div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Streak</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: <%= @writing_streak >= 3 ? 'var(--positive)' : 'var(--text)' %>;"><%= @writing_streak %> <span style="font-size: 0.75rem;">days</span></div>
    </div>
    <div style="padding: 1rem; text-align: center;">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Success Rate</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: <%= @success_rate >= 60 ? '#2e7d32' : (@success_rate >= 30 ? '#f57f17' : 'var(--negative)') %>;"><%= @success_rate %>%</div>
    </div>
  </div>
</div>

<%# Active Goals Section %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header">
    <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">track_changes</span> Active Goals</h2>
  </div>
  <div style="padding: 1.25rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem;">

      <%# Daily Word Goal %>
      <div style="border: 1px solid var(--border); border-radius: 8px; padding: 1rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span class="material-icons-outlined" style="font-size: 1.25rem; color: #2e7d32;">edit</span>
            <span style="font-weight: 600; font-size: 0.875rem;">Daily Words</span>
          </div>
          <span style="font-size: 0.6875rem; padding: 0.125rem 0.5rem; border-radius: 9999px; background: <%= @daily_progress >= 100 ? '#e8f5e9' : '#fff3e0' %>; color: <%= @daily_progress >= 100 ? '#2e7d32' : '#e65100' %>;"><%= @daily_progress >= 100 ? 'Complete' : 'In Progress' %></span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <div style="position: relative; width: 56px; height: 56px; flex-shrink: 0;">
            <svg viewBox="0 0 36 36" style="width: 56px; height: 56px; transform: rotate(-90deg);">
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="var(--border)" stroke-width="2.5"/>
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="#2e7d32" stroke-width="2.5"
                      stroke-dasharray="<%= @daily_progress %>, 100" stroke-linecap="round"/>
            </svg>
            <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 0.6875rem; font-weight: 700;"><%= @daily_progress.round(0) %>%</div>
          </div>
          <div style="flex: 1;">
            <div style="font-size: 1.25rem; font-weight: 700;"><%= number_with_delimiter(@today_words) %> <span style="font-size: 0.75rem; font-weight: 400; color: var(--text-secondary);">/ <%= number_with_delimiter(@daily_word_goal) %></span></div>
            <div style="width: 100%; height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; margin-top: 0.375rem;">
              <div style="height: 100%; width: <%= @daily_progress %>%; background: #2e7d32; border-radius: 2px;"></div>
            </div>
          </div>
        </div>
      </div>

      <%# Weekly Word Goal %>
      <div style="border: 1px solid var(--border); border-radius: 8px; padding: 1rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span class="material-icons-outlined" style="font-size: 1.25rem; color: #1565c0;">date_range</span>
            <span style="font-weight: 600; font-size: 0.875rem;">Weekly Words</span>
          </div>
          <span style="font-size: 0.6875rem; padding: 0.125rem 0.5rem; border-radius: 9999px; background: <%= @weekly_progress >= 100 ? '#e8f5e9' : '#fff3e0' %>; color: <%= @weekly_progress >= 100 ? '#2e7d32' : '#e65100' %>;"><%= @weekly_progress >= 100 ? 'Complete' : 'In Progress' %></span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <div style="position: relative; width: 56px; height: 56px; flex-shrink: 0;">
            <svg viewBox="0 0 36 36" style="width: 56px; height: 56px; transform: rotate(-90deg);">
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="var(--border)" stroke-width="2.5"/>
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="#1565c0" stroke-width="2.5"
                      stroke-dasharray="<%= @weekly_progress %>, 100" stroke-linecap="round"/>
            </svg>
            <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 0.6875rem; font-weight: 700;"><%= @weekly_progress.round(0) %>%</div>
          </div>
          <div style="flex: 1;">
            <div style="font-size: 1.25rem; font-weight: 700;"><%= number_with_delimiter(@week_words) %> <span style="font-size: 0.75rem; font-weight: 400; color: var(--text-secondary);">/ <%= number_with_delimiter(@weekly_word_goal) %></span></div>
            <div style="width: 100%; height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; margin-top: 0.375rem;">
              <div style="height: 100%; width: <%= @weekly_progress %>%; background: #1565c0; border-radius: 2px;"></div>
            </div>
          </div>
        </div>
      </div>

      <%# Monthly Word Goal %>
      <div style="border: 1px solid var(--border); border-radius: 8px; padding: 1rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span class="material-icons-outlined" style="font-size: 1.25rem; color: #6a1b9a;">calendar_month</span>
            <span style="font-weight: 600; font-size: 0.875rem;">Monthly Words</span>
          </div>
          <span style="font-size: 0.6875rem; padding: 0.125rem 0.5rem; border-radius: 9999px; background: <%= @monthly_progress >= 100 ? '#e8f5e9' : '#fff3e0' %>; color: <%= @monthly_progress >= 100 ? '#2e7d32' : '#e65100' %>;"><%= @monthly_progress >= 100 ? 'Complete' : 'In Progress' %></span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <div style="position: relative; width: 56px; height: 56px; flex-shrink: 0;">
            <svg viewBox="0 0 36 36" style="width: 56px; height: 56px; transform: rotate(-90deg);">
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="var(--border)" stroke-width="2.5"/>
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="#6a1b9a" stroke-width="2.5"
                      stroke-dasharray="<%= @monthly_progress %>, 100" stroke-linecap="round"/>
            </svg>
            <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 0.6875rem; font-weight: 700;"><%= @monthly_progress.round(0) %>%</div>
          </div>
          <div style="flex: 1;">
            <div style="font-size: 1.25rem; font-weight: 700;"><%= number_with_delimiter(@month_words) %> <span style="font-size: 0.75rem; font-weight: 400; color: var(--text-secondary);">/ <%= number_with_delimiter(@monthly_word_goal) %></span></div>
            <div style="width: 100%; height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; margin-top: 0.375rem;">
              <div style="height: 100%; width: <%= @monthly_progress %>%; background: #6a1b9a; border-radius: 2px;"></div>
            </div>
          </div>
        </div>
      </div>

      <%# Notes Per Week Goal %>
      <div style="border: 1px solid var(--border); border-radius: 8px; padding: 1rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span class="material-icons-outlined" style="font-size: 1.25rem; color: #00796b;">description</span>
            <span style="font-weight: 600; font-size: 0.875rem;">Notes Per Week</span>
          </div>
          <span style="font-size: 0.6875rem; padding: 0.125rem 0.5rem; border-radius: 9999px; background: <%= @notes_per_week_progress >= 100 ? '#e8f5e9' : '#fff3e0' %>; color: <%= @notes_per_week_progress >= 100 ? '#2e7d32' : '#e65100' %>;"><%= @notes_per_week_progress >= 100 ? 'Complete' : 'In Progress' %></span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <div style="position: relative; width: 56px; height: 56px; flex-shrink: 0;">
            <svg viewBox="0 0 36 36" style="width: 56px; height: 56px; transform: rotate(-90deg);">
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="var(--border)" stroke-width="2.5"/>
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="#00796b" stroke-width="2.5"
                      stroke-dasharray="<%= @notes_per_week_progress %>, 100" stroke-linecap="round"/>
            </svg>
            <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 0.6875rem; font-weight: 700;"><%= @notes_per_week_progress.round(0) %>%</div>
          </div>
          <div style="flex: 1;">
            <div style="font-size: 1.25rem; font-weight: 700;"><%= @week_note_count %> <span style="font-size: 0.75rem; font-weight: 400; color: var(--text-secondary);">/ <%= @notes_per_week_goal %></span></div>
            <div style="width: 100%; height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; margin-top: 0.375rem;">
              <div style="height: 100%; width: <%= @notes_per_week_progress %>%; background: #00796b; border-radius: 2px;"></div>
            </div>
          </div>
        </div>
      </div>

      <%# Streak Goal %>
      <div style="border: 1px solid var(--border); border-radius: 8px; padding: 1rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span class="material-icons-outlined" style="font-size: 1.25rem; color: #e65100;">local_fire_department</span>
            <span style="font-weight: 600; font-size: 0.875rem;">Writing Streak</span>
          </div>
          <span style="font-size: 0.6875rem; padding: 0.125rem 0.5rem; border-radius: 9999px; background: <%= @streak_progress >= 100 ? '#e8f5e9' : '#fff3e0' %>; color: <%= @streak_progress >= 100 ? '#2e7d32' : '#e65100' %>;"><%= @streak_progress >= 100 ? 'Complete' : 'In Progress' %></span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <div style="position: relative; width: 56px; height: 56px; flex-shrink: 0;">
            <svg viewBox="0 0 36 36" style="width: 56px; height: 56px; transform: rotate(-90deg);">
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="var(--border)" stroke-width="2.5"/>
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="#e65100" stroke-width="2.5"
                      stroke-dasharray="<%= @streak_progress %>, 100" stroke-linecap="round"/>
            </svg>
            <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 0.6875rem; font-weight: 700;"><%= @streak_progress.round(0) %>%</div>
          </div>
          <div style="flex: 1;">
            <div style="font-size: 1.25rem; font-weight: 700;"><%= @writing_streak %> <span style="font-size: 0.75rem; font-weight: 400; color: var(--text-secondary);">/ <%= @streak_goal %> days</span></div>
            <div style="width: 100%; height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; margin-top: 0.375rem;">
              <div style="height: 100%; width: <%= @streak_progress %>%; background: #e65100; border-radius: 2px;"></div>
            </div>
          </div>
        </div>
      </div>

      <%# Notebook Diversity Goal %>
      <div style="border: 1px solid var(--border); border-radius: 8px; padding: 1rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span class="material-icons-outlined" style="font-size: 1.25rem; color: #4527a0;">library_books</span>
            <span style="font-weight: 600; font-size: 0.875rem;">Notebook Diversity</span>
          </div>
          <span style="font-size: 0.6875rem; padding: 0.125rem 0.5rem; border-radius: 9999px; background: <%= @notebook_progress >= 100 ? '#e8f5e9' : '#fff3e0' %>; color: <%= @notebook_progress >= 100 ? '#2e7d32' : '#e65100' %>;"><%= @notebook_progress >= 100 ? 'Complete' : 'In Progress' %></span>
        </div>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <div style="position: relative; width: 56px; height: 56px; flex-shrink: 0;">
            <svg viewBox="0 0 36 36" style="width: 56px; height: 56px; transform: rotate(-90deg);">
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="var(--border)" stroke-width="2.5"/>
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="#4527a0" stroke-width="2.5"
                      stroke-dasharray="<%= @notebook_progress %>, 100" stroke-linecap="round"/>
            </svg>
            <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 0.6875rem; font-weight: 700;"><%= @notebook_progress.round(0) %>%</div>
          </div>
          <div style="flex: 1;">
            <div style="font-size: 1.25rem; font-weight: 700;"><%= @notebook_count %> <span style="font-size: 0.75rem; font-weight: 400; color: var(--text-secondary);">/ <%= @notebook_goal %> notebooks</span></div>
            <div style="width: 100%; height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; margin-top: 0.375rem;">
              <div style="height: 100%; width: <%= @notebook_progress %>%; background: #4527a0; border-radius: 2px;"></div>
            </div>
            <% if @week_notebooks.any? %>
              <div style="font-size: 0.6875rem; color: var(--text-secondary); margin-top: 0.375rem;"><%= @week_notebooks.join(", ") %></div>
            <% end %>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<%# 30-Day Calendar Grid %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header">
    <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">calendar_today</span> 30-Day Goal Calendar</h2>
    <span style="font-size: 0.75rem; color: var(--text-secondary);"><%= @days_goal_met %> of 30 days met (<%= @success_rate %>%)</span>
  </div>
  <div style="padding: 1.25rem;">
    <div style="display: grid; grid-template-columns: repeat(10, 1fr); gap: 4px;">
      <% @daily_words.each do |date, words| %>
        <% met = words >= @daily_word_goal %>
        <div style="aspect-ratio: 1; border-radius: 4px; background: <%= met ? '#2e7d32' : (words > 0 ? '#c8e6c9' : 'var(--bg)') %>; display: flex; flex-direction: column; align-items: center; justify-content: center; cursor: default; border: 1px solid <%= met ? '#1b5e20' : 'var(--border)' %>; position: relative;"
             title="<%= date.strftime('%b %-d') %>: <%= number_with_delimiter(words) %> words<%= met ? ' (goal met)' : '' %>">
          <div style="font-size: 0.5rem; color: <%= met ? '#fff' : 'var(--text-secondary)' %>; line-height: 1;"><%= date.day %></div>
          <% if words > 0 %>
            <div style="font-size: 0.4375rem; color: <%= met ? 'rgba(255,255,255,0.8)' : 'var(--text-secondary)' %>; line-height: 1; margin-top: 1px;"><%= words %></div>
          <% end %>
        </div>
      <% end %>
    </div>
    <div style="display: flex; gap: 1rem; margin-top: 0.75rem; font-size: 0.6875rem; color: var(--text-secondary);">
      <div style="display: flex; align-items: center; gap: 0.25rem;">
        <div style="width: 10px; height: 10px; border-radius: 2px; background: #2e7d32;"></div>
        Goal met
      </div>
      <div style="display: flex; align-items: center; gap: 0.25rem;">
        <div style="width: 10px; height: 10px; border-radius: 2px; background: #c8e6c9;"></div>
        Some writing
      </div>
      <div style="display: flex; align-items: center; gap: 0.25rem;">
        <div style="width: 10px; height: 10px; border-radius: 2px; background: var(--bg); border: 1px solid var(--border);"></div>
        No writing
      </div>
    </div>
  </div>
</div>

<%# Weekly Performance Chart %>
<% if @week_daily.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">bar_chart</span> This Week's Daily Output</h2>
    </div>
    <div style="padding: 1.25rem; overflow-x: auto;">
      <%
        wd_max = @week_daily.values.max.to_f
        wd_max = 1 if wd_max == 0
        bar_count = @week_daily.count
        bar_width = 48
        chart_width = bar_count * (bar_width + 16) + 40
      %>
      <svg viewBox="0 0 <%= chart_width %> 170" style="width: 100%; height: auto; min-height: 140px; font-family: Inter, sans-serif;">
        <%# Goal line %>
        <% goal_y = 140 - (@daily_word_goal.to_f / [wd_max, @daily_word_goal].max * 120) %>
        <line x1="20" y1="<%= goal_y %>" x2="<%= chart_width - 10 %>" y2="<%= goal_y %>" stroke="#2e7d32" stroke-width="1" stroke-dasharray="4,3" opacity="0.5"/>
        <text x="<%= chart_width - 8 %>" y="<%= goal_y - 3 %>" fill="#2e7d32" font-size="7" text-anchor="end">goal</text>

        <% @week_daily.each_with_index do |(date, words), i| %>
          <% bar_h = [wd_max, @daily_word_goal].max > 0 ? (words.to_f / [wd_max, @daily_word_goal].max * 120) : 0 %>
          <% x = 25 + i * (bar_width + 16) %>
          <% met = words >= @daily_word_goal %>
          <rect x="<%= x %>" y="<%= 140 - bar_h %>" width="<%= bar_width %>" height="<%= [bar_h, 2].max %>"
                fill="<%= met ? '#2e7d32' : '#81c784' %>" rx="3" opacity="0.8"/>
          <text x="<%= x + bar_width / 2 %>" y="<%= 140 - bar_h - 5 %>" text-anchor="middle" fill="var(--text-secondary)" font-size="8" font-weight="600"><%= number_with_delimiter(words) %></text>
          <text x="<%= x + bar_width / 2 %>" y="155" text-anchor="middle" fill="var(--text-secondary)" font-size="8"><%= date.strftime("%a") %></text>
          <text x="<%= x + bar_width / 2 %>" y="165" text-anchor="middle" fill="var(--text-secondary)" font-size="6"><%= date.strftime("%b %-d") %></text>
        <% end %>
      </svg>
    </div>
  </div>
<% end %>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">

  <%# Goal Success Rates %>
  <div class="card">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">assessment</span> Success Rates</h2>
    </div>
    <div style="padding: 1.25rem;">
      <% [
        { label: "Daily Goal", rate: @success_rate, color: "#2e7d32" },
        { label: "Weekly Goal", rate: @weekly_success_rate, color: "#1565c0" },
        { label: "Monthly Goal", rate: @monthly_success_rate, color: "#6a1b9a" }
      ].each do |goal| %>
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
          <span style="width: 5.5rem; font-size: 0.8125rem; text-align: right;"><%= goal[:label] %></span>
          <div style="flex: 1; height: 1rem; background: var(--bg); border-radius: 4px; overflow: hidden;">
            <div style="height: 100%; width: <%= goal[:rate] %>%; background: <%= goal[:color] %>; opacity: 0.7; border-radius: 4px;"></div>
          </div>
          <span style="min-width: 3rem; text-align: right; font-size: 0.8125rem; font-weight: 600;"><%= goal[:rate] %>%</span>
        </div>
      <% end %>
    </div>
  </div>

  <%# Trend Analysis %>
  <div class="card">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;"><%= @trend_direction == 'up' ? 'trending_up' : 'trending_down' %></span> Output Trend</h2>
    </div>
    <div style="padding: 1.25rem;">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
        <span class="material-icons-outlined" style="font-size: 2.5rem; color: <%= @trend_direction == 'up' ? '#2e7d32' : '#c62828' %>;"><%= @trend_direction == 'up' ? 'trending_up' : 'trending_down' %></span>
        <div>
          <div style="font-size: 1.25rem; font-weight: 700; color: <%= @trend_direction == 'up' ? '#2e7d32' : '#c62828' %>;"><%= @trend_direction == 'up' ? '+' : '-' %><%= number_with_delimiter(@trend_delta) %> <span style="font-size: 0.75rem; font-weight: 400;">words/day avg</span></div>
          <div style="font-size: 0.8125rem; color: var(--text-secondary);">Comparing last 15 days vs prior 15 days</div>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
        <div style="padding: 0.75rem; background: var(--bg); border-radius: 6px; text-align: center;">
          <div style="font-size: 0.625rem; color: var(--text-secondary); text-transform: uppercase;">Prior 15 Days Avg</div>
          <div style="font-size: 1.125rem; font-weight: 700;"><%= number_with_delimiter(@prior_avg) %></div>
        </div>
        <div style="padding: 0.75rem; background: var(--bg); border-radius: 6px; text-align: center;">
          <div style="font-size: 0.625rem; color: var(--text-secondary); text-transform: uppercase;">Recent 15 Days Avg</div>
          <div style="font-size: 1.125rem; font-weight: 700;"><%= number_with_delimiter(@recent_avg) %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">

  <%# Best Periods %>
  <div class="card">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">emoji_events</span> Best Periods</h2>
    </div>
    <div style="padding: 1.25rem;">
      <% if @best_week %>
        <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem; background: var(--bg); border-radius: 6px; margin-bottom: 0.75rem;">
          <span class="material-icons-outlined" style="font-size: 1.5rem; color: #f9a825;">star</span>
          <div>
            <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Best Week</div>
            <div style="font-weight: 600;"><%= number_with_delimiter(@best_week[1]) %> words</div>
            <div style="font-size: 0.75rem; color: var(--text-secondary);">Week of <%= @best_week[0].strftime("%b %-d, %Y") %></div>
          </div>
        </div>
      <% end %>
      <% if @best_month %>
        <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem; background: var(--bg); border-radius: 6px;">
          <span class="material-icons-outlined" style="font-size: 1.5rem; color: #f9a825;">workspace_premium</span>
          <div>
            <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Best Month</div>
            <div style="font-weight: 600;"><%= number_with_delimiter(@best_month[1]) %> words</div>
            <div style="font-size: 0.75rem; color: var(--text-secondary);"><%= @best_month[0].strftime("%B %Y") %></div>
          </div>
        </div>
      <% end %>
      <% unless @best_week || @best_month %>
        <div style="color: var(--text-secondary); font-size: 0.8125rem; text-align: center; padding: 1rem;">No data yet</div>
      <% end %>
    </div>
  </div>

  <%# Goal Suggestions %>
  <div class="card">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">lightbulb</span> Goal Suggestions</h2>
    </div>
    <div style="padding: 1.25rem;">
      <% [
        { label: "Daily", current: @daily_word_goal, actual: @actual_daily_avg, suggestion: @suggested_daily },
        { label: "Weekly", current: @weekly_word_goal, actual: @actual_weekly_avg, suggestion: @suggested_weekly },
        { label: "Monthly", current: @monthly_word_goal, actual: @actual_monthly_avg, suggestion: @suggested_monthly }
      ].each do |s| %>
        <div style="padding: 0.625rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 0.75rem;">
          <% if s[:suggestion][:direction] == "increase" %>
            <span class="material-icons-outlined" style="font-size: 1.25rem; color: #2e7d32;">arrow_upward</span>
          <% elsif s[:suggestion][:direction] == "decrease" %>
            <span class="material-icons-outlined" style="font-size: 1.25rem; color: #e65100;">arrow_downward</span>
          <% else %>
            <span class="material-icons-outlined" style="font-size: 1.25rem; color: #1565c0;">check_circle</span>
          <% end %>
          <div style="flex: 1;">
            <div style="font-size: 0.8125rem; font-weight: 600;"><%= s[:label] %>: <%= number_with_delimiter(s[:current]) %> &rarr; <%= number_with_delimiter(s[:suggestion][:value]) %></div>
            <div style="font-size: 0.6875rem; color: var(--text-secondary);"><%= s[:suggestion][:reason] %> (avg: <%= number_with_delimiter(s[:actual]) %>)</div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# Achievements %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div class="card-header">
    <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">military_tech</span> Achievements</h2>
  </div>
  <div style="padding: 1.25rem;">
    <% if @achievements.any? %>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 0.75rem;">
        <% @achievements.each do |a| %>
          <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem; background: linear-gradient(135deg, rgba(46,125,50,0.06), rgba(46,125,50,0.02)); border-radius: 8px; border: 1px solid rgba(46,125,50,0.15);">
            <span class="material-icons-outlined" style="font-size: 1.5rem; color: #f9a825;"><%= a[:icon] %></span>
            <div>
              <div style="font-size: 0.8125rem; font-weight: 600;"><%= a[:label] %></div>
              <div style="font-size: 0.6875rem; color: var(--text-secondary);"><%= a[:desc] %></div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div style="text-align: center; padding: 1.5rem; color: var(--text-secondary);">
        <span class="material-icons-outlined" style="font-size: 2.5rem; display: block; margin-bottom: 0.5rem; opacity: 0.4;">emoji_events</span>
        <div style="font-size: 0.8125rem;">Keep writing to unlock achievements!</div>
        <div style="font-size: 0.75rem; margin-top: 0.25rem;">Milestones include streak goals, word count records, and more.</div>
      </div>
    <% end %>
  </div>
</div>

<%# Bottom Nav %>
<div style="text-align: center; margin-top: 1.5rem;">
  <%= link_to "Writing Digest", writing_digest_path, class: "btn" %>
  <%= link_to "Writing Stats", writing_stats_path, class: "btn" %>
  <%= link_to "Focus Timer", focus_timer_path, class: "btn" %>
</div>
