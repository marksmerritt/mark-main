<div class="card">
  <div style="padding: 1.25rem;">
    <div style="margin-bottom: 1rem;">
      <label class="form-label">Name</label>
      <%= f.text_field "note_template[name]", value: @template["name"], class: "form-control", required: true, placeholder: "e.g. Weekly Review, Meeting Notes" %>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
      <div>
        <label class="form-label">Category</label>
        <%= f.select "note_template[category]", @categories.map { |c| [c.capitalize, c] }, { selected: @template["category"] || "blank" }, class: "form-control" %>
      </div>
      <div>
        <label class="form-label">Default Template</label>
        <div style="padding-top: 0.5rem;">
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
            <%= f.check_box "note_template[is_default]", { checked: @template["is_default"] }, "true", "false" %>
            <span style="font-size: 0.875rem;">Set as default for this category</span>
          </label>
        </div>
      </div>
    </div>

    <div style="margin-bottom: 1rem;">
      <label class="form-label">Description</label>
      <%= f.text_field "note_template[description]", value: @template["description"], class: "form-control", placeholder: "Brief description of what this template is for" %>
    </div>

    <div style="margin-bottom: 1rem;">
      <label class="form-label">Content</label>
      <%= f.text_area "note_template[content]", value: @template["content"], class: "form-control", rows: 12, placeholder: "Template content — this will be copied into new notes", style: "font-family: 'SF Mono', 'Fira Code', monospace; font-size: 0.8125rem;" %>
    </div>

    <div style="display: flex; gap: 0.5rem;">
      <%= f.submit @template["id"] ? "Update Template" : "Create Template", class: "btn btn-primary" %>
      <%= link_to "Cancel", note_templates_path, class: "btn" %>
    </div>
  </div>
</div>
