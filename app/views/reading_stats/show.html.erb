<% content_for(:title) { "Reading Stats" } %>

<div class="page-header">
  <h1>
    <span class="material-icons-outlined" style="font-size: 1.5rem; vertical-align: -4px; color: #795548;">menu_book</span>
    Reading Stats
  </h1>
</div>

<%# Stats Strip %>
<div class="card" style="margin-bottom: 1.5rem;">
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 0;">
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Total Reading Time</div>
      <div style="font-size: 1.5rem; font-weight: 700; color: #795548;">
        <% if @total_reading_hours >= 1 %>
          <%= @total_reading_hours %><span style="font-size: 0.75rem;"> hrs</span>
        <% else %>
          <%= @total_reading_minutes.round(0) %><span style="font-size: 0.75rem;"> min</span>
        <% end %>
      </div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Library Size</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= @book_equivalents %><span style="font-size: 0.75rem;"> books</span></div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Notes</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= @total_notes %></div>
    </div>
    <div style="padding: 1rem; text-align: center; border-right: 1px solid var(--border);">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Avg Words/Note</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= number_with_delimiter(@avg_words) %></div>
    </div>
    <div style="padding: 1rem; text-align: center;">
      <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Words/Day</div>
      <div style="font-size: 1.5rem; font-weight: 700;"><%= number_with_delimiter(@words_per_day) %></div>
    </div>
  </div>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">

  <%# Reading Time Distribution %>
  <div class="card">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">timer</span> Reading Time Distribution</h2>
    </div>
    <div style="padding: 1.25rem;">
      <% bucket_max = @time_buckets.values.max.to_f; bucket_max = 1 if bucket_max == 0 %>
      <% bucket_colors = ["#a5d6a7", "#81c784", "#66bb6a", "#43a047", "#2e7d32"] %>
      <% @time_buckets.each_with_index do |(label, count), i| %>
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.625rem;">
          <span style="width: 4.5rem; font-size: 0.8125rem; text-align: right; color: var(--text-secondary);"><%= label %></span>
          <div style="flex: 1; height: 1.5rem; background: var(--bg); border-radius: 4px; overflow: hidden; position: relative;">
            <div style="height: 100%; width: <%= (count / bucket_max * 100).round(1) %>%; background: <%= bucket_colors[i] %>; border-radius: 4px; transition: width 0.3s;"></div>
          </div>
          <span style="min-width: 2.5rem; text-align: right; font-size: 0.8125rem; font-weight: 600;"><%= count %></span>
        </div>
      <% end %>
    </div>
  </div>

  <%# Content Density %>
  <div class="card">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">analytics</span> Content Density</h2>
    </div>
    <div style="padding: 1.25rem;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
        <div style="text-align: center; padding: 1rem; background: var(--bg); border-radius: 8px;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Avg Words/Note</div>
          <div style="font-size: 1.75rem; font-weight: 700; color: #795548;"><%= number_with_delimiter(@avg_words) %></div>
        </div>
        <div style="text-align: center; padding: 1rem; background: var(--bg); border-radius: 8px;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Median Words</div>
          <div style="font-size: 1.75rem; font-weight: 700; color: #795548;"><%= number_with_delimiter(@median_words) %></div>
        </div>
        <div style="text-align: center; padding: 1rem; background: var(--bg); border-radius: 8px;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Total Words</div>
          <div style="font-size: 1.75rem; font-weight: 700;"><%= number_with_delimiter(@total_words) %></div>
        </div>
        <div style="text-align: center; padding: 1rem; background: var(--bg); border-radius: 8px;">
          <div style="font-size: 0.6875rem; color: var(--text-secondary); text-transform: uppercase;">Days Tracked</div>
          <div style="font-size: 1.75rem; font-weight: 700;"><%= number_with_delimiter(@days_since_first) %></div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Growth Curve %>
<% if @cumulative_growth.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">show_chart</span> Library Growth Over Time</h2>
    </div>
    <div style="padding: 1.25rem; overflow-x: auto;">
      <%
        cg_entries = @cumulative_growth.to_a
        cg_max_words = cg_entries.map { |_, v| v[:words] }.max.to_f
        cg_max_words = 1 if cg_max_words == 0
        chart_w = [cg_entries.length * 60, 600].max
        chart_h = 180
        pad_left = 50
        pad_bottom = 30
        pad_top = 15
        draw_w = chart_w - pad_left - 10
        draw_h = chart_h - pad_bottom - pad_top

        points = cg_entries.each_with_index.map do |(month, data), i|
          x = pad_left + (i.to_f / [cg_entries.length - 1, 1].max * draw_w)
          y = pad_top + draw_h - (data[:words] / cg_max_words * draw_h)
          [x.round(1), y.round(1), month, data]
        end
        polyline = points.map { |x, y, _, _| "#{x},#{y}" }.join(" ")

        fill_points = "#{points.first[0]},#{pad_top + draw_h} " + polyline + " #{points.last[0]},#{pad_top + draw_h}"
      %>
      <svg viewBox="0 0 <%= chart_w %> <%= chart_h %>" style="width: 100%; height: auto; font-family: Inter, sans-serif;">
        <%# Grid lines %>
        <% 5.times do |i| %>
          <% gy = pad_top + draw_h - (i.to_f / 4 * draw_h) %>
          <line x1="<%= pad_left %>" y1="<%= gy %>" x2="<%= chart_w - 10 %>" y2="<%= gy %>" stroke="var(--border)" stroke-width="0.5" stroke-dasharray="3,3"/>
          <text x="<%= pad_left - 5 %>" y="<%= gy + 3 %>" text-anchor="end" fill="var(--text-secondary)" font-size="7"><%= number_with_delimiter((cg_max_words * i / 4).round(0)) %></text>
        <% end %>

        <%# Fill area %>
        <polygon points="<%= fill_points %>" fill="#795548" opacity="0.12"/>

        <%# Line %>
        <polyline points="<%= polyline %>" fill="none" stroke="#795548" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>

        <%# Points and labels %>
        <% label_step = [(cg_entries.length / 8.0).ceil, 1].max %>
        <% points.each_with_index do |(x, y, month, data), i| %>
          <circle cx="<%= x %>" cy="<%= y %>" r="3" fill="#795548"/>
          <% if i % label_step == 0 || i == points.length - 1 %>
            <text x="<%= x %>" y="<%= chart_h - 5 %>" text-anchor="middle" fill="var(--text-secondary)" font-size="6.5"><%= month %></text>
          <% end %>
        <% end %>

        <%# Final value label %>
        <% if points.any? %>
          <text x="<%= points.last[0] + 5 %>" y="<%= points.last[1] - 5 %>" fill="#795548" font-size="7" font-weight="600"><%= number_with_delimiter(points.last[3][:words]) %>w</text>
        <% end %>
      </svg>
    </div>
  </div>
<% end %>

<%# Top Reads Table %>
<% if @longest_reads.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">auto_stories</span> Top Reads</h2>
    </div>
    <div style="overflow-x: auto;">
      <table class="table" style="width: 100%; border-collapse: collapse;">
        <thead>
          <tr style="border-bottom: 2px solid var(--border);">
            <th style="text-align: left; padding: 0.75rem 1rem; font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary);">#</th>
            <th style="text-align: left; padding: 0.75rem 1rem; font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary);">Title</th>
            <th style="text-align: left; padding: 0.75rem 1rem; font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary);">Notebook</th>
            <th style="text-align: right; padding: 0.75rem 1rem; font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary);">Words</th>
            <th style="text-align: right; padding: 0.75rem 1rem; font-size: 0.6875rem; text-transform: uppercase; color: var(--text-secondary);">Reading Time</th>
          </tr>
        </thead>
        <tbody>
          <% @longest_reads.each_with_index do |note, i| %>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 0.625rem 1rem; font-size: 0.8125rem; color: var(--text-secondary);"><%= i + 1 %></td>
              <td style="padding: 0.625rem 1rem; font-size: 0.8125rem; font-weight: 500;">
                <% if note["id"] %>
                  <%= link_to (note["title"].presence || "Untitled"), note_path(note["id"]), style: "color: var(--text); text-decoration: none;" %>
                <% else %>
                  <%= note["title"].presence || "Untitled" %>
                <% end %>
              </td>
              <td style="padding: 0.625rem 1rem; font-size: 0.8125rem; color: var(--text-secondary);"><%= note.dig("notebook", "name") || "—" %></td>
              <td style="padding: 0.625rem 1rem; font-size: 0.8125rem; text-align: right; font-weight: 600;"><%= number_with_delimiter(note["_word_count"]) %></td>
              <td style="padding: 0.625rem 1rem; font-size: 0.8125rem; text-align: right;">
                <% mins = note["_reading_minutes"] %>
                <% if mins >= 60 %>
                  <%= (mins / 60.0).round(1) %> hrs
                <% else %>
                  <%= mins %> min
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

<%# Notebook Comparison %>
<% if @by_notebook.any? %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">library_books</span> Reading Time by Notebook</h2>
    </div>
    <div style="padding: 1.25rem;">
      <% nb_max = @by_notebook.values.map { |v| v[:reading_minutes] }.max.to_f; nb_max = 1 if nb_max == 0 %>
      <% @by_notebook.first(10).each do |nb, data| %>
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
          <span style="width: 8rem; font-size: 0.8125rem; text-align: right; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= nb %>"><%= nb %></span>
          <div style="flex: 1; height: 1.25rem; background: var(--bg); border-radius: 4px; overflow: hidden;">
            <div style="height: 100%; width: <%= (data[:reading_minutes] / nb_max * 100).round(1) %>%; background: #795548; opacity: 0.6; border-radius: 4px;"></div>
          </div>
          <span style="min-width: 4rem; text-align: right; font-size: 0.8125rem; font-weight: 600;">
            <% if data[:reading_minutes] >= 60 %>
              <%= (data[:reading_minutes] / 60.0).round(1) %> hrs
            <% else %>
              <%= data[:reading_minutes].round(0) %> min
            <% end %>
          </span>
          <span style="min-width: 3rem; text-align: right; font-size: 0.6875rem; color: var(--text-secondary);"><%= data[:count] %> notes</span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 1.5rem;">

  <%# Content Freshness %>
  <div class="card">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">update</span> Content Freshness</h2>
    </div>
    <div style="padding: 1.25rem;">
      <div style="display: flex; height: 2rem; border-radius: 8px; overflow: hidden; margin-bottom: 1rem;">
        <% if @freshness_pct[:fresh] > 0 %>
          <div style="width: <%= @freshness_pct[:fresh] %>%; background: #4caf50; display: flex; align-items: center; justify-content: center;" title="Fresh (<30 days): <%= @freshness[:fresh] %>">
            <% if @freshness_pct[:fresh] > 8 %>
              <span style="font-size: 0.625rem; color: #fff; font-weight: 600;"><%= @freshness_pct[:fresh] %>%</span>
            <% end %>
          </div>
        <% end %>
        <% if @freshness_pct[:aging] > 0 %>
          <div style="width: <%= @freshness_pct[:aging] %>%; background: #ff9800; display: flex; align-items: center; justify-content: center;" title="Aging (30-90 days): <%= @freshness[:aging] %>">
            <% if @freshness_pct[:aging] > 8 %>
              <span style="font-size: 0.625rem; color: #fff; font-weight: 600;"><%= @freshness_pct[:aging] %>%</span>
            <% end %>
          </div>
        <% end %>
        <% if @freshness_pct[:stale] > 0 %>
          <div style="width: <%= @freshness_pct[:stale] %>%; background: #9e9e9e; display: flex; align-items: center; justify-content: center;" title="Stale (90+ days): <%= @freshness[:stale] %>">
            <% if @freshness_pct[:stale] > 8 %>
              <span style="font-size: 0.625rem; color: #fff; font-weight: 600;"><%= @freshness_pct[:stale] %>%</span>
            <% end %>
          </div>
        <% end %>
      </div>
      <div style="display: flex; gap: 1.25rem; justify-content: center; flex-wrap: wrap;">
        <div style="display: flex; align-items: center; gap: 0.375rem; font-size: 0.75rem;">
          <span style="width: 10px; height: 10px; border-radius: 50%; background: #4caf50; display: inline-block;"></span>
          Fresh (<30d): <strong><%= @freshness[:fresh] %></strong>
        </div>
        <div style="display: flex; align-items: center; gap: 0.375rem; font-size: 0.75rem;">
          <span style="width: 10px; height: 10px; border-radius: 50%; background: #ff9800; display: inline-block;"></span>
          Aging (30-90d): <strong><%= @freshness[:aging] %></strong>
        </div>
        <div style="display: flex; align-items: center; gap: 0.375rem; font-size: 0.75rem;">
          <span style="width: 10px; height: 10px; border-radius: 50%; background: #9e9e9e; display: inline-block;"></span>
          Stale (90d+): <strong><%= @freshness[:stale] %></strong>
        </div>
      </div>
    </div>
  </div>

  <%# Short Notes %>
  <div class="card">
    <div class="card-header">
      <h2><span class="material-icons-outlined" style="font-size: 1.1rem; vertical-align: -2px;">short_text</span> Short Notes (Could Expand)</h2>
    </div>
    <div style="padding: 1.25rem;">
      <% if @shortest_notes.any? %>
        <% @shortest_notes.each do |note| %>
          <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid var(--border);">
            <div style="flex: 1; min-width: 0;">
              <div style="font-size: 0.8125rem; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                <% if note["id"] %>
                  <%= link_to (note["title"].presence || "Untitled"), note_path(note["id"]), style: "color: var(--text); text-decoration: none;" %>
                <% else %>
                  <%= note["title"].presence || "Untitled" %>
                <% end %>
              </div>
              <div style="font-size: 0.6875rem; color: var(--text-secondary);"><%= note.dig("notebook", "name") || "No Notebook" %></div>
            </div>
            <div style="text-align: right; margin-left: 1rem;">
              <div style="font-size: 0.8125rem; font-weight: 600;"><%= note["_word_count"] %> words</div>
              <div style="font-size: 0.6875rem; color: var(--text-secondary);"><%= note["_reading_minutes"] %> min read</div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div style="text-align: center; color: var(--text-secondary); font-size: 0.8125rem; padding: 1rem 0;">No notes found</div>
      <% end %>
    </div>
  </div>
</div>

<%# Bottom Nav %>
<div style="text-align: center; margin-top: 1.5rem;">
  <%= link_to "Notes", notes_path, class: "btn" %>
  <%= link_to "Writing Stats", writing_stats_path, class: "btn" %>
  <%= link_to "Writing Digest", writing_digest_path, class: "btn" %>
</div>
